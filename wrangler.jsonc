{
	"compatibility_date": "2026-05-15",
	"name": "sokolsky-me-temp",
	"main": "./src/worker.ts",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS",
		"run_worker_first": true,
		"not_found_handling": "404-page",
		"html_handling": "auto-trailing-slash"
	},
	"observability": {
		"enabled": true
	}
}