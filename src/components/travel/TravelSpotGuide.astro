---
export type TravelSpot = {
  id: string;
  name: string;
  countries: string[];
  area: string;
  kind: string;
  access: string;
  scores: {
    globallyUnique: number;
    laymenInterest: number;
    easeOfAccess: number;
    lowTouristCrowds: number;
  };
  uniqueness: string;
  why: string;
  realityCheck: string;
  wikiUrl?: string;
  source?: {
    label: string;
    url: string;
  };
  map: {
    name: string;
    formattedAddress?: string;
    placeId?: string;
    rating?: number;
    reviewCount?: number;
    query?: string;
    location: { lat: number; lng: number };
    googleMapsUrl: string;
  };
  trip: {
    days: number;
    costUsd: number;
    note: string;
  };
};

type Props = {
  pageTitle: string;
  pageDescription: string;
  subject: string;
  keywords: string;
  eyebrow: string;
  dek: string;
  criteriaText: string;
  tripOriginLabel: string;
  mapHeading: string;
  mapAriaLabel: string;
  mapCenter: { lat: number; lng: number };
  mapZoom: number;
  mapErrorLabel: string;
  spots: TravelSpot[];
  showMap?: boolean;
  themeColorLight?: string;
  themeColorDark?: string;
};

const {
  pageTitle,
  pageDescription,
  subject,
  keywords,
  eyebrow,
  dek,
  criteriaText,
  tripOriginLabel,
  mapHeading,
  mapAriaLabel,
  mapCenter,
  mapZoom,
  mapErrorLabel,
  spots,
  showMap = true,
  themeColorLight = "#f7f0e5",
  themeColorDark = "#15120e",
} = Astro.props;

const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const googleMapsApiKey =
  showMap
    ? (import.meta.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
      process.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
      "")
    : "";

const getScoreTotal = (spot: TravelSpot) =>
  spot.scores.globallyUnique +
  spot.scores.laymenInterest +
  spot.scores.easeOfAccess +
  spot.scores.lowTouristCrowds;
const scoreEntries = [
  ["Globally unique", "globallyUnique"],
  ["Laymen interest", "laymenInterest"],
  ["Ease of access", "easeOfAccess"],
  ["Low tourist crowds", "lowTouristCrowds"],
] as const;
const scoringCriteriaText =
  "Ranking score is the straight sum of four 0-10 criteria: globally unique, laymen interest, ease of access and low tourist crowds. Low tourist crowds is positive: 0 means Venice-level crowding, 10 means effectively no one goes there. Ties break by laymen interest.";
const validateScore = (spot: TravelSpot, key: keyof TravelSpot["scores"]) => {
  const score = spot.scores[key];
  if (!Number.isInteger(score) || score < 0 || score > 10) {
    throw new Error(`${pageTitle} spot "${spot.id}" has invalid ${key} score.`);
  }
};

spots.forEach((spot) => {
  scoreEntries.forEach(([, key]) => validateScore(spot, key));
});

const rankedSpotsWithTrip = spots
  .map((spot, originalIndex) => ({
    ...spot,
    originalIndex,
    totalScore: getScoreTotal(spot),
  }))
  .sort(
    (a, b) =>
      b.totalScore - a.totalScore ||
      b.scores.laymenInterest - a.scores.laymenInterest ||
      a.originalIndex - b.originalIndex,
  );
const spotIds = new Set(rankedSpotsWithTrip.map((spot) => spot.id));

if (spotIds.size !== rankedSpotsWithTrip.length) {
  throw new Error(`${pageTitle} spot IDs must be unique.`);
}

const formatter = new Intl.NumberFormat("en-US");
const usdFormatter = new Intl.NumberFormat("en-US", {
  style: "currency",
  currency: "USD",
  maximumFractionDigits: 0,
});
const countryOptions = [...new Set(rankedSpotsWithTrip.flatMap((spot) => spot.countries))].sort(
  (a, b) => a.localeCompare(b),
);
const tripEstimateLabel = `${tripOriginLabel.replace(/^From /, "From-")} trip estimate`;
const kindOptions = [...new Set(rankedSpotsWithTrip.map((spot) => spot.kind))].sort((a, b) =>
  a.localeCompare(b),
);
const spotMapData = rankedSpotsWithTrip.map((spot, index) => ({
  id: spot.id,
  rank: index + 1,
  name: spot.name,
  kind: spot.kind,
  countries: spot.countries,
  uniqueness: spot.uniqueness,
  totalScore: spot.totalScore,
  scores: spot.scores,
  position: spot.map.location,
  googleMapsUrl: spot.map.googleMapsUrl,
}));
const structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  numberOfItems: rankedSpotsWithTrip.length,
  itemListElement: rankedSpotsWithTrip.map((spot, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "TouristAttraction",
      name: spot.name,
      description: spot.why,
      sameAs: spot.map.googleMapsUrl,
      geo: {
        "@type": "GeoCoordinates",
        latitude: spot.map.location.lat,
        longitude: spot.map.location.lng,
      },
    },
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="subject" content={subject} />
    <meta name="application-name" content={pageTitle} />
    <meta
      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="googlebot"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta name="keywords" content={keywords} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta
      name="theme-color"
      content={themeColorLight}
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content={themeColorDark}
      media="(prefers-color-scheme: dark)"
    />
    <meta name="msapplication-TileColor" content={themeColorDark} />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color={themeColorDark} />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Nikita Sokolsky" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <main class="page">
      <header class="hero">
        <a class="home-link" href="/">sokolsky.me</a>
        <p class="eyebrow">{eyebrow}</p>
        <h1>{pageTitle}</h1>
        <p class="dek">{dek}</p>
      </header>

      <section class="criteria" aria-labelledby="criteria-heading">
        <div>
          <p class="eyebrow">Selection rule</p>
          <h2 id="criteria-heading">What "interesting" means here</h2>
        </div>
        <p>{criteriaText} {scoringCriteriaText}</p>
      </section>

      {showMap && (
        <section class="map-section" aria-labelledby="map-heading">
          <div class="map-copy">
            <p class="eyebrow">Map</p>
            <h2 id="map-heading">{mapHeading}</h2>
            <p id="map-status" class="map-status">
              Showing all {rankedSpotsWithTrip.length} spots.
            </p>
          </div>
          {googleMapsApiKey ? (
            <div id="spots-map" class="spots-map" aria-label={mapAriaLabel}></div>
          ) : (
            <p class="map-unavailable">
              Map unavailable because the Google Maps public key is not configured.
            </p>
          )}
        </section>
      )}

      <section class="toolbar" aria-label="Spot filters">
        <label class="filter-field" for="country-filter">
          <span>Country</span>
          <select id="country-filter" autocomplete="off">
            <option value="">All countries</option>
            {countryOptions.map((country) => <option value={country}>{country}</option>)}
          </select>
        </label>
        <label class="filter-field" for="kind-filter">
          <span>Type</span>
          <select id="kind-filter" autocomplete="off">
            <option value="">All types</option>
            {kindOptions.map((kind) => <option value={kind}>{kind}</option>)}
          </select>
        </label>
        <label class="filter-field" for="sort-select">
          <span>Sort</span>
          <select id="sort-select" autocomplete="off">
            <option value="score">Total score</option>
            <option value="globallyUnique">Globally unique</option>
            <option value="laymenInterest">Laymen interest</option>
            <option value="easeOfAccess">Ease of access</option>
            <option value="lowTouristCrowds">Low tourist crowds</option>
            <option value="popularity">Popularity (GMaps reviews)</option>
            <option value="cost">Cost (low to high)</option>
            <option value="time">Time required (short to long)</option>
          </select>
        </label>
        <button id="reset-filters" class="reset-button" type="button">Reset</button>
      </section>

      <section class="spot-list" aria-label={subject}>
        {rankedSpotsWithTrip.map((spot, index) => (
          <article
            id={spot.id}
            class="spot-card"
            data-country-list={spot.countries.join("|")}
            data-kind={spot.kind}
            data-cost-usd={spot.trip.costUsd}
            data-trip-days={spot.trip.days}
            data-review-count={spot.map.reviewCount ?? 0}
            data-score-rank={index + 1}
            data-total-score={spot.totalScore}
            data-globally-unique={spot.scores.globallyUnique}
            data-laymen-interest={spot.scores.laymenInterest}
            data-ease-of-access={spot.scores.easeOfAccess}
            data-low-tourist-crowds={spot.scores.lowTouristCrowds}
          >
            <div class="spot-rank" aria-label={`Rank ${index + 1}`}>
              {String(index + 1).padStart(2, "0")}
            </div>
            <div class="spot-body">
              <div class="spot-heading">
                <div>
                  <p class="spot-area">{spot.area}</p>
                  <h2>
                    {spot.wikiUrl ? (
                      <a
                        class="spot-title-link"
                        href={spot.wikiUrl}
                        target="_blank"
                        rel="noreferrer noopener"
                      >
                        {spot.name}
                      </a>
                    ) : (
                      spot.name
                    )}
                  </h2>
                </div>
                <a
                  class="maps-link"
                  href={spot.map.googleMapsUrl}
                  target="_blank"
                  rel="noreferrer noopener"
                >
                  Open map
                </a>
              </div>
              <div class="badges" aria-label={`${spot.name} attributes`}>
                <span>{spot.kind}</span>
                <span>{spot.countries.join(" / ")}</span>
                <span>{spot.access}</span>
                <span>
                  {tripOriginLabel}: {spot.trip.days} days · {usdFormatter.format(spot.trip.costUsd)}
                </span>
                {typeof spot.map.rating === "number" && (
                  <span>
                    GMaps {spot.map.rating.toFixed(1)} · {formatter.format(spot.map.reviewCount ?? 0)} reviews
                  </span>
                )}
              </div>
              <div class="score-panel" aria-label={`${spot.name} ranking scores`}>
                <div class="score-total">
                  <span>Total score</span>
                  <strong>{spot.totalScore}/40</strong>
                </div>
                <dl class="score-grid">
                  {scoreEntries.map(([label, key]) => (
                    <div>
                      <dt>{label}</dt>
                      <dd>{spot.scores[key]}/10</dd>
                    </div>
                  ))}
                </dl>
              </div>
              <p class="uniqueness">{spot.uniqueness}</p>
              <p>{spot.why}</p>
              <p class="reality-check">{spot.realityCheck}</p>
              <p class="trip-estimate">
                <strong>{tripEstimateLabel}:</strong> {spot.trip.days} days · {usdFormatter.format(spot.trip.costUsd)}. {spot.trip.note}
              </p>
              {spot.source && (
                <p class="source-link">
                  Source: <a href={spot.source.url} target="_blank" rel="noreferrer noopener">{spot.source.label}</a>
                </p>
              )}
            </div>
          </article>
        ))}
      </section>
    </main>
  </body>
</html>

<script is:inline define:vars={{ googleMapsApiKey, spotMapData, mapCenter, mapZoom, mapErrorLabel }}>
  if (googleMapsApiKey) {
    ((g) => {
      let h;
      let a;
      let k;
      const p = "The Google Maps JavaScript API";
      const c = "google";
      const l = "importLibrary";
      const q = "__ib__";
      const m = document;
      let b = window;
      b = b[c] || (b[c] = {});
      const d = b.maps || (b.maps = {});
      const r = new Set();
      const e = new URLSearchParams();
      const u = () =>
        h ||
        (h = new Promise(async (resolve, reject) => {
          await (a = m.createElement("script"));
          e.set("libraries", [...r] + "");
          for (k in g) {
            e.set(k.replace(/[A-Z]/g, (t) => `_${t[0].toLowerCase()}`), g[k]);
          }
          e.set("callback", `${c}.maps.${q}`);
          a.src = `https://maps.${c}apis.com/maps/api/js?${e}`;
          d[q] = resolve;
          a.onerror = () => (h = reject(Error(`${p} could not load.`)));
          a.nonce = m.querySelector("script[nonce]")?.nonce || "";
          m.head.append(a);
        }));
      d[l] ? console.warn(`${p} only loads once. Ignoring:`, g) : (d[l] = (f, ...n) => r.add(f) && u().then(() => d[l](f, ...n)));
    })({
      key: googleMapsApiKey,
      v: "weekly",
    });
  }

  const countryFilter = document.querySelector("#country-filter");
  const kindFilter = document.querySelector("#kind-filter");
  const sortSelect = document.querySelector("#sort-select");
  const resetFiltersButton = document.querySelector("#reset-filters");
  const spotList = document.querySelector(".spot-list");
  const spotCards = [...document.querySelectorAll(".spot-card")];
  const mapElement = document.querySelector("#spots-map");
  const mapStatus = document.querySelector("#map-status");
  const markerRecords = [];
  let spotsMap;
  let infoWindow;

  const escapeHtml = (value) =>
    String(value).replace(/[&<>"']/g, (character) => ({
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#39;",
    })[character]);

  const getVisibleSpots = (selectedCountry, selectedKind) =>
    spotMapData.filter(
      (spot) =>
        (!selectedCountry || spot.countries.includes(selectedCountry)) &&
        (!selectedKind || spot.kind === selectedKind),
    );

  const updateMapStatus = (selectedCountry, selectedKind) => {
    if (!mapStatus) return;

    const visibleCount = getVisibleSpots(selectedCountry, selectedKind).length;
    const label = visibleCount === 1 ? "spot" : "spots";
    const filterLabel = [selectedCountry, selectedKind].filter(Boolean).join(" · ");
    mapStatus.textContent = filterLabel
      ? `Showing ${visibleCount} ${label} for ${filterLabel}.`
      : `Showing all ${visibleCount} ${label}.`;
  };

  const fitMapToMarkers = (visibleRecords) => {
    if (!spotsMap || !window.google?.maps || visibleRecords.length === 0) return;

    if (visibleRecords.length === 1) {
      spotsMap.setCenter(visibleRecords[0].spot.position);
      spotsMap.setZoom(8);
      return;
    }

    const bounds = new google.maps.LatLngBounds();
    for (const { spot } of visibleRecords) {
      bounds.extend(spot.position);
    }
    spotsMap.fitBounds(bounds, 42);
  };

  const syncMapMarkers = (selectedCountry, selectedKind) => {
    updateMapStatus(selectedCountry, selectedKind);
    if (!spotsMap) return;

    const visibleIds = new Set(
      getVisibleSpots(selectedCountry, selectedKind).map((spot) => spot.id),
    );
    const visibleRecords = [];

    for (const record of markerRecords) {
      const isVisible = visibleIds.has(record.spot.id);
      record.marker.setMap(isVisible ? spotsMap : null);
      if (isVisible) visibleRecords.push(record);
    }

    fitMapToMarkers(visibleRecords);
  };

  const getNumberData = (element, key) => Number(element.dataset[key] ?? 0);

  const sortedSpotCards = () => {
    const selectedSort = sortSelect?.value ?? "score";

    return [...spotCards].sort((a, b) => {
      const scoreDelta =
        getNumberData(b, "totalScore") - getNumberData(a, "totalScore") ||
        getNumberData(b, "laymenInterest") - getNumberData(a, "laymenInterest") ||
        getNumberData(a, "scoreRank") - getNumberData(b, "scoreRank");

      if (
        ["globallyUnique", "laymenInterest", "easeOfAccess", "lowTouristCrowds"].includes(
          selectedSort,
        )
      ) {
        const selectedScoreDelta =
          getNumberData(b, selectedSort) - getNumberData(a, selectedSort);

        return selectedScoreDelta || scoreDelta;
      }

      if (selectedSort === "popularity") {
        const popularityDelta =
          getNumberData(b, "reviewCount") - getNumberData(a, "reviewCount");

        return popularityDelta || scoreDelta;
      }

      if (selectedSort === "cost") {
        const costDelta = getNumberData(a, "costUsd") - getNumberData(b, "costUsd");

        return costDelta || scoreDelta;
      }

      if (selectedSort === "time") {
        const timeDelta = getNumberData(a, "tripDays") - getNumberData(b, "tripDays");

        return timeDelta || scoreDelta;
      }

      return scoreDelta;
    });
  };

  const syncCardOrderAndRanks = () => {
    const sortedCards = sortedSpotCards();
    let visibleIndex = 0;

    for (const card of sortedCards) {
      spotList?.append(card);

      if (card.hidden) continue;

      visibleIndex += 1;
      const rank = card.querySelector(".spot-rank");
      if (!rank) continue;

      rank.textContent = String(visibleIndex).padStart(2, "0");
      rank.setAttribute("aria-label", `Display rank ${visibleIndex}`);
    }
  };

  const applyFilters = () => {
    const selectedCountry = countryFilter?.value ?? "";
    const selectedKind = kindFilter?.value ?? "";

    for (const card of spotCards) {
      const countries = card.dataset.countryList?.split("|") ?? [];
      const countryMismatch =
        Boolean(selectedCountry) && !countries.includes(selectedCountry);
      const kindMismatch =
        Boolean(selectedKind) && card.dataset.kind !== selectedKind;
      card.hidden = countryMismatch || kindMismatch;
    }

    syncCardOrderAndRanks();
    syncMapMarkers(selectedCountry, selectedKind);
  };

  const initMap = async () => {
    if (!mapElement || !googleMapsApiKey || !window.google?.maps?.importLibrary) return;

    const { Map, InfoWindow } = await google.maps.importLibrary("maps");
    await google.maps.importLibrary("marker");

    spotsMap = new Map(mapElement, {
      center: mapCenter,
      clickableIcons: false,
      fullscreenControl: true,
      mapTypeControl: false,
      streetViewControl: false,
      zoom: mapZoom,
    });
    infoWindow = new InfoWindow();

    for (const spot of spotMapData) {
      const marker = new google.maps.Marker({
        map: spotsMap,
        position: spot.position,
        title: `${spot.rank}. ${spot.name}`,
        label: String(spot.rank),
      });

      marker.addListener("click", () => {
        infoWindow.setContent(
          `<strong>${escapeHtml(spot.rank)}. ${escapeHtml(spot.name)}</strong><br>${escapeHtml(spot.uniqueness)}<br><a href="${escapeHtml(spot.googleMapsUrl)}" target="_blank" rel="noreferrer noopener">Open in Google Maps</a>`,
        );
        infoWindow.open(spotsMap, marker);
      });

      markerRecords.push({ spot, marker });
    }

    applyFilters();
  };

  countryFilter?.addEventListener("change", applyFilters);
  kindFilter?.addEventListener("change", applyFilters);
  sortSelect?.addEventListener("change", applyFilters);
  resetFiltersButton?.addEventListener("click", () => {
    if (countryFilter) countryFilter.value = "";
    if (kindFilter) kindFilter.value = "";
    if (sortSelect) sortSelect.value = "score";
    applyFilters();
  });
  window.addEventListener("pageshow", applyFilters);
  initMap().catch((error) => {
    console.error(`Unable to initialize ${mapErrorLabel} spots map`, error);
    if (mapStatus) mapStatus.textContent = "Map unavailable. The list still works.";
  });
</script>

<style>
  :root {
    color-scheme: light dark;
    --bg: #f7f0e5;
    --panel: #fffaf2;
    --panel-strong: #ede0cd;
    --text: #1e1912;
    --muted: #6e604f;
    --border: #dfcfb8;
    --accent: #8a4b2a;
    --accent-strong: #4f2b18;
    --shadow: 0 22px 70px rgba(64, 43, 24, 0.12);
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #15120e;
      --panel: #211c16;
      --panel-strong: #30271d;
      --text: #f4eadb;
      --muted: #c0ae97;
      --border: #493a2a;
      --accent: #e0a069;
      --accent-strong: #ffd3a9;
      --shadow: 0 22px 70px rgba(0, 0, 0, 0.32);
    }
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-width: 320px;
    background:
      radial-gradient(circle at 12% 0%, rgba(138, 75, 42, 0.18), transparent 28rem),
      linear-gradient(180deg, var(--bg), var(--panel-strong));
    color: var(--text);
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    line-height: 1.55;
  }

  a {
    color: inherit;
  }

  .page {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
    padding: 32px 0 72px;
  }

  .hero,
  .criteria,
  .map-section,
  .toolbar,
  .spot-card {
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--panel) 92%, transparent);
    box-shadow: var(--shadow);
  }

  .hero {
    position: relative;
    overflow: hidden;
    min-height: 520px;
    padding: clamp(28px, 7vw, 72px);
    border-radius: 34px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 28px;
    border-radius: 28px;
    border: 1px solid color-mix(in srgb, var(--border) 65%, transparent);
    pointer-events: none;
  }

  .hero::after {
    content: "";
    position: absolute;
    right: -8%;
    top: -16%;
    width: min(58vw, 620px);
    aspect-ratio: 1;
    border-radius: 50%;
    background:
      linear-gradient(120deg, transparent 42%, color-mix(in srgb, var(--accent) 40%, transparent) 43% 45%, transparent 46%),
      repeating-linear-gradient(155deg, transparent 0 20px, color-mix(in srgb, var(--accent) 18%, transparent) 21px 22px);
    opacity: 0.55;
    pointer-events: none;
  }

  .home-link {
    position: absolute;
    top: 28px;
    left: 28px;
    z-index: 1;
    font-size: 0.82rem;
