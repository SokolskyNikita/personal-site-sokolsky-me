---
import {
  ARCHETYPES,
  DECK,
  type QuizQuestion,
} from "../../data/cishet-male-archetype-quiz";
import wikiLinksRaw from "../../data/cishet-male-archetype-wiki-links.json";
import kymLinksRaw from "../../data/cishet-male-archetype-kym-links.json";

export const prerender = true;

const pageTitle = "Which cishet male archetypes are you?";
const pageDescription =
  `Answer 25 questions and get your five closest matches from ${ARCHETYPES.length} cishet male archetypes.`;
const themeColorLight = "#fefffd";
const themeColorDark = "#141614";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;

type ExtLink = { title: string; url: string };
const wikiLinks = wikiLinksRaw as Record<string, ExtLink>;
const kymLinks = kymLinksRaw as Record<string, ExtLink>;

const deckForClient: QuizQuestion[] = DECK.map((q) => ({
  topic: q.topic,
  q: q.q,
  opts: q.opts.map((o) => ({
    t: o.t,
    sections: o.sections,
    boosts: o.boosts,
    skip: o.skip,
  })),
}));

const archetypesForClient = ARCHETYPES.map((a) => ({
  id: a.id,
  terms: a.terms,
  gloss: a.gloss,
  sectionId: a.sectionId,
  sectionTitle: a.sectionTitle,
}));

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  applicationCategory: "EntertainmentApplication",
  operatingSystem: "Any",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  author: { "@type": "Person", name: "Nikita Sokolsky" },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="googlebot" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta name="theme-color" content={themeColorLight} media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content={themeColorDark} media="(prefers-color-scheme: dark)" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="sokolsky.me" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&family=Newsreader:opsz,wght@6..72,500;6..72,600&display=swap"
    />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <main class="page">
      <p class="home"><a href="/">sokolsky.me</a></p>

      <header class="hero">
        <h1>{pageTitle}</h1>
        <p class="lede">
          Choose every answer that fits across twenty-five questions. The quiz scores
          all <a href="/culture/cishet-male-archetypes">{ARCHETYPES.length} labels in the field guide</a>
          and gives you the five closest matches.
        </p>
        <p class="meta">
          {DECK.length} questions · top 5 of {ARCHETYPES.length} labels
          <span aria-hidden="true"> · </span>
          <a href="/tests/cishet-female-archetypes">Equivalent test for women</a>
        </p>
      </header>

      <section id="intro" aria-label="Start the quiz">
        <button type="button" class="btn btn-primary" id="start-quiz">Take the quiz</button>
        <p class="intro-note">
          Choose one or several answers per question. “None of these” is always available and does not count toward any archetype.
        </p>
        <noscript>
          <p class="intro-note">
            This quiz needs JavaScript. You can still browse the
            <a href="/culture/cishet-male-archetypes">full archetype list</a>.
          </p>
        </noscript>
      </section>

      <section id="quiz" aria-label="The quiz" hidden>
        <nav class="progress" id="progress" aria-label="Questions"></nav>
        <div class="quiz-card" id="quiz-card" aria-live="polite"></div>
      </section>

      <section id="results" aria-label="Your results" hidden>
        <div class="verdict" id="verdict"></div>
        <div class="share-row">
          <button type="button" class="btn btn-primary" id="copy-link">Copy share link</button>
          <button type="button" class="btn" id="copy-text">Copy as text</button>
          <button type="button" class="btn btn-ghost" id="retake">Retake</button>
        </div>
        <p class="results-links">
          <a href="/culture/cishet-male-archetypes">Browse the full field guide →</a>
        </p>
      </section>
    </main>

    <script
      is:inline
      define:vars={{
        DECK: deckForClient,
        ARCHETYPES: archetypesForClient,
        wikiLinks,
        kymLinks,
      }}
    >
      const STORE_KEY = "cishet-archetype-quiz-v2";
      const LEGACY_STORE_KEY = "cishet-archetype-quiz-v1";
      const TOP_N = 5;
      const SPECIFIC_EVIDENCE_PRIOR = 4;

      const state = {
        answers: Array.from({ length: DECK.length }, () => []),
        idx: 0,
        finished: false,
      };

      const introSection = document.getElementById("intro");
      const quizSection = document.getElementById("quiz");
      const quizCard = document.getElementById("quiz-card");
      const progressEl = document.getElementById("progress");
      const resultsSection = document.getElementById("results");
      const verdictEl = document.getElementById("verdict");

      function saveLocal() {
        try {
          localStorage.setItem(
            STORE_KEY,
            JSON.stringify({
              answers: state.answers,
              idx: state.idx,
              finished: state.finished,
            }),
          );
        } catch (_) {}
      }

      function loadLocal() {
        try {
          const raw =
            localStorage.getItem(STORE_KEY) ||
            localStorage.getItem(LEGACY_STORE_KEY);
          if (!raw) return false;
          const data = JSON.parse(raw);
          if (!Array.isArray(data.answers) || data.answers.length !== DECK.length) return false;
          state.answers = data.answers.map((value, questionIndex) => {
            const values = Array.isArray(value) ? value : [value];
            return [...new Set(values)].filter(
              (optionIndex) =>
                Number.isInteger(optionIndex) &&
                optionIndex >= 0 &&
                optionIndex < DECK[questionIndex].opts.length,
            );
          });
          state.idx = Math.min(Math.max(0, data.idx | 0), DECK.length - 1);
          state.finished = Boolean(data.finished);
          return true;
        } catch (_) {
          return false;
        }
      }

      function encodeAnswers() {
        return state.answers.map((selection) =>
          selection.map((value) => (value + 1).toString(36)).join("")
        ).join(".");
      }

      function decodeAnswers(value) {
        if (typeof value !== "string") return null;
        if (!value.includes(".") && value.length === DECK.length) {
          const legacyAnswers = [];
          for (let index = 0; index < value.length; index++) {
            const digit = Number.parseInt(value[index], 36);
            if (!Number.isInteger(digit) || digit < 0 || digit > DECK[index].opts.length) {
              return null;
            }
            legacyAnswers.push(digit === 0 ? [] : [digit - 1]);
          }
          return legacyAnswers;
        }
        const segments = value.split(".");
        if (segments.length !== DECK.length) return null;
        const answers = segments.map((segment, questionIndex) => {
          const selection = [...new Set([...segment].map((character) =>
            Number.parseInt(character, 36) - 1
          ))];
          return selection.every(
            (optionIndex) =>
              Number.isInteger(optionIndex) &&
              optionIndex >= 0 &&
              optionIndex < DECK[questionIndex].opts.length,
          ) ? selection : null;
        });
        return answers.some((selection) => selection === null) ? null : answers;
      }

      function firstUnansweredIndex() {
        const idx = state.answers.findIndex((selection) => selection.length === 0);
        return idx === -1 ? DECK.length - 1 : idx;
      }

      function allAnswered() {
        return state.answers.every((selection) => selection.length > 0);
      }

      function canVisitQuestion(idx) {
        return state.answers[idx].length > 0 || idx <= firstUnansweredIndex();
      }

      const LEXICAL_STOP_WORDS = new Set(
        "about after again against almost also always among around because before being between both could default does doing down during each enough every first from further have having here honestly into just maybe more most much myself next only other over same should some still such than that their them then there these they this those through under until very what when where which while with would your youre guy guys male man mostly energy mode thing stuff vibe vibes looks like".split(" "),
      );
      const optionTokenCache = new WeakMap();
      const archetypeTokenCache = new Map();

      function lexicalTokens(value) {
        return new Set(
          String(value)
            .toLowerCase()
            .replace(/[^a-z0-9]+/g, " ")
            .split(/\s+/)
            .filter((token) => token.length >= 4 && !LEXICAL_STOP_WORDS.has(token))
            .map((token) => token.replace(/(ies|ing|ers|er|ed|s)$/, "")),
        );
      }

      function lexicalWeight(option, archetype) {
        let optionTokens = optionTokenCache.get(option);
        if (!optionTokens) {
          optionTokens = lexicalTokens(option.t);
          optionTokenCache.set(option, optionTokens);
        }

        let archetypeTokens = archetypeTokenCache.get(archetype.id);
        if (!archetypeTokens) {
          archetypeTokens = lexicalTokens(archetype.terms + " " + archetype.gloss);
          archetypeTokenCache.set(archetype.id, archetypeTokens);
        }

        let overlaps = 0;
        for (const token of optionTokens) {
          if (token.length >= 3 && archetypeTokens.has(token)) overlaps += 1;
        }
        return Math.min(2.4, overlaps * 0.6);
      }

      function escapeRegExp(value) {
        return String(value).replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
      }

      function exactPhraseMatch(haystack, needle) {
        const pattern = new RegExp(
          `(^|[^a-z0-9])${escapeRegExp(needle)}(?=$|[^a-z0-9])`,
          "i",
        );
        return pattern.test(haystack);
      }

      function specificWeight(option, archetype) {
        let w = lexicalWeight(option, archetype);
        if (option.boosts) {
          const hay = archetype.terms;
          for (const boost of option.boosts) {
            if (exactPhraseMatch(hay, boost.match)) w += boost.w;
          }
        }
        return w;
      }

      function optionWeight(option, archetype) {
        return (
          (option.sections[archetype.sectionId] || 0) +
          specificWeight(option, archetype)
        );
      }

      function rankMatches(answers) {
        const scores = new Float64Array(ARCHETYPES.length);
        const maxes = new Float64Array(ARCHETYPES.length);
        const specificScores = new Float64Array(ARCHETYPES.length);
        const specificMaxes = new Float64Array(ARCHETYPES.length);

        for (let qi = 0; qi < DECK.length; qi++) {
          const selection = answers[qi];
          const q = DECK[qi];
          if (!Array.isArray(selection) || selection.length === 0) continue;
          const chosenOptions = selection
            .filter((answer) => answer >= 0 && answer < q.opts.length)
            .map((answer) => q.opts[answer]);
          if (chosenOptions.length === 0) continue;
          for (let ai = 0; ai < ARCHETYPES.length; ai++) {
            const arch = ARCHETYPES[ai];
            for (const chosen of chosenOptions) {
              scores[ai] += optionWeight(chosen, arch) / chosenOptions.length;
              specificScores[ai] += specificWeight(chosen, arch) / chosenOptions.length;
            }
            let best = 0;
            let bestSpecific = 0;
            for (const opt of q.opts) {
              best = Math.max(best, optionWeight(opt, arch));
              bestSpecific = Math.max(bestSpecific, specificWeight(opt, arch));
            }
            maxes[ai] += best;
            specificMaxes[ai] += bestSpecific;
          }
        }

        return ARCHETYPES.map((archetype, i) => {
          const score = scores[i];
          const maxPossible = maxes[i];
          const baseFit = maxPossible > 0 ? score / maxPossible : 0;
          const specificFit =
            specificMaxes[i] > 0
              ? specificScores[i] /
                (specificMaxes[i] + SPECIFIC_EVIDENCE_PRIOR)
              : 0;
          const fit = baseFit * 0.65 + specificFit * 0.35;
          const matchPct =
            Math.round(1000 * fit) / 10;
          const specificScore = specificScores[i];
          return {
            archetype,
            score,
            maxPossible,
            matchPct,
            fit,
            specificFit,
            specificScore,
          };
        }).filter((result) => result.fit > 0).sort(
          (a, b) =>
            b.fit - a.fit ||
            b.specificScore - a.specificScore ||
            a.archetype.terms.localeCompare(b.archetype.terms),
        );
      }

      function escapeHtml(value) {
        return String(value)
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;");
      }

      function linkForTerm(part) {
        if (wikiLinks[part]) return { ...wikiLinks[part], source: "wiki" };
        if (kymLinks[part]) return { ...kymLinks[part], source: "kym" };
        return null;
      }

      function renderTermsHtml(terms) {
        return terms
          .split(/\s*\/\s*/)
          .map((part) => {
            const link = linkForTerm(part);
            const label = escapeHtml(part);
            if (!link) return label;
            const cls = link.source === "wiki" ? "wiki-term" : "kym-term";
            const sourceLabel = link.source === "wiki" ? "Wikipedia" : "Know Your Meme";
            return (
              `<a class="${cls}" href="${escapeHtml(link.url)}" target="_blank" rel="noopener noreferrer" title="${escapeHtml(sourceLabel + ": " + link.title)}">${label}</a>`
            );
          })
          .join(" / ");
      }

      function renderProgress() {
        progressEl.innerHTML = "";
        DECK.forEach((q, i) => {
          const dot = document.createElement("button");
          dot.type = "button";
          dot.className = "p-dot";
          if (state.answers[i].length > 0) dot.classList.add("done");
          if (i === state.idx) dot.classList.add("here");
          dot.disabled = !canVisitQuestion(i);
          const status = state.answers[i].length > 0 ? "answered" : "unanswered";
          dot.setAttribute("aria-label", `Question ${i + 1}: ${q.topic}, ${status}`);
          dot.title = `${i + 1} · ${q.topic}`;
          dot.addEventListener("click", () => goTo(i));
          progressEl.appendChild(dot);
        });
        const currentDot = progressEl.children[state.idx];
        if (currentDot) {
          requestAnimationFrame(() => {
            progressEl.scrollTo({
              left:
                currentDot.offsetLeft -
                progressEl.clientWidth / 2 +
                currentDot.clientWidth / 2,
              behavior: "smooth",
            });
          });
        }
      }

      function renderQuestion() {
        const q = DECK[state.idx];
        const chosen = state.answers[state.idx];
        const isLast = state.idx === DECK.length - 1;

        quizCard.innerHTML = "";

        const meta = document.createElement("div");
        meta.className = "q-meta";
        meta.innerHTML =
          `<span class="q-topic">${escapeHtml(q.topic)}</span>` +
          `<span class="q-count">${state.idx + 1} / ${DECK.length}</span>`;
        quizCard.appendChild(meta);

        const prompt = document.createElement("h2");
        prompt.className = "q-prompt";
        prompt.textContent = q.q;
        quizCard.appendChild(prompt);

        const hint = document.createElement("p");
        hint.className = "q-hint";
        hint.textContent = "Choose one or several. Multiple answers are blended equally.";
        quizCard.appendChild(hint);

        const list = document.createElement("div");
        list.className = "q-options";
        list.setAttribute("role", "group");
        list.setAttribute("aria-label", "Answers");
        q.opts.forEach((opt, i) => {
          const btn = document.createElement("button");
          btn.type = "button";
          btn.className = "q-option";
          btn.setAttribute("role", "checkbox");
          btn.setAttribute("aria-checked", chosen.includes(i) ? "true" : "false");
          if (chosen.includes(i)) btn.classList.add("selected");
          btn.innerHTML = `<span class="q-key">${i + 1}</span><span class="q-text"></span>`;
          btn.querySelector(".q-text").textContent = opt.t;
          btn.addEventListener("click", () => selectOption(i));
          list.appendChild(btn);
        });
        quizCard.appendChild(list);

        const nav = document.createElement("div");
        nav.className = "q-nav";

        const back = document.createElement("button");
        back.type = "button";
        back.className = "btn btn-ghost";
        back.textContent = "← Back";
        back.disabled = state.idx === 0;
        back.addEventListener("click", () => goTo(state.idx - 1));
        nav.appendChild(back);

        if (isLast) {
          const finish = document.createElement("button");
          finish.type = "button";
          finish.className = "btn btn-primary";
          finish.textContent = "See my results";
          finish.disabled = !allAnswered();
          finish.addEventListener("click", () => showResults());
          nav.appendChild(finish);
        } else {
          const next = document.createElement("button");
          next.type = "button";
          next.className = "btn btn-primary";
          next.textContent = "Next →";
          next.disabled = chosen.length === 0;
          next.addEventListener("click", () => goTo(state.idx + 1));
          nav.appendChild(next);
        }

        quizCard.appendChild(nav);
        renderProgress();
      }

      function selectOption(optIdx) {
        const selection = state.answers[state.idx];
        const options = DECK[state.idx].opts;
        if (options[optIdx].skip) {
          state.answers[state.idx] = [optIdx];
        } else {
          const withoutSkip = selection.filter((value) => !options[value].skip);
          state.answers[state.idx] = withoutSkip.includes(optIdx)
            ? withoutSkip.filter((value) => value !== optIdx)
            : [...withoutSkip, optIdx].sort((a, b) => a - b);
        }
        state.finished = false;
        saveLocal();
        renderQuestion();
      }

      function goTo(idx) {
        quizCard.classList.remove("settling");
        const clamped = Math.min(Math.max(0, idx), DECK.length - 1);
        state.idx = canVisitQuestion(clamped) ? clamped : firstUnansweredIndex();
        saveLocal();
        renderQuestion();
      }

      function resultText(top) {
        return (
          `My cishet male archetypes:\n` +
          top
            .map((r, i) => `${i + 1}. ${r.matchPct}% — ${r.archetype.terms}`)
            .join("\n") +
          `\n${location.origin}/tests/cishet-male-archetypes?r=${encodeAnswers()}`
        );
      }

      function showResults() {
        if (!allAnswered()) return;
        state.finished = true;
        saveLocal();

        const ranked = rankMatches(state.answers);
        const top = ranked.slice(0, TOP_N);
        const matchedQuestions = state.answers.filter((selection, questionIndex) =>
          selection.some((optionIndex) => !DECK[questionIndex].opts[optionIndex].skip)
        ).length;
        const url = new URL(location.href);
        url.searchParams.set("r", encodeAnswers());
        history.replaceState(null, "", url);

        introSection.hidden = true;
        quizSection.hidden = true;
        resultsSection.hidden = false;

        if (top.length === 0) {
          verdictEl.innerHTML =
            `<p class="verdict-kicker">No strong match</p>` +
            `<p class="no-match">These answers did not point to any archetype in the current quiz. That is a limitation of the quiz, not a requirement to force yourself into the closest label.</p>`;
        } else {
          const confidenceNote = matchedQuestions < 15
            ? `You found a fitting answer for ${matchedQuestions} of ${DECK.length} questions, so treat these as low-confidence suggestions. The archetype you have in mind may not be represented here.`
            : `The percentage combines your general pattern with direct matches to a label’s name and description.`;
          verdictEl.innerHTML =
            `<p class="verdict-kicker">Your five best matches</p>` +
            `<ol class="match-list">` +
            top
              .map((r, i) => {
                const pct = r.matchPct;
                return (
                  `<li class="match-item" style="--pct:${pct}">` +
                  `<div class="match-rank">${i + 1}</div>` +
                  `<div class="match-body">` +
                  `<div class="match-head">` +
                  `<span class="match-terms">${renderTermsHtml(r.archetype.terms)}</span>` +
                  `<span class="match-pct">${pct}%</span>` +
                  `</div>` +
                  `<p class="match-gloss">${escapeHtml(r.archetype.gloss)}</p>` +
                  `<p class="match-section">${escapeHtml(r.archetype.sectionTitle)}</p>` +
                  `<div class="match-bar" aria-hidden="true"><span style="width:${pct}%"></span></div>` +
                  `</div>` +
                  `</li>`
                );
              })
              .join("") +
            `</ol>` +
            `<p class="verdict-note">${escapeHtml(confidenceNote)} The descriptions explain how people use these terms; they are not endorsements.</p>`;
        }

        resultsSection.scrollIntoView({ behavior: "smooth", block: "start" });
      }

      function startQuiz(resume) {
        introSection.hidden = true;
        resultsSection.hidden = true;
        quizSection.hidden = false;
        state.finished = false;
        if (!resume) {
          state.answers = Array.from({ length: DECK.length }, () => []);
          state.idx = 0;
        } else {
          state.idx = firstUnansweredIndex();
        }
        saveLocal();
        renderQuestion();
        quizSection.scrollIntoView({ behavior: "smooth", block: "start" });
      }

      function retake() {
        const url = new URL(location.href);
        url.searchParams.delete("r");
        history.replaceState(null, "", url);
        startQuiz(false);
      }

      document.getElementById("start-quiz")?.addEventListener("click", () => {
        const hasProgress = state.answers.some((selection) => selection.length > 0);
        startQuiz(hasProgress && !state.finished);
      });
      document.getElementById("retake")?.addEventListener("click", retake);

      document.getElementById("copy-link")?.addEventListener("click", async () => {
        const url = new URL(location.href);
        url.searchParams.set("r", encodeAnswers());
        try {
          await navigator.clipboard.writeText(url.toString());
          const btn = document.getElementById("copy-link");
          if (btn) {
            const prev = btn.textContent;
            btn.textContent = "Copied";
            setTimeout(() => {
              btn.textContent = prev;
            }, 1200);
          }
        } catch (_) {}
      });

      document.getElementById("copy-text")?.addEventListener("click", async () => {
        const top = rankMatches(state.answers).slice(0, TOP_N);
        try {
          await navigator.clipboard.writeText(resultText(top));
          const btn = document.getElementById("copy-text");
          if (btn) {
            const prev = btn.textContent;
            btn.textContent = "Copied";
            setTimeout(() => {
              btn.textContent = prev;
            }, 1200);
          }
        } catch (_) {}
      });

      document.addEventListener("keydown", (e) => {
        if (quizSection.hidden) return;
        if (e.target && ["INPUT", "TEXTAREA"].includes(e.target.tagName)) return;
        const n =
          e.key >= "1" && e.key <= "9"
            ? Number(e.key) - 1
            : e.key === "0"
              ? 9
              : -1;
        if (n >= 0 && n < DECK[state.idx].opts.length) {
          e.preventDefault();
          selectOption(n);
        }
      });

      // boot
      const params = new URLSearchParams(location.search);
      const shared = decodeAnswers(params.get("r") || "");
      if (shared && shared.every((selection) => selection.length > 0)) {
        state.answers = shared;
        state.finished = true;
        showResults();
      } else {
        loadLocal();
        if (state.finished && allAnswered()) showResults();
        else if (state.answers.some((selection) => selection.length > 0)) {
          const startBtn = document.getElementById("start-quiz");
          if (startBtn) startBtn.textContent = "Continue quiz";
        }
      }
    </script>
  </body>
</html>

