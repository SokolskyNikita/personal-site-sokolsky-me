---
import {
  ARCHETYPES,
  DECK,
  type QuizQuestion,
} from "../../data/cishet-female-archetype-quiz";
import wikiLinksRaw from "../../data/cishet-female-archetype-wiki-links.json";
import kymLinksRaw from "../../data/cishet-female-archetype-kym-links.json";

export const prerender = true;

const pageTitle = "Which cishet female archetypes are you?";
const pageDescription =
  `Answer 25 questions and get your five closest matches from ${ARCHETYPES.length} cishet female archetypes.`;
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
type ExtLink = { title: string; url: string };
const wikiLinks = wikiLinksRaw as Record<string, ExtLink>;
const kymLinks = kymLinksRaw as Record<string, ExtLink>;

const deckForClient: QuizQuestion[] = DECK.map((question) => ({
  topic: question.topic,
  q: question.q,
  opts: question.opts.map((option) => ({
    t: option.t,
    sections: option.sections,
    boosts: option.boosts,
    skip: option.skip,
  })),
}));
const archetypesForClient = ARCHETYPES.map((archetype) => ({
  id: archetype.id,
  terms: archetype.terms,
  gloss: archetype.gloss,
  sectionId: archetype.sectionId,
  sectionTitle: archetype.sectionTitle,
}));
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  applicationCategory: "EntertainmentApplication",
  operatingSystem: "Any",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  author: { "@type": "Person", name: "Nikita Sokolsky" },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content="#fdfefc" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#141614" media="(prefers-color-scheme: dark)" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="sokolsky.me" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&family=Newsreader:opsz,wght@6..72,500;6..72,600&display=swap"
    />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <main class="page">
      <p class="home"><a href="/">sokolsky.me</a></p>
      <header class="hero">
        <h1>{pageTitle}</h1>
        <p class="lede">
          Choose every answer that fits across twenty-five questions. The quiz scores
          all <a href="/culture/cishet-female-archetypes">{ARCHETYPES.length} labels in the field guide</a>
          and gives you the five closest matches.
        </p>
        <p class="meta">
          {DECK.length} questions · top 5 of {ARCHETYPES.length} labels
          <span aria-hidden="true"> · </span>
          <a href="/tests/cishet-male-archetypes">Male companion</a>
        </p>
      </header>

      <section id="intro" aria-label="Start the quiz">
        <button type="button" class="btn btn-primary" id="start-quiz">Take the quiz</button>
        <p class="intro-note">Choose one or several answers per question. “None of these” is always available and does not count toward any archetype.</p>
        <noscript>
          <p class="intro-note">
            This quiz needs JavaScript. You can still browse the
            <a href="/culture/cishet-female-archetypes">full archetype list</a>.
          </p>
        </noscript>
      </section>

      <section id="quiz" aria-label="The quiz" hidden>
        <nav class="progress" id="progress" aria-label="Questions"></nav>
        <div class="quiz-card" id="quiz-card" aria-live="polite"></div>
      </section>

      <section id="results" aria-label="Your results" hidden>
        <div class="verdict" id="verdict"></div>
        <div class="share-row">
          <button type="button" class="btn btn-primary" id="copy-link">Copy share link</button>
          <button type="button" class="btn" id="copy-text">Copy as text</button>
          <button type="button" class="btn btn-ghost" id="retake">Retake</button>
        </div>
        <p class="results-links">
          <a href="/culture/cishet-female-archetypes">Browse the full field guide →</a>
        </p>
      </section>
    </main>

    <script
      is:inline
      define:vars={{
        DECK: deckForClient,
        ARCHETYPES: archetypesForClient,
        wikiLinks,
        kymLinks,
      }}
    >
      const STORE_KEY = "cishet-female-archetype-quiz-v3";
      const QUIZ_VERSION = "3";
      const TELEMETRY_ENDPOINT = "/api/cishet-archetypes/result";
      const QUIZ_ID = "cishet-female-archetypes";
      const TOP_N = 5;
      const SPECIFIC_EVIDENCE_PRIOR = 4;
      const state = {
        answers: Array.from({ length: DECK.length }, () => []),
        idx: 0,
        finished: false,
        telemetrySent: false,
        startedAt: Date.now(),
      };
      const introSection = document.getElementById("intro");
      const quizSection = document.getElementById("quiz");
      const quizCard = document.getElementById("quiz-card");
      const progressEl = document.getElementById("progress");
      const resultsSection = document.getElementById("results");
      const verdictEl = document.getElementById("verdict");

      function saveLocal() {
        try {
          localStorage.setItem(
            STORE_KEY,
            JSON.stringify({
              answers: state.answers,
              idx: state.idx,
              finished: state.finished,
              telemetrySent: state.telemetrySent,
              startedAt: state.startedAt,
            }),
          );
        } catch (_) {}
      }

      function loadLocal() {
        try {
          const saved = JSON.parse(
            localStorage.getItem(STORE_KEY) || "null",
          );
          if (!saved || !Array.isArray(saved.answers) || saved.answers.length !== DECK.length) return false;
          state.answers = saved.answers.map((value, index) => {
            const values = Array.isArray(value) ? value : [value];
            return [...new Set(values)].filter(
              (optionIndex) =>
                Number.isInteger(optionIndex) &&
                optionIndex >= 0 &&
                optionIndex < DECK[index].opts.length,
            );
          });
          state.idx = Math.min(Math.max(0, saved.idx | 0), DECK.length - 1);
          state.finished = Boolean(saved.finished);
          state.telemetrySent =
            saved.telemetrySent === undefined && state.finished
              ? true
              : Boolean(saved.telemetrySent);
          state.startedAt = Number.isFinite(saved.startedAt)
            ? saved.startedAt
            : Date.now();
          return true;
        } catch (_) {
          return false;
        }
      }

      function encodeAnswers() {
        return state.answers.map((selection) =>
          selection.map((value) => (value + 1).toString(36)).join("")
        ).join(".");
      }

      function decodeAnswers(value) {
        if (typeof value !== "string") return null;
        if (!value.includes(".") && value.length === DECK.length) {
          const legacyAnswers = [];
          for (let index = 0; index < value.length; index++) {
            const digit = value.charCodeAt(index) - 48;
            if (digit < 0 || digit > DECK[index].opts.length) return null;
            legacyAnswers.push(digit === 0 ? [] : [digit - 1]);
          }
          return legacyAnswers;
        }
        const segments = value.split(".");
        if (segments.length !== DECK.length) return null;
        const answers = segments.map((segment, questionIndex) => {
          const selection = [...new Set([...segment].map((character) =>
            Number.parseInt(character, 36) - 1
          ))];
          return selection.every(
            (optionIndex) =>
              Number.isInteger(optionIndex) &&
              optionIndex >= 0 &&
              optionIndex < DECK[questionIndex].opts.length,
          ) ? selection : null;
        });
        return answers.some((selection) => selection === null) ? null : answers;
      }

      function firstUnansweredIndex() {
        const index = state.answers.findIndex((selection) => selection.length === 0);
        return index === -1 ? DECK.length - 1 : index;
      }

      function allAnswered() {
        return state.answers.every((selection) => selection.length > 0);
      }

      function canVisitQuestion(index) {
        return state.answers[index].length > 0 || index <= firstUnansweredIndex();
      }

      const stopWords = new Set(
        "about after again against almost also always among around because before being between both could default does doing down during each enough every first from further have having here honestly into just maybe more most much myself next only other over same should some still such than that their them then there these they this those through under until very what when where which while with would your youre girl girls female woman women mostly energy mode thing stuff vibe vibes looks like".split(" "),
      );
      const optionTokenCache = new WeakMap();
      const archetypeTokenCache = new Map();

      function lexicalTokens(value) {
        return new Set(
          String(value)
            .toLowerCase()
            .replace(/[^a-z0-9]+/g, " ")
            .split(/\s+/)
            .filter((token) => token.length >= 4 && !stopWords.has(token))
            .map((token) => token.replace(/(ies|ing|ers|er|ed|s)$/, "")),
        );
      }

      function lexicalWeight(option, archetype) {
        let optionTokens = optionTokenCache.get(option);
        if (!optionTokens) {
          optionTokens = lexicalTokens(option.t);
          optionTokenCache.set(option, optionTokens);
        }
        let archetypeTokens = archetypeTokenCache.get(archetype.id);
        if (!archetypeTokens) {
          archetypeTokens = lexicalTokens(archetype.terms + " " + archetype.gloss);
          archetypeTokenCache.set(archetype.id, archetypeTokens);
        }
        let overlaps = 0;
        for (const token of optionTokens) {
          if (archetypeTokens.has(token)) overlaps += 1;
        }
        return Math.min(2.4, overlaps * 0.6);
      }

      function escapeRegExp(value) {
        return String(value).replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
      }

      function specificWeight(option, archetype) {
        let weight = lexicalWeight(option, archetype);
        for (const boost of option.boosts || []) {
          const pattern = new RegExp(
            `(^|[^a-z0-9])${escapeRegExp(boost.match)}(?=$|[^a-z0-9])`,
            "i",
          );
          if (pattern.test(archetype.terms)) weight += boost.w;
        }
        return weight;
      }

      function optionWeight(option, archetype) {
        return (option.sections[archetype.sectionId] || 0) + specificWeight(option, archetype);
      }

      function rankMatches(answers) {
        const scores = new Float64Array(ARCHETYPES.length);
        const maxes = new Float64Array(ARCHETYPES.length);
        const specificScores = new Float64Array(ARCHETYPES.length);
        const specificMaxes = new Float64Array(ARCHETYPES.length);
        for (let questionIndex = 0; questionIndex < DECK.length; questionIndex++) {
          const selection = answers[questionIndex];
          const question = DECK[questionIndex];
          if (!Array.isArray(selection) || selection.length === 0) continue;
          const chosenOptions = selection
            .filter((answer) => answer >= 0 && answer < question.opts.length)
            .map((answer) => question.opts[answer]);
          if (chosenOptions.length === 0) continue;
          for (let archetypeIndex = 0; archetypeIndex < ARCHETYPES.length; archetypeIndex++) {
            const archetype = ARCHETYPES[archetypeIndex];
            const divisor = chosenOptions.length;
            for (const chosen of chosenOptions) {
              scores[archetypeIndex] += optionWeight(chosen, archetype) / divisor;
              specificScores[archetypeIndex] += specificWeight(chosen, archetype) / divisor;
            }
            let best = 0;
            let bestSpecific = 0;
            for (const option of question.opts) {
              best = Math.max(best, optionWeight(option, archetype));
              bestSpecific = Math.max(bestSpecific, specificWeight(option, archetype));
            }
            maxes[archetypeIndex] += best;
            specificMaxes[archetypeIndex] += bestSpecific;
          }
        }
        return ARCHETYPES.map((archetype, index) => {
          const baseFit = maxes[index] > 0 ? scores[index] / maxes[index] : 0;
          const specificFit = specificMaxes[index] > 0
            ? specificScores[index] /
              (specificMaxes[index] + SPECIFIC_EVIDENCE_PRIOR)
            : 0;
          // Broad sections keep adjacent labels plausible, but explicit answer-to-label
          // mappings do most of the work so a generic lifestyle choice cannot dominate.
          const fit = baseFit * 0.25 + specificFit * 0.75;
          return {
            archetype,
            fit,
            specificScore: specificScores[index],
            matchPct: Math.round(1000 * fit) / 10,
          };
        }).filter((result) => result.fit > 0).sort(
          (a, b) =>
            b.fit - a.fit ||
            b.specificScore - a.specificScore ||
            a.archetype.terms.localeCompare(b.archetype.terms),
        );
      }

      function escapeHtml(value) {
        return String(value)
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;");
      }

      function renderTermsHtml(terms) {
        return terms.split(/\s*\/\s*/).map((part) => {
          const link = wikiLinks[part]
            ? { ...wikiLinks[part], source: "wiki" }
            : kymLinks[part]
              ? { ...kymLinks[part], source: "kym" }
              : null;
          if (!link) return escapeHtml(part);
          const sourceLabel = link.source === "wiki" ? "Wikipedia" : "Know Your Meme";
          return `<a class="${link.source}-term" href="${escapeHtml(link.url)}" target="_blank" rel="noopener noreferrer" title="${escapeHtml(sourceLabel + ": " + link.title)}">${escapeHtml(part)}</a>`;
        }).join(" / ");
      }

      function renderProgress() {
        progressEl.innerHTML = "";
        DECK.forEach((question, index) => {
          const dot = document.createElement("button");
          dot.type = "button";
          dot.className = "p-dot";
          if (state.answers[index].length > 0) dot.classList.add("done");
          if (index === state.idx) dot.classList.add("here");
          dot.disabled = !canVisitQuestion(index);
          dot.setAttribute(
            "aria-label",
            `Question ${index + 1}: ${question.topic}, ${state.answers[index].length > 0 ? "answered" : "unanswered"}`,
          );
          dot.title = `${index + 1} · ${question.topic}`;
          dot.addEventListener("click", () => goTo(index));
          progressEl.appendChild(dot);
        });
        const currentDot = progressEl.children[state.idx];
        if (currentDot) {
          requestAnimationFrame(() => {
            progressEl.scrollTo({
              left: currentDot.offsetLeft - progressEl.clientWidth / 2 + currentDot.clientWidth / 2,
              behavior: "smooth",
            });
          });
        }
      }

      function renderQuestion() {
        const question = DECK[state.idx];
        const chosen = state.answers[state.idx];
        quizCard.innerHTML = `
          <div class="q-meta">
            <span class="q-topic">${escapeHtml(question.topic)}</span>
            <span>${state.idx + 1} / ${DECK.length}</span>
          </div>
          <h2 class="q-prompt">${escapeHtml(question.q)}</h2>
          <p class="q-hint">Choose one or several. Multiple answers are blended equally.</p>
          <div class="q-options" role="group" aria-label="Answers"></div>
          <div class="q-nav"></div>
        `;
        const options = quizCard.querySelector(".q-options");
        question.opts.forEach((option, index) => {
          const button = document.createElement("button");
          button.type = "button";
          button.className = `q-option${chosen.includes(index) ? " selected" : ""}`;
          button.setAttribute("role", "checkbox");
          button.setAttribute("aria-checked", chosen.includes(index) ? "true" : "false");
          button.innerHTML = `<span class="q-key">${index + 1}</span><span class="q-text"></span>`;
          button.querySelector(".q-text").textContent = option.t;
          button.addEventListener("click", () => selectOption(index));
          options.appendChild(button);
        });
        const nav = quizCard.querySelector(".q-nav");
        const back = document.createElement("button");
        back.type = "button";
        back.className = "btn btn-ghost";
        back.textContent = "← Back";
        back.disabled = state.idx === 0;
        back.addEventListener("click", () => goTo(state.idx - 1));
        nav.appendChild(back);
        if (state.idx === DECK.length - 1) {
          const finish = document.createElement("button");
          finish.type = "button";
          finish.className = "btn btn-primary";
          finish.textContent = "See my results";
          finish.disabled = !allAnswered();
          finish.addEventListener("click", showResults);
          nav.appendChild(finish);
        } else {
          const next = document.createElement("button");
          next.type = "button";
          next.className = "btn btn-primary";
          next.textContent = "Next →";
          next.disabled = chosen.length === 0;
          next.addEventListener("click", () => goTo(state.idx + 1));
          nav.appendChild(next);
        }
        renderProgress();
      }

      function selectOption(optionIndex) {
        const selection = state.answers[state.idx];
        const options = DECK[state.idx].opts;
        if (options[optionIndex].skip) {
          state.answers[state.idx] = [optionIndex];
        } else {
          const withoutSkip = selection.filter((value) => !options[value].skip);
          state.answers[state.idx] = withoutSkip.includes(optionIndex)
            ? withoutSkip.filter((value) => value !== optionIndex)
            : [...withoutSkip, optionIndex].sort((a, b) => a - b);
        }
        state.finished = false;
        state.telemetrySent = false;
        saveLocal();
        renderQuestion();
      }

      function goTo(index) {
        quizCard.classList.remove("settling");
        const clamped = Math.min(Math.max(0, index), DECK.length - 1);
        state.idx = canVisitQuestion(clamped) ? clamped : firstUnansweredIndex();
        saveLocal();
        renderQuestion();
      }

      function resultText(top) {
        return (
          `My cishet female archetypes:\n` +
          top.map((result, index) =>
            `${index + 1}. ${result.matchPct}%: ${result.archetype.terms}`,
          ).join("\n") +
          `\n${location.origin}/tests/cishet-female-archetypes?v=${QUIZ_VERSION}&r=${encodeAnswers()}`
        );
      }

      function sendResultTelemetry(top, matchedQuestions, persist) {
        if (!persist || state.telemetrySent || !("fetch" in window)) return;

        const durationMs = Number.isFinite(state.startedAt)
          ? Date.now() - state.startedAt
          : null;
        fetch(TELEMETRY_ENDPOINT, {
          method: "POST",
          keepalive: true,
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            version: 1,
            quiz: QUIZ_ID,
            path: location.pathname,
            answers: encodeAnswers(),
            matchedQuestions,
            topIds: top.map((result) => result.archetype.id),
            topNames: top.map((result) => result.archetype.terms),
            topFits: top.map((result) => result.matchPct),
            durationMs,
          }),
        })
          .then((response) => {
            if (!response.ok) return;
            state.telemetrySent = true;
            saveLocal();
          })
          .catch(() => { /* telemetry should never affect the quiz. */ });
      }

      function showResults(persist = true) {
        if (!allAnswered()) return;
        state.finished = true;
        if (persist) saveLocal();
        const top = rankMatches(state.answers).slice(0, TOP_N);
        const matchedQuestions = state.answers.filter((selection, questionIndex) =>
          selection.some((optionIndex) => !DECK[questionIndex].opts[optionIndex].skip)
        ).length;
        const url = new URL(location.href);
        url.searchParams.set("v", QUIZ_VERSION);
        url.searchParams.set("r", encodeAnswers());
        history.replaceState(null, "", url);
        introSection.hidden = true;
        quizSection.hidden = true;
        resultsSection.hidden = false;
        if (top.length === 0) {
          verdictEl.innerHTML =
            `<p class="verdict-kicker">No strong match</p>` +
            `<p class="no-match">These answers did not point to any archetype in the current quiz. That is a limitation of the quiz, not a requirement to force yourself into the closest label.</p>`;
        } else {
          const confidenceNote = matchedQuestions < 15
            ? `You found a fitting answer for ${matchedQuestions} of ${DECK.length} questions, so treat these as low-confidence suggestions. The archetype you have in mind may not be represented here.`
            : `Scores use answer categories plus direct label matches.`;
          verdictEl.innerHTML =
            `<p class="verdict-kicker">Your five best matches</p>` +
            `<ol class="match-list">` +
            top.map((result, index) =>
              `<li class="match-item">` +
              `<div class="match-rank">${index + 1}</div>` +
              `<div class="match-body">` +
              `<div class="match-head">` +
              `<span class="match-terms">${renderTermsHtml(result.archetype.terms)}</span>` +
              `<span class="match-pct">${result.matchPct}%</span>` +
              `</div>` +
              `<p class="match-gloss">${escapeHtml(result.archetype.gloss)}</p>` +
              `<p class="match-section">${escapeHtml(result.archetype.sectionTitle)}</p>` +
              `<div class="match-bar" aria-hidden="true"><span style="width:${result.matchPct}%"></span></div>` +
              `</div></li>`,
            ).join("") +
            `</ol>` +
            `<p class="verdict-note">${escapeHtml(confidenceNote)} The descriptions show how people use each term; they are not endorsements.</p>`;
        }
        sendResultTelemetry(top, matchedQuestions, persist);
        resultsSection.scrollIntoView({ behavior: "smooth", block: "start" });
      }

      function startQuiz(resume) {
        introSection.hidden = true;
        resultsSection.hidden = true;
        quizSection.hidden = false;
        state.finished = false;
        if (!resume) {
          state.answers = Array.from({ length: DECK.length }, () => []);
          state.idx = 0;
          state.telemetrySent = false;
          state.startedAt = Date.now();
        } else {
          state.idx = firstUnansweredIndex();
        }
        saveLocal();
        renderQuestion();
        quizSection.scrollIntoView({ behavior: "smooth", block: "start" });
      }

      document.getElementById("start-quiz")?.addEventListener("click", () => {
        startQuiz(state.answers.some((selection) => selection.length > 0) && !state.finished);
      });
      document.getElementById("retake")?.addEventListener("click", () => {
        const url = new URL(location.href);
        url.searchParams.delete("r");
        url.searchParams.delete("v");
        history.replaceState(null, "", url);
        startQuiz(false);
      });
      document.getElementById("copy-link")?.addEventListener("click", async (event) => {
        const url = new URL(location.href);
        url.searchParams.set("v", QUIZ_VERSION);
        url.searchParams.set("r", encodeAnswers());
        try {
          await navigator.clipboard.writeText(url.toString());
          const button = event.currentTarget;
          const previous = button.textContent;
          button.textContent = "Copied";
          setTimeout(() => { button.textContent = previous; }, 1200);
        } catch (_) {}
      });
      document.getElementById("copy-text")?.addEventListener("click", async (event) => {
        try {
          await navigator.clipboard.writeText(
            resultText(rankMatches(state.answers).slice(0, TOP_N)),
          );
          const button = event.currentTarget;
          const previous = button.textContent;
          button.textContent = "Copied";
          setTimeout(() => { button.textContent = previous; }, 1200);
        } catch (_) {}
      });
      document.addEventListener("keydown", (event) => {
        if (quizSection.hidden) return;
        const optionIndex = event.key === "0"
          ? 9
          : /^[1-9]$/.test(event.key)
            ? Number(event.key) - 1
            : -1;
        if (optionIndex >= 0 && optionIndex < DECK[state.idx].opts.length) {
          event.preventDefault();
          selectOption(optionIndex);
        }
      });

      const searchParams = new URLSearchParams(location.search);
      const shared = searchParams.get("v") === QUIZ_VERSION
        ? decodeAnswers(searchParams.get("r") || "")
        : null;
      if (shared && shared.every((selection) => selection.length > 0)) {
        state.answers = shared;
        state.finished = true;
        showResults(false);
      } else {
        loadLocal();
        if (state.finished && allAnswered()) showResults();
        else if (state.answers.some((selection) => selection.length > 0)) {
          document.getElementById("start-quiz").textContent = "Continue quiz";
        }
      }
    </script>
  </body>
</html>

