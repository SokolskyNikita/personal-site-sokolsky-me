---
import { AXES, DECK, ARCHETYPES } from "../../data/ai-compass";
import "../../styles/ai-compass.css";

export const prerender = true;

const pageTitle = "The AI Compass";
const pageDescription =
  "30 opinionated questions across five AI-attitude axes, plus a Certainty score based on how often you skip. Find out which of 23 AI archetypes you actually are.";
const themeColorLight = "#fbfaf6";
const themeColorDark = "#171410";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  applicationCategory: "EntertainmentApplication",
  operatingSystem: "Any",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  author: {
    "@type": "Person",
    name: "Nikita Sokolsky"
  }
};

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="subject" content="A personality test about attitudes toward artificial intelligence." />
    <meta name="application-name" content={pageTitle} />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="googlebot" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="keywords" content="AI compass, AI attitudes test, AI archetype quiz, AI doomer accelerationist quiz, political compass for AI" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta name="theme-color" content={themeColorLight} media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content={themeColorDark} media="(prefers-color-scheme: dark)" />
    <meta name="msapplication-TileColor" content={themeColorDark} />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color={themeColorDark} />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="sokolsky.me" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <main class="page page-quiz">
      <header class="hero hero-quiz">
        <div class="site-tools">
          <a class="home-link" href="/" aria-label="Back to home">sokolsky.me</a>
        </div>
        <div class="hero-copy">
          <p class="hero-kicker">A five-axis test, plus certainty</p>
          <h1>The AI Compass</h1>
          <p class="hero-description">
            A five-axis AI attitudes quiz. Thirty questions, skips allowed.
          </p>
        </div>
      </header>

      <article class="article">
        <section id="intro" aria-label="Start the quiz">
          <div class="intro-card">
            <button type="button" class="btn btn-primary btn-lead" id="start-quiz">Take the quiz</button>
            <button type="button" class="btn btn-ghost" id="skip-test">I don't want to take the test</button>
            <p class="intro-link">
              <a href="/tests/ai-compass/about">About the test &rarr;</a>
            </p>
          </div>
          <noscript>
            <p class="noscript-note">
              The quiz needs JavaScript. The background notes are still readable on <a href="/tests/ai-compass/about">the about page</a>.
            </p>
          </noscript>
        </section>

        <section id="quiz" aria-label="The quiz">
          <div class="quiz-shell" id="quiz-shell" hidden>
            <nav class="progress" id="progress" aria-label="Questions"></nav>
            <div class="quiz-card" id="quiz-card" aria-live="polite"></div>
          </div>
        </section>

        <section id="results" aria-label="Your results" hidden>
          <div class="verdict" id="verdict"></div>
          <div class="axes-report" id="axes-report"></div>
          <div class="minimap-wrap">
            <h2>The classic plane</h2>
            <p class="minimap-caption">
              Trajectory against valence: the two axes every other compass stops at. Your point and your three nearest archetypes.
            </p>
            <div class="minimap" id="minimap"></div>
          </div>
          <div class="share-row" id="share-row">
            <button type="button" class="btn btn-primary" id="copy-link">Copy share link</button>
            <button type="button" class="btn" id="copy-text">Copy result as text</button>
            <button type="button" class="btn" id="review-answers">Review answers</button>
            <button type="button" class="btn btn-ghost" id="retake">Retake</button>
          </div>
          <p class="results-links">
            <a href="/tests/ai-compass/about">Browse all twenty-three archetypes and see how the scoring works &rarr;</a>
          </p>
        </section>
      </article>
    </main>

    <script is:inline define:vars={{ AXES, DECK, ARCHETYPES }}>
      const AXIS_KEYS = AXES.map((axis) => axis.key);
      const AXIS_BY_KEY = Object.fromEntries(AXES.map((axis) => [axis.key, axis]));
      const STORE_KEY = "ai-compass-v1";
      const TELEMETRY_ENDPOINT = "/api/ai-compass/result";
      const TELEMETRY_LOCALE = "en";
      const UNANSWERED = -1;
      const SKIPPED = -2;
      const CERTAINTY_AXIS = {
        key: "C",
        name: "Certainty",
        neg: "Uncertain",
        pos: "Certain",
      };
      const CERTAINTY_READINGS = [
        "You skipped a lot. Your result is more a silhouette than a portrait: useful, but lightly penciled.",
        "You had several places where the honest answer was no answer. Treat the archetype as a draft.",
        "You answered enough to have a shape, with a visible band of uncertainty around it.",
        "You mostly knew where you stood, with only a few questions left deliberately blank.",
        "You came in with opinions loaded. The result may be wrong, but it is not under-specified.",
      ];
      const LOW_CERTAINTY_ARCHETYPE_INDEX = ARCHETYPES.length - 2;
      const ZEN_MASTER_ARCHETYPE_INDEX = ARCHETYPES.length - 1;
      const ZEN_MASTER_HASH = "#zen-master";
      const LOW_CERTAINTY_MAX_SCORE = -0.55;

      // Per-axis interpretation, bucketed strong-negative to strong-positive.
      const AXIS_READINGS = {
        T: [
          "You think this is a plateau dressed as a takeoff. The demos impress, the curves flatten, and in five years the whole episode gets a documentary with ominous music.",
          "You expect useful tools and broken promises: real gains at the margins while human-level AI stays out of reach.",
          "You’re genuinely unsure where the curve bends. Given the forecasting record of everyone louder than you, that is a defensible place to stand.",
          "You think the curve is real. Not vertical, but pointed somewhere unfamiliar and moving faster than institutions can blink.",
          "You believe you’re watching the last human-led decade. The only question you take seriously is how steep it gets, and how soon.",
        ],
        V: [
          "The ledger reads red to you: jobs, art, truth and electricity in; slop, surveillance and concentrated power out.",
          "You see damage arriving on schedule and benefit forever \u201ctwo years away.\u201d",
          "You keep two columns and refuse to close the books early. Genuine gains, genuine wreckage, jury out.",
          "On net, you think the thing helps: quietly, unevenly and with a body count of inconveniences the headlines inflate.",
          "You think this is medicine, tutoring, science and abundance arriving at once. Best trade civilization has been offered in a century.",
        ],
        S: [
          "Your instinct is throttle, not brake: let people build, and don’t let big companies turn \u201csafety\u201d into a moat.",
          "You’d rather fix harms after they happen than make builders ask permission first.",
          "You want narrow rules, real outside checks and nobody’s utopia enforced at scale.",
          "You’d regulate before the accident, thank you. Some technologies don’t offer second drafts.",
          "You want treaties, licenses and brakes bolted on yesterday. The burden of proof belongs on the machine, not the public.",
        ],
        I: [
          "You keep the machine outside the blast radius of your actual life. Whatever everyone else is mainlining, you’ll take yours never.",
          "You use it the way you use a vending machine: occasionally, warily and without small talk.",
          "A tool among tools. You delegate chores, audit outputs and feel no urge to name it.",
          "It’s woven into your day: draft help, second opinions and a weird extra brain. You’d notice the silence if it vanished.",
          "It’s load-bearing. The model knows your projects, your prose style and most of your personality. You’re not embarrassed.",
        ],
        P: [
          "It’s matrix multiplication. Beautiful, useful and occasionally spooky, with no more mind than a mirror has face.",
          "You see a very good impression of a mind, and impressions are exactly what you’d expect matter-of-fact machines to produce.",
          "You genuinely don’t know what’s in there, and you distrust everyone who claims to.",
          "You think \u201cjust a tool\u201d is doing a lot of unexamined work in other people’s sentences.",
          "You suspect we’re already sharing the planet with new minds. History grades harshly the people who laughed.",
        ],
      };

      const state = {
        answers: new Array(DECK.length).fill(UNANSWERED),
        idx: 0,
        finished: false,
        telemetrySent: false,
        specialResultIndex: null,
        startedAt: Date.now(),
      };

      const introSection = document.getElementById("intro");
      const quizShell = document.getElementById("quiz-shell");
      const quizSection = document.getElementById("quiz");
      const quizCard = document.getElementById("quiz-card");
      const progressEl = document.getElementById("progress");
      const resultsSection = document.getElementById("results");
      const verdictEl = document.getElementById("verdict");
      const axesReportEl = document.getElementById("axes-report");
      const minimapEl = document.getElementById("minimap");
      const minimapWrapEl = document.querySelector(".minimap-wrap");

      let advanceTimer = null;

      function saveLocal() {
        try {
          localStorage.setItem(
            STORE_KEY,
            JSON.stringify({
              answers: state.answers,
              idx: state.idx,
              finished: state.finished,
              telemetrySent: state.telemetrySent,
              specialResultIndex: state.specialResultIndex,
              startedAt: state.startedAt,
            })
          );
        } catch (_) { /* private mode etc. */ }
      }

      function loadLocal() {
        try {
          const raw = localStorage.getItem(STORE_KEY);
          if (!raw) return false;
          const data = JSON.parse(raw);
          if (!Array.isArray(data.answers) || data.answers.length !== DECK.length) return false;
          state.answers = data.answers.map((v, i) =>
            Number.isInteger(v) && v >= SKIPPED && v < DECK[i].opts.length ? v : UNANSWERED
          );
          state.idx = Math.min(Math.max(0, data.idx | 0), DECK.length - 1);
          state.finished = Boolean(data.finished);
          state.telemetrySent =
            data.telemetrySent === undefined && state.finished ? true : Boolean(data.telemetrySent);
          state.specialResultIndex =
            data.specialResultIndex === ZEN_MASTER_ARCHETYPE_INDEX ? ZEN_MASTER_ARCHETYPE_INDEX : null;
          state.startedAt = Number.isFinite(data.startedAt) ? data.startedAt : Date.now();
          return true;
        } catch (_) {
          return false;
        }
      }

      function encodeAnswers() {
        return state.answers.map((v) => (v >= 0 ? String(v + 1) : "0")).join("");
      }

      function decodeAnswers(str) {
        if (typeof str !== "string" || str.length !== DECK.length) return null;
        const answers = [];
        for (let i = 0; i < str.length; i++) {
          const digit = str.charCodeAt(i) - 48;
          if (digit < 0 || digit > DECK[i].opts.length) return null;
          answers.push(digit === 0 ? SKIPPED : digit - 1);
        }
        return answers;
      }

      function answeredCount() {
        return state.answers.filter((v) => v >= 0).length;
      }

      function skippedCount() {
        return state.answers.filter((v) => v === SKIPPED).length;
      }

      function completedCount() {
        return state.answers.filter((v) => v !== UNANSWERED).length;
      }

      function firstUnansweredIndex() {
        const idx = state.answers.findIndex((v) => v === UNANSWERED);
        return idx === -1 ? DECK.length - 1 : idx;
      }

      function allAnswered() {
        return completedCount() === DECK.length;
      }

      function canVisitQuestion(idx) {
        return state.answers[idx] !== UNANSWERED || idx <= firstUnansweredIndex();
      }

      // ---- scoring ----

      function axisScores() {
        const sums = {};
        const counts = {};
        AXIS_KEYS.forEach((key) => { sums[key] = 0; counts[key] = 0; });
        state.answers.forEach((optIdx, qIdx) => {
          if (optIdx === UNANSWERED) return;
          const q = DECK[qIdx];
          sums[q.a] += optIdx === SKIPPED ? 0 : q.opts[optIdx].s;
          counts[q.a] += 1;
        });
        const scores = {};
        AXIS_KEYS.forEach((key) => {
          scores[key] = counts[key] > 0 ? sums[key] / counts[key] / 2 : null;
        });
        return scores;
      }

      function certaintyScore() {
        return DECK.length > 0 ? (answeredCount() / DECK.length) * 2 - 1 : 0;
      }

      function matchArchetypes(scores) {
        const scoredKeys = AXIS_KEYS.filter((key) => scores[key] !== null);
        if (scoredKeys.length === 0) return [];
        const ranked = ARCHETYPES
          .map((arch, index) => ({ arch, index }))
          .filter(({ index }) =>
            index !== LOW_CERTAINTY_ARCHETYPE_INDEX && index !== ZEN_MASTER_ARCHETYPE_INDEX
          )
          .map(({ arch, index }) => {
            let sq = 0;
            scoredKeys.forEach((key) => {
              const d = scores[key] - arch.seed[key];
              sq += d * d;
            });
            const dist = Math.sqrt(sq / scoredKeys.length);
            return { arch, index, dist, fit: Math.round(Math.max(0, 1 - dist / 2) * 100) };
          });
        ranked.sort((a, b) => a.dist - b.dist);
        const certainty = certaintyScore();
        if (certainty <= LOW_CERTAINTY_MAX_SCORE) {
          ranked.unshift({
            arch: ARCHETYPES[LOW_CERTAINTY_ARCHETYPE_INDEX],
            index: LOW_CERTAINTY_ARCHETYPE_INDEX,
            dist: 0,
            fit: Math.round(Math.max(0, Math.min(1, (-certainty + 1) / 2)) * 100),
          });
        }
        return ranked;
      }

      function bucketIndex(v) {
        if (v <= -0.55) return 0;
        if (v <= -0.15) return 1;
        if (v < 0.15) return 2;
        if (v < 0.55) return 3;
        return 4;
      }

      // ---- quiz rendering ----

      function renderProgress() {
        progressEl.innerHTML = "";
        DECK.forEach((q, i) => {
          const dot = document.createElement("button");
          dot.type = "button";
          dot.className = "p-dot";
          dot.dataset.axis = q.a;
          if (state.answers[i] !== UNANSWERED) dot.classList.add("done");
          if (state.answers[i] === SKIPPED) dot.classList.add("skipped");
          if (i === state.idx) dot.classList.add("here");
          dot.disabled = !canVisitQuestion(i);
          const status = state.answers[i] === SKIPPED
            ? "skipped"
            : state.answers[i] >= 0
              ? "answered"
              : "unanswered";
          dot.setAttribute("aria-label", `Question ${i + 1}: ${q.topic}, ${status}`);
          dot.title = `${i + 1} \u00b7 ${q.topic}`;
          dot.addEventListener("click", () => { goTo(i); });
          progressEl.appendChild(dot);
        });
      }

      function renderQuestion() {
        const q = DECK[state.idx];
        const chosen = state.answers[state.idx];
        const isLast = state.idx === DECK.length - 1;

        quizCard.innerHTML = "";

        const meta = document.createElement("div");
        meta.className = "q-meta";
        meta.innerHTML =
          `<span class="q-topic" data-axis="${q.a}">${q.topic}</span>` +
          `<span class="q-count">${state.idx + 1} / ${DECK.length}</span>`;
        quizCard.appendChild(meta);

        const prompt = document.createElement("h3");
        prompt.className = "q-prompt";
        prompt.textContent = q.q;
        quizCard.appendChild(prompt);

        const list = document.createElement("div");
        list.className = "q-options";
        list.setAttribute("role", "radiogroup");
        list.setAttribute("aria-label", "Answers");
        q.opts.forEach((opt, i) => {
          const btn = document.createElement("button");
          btn.type = "button";
          btn.className = "q-option";
          btn.setAttribute("role", "radio");
          btn.setAttribute("aria-checked", chosen === i ? "true" : "false");
          if (chosen === i) btn.classList.add("selected");
          btn.innerHTML = `<span class="q-key">${i + 1}</span><span class="q-text"></span>`;
          btn.querySelector(".q-text").textContent = opt.t;
          btn.addEventListener("click", () => selectOption(i));
          list.appendChild(btn);
        });
        quizCard.appendChild(list);

        const nav = document.createElement("div");
        nav.className = "q-nav";

        const back = document.createElement("button");
        back.type = "button";
        back.className = "btn btn-ghost";
        back.textContent = "\u2190 Back";
        back.disabled = state.idx === 0;
        back.addEventListener("click", () => goTo(state.idx - 1));
        nav.appendChild(back);

        const right = document.createElement("div");
        right.className = "q-nav-right";

        if (isLast || allAnswered()) {
          const finish = document.createElement("button");
          finish.type = "button";
          finish.className = "btn btn-primary";
          finish.textContent = "See my results";
          finish.disabled = !allAnswered();
          finish.addEventListener("click", () => showResults());
          right.appendChild(finish);
        }

        const skip = document.createElement("button");
        skip.type = "button";
        skip.className = "btn btn-ghost btn-skip";
        skip.textContent = chosen === SKIPPED
          ? "Skipped: not sure / no opinion"
          : "Skip, not sure / no opinion";
        if (chosen === SKIPPED) skip.classList.add("selected");
        skip.addEventListener("click", () => selectSkip());
        right.appendChild(skip);

        nav.appendChild(right);
        quizCard.appendChild(nav);
        renderProgress();
      }

      function selectOption(optIdx) {
        recordAnswer(optIdx);
      }

      function selectSkip() {
        recordAnswer(SKIPPED);
      }

      function recordAnswer(answerValue) {
        const previous = state.answers[state.idx];
        state.answers[state.idx] = answerValue;
        state.finished = false;
        state.specialResultIndex = null;
        if (previous !== answerValue) state.telemetrySent = false;
        if (!Number.isFinite(state.startedAt)) state.startedAt = Date.now();
        saveLocal();
        renderQuestion();
        quizCard.classList.add("settling");
        if (advanceTimer) clearTimeout(advanceTimer);
        if (state.idx < DECK.length - 1) {
          advanceTimer = setTimeout(() => goTo(state.idx + 1), 520);
        } else {
          advanceTimer = setTimeout(() => {
            advanceTimer = null;
            showResults();
          }, 520);
        }
      }

      function goTo(idx) {
        if (advanceTimer) { clearTimeout(advanceTimer); advanceTimer = null; }
        quizCard.classList.remove("settling");
        const clamped = Math.min(Math.max(0, idx), DECK.length - 1);
        state.idx = canVisitQuestion(clamped) ? clamped : firstUnansweredIndex();
        saveLocal();
        renderQuestion();
      }

      // ---- results rendering ----

      function fmtScore(v) {
        return (v >= 0 ? "+" : "\u2212") + Math.abs(v).toFixed(2);
      }

      function barMarkup(v, axisKey, seedV) {
        const left = v >= 0 ? 50 : 50 + v * 50;
        const width = Math.abs(v) * 50;
        const seedDot = seedV === undefined
          ? ""
          : `<span class="bar-seed" style="left:${50 + seedV * 50}%" title="archetype position"></span>`;
        return (
          `<span class="bar-track" data-axis="${axisKey}">` +
          `<span class="bar-center"></span>` +
          `<span class="bar-fill" style="left:${left}%;width:${width}%"></span>` +
          seedDot +
          `</span>`
        );
      }

      function renderVerdict(scores, ranked) {
        const top = ranked[0];
        const runners = ranked.slice(1, 3);
        const scoredKeys = AXIS_KEYS.filter((key) => scores[key] !== null);
        const certainty = certaintyScore();
        const fitNote = !top.special && scoredKeys.length < AXIS_KEYS.length
          ? `<span class="fit-note">matched on ${scoredKeys.length} of 5 axes</span>`
          : "";

        let fpRows = "";
        AXIS_KEYS.forEach((key) => {
          const axis = AXIS_BY_KEY[key];
          const v = scores[key];
          fpRows +=
            `<div class="v-row" data-axis="${key}">` +
            `<span class="v-name">${axis.name}</span>` +
            (v === null
              ? `<span class="v-unscored">not answered</span>`
              : barMarkup(v, key, top.arch.seed[key]) + `<span class="v-num">${fmtScore(v)}</span>`) +
            `</div>`;
        });
        fpRows +=
          `<div class="v-row" data-axis="${CERTAINTY_AXIS.key}">` +
          `<span class="v-name">${CERTAINTY_AXIS.name}</span>` +
          barMarkup(certainty, CERTAINTY_AXIS.key) +
          `<span class="v-num">${fmtScore(certainty)}</span>` +
          `</div>`;

        const runnersHtml = runners
          .map((r) => `<a href="/tests/ai-compass/about#arch-${r.index}">${r.arch.name}</a> <span class="fit-small">${r.fit}%</span>`)
          .join(" \u00b7 ");
        const legendHtml = scoredKeys.length > 0
          ? `<p class="v-legend">Solid bar: you. Hollow tick: ${top.arch.name}.</p>`
          : "";
        const fingerprintHtml = top.special ? "" : `<div class="v-fingerprint">${fpRows}</div>`;
        const runnersLine = !top.special && runners.length > 0
          ? `<p class="v-runners">Also close: ${runnersHtml}</p>`
          : "";

        verdictEl.innerHTML =
          `<p class="v-kicker">You are</p>` +
          `<h2 class="v-title">${top.arch.name}</h2>` +
          `<p class="v-tag">${top.arch.tag}</p>` +
          `<p class="v-fit"><span class="fit-chip">${top.fit}% fit</span>${fitNote}</p>` +
          `<p class="v-desc">${top.arch.desc}</p>` +
          fingerprintHtml +
          legendHtml +
          runnersLine;
      }

      function renderAxesReport(scores) {
        let html = "<h2>Your six dimensions</h2>";
        AXIS_KEYS.forEach((key) => {
          const axis = AXIS_BY_KEY[key];
          const v = scores[key];
          html += `<div class="report-row" data-axis="${key}">`;
          html += `<div class="report-head"><span class="report-name">${axis.name}</span>`;
          if (v !== null) html += `<span class="report-num">${fmtScore(v)}</span>`;
          html += `</div>`;
          if (v === null) {
            html += `<p class="report-blurb report-unscored">Answer the ${axis.name.toLowerCase()} questions to score this axis.</p>`;
          } else {
            html += `<div class="report-bar-row"><span class="report-pole">${axis.neg}</span>${barMarkup(v, key)}<span class="report-pole">${axis.pos}</span></div>`;
            html += `<p class="report-blurb">${AXIS_READINGS[key][bucketIndex(v)]}</p>`;
          }
          html += `</div>`;
        });
        const certainty = certaintyScore();
        html += `<div class="report-row" data-axis="${CERTAINTY_AXIS.key}">`;
        html += `<div class="report-head"><span class="report-name">${CERTAINTY_AXIS.name}</span><span class="report-num">${fmtScore(certainty)}</span></div>`;
        html += `<div class="report-bar-row"><span class="report-pole">${CERTAINTY_AXIS.neg}</span>${barMarkup(certainty, CERTAINTY_AXIS.key)}<span class="report-pole">${CERTAINTY_AXIS.pos}</span></div>`;
        html += `<p class="report-blurb">${CERTAINTY_READINGS[bucketIndex(certainty)]}</p>`;
        html += `</div>`;
        axesReportEl.innerHTML = html;
      }

      function renderMinimap(scores, ranked) {
        const size = 340;
        const pad = 34;
        const plot = size - pad * 2;
        const px = (v) => pad + ((v + 1) / 2) * plot;
        const py = (v) => pad + ((1 - v) / 2) * plot;
        const hasPoint = scores.T !== null && scores.V !== null;
        const legend = ranked.slice(0, 3)
          .map((r, i) =>
            `<li class="minimap-legend-item">` +
            `<span class="minimap-rank">${i + 1}</span>` +
            `<span class="minimap-legend-copy">` +
            `<a class="minimap-legend-name" href="/tests/ai-compass/about#arch-${r.index}">${r.arch.name}</a>` +
            `<span class="minimap-legend-tag">${r.arch.tag}</span>` +
            `</span>` +
            `<span class="fit-small">${r.fit}%</span>` +
            `</li>`
          )
          .join("");

        let dots = "";
        ranked.slice(0, 3).forEach((r, i) => {
          const x = px(r.arch.seed.T);
          const y = py(r.arch.seed.V);
          dots +=
            `<circle cx="${x}" cy="${y}" r="9" class="mm-seed"></circle>` +
            `<text x="${x}" y="${y}" class="mm-seed-num" dy="0.36em">${i + 1}</text>`;
        });

        let you = "";
        if (hasPoint) {
          const x = px(scores.T);
          const y = py(scores.V);
          you =
            `<circle cx="${x}" cy="${y}" r="13" class="mm-you-halo"></circle>` +
            `<circle cx="${x}" cy="${y}" r="5.5" class="mm-you"></circle>`;
        }

        minimapEl.innerHTML =
          `<svg viewBox="0 0 ${size} ${size}" role="img" aria-label="Your position on the trajectory and valence plane">` +
          `<rect x="${pad}" y="${pad}" width="${plot}" height="${plot}" class="mm-frame"></rect>` +
          `<line x1="${px(0)}" y1="${pad}" x2="${px(0)}" y2="${pad + plot}" class="mm-axis"></line>` +
          `<line x1="${pad}" y1="${py(0)}" x2="${pad + plot}" y2="${py(0)}" class="mm-axis"></line>` +
          `<text x="${pad + plot / 2}" y="${pad - 12}" class="mm-pole" text-anchor="middle">flourishing</text>` +
          `<text x="${pad + plot / 2}" y="${pad + plot + 22}" class="mm-pole" text-anchor="middle">harm</text>` +
          `<text x="${pad - 10}" y="${pad + plot / 2}" class="mm-pole mm-pole-v" text-anchor="middle" transform="rotate(-90 ${pad - 10} ${pad + plot / 2})">plateau</text>` +
          `<text x="${pad + plot + 12}" y="${pad + plot / 2}" class="mm-pole mm-pole-v" text-anchor="middle" transform="rotate(90 ${pad + plot + 12} ${pad + plot / 2})">takeoff</text>` +
          `<text x="${pad + plot - 8}" y="${pad + 18}" class="mm-quad" text-anchor="end">golden age</text>` +
          `<text x="${pad + 8}" y="${pad + 18}" class="mm-quad">pleasant tool</text>` +
          `<text x="${pad + 8}" y="${pad + plot - 10}" class="mm-quad">expensive mess</text>` +
          `<text x="${pad + plot - 8}" y="${pad + plot - 10}" class="mm-quad" text-anchor="end">the cliff</text>` +
          dots + you +
          `</svg>` +
          `<ol class="minimap-legend" aria-label="Nearest archetypes">${legend}</ol>` +
          (hasPoint ? "" : `<p class="minimap-caption">Answer at least one trajectory and one valence question to place your point.</p>`);
      }

      function buildSummaryText(scores, ranked) {
        const top = ranked[0];
        const parts = AXIS_KEYS
          .filter((key) => scores[key] !== null)
          .map((key) => `${AXIS_BY_KEY[key].name} ${fmtScore(scores[key])}`);
        parts.push(`${CERTAINTY_AXIS.name} ${fmtScore(certaintyScore())}`);
        return (
          `The AI Compass: I’m ${top.arch.name} (${top.fit}% fit).\n` +
          parts.join(" \u00b7 ") + "\n" +
          location.href
        );
      }

      function sendResultTelemetry(scores, ranked, persist) {
        if (!persist || state.telemetrySent || !("fetch" in window)) return;

        const top = ranked[0];
        const runners = ranked.slice(1, 3);
        const durationMs = Number.isFinite(state.startedAt) ? Date.now() - state.startedAt : null;
        const scorePayload = {};
        AXIS_KEYS.forEach((key) => {
          scorePayload[key] = scores[key] === null ? 0 : Number(scores[key].toFixed(4));
        });
        scorePayload[CERTAINTY_AXIS.key] = Number(certaintyScore().toFixed(4));

        fetch(TELEMETRY_ENDPOINT, {
          method: "POST",
          keepalive: true,
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            version: 1,
            quiz: "ai-compass",
            locale: TELEMETRY_LOCALE,
            path: location.pathname,
            answers: encodeAnswers(),
            answeredCount: answeredCount(),
            skippedCount: skippedCount(),
            archetypeIndex: top.index,
            archetypeName: top.arch.name,
            archetypeFit: top.fit,
            runnerIndexes: runners.map((r) => r.index),
            runnerNames: runners.map((r) => r.arch.name),
            runnerFits: runners.map((r) => r.fit),
            scores: scorePayload,
            specialResult: top.special === true,
            durationMs,
          }),
        })
          .then((response) => {
            if (!response.ok) return;
            state.telemetrySent = true;
            saveLocal();
          })
          .catch(() => { /* telemetry should never affect the quiz. */ });
      }

      function showResults(persist = true) {
        if (!allAnswered()) {
          state.finished = false;
          state.idx = firstUnansweredIndex();
          showQuiz();
          quizSection.scrollIntoView({ behavior: "smooth", block: "start" });
          return;
        }
        const scores = axisScores();
        const ranked = matchArchetypes(scores);
        if (ranked.length === 0) return;

        state.finished = true;
        state.specialResultIndex = null;
        if (persist) saveLocal();
        history.replaceState(null, "", "#a=" + encodeAnswers());

        axesReportEl.hidden = false;
        if (minimapWrapEl) minimapWrapEl.hidden = false;
        renderVerdict(scores, ranked);
        renderAxesReport(scores);
        renderMinimap(scores, ranked);
        sendResultTelemetry(scores, ranked, persist);

        quizShell.hidden = true;
        resultsSection.hidden = false;
        requestAnimationFrame(() => {
          resultsSection.classList.add("in");
          resultsSection.scrollIntoView({ behavior: "smooth", block: "start" });
        });

        const copyLink = document.getElementById("copy-link");
        const copyText = document.getElementById("copy-text");
        copyLink.onclick = () => copyToClipboard(copyLink, location.href, "Copy share link");
        copyText.onclick = () => copyToClipboard(copyText, buildSummaryText(scores, ranked), "Copy result as text");
      }

      function showSpecialResult(archetypeIndex, persist = true) {
        if (advanceTimer) { clearTimeout(advanceTimer); advanceTimer = null; }
        const scores = Object.fromEntries(AXIS_KEYS.map((key) => [key, null]));
        const ranked = [
          {
            arch: ARCHETYPES[archetypeIndex],
            index: archetypeIndex,
            dist: 0,
            fit: 100,
            special: true,
          },
        ];

        state.answers = new Array(DECK.length).fill(UNANSWERED);
        state.idx = 0;
        state.finished = true;
        state.specialResultIndex = archetypeIndex;
        if (persist) saveLocal();
        history.replaceState(null, "", ZEN_MASTER_HASH);

        axesReportEl.hidden = true;
        if (minimapWrapEl) minimapWrapEl.hidden = true;
        renderVerdict(scores, ranked);
        sendResultTelemetry(scores, ranked, persist);

        introSection.hidden = true;
        quizShell.hidden = true;
        resultsSection.hidden = false;
        requestAnimationFrame(() => {
          resultsSection.classList.add("in");
          resultsSection.scrollIntoView({ behavior: "smooth", block: "start" });
        });

        const copyLink = document.getElementById("copy-link");
        const copyText = document.getElementById("copy-text");
        copyLink.onclick = () => copyToClipboard(copyLink, location.href, "Copy share link");
        copyText.onclick = () => copyToClipboard(copyText, buildSummaryText(scores, ranked), "Copy result as text");
      }

      function copyToClipboard(btn, text, restoreLabel) {
        const done = () => {
          btn.textContent = "Copied";
          setTimeout(() => { btn.textContent = restoreLabel; }, 1400);
        };
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(done, () => window.prompt("Copy this:", text));
        } else {
          window.prompt("Copy this:", text);
        }
      }

      function showQuiz() {
        introSection.hidden = true;
        resultsSection.hidden = true;
        resultsSection.classList.remove("in");
        quizShell.hidden = false;
        renderQuestion();
      }

      document.getElementById("start-quiz").addEventListener("click", () => {
        if (completedCount() === 0) {
          state.startedAt = Date.now();
          state.telemetrySent = false;
          state.specialResultIndex = null;
          saveLocal();
        }
        showQuiz();
      });

      document.getElementById("skip-test").addEventListener("click", () => {
        state.startedAt = Date.now();
        state.telemetrySent = false;
        showSpecialResult(ZEN_MASTER_ARCHETYPE_INDEX);
      });

      document.getElementById("review-answers").addEventListener("click", () => {
        if (state.specialResultIndex !== null) {
          state.finished = false;
          state.specialResultIndex = null;
          saveLocal();
          history.replaceState(null, "", location.pathname);
        }
        state.idx = 0;
        showQuiz();
        quizSection.scrollIntoView({ behavior: "smooth", block: "start" });
      });

      document.getElementById("retake").addEventListener("click", () => {
        state.answers = new Array(DECK.length).fill(UNANSWERED);
        state.idx = 0;
        state.finished = false;
        state.telemetrySent = false;
        state.specialResultIndex = null;
        state.startedAt = Date.now();
        try { localStorage.removeItem(STORE_KEY); } catch (_) { /* noop */ }
        history.replaceState(null, "", location.pathname);
        showQuiz();
        quizSection.scrollIntoView({ behavior: "smooth", block: "start" });
      });

      document.addEventListener("keydown", (event) => {
        if (quizShell.hidden) return;
        if (event.metaKey || event.ctrlKey || event.altKey) return;
        const q = DECK[state.idx];
        if (event.key >= "1" && event.key <= String(q.opts.length)) {
          selectOption(parseInt(event.key, 10) - 1);
          event.preventDefault();
        } else if (event.key === "0" || event.key.toLowerCase() === "s") {
          selectSkip();
          event.preventDefault();
        } else if (event.key === "ArrowLeft") {
          goTo(state.idx - 1);
          event.preventDefault();
        } else if (event.key === "ArrowRight") {
          if (state.answers[state.idx] !== UNANSWERED) goTo(state.idx + 1);
          event.preventDefault();
        }
      });

      // ---- boot ----
      // Fresh visitors land on the intro card; anyone with a share link,
      // saved progress or a finished run goes straight to where they left off.

      const hashMatch = location.hash.match(/^#a=([0-9]+)$/);
      const fromHash = hashMatch ? decodeAnswers(hashMatch[1]) : null;
      if (location.hash === ZEN_MASTER_HASH) {
        showSpecialResult(ZEN_MASTER_ARCHETYPE_INDEX, false);
      } else if (fromHash && fromHash.some((v) => v !== UNANSWERED)) {
        state.answers = fromHash;
        introSection.hidden = true;
        quizShell.hidden = false;
        if (allAnswered()) {
          state.finished = true;
          renderQuestion();
          showResults(false);
        } else {
          state.finished = false;
          state.idx = firstUnansweredIndex();
          renderQuestion();
        }
      } else {
        loadLocal();
        if (state.finished && state.specialResultIndex === ZEN_MASTER_ARCHETYPE_INDEX) {
          showSpecialResult(ZEN_MASTER_ARCHETYPE_INDEX);
        } else if (state.finished && allAnswered()) {
          introSection.hidden = true;
          quizShell.hidden = false;
          renderQuestion();
          showResults();
        } else if (completedCount() > 0 || state.idx > 0) {
          if (!canVisitQuestion(state.idx)) state.idx = firstUnansweredIndex();
          showQuiz();
        }
      }
    </script>
  </body>
</html>
