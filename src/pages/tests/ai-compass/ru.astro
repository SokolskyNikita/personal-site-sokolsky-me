---
import { AXES, DECK, ARCHETYPES } from "../../../data/ai-compass-ru";
import "../../../styles/ai-compass.css";

export const prerender = true;

const pageTitle = "ИИ-компас";
const pageDescription =
  "30 вопросов по пяти независимым осям: траектория, баланс, управление, близость и личность. Узнайте, какой из 21 ИИ-архетипа ближе всего к вам.";
const themeColorLight = "#fbfaf6";
const themeColorDark = "#171410";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  applicationCategory: "EntertainmentApplication",
  operatingSystem: "Any",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  author: {
    "@type": "Person",
    name: "Nikita Sokolsky"
  }
};
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="subject" content="Тест по пяти осям об отношении к искусственному интеллекту." />
    <meta name="application-name" content={pageTitle} />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="googlebot" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="keywords" content="ИИ-компас, тест об ИИ, AI Compass, тест про искусственный интеллект, архетип ИИ" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta name="theme-color" content={themeColorLight} media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content={themeColorDark} media="(prefers-color-scheme: dark)" />
    <meta name="msapplication-TileColor" content={themeColorDark} />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color={themeColorDark} />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="sokolsky.me" />
    <meta property="og:locale" content="ru_RU" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <main class="page page-quiz">
      <header class="hero hero-quiz">
        <div class="site-tools">
          <a class="home-link" href="/" aria-label="На главную">sokolsky.me</a>
        </div>
        <div class="hero-copy">
          <p class="hero-kicker">Тест по пяти осям</p>
          <h1>ИИ-компас</h1>
          <p class="hero-description">
            Тест об отношении к ИИ: пять осей, тридцать вопросов, без пропусков.
          </p>
        </div>
      </header>

      <article class="article">
        <section id="intro" aria-label="Начать тест">
          <div class="intro-card">
            <button type="button" class="btn btn-primary btn-lead" id="start-quiz">Пройти тест</button>
            <p class="intro-link">
              <a href="/tests/ai-compass/ru/about">О тесте &rarr;</a>
            </p>
          </div>
          <noscript>
            <p class="noscript-note">
              Для теста нужен JavaScript. Заметки о методе доступны на <a href="/tests/ai-compass/ru/about">странице о тесте</a>.
            </p>
          </noscript>
        </section>

        <section id="quiz" aria-label="Тест">
          <div class="quiz-shell" id="quiz-shell" hidden>
            <nav class="progress" id="progress" aria-label="Вопросы"></nav>
            <div class="quiz-card" id="quiz-card" aria-live="polite"></div>
          </div>
        </section>

        <section id="results" aria-label="Ваш результат" hidden>
          <div class="verdict" id="verdict"></div>
          <div class="axes-report" id="axes-report"></div>
          <div class="minimap-wrap">
            <h2>Классическая плоскость</h2>
            <p class="minimap-caption">
              Траектория против баланса: две оси, на которых обычно останавливаются другие компасы. Ваша точка и три ближайших архетипа.
            </p>
            <div class="minimap" id="minimap"></div>
          </div>
          <div class="share-row" id="share-row">
            <button type="button" class="btn btn-primary" id="copy-link">Скопировать ссылку</button>
            <button type="button" class="btn" id="copy-text">Скопировать результат текстом</button>
            <button type="button" class="btn" id="review-answers">Посмотреть ответы</button>
            <button type="button" class="btn btn-ghost" id="retake">Пройти заново</button>
          </div>
          <p class="results-links">
            <a href="/tests/ai-compass/ru/about">Посмотреть все архетипы — их двадцать один — и узнать, как работает подсчет &rarr;</a>
          </p>
        </section>
      </article>
    </main>

    <script is:inline define:vars={{ AXES, DECK, ARCHETYPES }}>
      const AXIS_KEYS = AXES.map((axis) => axis.key);
      const AXIS_BY_KEY = Object.fromEntries(AXES.map((axis) => [axis.key, axis]));
      const STORE_KEY = "ai-compass-ru-v1";
      const TELEMETRY_ENDPOINT = "/api/ai-compass/result";
      const TELEMETRY_LOCALE = "ru";

      const AXIS_READINGS = {
        T: [
          "Вы думаете, что это плато, переодетое под взлет. Демо впечатляют, кривые выравниваются, а через пять лет обо всем снимут документалку с тревожной музыкой.",
          "Вы ждете полезных инструментов и несбывшихся обещаний: реальный прогресс в мелочах, а ИИ человеческого уровня по-прежнему вне досягаемости.",
          "Вы правда не уверены, куда изгибается кривая. С учетом того, как сбываются прогнозы у тех, кто громче вас, это вполне разумная позиция.",
          "Вы думаете, что кривая настоящая. Не вертикальная, но она указывает куда-то в непривычную сторону, и эффект накапливается быстрее, чем институты успевают моргнуть.",
          "Вы считаете, что смотрите на последнее десятилетие, которым руководят люди. Серьезный вопрос только один: насколько крутым будет подъем и как скоро.",
        ],
        V: [
          "Для вас итог в минусе: рабочие места, искусство, истина и электричество — на входе; мусор, слежка и концентрированная власть — на выходе.",
          "Вы видите, что вред приходит по расписанию, а польза всегда «через два года».",
          "Вы держите две колонки и не закрываете бухгалтерию раньше времени. Реальная польза, реальный ущерб, вердикт позже.",
          "В целом вы думаете, что эта штука помогает: тихо, неравномерно и с числом мелких потерь, которое заголовки раздувают.",
          "Вы думаете, что к нам одновременно идут медицина, обучение, наука и изобилие: лучшая сделка, которую цивилизации предлагали за век.",
        ],
        S: [
          "Ваш инстинкт — газ, а не тормоз: пусть люди строят, и не давайте крупным компаниям превращать «безопасность» в ров вокруг бизнеса.",
          "Вы скорее будете чинить уже случившийся вред, чем заставлять разработчиков заранее просить разрешения.",
          "Вы за узкие правила и реальные внешние проверки — и против того, чтобы кто-то насаждал свою утопию всем сразу.",
          "Вы бы регулировали до аварии, спасибо. Некоторые технологии не дают второго черновика.",
          "Вы хотите договоры, лицензии и тормоза еще вчера: бремя доказательства должно быть на машине, а не на обществе.",
        ],
        I: [
          "Вы держите машину подальше от своей настоящей жизни. Чем бы ни закидывались все остальные, ваша доза — ноль.",
          "Вы пользуетесь им как автоматом с напитками: иногда, настороженно и без светских бесед.",
          "Инструмент среди инструментов. Делегируете рутину, проверяете результат и не хотите давать ему имя.",
          "Он вплетен в ваш день: первый черновик, второе мнение, третий мозг. Если бы он исчез, тишина была бы заметна.",
          "Он держит все на себе. Модель знает ваши проекты, стиль письма и большую часть личности. Вам не стыдно.",
        ],
        P: [
          "Это матричное умножение. Красивое, полезное, иногда жутковатое — и разума в нем не больше, чем лица в зеркале.",
          "Вы видите очень удачную имитацию разума, а имитации — ровно то, что и должны выдавать сугубо прозаичные машины.",
          "Вы правда не знаете, что там внутри, и не доверяете никому, кто утверждает обратное.",
          "Вы думаете, что фраза «просто инструмент» в чужих устах прикрывает слишком много непроверенных допущений.",
          "Вы подозреваете, что мы уже делим планету с новыми разумами, а история сурово оценивает людей, которые смеялись.",
        ],
      };

      const state = {
        answers: new Array(DECK.length).fill(-1),
        idx: 0,
        finished: false,
        telemetrySent: false,
        startedAt: Date.now(),
      };

      const introSection = document.getElementById("intro");
      const quizShell = document.getElementById("quiz-shell");
      const quizSection = document.getElementById("quiz");
      const quizCard = document.getElementById("quiz-card");
      const progressEl = document.getElementById("progress");
      const resultsSection = document.getElementById("results");
      const verdictEl = document.getElementById("verdict");
      const axesReportEl = document.getElementById("axes-report");
      const minimapEl = document.getElementById("minimap");

      let advanceTimer = null;

      function saveLocal() {
        try {
          localStorage.setItem(
            STORE_KEY,
            JSON.stringify({
              answers: state.answers,
              idx: state.idx,
              finished: state.finished,
              telemetrySent: state.telemetrySent,
              startedAt: state.startedAt,
            })
          );
        } catch (_) { /* private mode etc. */ }
      }

      function loadLocal() {
        try {
          const raw = localStorage.getItem(STORE_KEY);
          if (!raw) return false;
          const data = JSON.parse(raw);
          if (!Array.isArray(data.answers) || data.answers.length !== DECK.length) return false;
          state.answers = data.answers.map((v) => (Number.isInteger(v) ? v : -1));
          state.idx = Math.min(Math.max(0, data.idx | 0), DECK.length - 1);
          state.finished = Boolean(data.finished);
          state.telemetrySent =
            data.telemetrySent === undefined && state.finished ? true : Boolean(data.telemetrySent);
          state.startedAt = Number.isFinite(data.startedAt) ? data.startedAt : Date.now();
          return true;
        } catch (_) {
          return false;
        }
      }

      function encodeAnswers() {
        return state.answers.map((v) => (v < 0 ? "0" : String(v + 1))).join("");
      }

      function decodeAnswers(str) {
        if (typeof str !== "string" || str.length !== DECK.length) return null;
        const answers = [];
        for (let i = 0; i < str.length; i++) {
          const digit = str.charCodeAt(i) - 48;
          if (digit < 0 || digit > DECK[i].opts.length) return null;
          answers.push(digit - 1);
        }
        return answers;
      }

      function answeredCount() {
        return state.answers.filter((v) => v >= 0).length;
      }

      function firstUnansweredIndex() {
        const idx = state.answers.findIndex((v) => v < 0);
        return idx === -1 ? DECK.length - 1 : idx;
      }

      function allAnswered() {
        return answeredCount() === DECK.length;
      }

      function canVisitQuestion(idx) {
        return state.answers[idx] >= 0 || idx <= firstUnansweredIndex();
      }

      function axisScores() {
        const sums = {};
        const counts = {};
        AXIS_KEYS.forEach((key) => { sums[key] = 0; counts[key] = 0; });
        state.answers.forEach((optIdx, qIdx) => {
          if (optIdx < 0) return;
          const q = DECK[qIdx];
          sums[q.a] += q.opts[optIdx].s;
          counts[q.a] += 1;
        });
        const scores = {};
        AXIS_KEYS.forEach((key) => {
          scores[key] = counts[key] > 0 ? sums[key] / counts[key] / 2 : null;
        });
        return scores;
      }

      function matchArchetypes(scores) {
        const scoredKeys = AXIS_KEYS.filter((key) => scores[key] !== null);
        if (scoredKeys.length === 0) return [];
        const ranked = ARCHETYPES.map((arch, index) => {
          let sq = 0;
          scoredKeys.forEach((key) => {
            const d = scores[key] - arch.seed[key];
            sq += d * d;
          });
          const dist = Math.sqrt(sq / scoredKeys.length);
          return { arch, index, dist, fit: Math.round(Math.max(0, 1 - dist / 2) * 100) };
        });
        ranked.sort((a, b) => a.dist - b.dist);
        return ranked;
      }

      function bucketIndex(v) {
        if (v <= -0.55) return 0;
        if (v <= -0.15) return 1;
        if (v < 0.15) return 2;
        if (v < 0.55) return 3;
        return 4;
      }

      function renderProgress() {
        progressEl.innerHTML = "";
        DECK.forEach((q, i) => {
          const dot = document.createElement("button");
          dot.type = "button";
          dot.className = "p-dot";
          dot.dataset.axis = q.a;
          if (state.answers[i] >= 0) dot.classList.add("done");
          if (i === state.idx) dot.classList.add("here");
          dot.disabled = !canVisitQuestion(i);
          const status = state.answers[i] >= 0 ? "есть ответ" : "без ответа";
          dot.setAttribute("aria-label", `Вопрос ${i + 1}: ${q.topic}, ${status}`);
          dot.title = `${i + 1} · ${q.topic}`;
          dot.addEventListener("click", () => { goTo(i); });
          progressEl.appendChild(dot);
        });
      }

      function renderQuestion() {
        const q = DECK[state.idx];
        const chosen = state.answers[state.idx];
        const isLast = state.idx === DECK.length - 1;

        quizCard.innerHTML = "";

        const meta = document.createElement("div");
        meta.className = "q-meta";
        meta.innerHTML =
          `<span class="q-topic" data-axis="${q.a}">${q.topic}</span>` +
          `<span class="q-count">${state.idx + 1} / ${DECK.length}</span>`;
        quizCard.appendChild(meta);

        const prompt = document.createElement("h3");
        prompt.className = "q-prompt";
        prompt.textContent = q.q;
        quizCard.appendChild(prompt);

        const list = document.createElement("div");
        list.className = "q-options";
        list.setAttribute("role", "radiogroup");
        list.setAttribute("aria-label", "Ответы");
        q.opts.forEach((opt, i) => {
          const btn = document.createElement("button");
          btn.type = "button";
          btn.className = "q-option";
          btn.setAttribute("role", "radio");
          btn.setAttribute("aria-checked", chosen === i ? "true" : "false");
          if (chosen === i) btn.classList.add("selected");
          btn.innerHTML = `<span class="q-key">${i + 1}</span><span class="q-text"></span>`;
          btn.querySelector(".q-text").textContent = opt.t;
          btn.addEventListener("click", () => selectOption(i));
          list.appendChild(btn);
        });
        quizCard.appendChild(list);

        const nav = document.createElement("div");
        nav.className = "q-nav";

        const back = document.createElement("button");
        back.type = "button";
        back.className = "btn btn-ghost";
        back.textContent = "← Назад";
        back.disabled = state.idx === 0;
        back.addEventListener("click", () => goTo(state.idx - 1));
        nav.appendChild(back);

        const right = document.createElement("div");
        right.className = "q-nav-right";

        if (isLast || allAnswered()) {
          const finish = document.createElement("button");
          finish.type = "button";
          finish.className = "btn btn-primary";
          finish.textContent = "Показать результат";
          finish.disabled = !allAnswered();
          finish.addEventListener("click", () => showResults());
          right.appendChild(finish);
        }

        nav.appendChild(right);
        quizCard.appendChild(nav);
        renderProgress();
      }

      function selectOption(optIdx) {
        const previous = state.answers[state.idx];
        state.answers[state.idx] = optIdx;
        state.finished = false;
        if (previous !== optIdx) state.telemetrySent = false;
        if (!Number.isFinite(state.startedAt)) state.startedAt = Date.now();
        saveLocal();
        renderQuestion();
        quizCard.classList.add("settling");
        if (advanceTimer) clearTimeout(advanceTimer);
        if (state.idx < DECK.length - 1) {
          advanceTimer = setTimeout(() => goTo(state.idx + 1), 520);
        } else {
          advanceTimer = setTimeout(() => {
            advanceTimer = null;
            showResults();
          }, 520);
        }
      }

      function goTo(idx) {
        if (advanceTimer) { clearTimeout(advanceTimer); advanceTimer = null; }
        quizCard.classList.remove("settling");
        const clamped = Math.min(Math.max(0, idx), DECK.length - 1);
        state.idx = canVisitQuestion(clamped) ? clamped : firstUnansweredIndex();
        saveLocal();
        renderQuestion();
      }

      function fmtScore(v) {
        return (v >= 0 ? "+" : "−") + Math.abs(v).toFixed(2);
      }

      function barMarkup(v, axisKey, seedV) {
        const left = v >= 0 ? 50 : 50 + v * 50;
        const width = Math.abs(v) * 50;
        const seedDot = seedV === undefined
          ? ""
          : `<span class="bar-seed" style="left:${50 + seedV * 50}%" title="позиция архетипа"></span>`;
        return (
          `<span class="bar-track" data-axis="${axisKey}">` +
          `<span class="bar-center"></span>` +
          `<span class="bar-fill" style="left:${left}%;width:${width}%"></span>` +
          seedDot +
          `</span>`
        );
      }

      function renderVerdict(scores, ranked) {
        const top = ranked[0];
        const runners = ranked.slice(1, 3);
        const scoredKeys = AXIS_KEYS.filter((key) => scores[key] !== null);

        let fpRows = "";
        AXIS_KEYS.forEach((key) => {
          const axis = AXIS_BY_KEY[key];
          const v = scores[key];
          fpRows +=
            `<div class="v-row" data-axis="${key}">` +
            `<span class="v-name">${axis.name}</span>` +
            (v === null
              ? `<span class="v-unscored">нет ответа</span>`
              : barMarkup(v, key, top.arch.seed[key]) + `<span class="v-num">${fmtScore(v)}</span>`) +
            `</div>`;
        });

        const runnersHtml = runners
          .map((r) => `<a href="/tests/ai-compass/ru/about#arch-${r.index}">${r.arch.name}</a> <span class="fit-small">${r.fit}%</span>`)
          .join(" · ");

        verdictEl.innerHTML =
          `<p class="v-kicker">Ваш результат</p>` +
          `<h2 class="v-title">${top.arch.name}</h2>` +
          `<p class="v-tag">${top.arch.tag}</p>` +
          `<p class="v-fit"><span class="fit-chip">совпадение ${top.fit}%</span>${scoredKeys.length < AXIS_KEYS.length ? `<span class="fit-note">учтено ${scoredKeys.length} из 5 осей</span>` : ""}</p>` +
          `<p class="v-desc">${top.arch.desc}</p>` +
          `<div class="v-fingerprint">${fpRows}</div>` +
          `<p class="v-legend">Сплошная полоса: вы. Пустая метка: ${top.arch.name}.</p>` +
          `<p class="v-runners">Рядом также: ${runnersHtml}</p>`;
      }

      function renderAxesReport(scores) {
        let html = "<h2>Ваши пять осей</h2>";
        AXIS_KEYS.forEach((key) => {
          const axis = AXIS_BY_KEY[key];
          const v = scores[key];
          html += `<div class="report-row" data-axis="${key}">`;
          html += `<div class="report-head"><span class="report-name">${axis.name}</span>`;
          if (v !== null) html += `<span class="report-num">${fmtScore(v)}</span>`;
          html += `</div>`;
          if (v === null) {
            html += `<p class="report-blurb report-unscored">Ответьте на вопросы оси «${axis.name}», чтобы получить оценку.</p>`;
          } else {
            html += `<div class="report-bar-row"><span class="report-pole">${axis.neg}</span>${barMarkup(v, key)}<span class="report-pole">${axis.pos}</span></div>`;
            html += `<p class="report-blurb">${AXIS_READINGS[key][bucketIndex(v)]}</p>`;
          }
          html += `</div>`;
        });
        axesReportEl.innerHTML = html;
      }

      function renderMinimap(scores, ranked) {
        const size = 340;
        const pad = 34;
        const plot = size - pad * 2;
        const px = (v) => pad + ((v + 1) / 2) * plot;
        const py = (v) => pad + ((1 - v) / 2) * plot;
        const hasPoint = scores.T !== null && scores.V !== null;
        const legend = ranked.slice(0, 3)
          .map((r, i) =>
            `<li class="minimap-legend-item">` +
            `<span class="minimap-rank">${i + 1}</span>` +
            `<span class="minimap-legend-copy">` +
            `<a class="minimap-legend-name" href="/tests/ai-compass/ru/about#arch-${r.index}">${r.arch.name}</a>` +
            `<span class="minimap-legend-tag">${r.arch.tag}</span>` +
            `</span>` +
            `<span class="fit-small">${r.fit}%</span>` +
            `</li>`
          )
          .join("");

        let dots = "";
        ranked.slice(0, 3).forEach((r, i) => {
          const x = px(r.arch.seed.T);
          const y = py(r.arch.seed.V);
          dots +=
            `<circle cx="${x}" cy="${y}" r="9" class="mm-seed"></circle>` +
            `<text x="${x}" y="${y}" class="mm-seed-num" dy="0.36em">${i + 1}</text>`;
        });

        let you = "";
        if (hasPoint) {
          const x = px(scores.T);
          const y = py(scores.V);
          you =
            `<circle cx="${x}" cy="${y}" r="13" class="mm-you-halo"></circle>` +
            `<circle cx="${x}" cy="${y}" r="5.5" class="mm-you"></circle>`;
        }

        minimapEl.innerHTML =
          `<svg viewBox="0 0 ${size} ${size}" role="img" aria-label="Ваша позиция на плоскости траектории и баланса">` +
          `<rect x="${pad}" y="${pad}" width="${plot}" height="${plot}" class="mm-frame"></rect>` +
          `<line x1="${px(0)}" y1="${pad}" x2="${px(0)}" y2="${pad + plot}" class="mm-axis"></line>` +
          `<line x1="${pad}" y1="${py(0)}" x2="${pad + plot}" y2="${py(0)}" class="mm-axis"></line>` +
          `<text x="${pad + plot / 2}" y="${pad - 12}" class="mm-pole" text-anchor="middle">польза</text>` +
          `<text x="${pad + plot / 2}" y="${pad + plot + 22}" class="mm-pole" text-anchor="middle">вред</text>` +
          `<text x="${pad - 10}" y="${pad + plot / 2}" class="mm-pole mm-pole-v" text-anchor="middle" transform="rotate(-90 ${pad - 10} ${pad + plot / 2})">плато</text>` +
          `<text x="${pad + plot + 12}" y="${pad + plot / 2}" class="mm-pole mm-pole-v" text-anchor="middle" transform="rotate(90 ${pad + plot + 12} ${pad + plot / 2})">взлет</text>` +
          `<text x="${pad + plot - 8}" y="${pad + 18}" class="mm-quad" text-anchor="end">золотой век</text>` +
          `<text x="${pad + 8}" y="${pad + 18}" class="mm-quad">приятный инструмент</text>` +
          `<text x="${pad + 8}" y="${pad + plot - 10}" class="mm-quad">дорогой бардак</text>` +
          `<text x="${pad + plot - 8}" y="${pad + plot - 10}" class="mm-quad" text-anchor="end">обрыв</text>` +
          dots + you +
          `</svg>` +
          `<ol class="minimap-legend" aria-label="Ближайшие архетипы">${legend}</ol>` +
          (hasPoint ? "" : `<p class="minimap-caption">Ответьте хотя бы на один вопрос про траекторию и один про баланс, чтобы появилась ваша точка.</p>`);
      }

      function buildSummaryText(scores, ranked) {
        const top = ranked[0];
        const parts = AXIS_KEYS
          .filter((key) => scores[key] !== null)
          .map((key) => `${AXIS_BY_KEY[key].name} ${fmtScore(scores[key])}`);
        return (
          `ИИ-компас — мой результат: ${top.arch.name} (совпадение ${top.fit}%).\n` +
          parts.join(" · ") + "\n" +
          location.origin + location.pathname + "#a=" + encodeAnswers()
        );
      }

      function sendResultTelemetry(scores, ranked, persist) {
        if (!persist || state.telemetrySent || !("fetch" in window)) return;

        const top = ranked[0];
        const runners = ranked.slice(1, 3);
        const durationMs = Number.isFinite(state.startedAt) ? Date.now() - state.startedAt : null;
        const scorePayload = {};
        AXIS_KEYS.forEach((key) => {
          scorePayload[key] = Number(scores[key].toFixed(4));
        });

        fetch(TELEMETRY_ENDPOINT, {
          method: "POST",
          keepalive: true,
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            version: 1,
            quiz: "ai-compass",
            locale: TELEMETRY_LOCALE,
            path: location.pathname,
            answers: encodeAnswers(),
            answeredCount: answeredCount(),
            archetypeIndex: top.index,
            archetypeName: top.arch.name,
            archetypeFit: top.fit,
            runnerIndexes: runners.map((r) => r.index),
            runnerNames: runners.map((r) => r.arch.name),
            runnerFits: runners.map((r) => r.fit),
            scores: scorePayload,
            durationMs,
          }),
        })
          .then((response) => {
            if (!response.ok) return;
            state.telemetrySent = true;
            saveLocal();
          })
          .catch(() => { /* telemetry should never affect the quiz. */ });
      }

      function showResults(persist = true) {
        if (!allAnswered()) {
          state.finished = false;
          state.idx = firstUnansweredIndex();
          showQuiz();
          quizSection.scrollIntoView({ behavior: "smooth", block: "start" });
          return;
        }
        const scores = axisScores();
        const ranked = matchArchetypes(scores);
        if (ranked.length === 0) return;

        state.finished = true;
        if (persist) saveLocal();
        history.replaceState(null, "", "#a=" + encodeAnswers());

        renderVerdict(scores, ranked);
        renderAxesReport(scores);
        renderMinimap(scores, ranked);
        sendResultTelemetry(scores, ranked, persist);

        quizShell.hidden = true;
        resultsSection.hidden = false;
        requestAnimationFrame(() => {
          resultsSection.classList.add("in");
          resultsSection.scrollIntoView({ behavior: "smooth", block: "start" });
        });

        const copyLink = document.getElementById("copy-link");
        const copyText = document.getElementById("copy-text");
        copyLink.onclick = () => copyToClipboard(copyLink, location.href, "Скопировать ссылку");
        copyText.onclick = () => copyToClipboard(copyText, buildSummaryText(scores, ranked), "Скопировать результат текстом");
      }

      function copyToClipboard(btn, text, restoreLabel) {
        const done = () => {
          btn.textContent = "Скопировано";
          setTimeout(() => { btn.textContent = restoreLabel; }, 1400);
        };
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(done, () => window.prompt("Скопируйте:", text));
        } else {
          window.prompt("Скопируйте:", text);
        }
      }

      function showQuiz() {
        introSection.hidden = true;
        resultsSection.hidden = true;
        resultsSection.classList.remove("in");
        quizShell.hidden = false;
        renderQuestion();
      }

      document.getElementById("start-quiz").addEventListener("click", () => {
        if (answeredCount() === 0) {
          state.startedAt = Date.now();
          state.telemetrySent = false;
          saveLocal();
        }
        showQuiz();
      });

      document.getElementById("review-answers").addEventListener("click", () => {
        state.idx = 0;
        showQuiz();
        quizSection.scrollIntoView({ behavior: "smooth", block: "start" });
      });

      document.getElementById("retake").addEventListener("click", () => {
        state.answers = new Array(DECK.length).fill(-1);
        state.idx = 0;
        state.finished = false;
        state.telemetrySent = false;
        state.startedAt = Date.now();
        try { localStorage.removeItem(STORE_KEY); } catch (_) { /* noop */ }
        history.replaceState(null, "", location.pathname);
        showQuiz();
        quizSection.scrollIntoView({ behavior: "smooth", block: "start" });
      });

      document.addEventListener("keydown", (event) => {
        if (quizShell.hidden) return;
        if (event.metaKey || event.ctrlKey || event.altKey) return;
        const q = DECK[state.idx];
        if (event.key >= "1" && event.key <= String(q.opts.length)) {
          selectOption(parseInt(event.key, 10) - 1);
          event.preventDefault();
        } else if (event.key === "ArrowLeft") {
          goTo(state.idx - 1);
          event.preventDefault();
        } else if (event.key === "ArrowRight") {
          if (state.answers[state.idx] >= 0) goTo(state.idx + 1);
          event.preventDefault();
        }
      });

      const hashMatch = location.hash.match(/^#a=([0-9]+)$/);
      const fromHash = hashMatch ? decodeAnswers(hashMatch[1]) : null;
      if (fromHash && fromHash.some((v) => v >= 0)) {
        state.answers = fromHash;
        introSection.hidden = true;
        quizShell.hidden = false;
        if (allAnswered()) {
          state.finished = true;
          renderQuestion();
          showResults(false);
        } else {
          state.finished = false;
          state.idx = firstUnansweredIndex();
          renderQuestion();
        }
      } else {
        loadLocal();
        if (state.finished && allAnswered()) {
          introSection.hidden = true;
          quizShell.hidden = false;
          renderQuestion();
          showResults();
        } else if (answeredCount() > 0 || state.idx > 0) {
          if (!canVisitQuestion(state.idx)) state.idx = firstUnansweredIndex();
          showQuiz();
        }
      }
    </script>
  </body>
</html>
