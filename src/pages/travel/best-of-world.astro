---
import TravelSpotGuide, { type TravelSpot } from "../../components/travel/TravelSpotGuide.astro";
import { extractTravelSpotsFromSource } from "../../data/travelRawParser";

const pageSources = import.meta.glob<string>(
  ["./best-of-*.astro", "!./best-of-world.astro", "!./best-of-europe.astro"],
  {
    eager: true,
    query: "?raw",
    import: "default",
  },
);
const importedSpotPages = import.meta.glob<{ travelSpots: TravelSpot[] }>("./best-of-europe.astro");

const formatRegionName = (slug: string) =>
  slug
    .replace(/^best-of-/, "")
    .split("-")
    .map((word) => (word === "usa" ? "USA" : word[0].toUpperCase() + word.slice(1)))
    .join(" ");

const normalizeRegionSpots = (path: string, spots: TravelSpot[]) => {
  const slug = path.replace("./", "").replace(/\.astro$/, "");
  const region = formatRegionName(slug);

  return spots.map((spot) => ({
    ...spot,
    id: `${slug}-${spot.id}`,
    area: `${region} · ${spot.area}`,
  }));
};

const parsedTravelSpots = Object.entries(pageSources).flatMap(([path, source]) => {
  return normalizeRegionSpots(path, extractTravelSpotsFromSource(String(source)));
});

const importedTravelSpots = (
  await Promise.all(
    Object.entries(importedSpotPages).map(async ([path, loadPage]) => {
      const page = await loadPage();
      return normalizeRegionSpots(path, page.travelSpots);
    }),
  )
).flat();

const allTravelSpots = [...parsedTravelSpots, ...importedTravelSpots];
---

<TravelSpotGuide
  pageTitle={"The world's most interesting places"}
  pageDescription={"A ranked global guide that combines every regional travel site on sokolsky.me using the same four-part scoring system."}
  subject={"The world's most interesting places"}
  keywords={"world travel ranking, unique places worldwide, best travel sites, global travel guide"}
  eyebrow={"World field guide"}
  dek={"Every site from every regional travel guide on this site, combined into one global ranking by uniqueness, laymen interest, ease of access and low tourist crowds."}
  criteriaText={"This page dynamically imports every regional travel guide and ranks all included sites together with the same scoring model used on the regional pages."}
  tripOriginLabel={"From listed regional gateway"}
  mapHeading={"Map hidden"}
  mapAriaLabel={"Google Map with pins for the world's most interesting places"}
  mapCenter={{ lat: 18, lng: 0 }}
  mapZoom={2}
  mapErrorLabel={"the world"}
  spots={allTravelSpots}
  showMap={false}
/>
