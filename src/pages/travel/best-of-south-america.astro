type Spot = (typeof spots)[number];
const scoreEntries = [
  ["Globally unique", "globallyUnique"],
  ["Laymen interest", "laymenInterest"],
  ["Ease of access", "easeOfAccess"],
  ["Low tourist crowds", "lowTouristCrowds"],
] as const;
const getScoreTotal = (spot: Spot) =>
  spot.scores.globallyUnique +
  spot.scores.laymenInterest +
  spot.scores.easeOfAccess +
  spot.scores.lowTouristCrowds;
const validateScore = (spot: Spot, key: keyof Spot["scores"]) => {
  const score = spot.scores[key];
  if (!Number.isInteger(score) || score < 0 || score > 10) {
    throw new Error(`South America spot "${spot.id}" has invalid ${key} score.`);
  }
};

spots.forEach((spot) => {
  scoreEntries.forEach(([, key]) => validateScore(spot, key));
});

const spotById = new Map(spots.map((spot) => [spot.id, spot] as const));
const rankedSpots = interestingnessOrder
  .map((id) => spotById.get(id))
  .filter((spot): spot is Spot => Boolean(spot));
const rankedSpotIds = new Set(interestingnessOrder);

if (rankedSpotIds.size !== spots.length || rankedSpots.length !== spots.length) {
  throw new Error("South America spot ranking must include each spot exactly once.");
}

