const getGoogleMapsUrl = (spot: Spot) => {
  const formattedAddress =
    "formattedAddress" in spot.map ? spot.map.formattedAddress : undefined;
  const queryParts = [spot.map.name || spot.name, formattedAddress, ...spot.countries].filter(
    (value): value is string => typeof value === "string" && value.length > 0,
  );
  const query =
    ("query" in spot.map && typeof spot.map.query === "string" ? spot.map.query : undefined) ??
    queryParts.join(", ");
  const params = new URLSearchParams({ api: "1", query });

  if ("placeId" in spot.map && spot.map.placeId) {
    params.set("query_place_id", spot.map.placeId);
  }

  return `https://www.google.com/maps/search/?${params.toString()}`;
};

const rankedSpotsWithTrip = rankedSpots.map((spot) => {
  const trip = tripEstimates[spot.id];

  if (!trip) {
    throw new Error(`Missing trip estimate for ${spot.id}.`);
  }

  return {
    ...spot,
    trip,
    wikiUrl: wikiUrls[spot.id],
    totalScore: getScoreTotal(spot),
    googleMapsUrl: getGoogleMapsUrl(spot),
  };
});

if (Object.keys(tripEstimates).length !== rankedSpotsWithTrip.length) {
  throw new Error("Trip estimates must match the ranked South America spot list.");
}

const formatter = new Intl.NumberFormat("en-US");
const usdFormatter = new Intl.NumberFormat("en-US", {
  style: "currency",
  currency: "USD",
  maximumFractionDigits: 0,
});
const countryOptions = [...new Set(rankedSpotsWithTrip.flatMap((spot) => spot.countries))].sort(
  (a, b) => a.localeCompare(b),
);
const kindOptions = [...new Set(rankedSpotsWithTrip.map((spot) => spot.kind))].sort((a, b) =>
  a.localeCompare(b),
);
const spotMapData = rankedSpotsWithTrip.map((spot, index) => ({
  id: spot.id,
  rank: index + 1,
  name: spot.name,
  kind: spot.kind,
  countries: spot.countries,
  uniqueness: spot.uniqueness,
  totalScore: spot.totalScore,
  scores: spot.scores,
  position: spot.map.location,
  googleMapsUrl: spot.googleMapsUrl,
}));
const structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  numberOfItems: rankedSpotsWithTrip.length,
  itemListElement: rankedSpotsWithTrip.map((spot, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "TouristAttraction",
      name: spot.name,
      description: spot.why,
      sameAs: spot.googleMapsUrl,
      geo: {
        "@type": "GeoCoordinates",
        latitude: spot.map.location.lat,
        longitude: spot.map.location.lng,
      },
    },
  })),
};

