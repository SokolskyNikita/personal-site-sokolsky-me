---
import TravelSpotGuide from "../../components/travel/TravelSpotGuide.astro";
import { europeTravelSpots as spots } from "../../data/europeTravelSpots";

export const travelSpots = spots;
---

<TravelSpotGuide
  pageTitle={"Most interesting spots in Europe"}
  pageDescription={"A researched field guide to Europe's most globally distinctive places, ranked by rarity and difficulty of substitution, with Google Maps pins."}
  subject={"Unique places to visit in Europe"}
  keywords={"Europe travel, unique places Europe, globally distinctive travel, Europe map"}
  eyebrow={"Europe field guide"}
  dek={"A Europe list built for travelers who care about deep rarity first: geology, ecology, archaeology, sacred sites, difficult access and places that are hard to replace with a prettier version nearby."}
  criteriaText={"Trip estimates are per person from London via Heathrow (LHR). The origin follows the busiest-airport methodology for this region. The order is the ranking. Higher means rarer globally, more mind-expanding or harder to replace with a similar trip. Cities and urban spots in metro areas over roughly 1 million people are excluded unless the spot itself is very rarely visited by Westerners. Estimates assume economy flights where needed, midrange lodging, meals, local transfers, required fees and the shortest realistic visit."}
  tripOriginLabel={"From London"}
  mapHeading={"Pins across Europe"}
  mapAriaLabel={"Google Map with pins for interesting places in Europe"}
  mapCenter={{"lat":52,"lng":12}}
  mapZoom={3}
  mapErrorLabel={"Europe"}
  spots={spots}
/>
