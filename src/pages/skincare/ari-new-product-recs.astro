---
export const prerender = true;

type Link = {
  label: string;
  url: string;
};

type Rec = {
  name: string;
  origin: string;
  markets: string[];
  why: string;
  anchors: string[];
  price: string;
  buy: Link[];
  caution?: string;
};

type Section = {
  title: string;
  gap: string;
  recs: Rec[];
};

const pageTitle = "Ari skincare recs";
const pageDescription =
  "New-product suggestions mapped from Ari's current skincare list: barrier repair, pigmentation, cleansers, SPF and extras, buyable in Argentina, the US, or shipped from Japan/Korea.";
const themeColorLight = "#ffffff";
const themeColorDark = "#111111";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;

const amazonSearch = (query: string): Link => ({
  label: "Amazon US",
  url: `https://www.amazon.com/s?k=${encodeURIComponent(query)}`,
});

const mercadoLibreSearch = (query: string): Link => ({
  label: "Mercado Libre AR",
  url: `https://listado.mercadolibre.com.ar/${encodeURIComponent(query).replace(/%20/g, "-")}`,
});

const profile = [
  "Acid-heavy routine: glycolic 4%, tretinoin 0.025-0.05%, BHA, daily vitamin C. Barrier support is the recurring bottleneck.",
  "Benchmarks to beat: Irene Bermejo moisturiser (barrier), Codexial Enobright (vit C), Vichy Mineral 89 (hydration), NeoStrata glycolic, Murad spot treatment.",
  "Finish rules: humid climate wants matte/fully absorbed (Effaclar Mat, Biore UV); dry climate tolerates richer (Skin Aqua, Benton, SKIN1004).",
  "Preference filter: no The Ordinary, no adapalene, and Asian options win over La Roche-Posay or ISDIN unless access is limited.",
  "Explicit missing replacement: CeraVe SA Smoothing Cleanser / SA shower gel for body use.",
  "Known reactions: COSRX Snail 96 breaks her out; Tatcha Dewy Skin reacts; Cetaphil Optimal and Neutrogena Hydro Boost DE sting under acids; LRP lait demaquillant stings.",
];

