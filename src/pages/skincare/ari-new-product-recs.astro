          <p>
            New products to try, derived from her current list: each pick answers a gap or benchmark in her own notes.
            Everything is buyable in Argentina, the US, or with easy shipping to the US from Japan/Korea.
          </p>
        </div>
        <p class="count">{totalRecs} suggestions · {sections.length} categories</p>
      </header>

      <section class="profile" aria-label="Skin profile from her notes">
        <h2>What her list says</h2>
        <ul>
          {profile.map((line) => <li>{line}</li>)}
        </ul>
      </section>

      {sections.map((section) => (
        <section class="group">
          <h2>{section.title}</h2>
          <p class="gap">{section.gap}</p>
          <div class="cards">
            {section.recs.map((rec) => (
              <article class="card">
                <div class="card-top">
                  <h3>{rec.name}</h3>
                  <div class="tags">
                    <span class="pill origin">{rec.origin}</span>
                    {rec.markets.map((market) => <span class="pill market">{market}</span>)}
                  </div>
                </div>
                <p class="why">{rec.why}</p>
                <ul class="anchors" aria-label={`Key points for ${rec.name}`}>
                  {rec.anchors.map((anchor) => <li>{anchor}</li>)}
                </ul>
                <p class="price">{rec.price}</p>
                <ul class="buy">
                  {rec.buy.map((link) => (
                    <li>
                      <a href={link.url} target="_blank" rel="noreferrer noopener">{link.label}</a>
                    </li>
                  ))}
                </ul>
                {rec.caution && <p class="caution">{rec.caution}</p>}
              </article>
            ))}
          </div>
        </section>
      ))}

      <section class="group">
        <h2>Skip despite the hype</h2>
        <ul class="avoid">
          {avoid.map((item) => (
            <li>
              <strong>{item.name}</strong> — {item.reason}
            </li>
          ))}
        </ul>
      </section>

      <section class="group">
        <h2>Where to buy, by route</h2>
        <ul class="routes">
          {buyingNotes.map((route) => (
            <li>
              <strong>{route.label}:</strong> {route.note}
            </li>
          ))}
        </ul>
      </section>

      <p class="footnote">
        Prices are rough public-listing estimates (July 2026); Argentina prices swing with promos.
        Ingredient claims follow current retailer/INCI listings; the box label wins if they disagree.
      </p>
    </main>
  </body>
