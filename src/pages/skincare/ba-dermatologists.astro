const totalReviewMentions = dermatologists
  .map((dermatologist) => dermatologist.reviewSignal.match(/\d+/g)?.map(Number) ?? [])
  .flat()
  .filter((value) => value > 10)
  .reduce((sum, value) => sum + value, 0);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  numberOfItems: dermatologists.length,
  itemListElement: dermatologists.map((dermatologist, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": dermatologist.providerType === "Individual" ? "Physician" : "MedicalClinic",
      name: dermatologist.name,
      medicalSpecialty: "Dermatology",
      url: dermatologist.sources[0]?.url,
      description: dermatologist.bestFor,
    },
  })),
};
