<script is:inline define:vars={{ googleMapsApiKey, dermatologistMapData }}>
  if (googleMapsApiKey) {
    ((g) => {
      let h;
      let a;
      let k;
      const p = "The Google Maps JavaScript API";
      const c = "google";
      const l = "importLibrary";
      const q = "__ib__";
      const m = document;
      let b = window;
      b = b[c] || (b[c] = {});
      const d = b.maps || (b.maps = {});
      const r = new Set();
      const e = new URLSearchParams();
      const u = () =>
        h ||
        (h = new Promise(async (resolve, reject) => {
          await (a = m.createElement("script"));
          e.set("libraries", [...r] + "");
          for (k in g) {
            e.set(k.replace(/[A-Z]/g, (t) => `_${t[0].toLowerCase()}`), g[k]);
          }
          e.set("callback", `${c}.maps.${q}`);
          a.src = `https://maps.${c}apis.com/maps/api/js?${e}`;
          d[q] = resolve;
          a.onerror = () => (h = reject(Error(`${p} could not load.`)));
          a.nonce = m.querySelector("script[nonce]")?.nonce || "";
          m.head.append(a);
        }));
      d[l] ? console.warn(`${p} only loads once. Ignoring:`, g) : (d[l] = (f, ...n) => r.add(f) && u().then(() => d[l](f, ...n)));
    })({
      key: googleMapsApiKey,
      v: "weekly",
    });
  }

  const escapeHtml = (value) =>
    String(value).replace(/[&<>"']/g, (character) => ({
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#39;",
    })[character]);

  const initDermatologistMap = async () => {
    const mapElement = document.querySelector("#dermatologist-map");

    if (!mapElement || !googleMapsApiKey || !dermatologistMapData.length) return;

    const { Map } = await google.maps.importLibrary("maps");
    const bounds = new google.maps.LatLngBounds();
    const infoWindow = new google.maps.InfoWindow();
    const map = new Map(mapElement, {
      center: { lat: -34.6037, lng: -58.3816 },
      zoom: 12,
      disableDefaultUI: true,
      zoomControl: true,
      fullscreenControl: true,
    });

    for (const dermatologist of dermatologistMapData) {
      const marker = new google.maps.Marker({
        map,
        position: dermatologist.position,
        title: dermatologist.name,
        label: {
          text: String(dermatologist.rank),
          color: "#fffaf2",
          fontWeight: "700",
        },
      });

      bounds.extend(dermatologist.position);
      marker.addListener("click", () => {
        infoWindow.setContent(`
          <strong>${escapeHtml(dermatologist.name)}</strong>
          <span>${escapeHtml(dermatologist.mapName)}</span>
          <span>${escapeHtml(dermatologist.rating.toFixed(1))} stars · ${escapeHtml(dermatologist.reviewCount)} Google reviews</span>
          <span>${escapeHtml(dermatologist.address)}</span>
          <a href="${escapeHtml(dermatologist.url)}" target="_blank" rel="noopener noreferrer">Open in Google Maps</a>
        `);
        infoWindow.open({ anchor: marker, map });
      });
    }

    map.fitBounds(bounds, 48);
  };

  initDermatologistMap().catch((error) => {
    console.error("Could not initialize dermatologist map", error);
  });
</script>

