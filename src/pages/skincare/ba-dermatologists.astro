---
export const prerender = true;

const pageTitle = "Buenos Aires dermatologist ranking";
const pageDescription =
  "A public-evidence ranking of aesthetics-focused dermatologists and dermatologist-led skincare clinics in Buenos Aires.";
const themeColorLight = "#f5efe6";
const themeColorDark = "#15120f";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const updatedDate = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
}).format(new Date());
const formatter = new Intl.NumberFormat("en-US", {
  maximumFractionDigits: 0,
});

type Source = {
  label: string;
  url: string;
};

type Metric = {
  label: string;
  value: number;
  max: number;
};

type Dermatologist = {
  name: string;
  rankLabel: string;
  neighborhood: string;
  providerType: "Individual" | "Clinic" | "Hospital";
  bestFor: string;
  score: number;
  reviewSignal: string;
  credentialSignal: string;
  aestheticSignal: string;
  caution: string;
  sources: Source[];
  metrics: Metric[];
};

const metrics = [
  {
    name: "Dermatology credential",
    weight: 25,
    note: "Public evidence that a dermatologist, dermatology team, or dermatology service is directly involved.",
  },
  {
    name: "Aesthetic fit",
    weight: 25,
    note: "Botox, fillers, facial rejuvenation, lasers, skin quality, natural-result framing, and other non-surgical aesthetics.",
  },
  {
    name: "Review strength",
    weight: 20,
    note: "Visible Doctoralia, TopDoctors, Google snippets, and testimonial volume. Verified medical-directory reviews count more than site testimonials.",
  },
  {
    name: "Technology depth",
    weight: 15,
    note: "Public evidence of lasers, IPL, CO2, ultrasound, skin-quality devices, or other medical technology.",
  },
  {
    name: "Experience depth",
    weight: 10,
    note: "Years in practice, team depth, teaching, society membership, hospital links, or research signals.",
  },
  {
    name: "Transparency",
    weight: 5,
    note: "Clear address, booking path, procedure pages, and enough public information to evaluate fit before contacting them.",
  },
];

