        longitude: dermatologist.googlePlace.location.lng,
      },
      aggregateRating: {
        "@type": "AggregateRating",
        ratingValue: dermatologist.googlePlace.rating.toFixed(1),
        ratingCount: dermatologist.googlePlace.reviewCount,
      },
      description: dermatologist.bestFor,
