const totalGoogleReviews = rankedDermatologists.reduce(
  (sum, dermatologist) => sum + dermatologist.googlePlace.reviewCount,
  0,
);
const dermatologistMapData = rankedDermatologists.map((dermatologist, index) => ({
  id: dermatologist.googlePlace.id,
  rank: index + 1,
  name: dermatologist.name,
  mapName: dermatologist.googlePlace.name,
  score: dermatologist.score,
  rating: dermatologist.googlePlace.rating,
  reviewCount: dermatologist.googlePlace.reviewCount,
  url: dermatologist.googlePlace.url,
  address: dermatologist.googlePlace.address,
  position: dermatologist.googlePlace.location,
}));

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  numberOfItems: rankedDermatologists.length,
  itemListElement: rankedDermatologists.map((dermatologist, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": dermatologist.providerType === "Individual" ? "Physician" : "MedicalClinic",
      name: dermatologist.name,
      medicalSpecialty: "Dermatology",
      url: dermatologist.sources[0]?.url,
      sameAs: dermatologist.googlePlace.url,
      address: dermatologist.googlePlace.address,
      geo: {
        "@type": "GeoCoordinates",
