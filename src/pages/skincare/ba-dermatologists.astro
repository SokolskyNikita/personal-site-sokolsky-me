<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="subject" content="Buenos Aires dermatologist ranking" />
    <meta name="application-name" content={pageTitle} />
    <meta
      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="googlebot"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="keywords"
      content="Buenos Aires dermatologist ranking, dermatología estética Buenos Aires, dermatologist Botox Buenos Aires, fillers Buenos Aires, laser dermatology Buenos Aires"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta
      name="theme-color"
      content={themeColorLight}
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content={themeColorDark}
      media="(prefers-color-scheme: dark)"
    />
    <meta name="msapplication-TileColor" content={themeColorDark} />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color={themeColorDark} />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Nikita Sokolsky" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <main class="page">
      <header class="hero">
        <a class="home-link" href="/">Nikita Sokolsky</a>
        <div class="hero-grid">
          <div class="hero-copy">
            <p class="eyebrow">Buenos Aires guide</p>
            <h1>{pageTitle}</h1>
            <p class="intro">
              A research-backed shortlist of aesthetics-focused dermatologists and
              dermatologist-led clinics in Buenos Aires. Every provider below is
              operational on Google Maps and has at least 10 Google reviews, then gets
              cross-checked against regular search, BrightData, Doctoralia, TopDoctors,
              official pages and review snippets. For facial-only options, see the{" "}
              <a href="/skincare/ba-facials/">Buenos Aires facials guide</a>.
            </p>
          </div>
          <aside class="scorecard" aria-label="Ranking summary">
            <span class="scorecard-number">{rankedDermatologists.length}</span>
            <span class="scorecard-label">ranked providers</span>
            <span class="scorecard-detail">
              {formatter.format(totalGoogleReviews)} Google reviews across operational Google Maps listings
            </span>
          </aside>
        </div>
        <p class="disclaimer">
          This is not medical advice or a clinical endorsement. It ranks public evidence
          for non-surgical aesthetic dermatology: injectables, skin quality, lasers,
          rejuvenation, scars, pigment and cosmetic skin concerns.
        </p>
      </header>

      <section class="ranking" aria-labelledby="ranking-heading">
        <div class="section-heading">
          <p class="eyebrow">Ranking</p>
          <h2 id="ranking-heading">Best public-evidence matches</h2>
        </div>

        {rankedDermatologists.map((dermatologist, index) => (
          <article class="doctor-card">
            <div class="rank">
              <span>{String(index + 1).padStart(2, "0")}</span>
              <strong>{dermatologist.score}</strong>
              <small>/100</small>
            </div>
            <div class="doctor-main">
              <div class="doctor-head">
                <div>
                  <p class="doctor-type">
                    {dermatologist.providerType} · {dermatologist.neighborhood}
                  </p>
                  <div class="doctor-title-row">
                    <h3>{dermatologist.name}</h3>
                    {dermatologist.instagramUrl && (
                      <a
                        class="instagram-link"
                        href={dermatologist.instagramUrl}
                        target="_blank"
                        rel="nofollow noopener noreferrer"
                        aria-label={`Open ${dermatologist.name} on Instagram`}
                        title={`Open ${dermatologist.name} on Instagram`}
                      >
                        <span set:html={instagramIcon}></span>
                      </a>
                    )}
                  </div>
                  <p class="rank-label">{dermatologist.rankLabel}</p>
                  {dermatologist.englishSupport.speaksEnglish && (
                    <p class="english-signal english-yes">
                      {dermatologist.englishSupport.label}
                    </p>
                  )}
                </div>
                <p class="best-for">{dermatologist.bestFor}</p>
              </div>

              <div class="google-panel">
                <div class="google-place">
                  <span class="google-kicker">Google Maps verified</span>
                  <strong>{dermatologist.googlePlace.rating.toFixed(1)}</strong>
                  <span>{formatter.format(dermatologist.googlePlace.reviewCount)} reviews</span>
                  <small>{dermatologist.googlePlace.name}</small>
                  <a
                    href={dermatologist.googlePlace.url}
                    target="_blank"
                    rel="nofollow noopener noreferrer"
                  >
                    Open map listing
                  </a>
                </div>
                <div class="google-notes">
                  <h4>Google review readout</h4>
                  <ul>
                    {dermatologist.googlePlace.reviewThemes.map((theme) => (
                      <li>{theme}</li>
                    ))}
                  </ul>
                  {dermatologist.googlePlace.reviewCaution && (
                    <p>{dermatologist.googlePlace.reviewCaution}</p>
                  )}
                </div>
              </div>

              <div class="evidence-grid">
                <div>
                  <h4>Credential signal</h4>
                  <p>{dermatologist.credentialSignal}</p>
                </div>
                <div>
                  <h4>Aesthetic signal</h4>
                  <p>{dermatologist.aestheticSignal}</p>
                </div>
                <div>
                  <h4>Review signal</h4>
                  <p>{dermatologist.reviewSignal}</p>
                </div>
                <div>
                  <h4>Check before booking</h4>
                  <p>{dermatologist.caution}</p>
                </div>
                {dermatologist.consultationPrice && (
                  <div>
                    <h4>Initial consultation</h4>
                    <p>
                      {dermatologist.consultationPrice.label}{" "}
                      <a
                        href={dermatologist.consultationPrice.source.url}
                        rel="nofollow noopener noreferrer"
                        target="_blank"
                      >
                        {dermatologist.consultationPrice.source.label}
                      </a>
                    </p>
                  </div>
                )}
              </div>

              <div class="bars" aria-label={`${dermatologist.name} metric scores`}>
                {dermatologist.metrics.map((metric) => (
                  <div
                    class="bar-row"
                    style={`--bar-width: ${(metric.value / metric.max) * 100}%`}
                  >
                    <span>{metric.label}</span>
                    <div class="bar-track" aria-hidden="true">
                      <span></span>
                    </div>
                    <strong>{metric.value}/{metric.max}</strong>
                  </div>
                ))}
              </div>

              <div class="sources">
                {dermatologist.sources.map((source) => (
                  <a href={source.url} rel="nofollow noopener noreferrer" target="_blank">
                    {source.label}
                  </a>
                ))}
                <a
                  href={dermatologist.googlePlace.url}
                  rel="nofollow noopener noreferrer"
                  target="_blank"
                >
                  Google Maps
                </a>
              </div>
            </div>
          </article>
        ))}
      </section>

      <section class="notes" aria-labelledby="notes-heading">
        <div>
          <p class="eyebrow">Notes</p>
          <h2 id="notes-heading">What did not make the list</h2>
        </div>
        <div class="note-list">
          {screenedOut.map((item) => (
            <article>
