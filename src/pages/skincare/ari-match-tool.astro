    max-width: 48rem;
    color: var(--muted);
    font-size: 0.86rem;
  }

  .count {
    white-space: nowrap;
    font-weight: 700;
  }

  .markup-summary {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    align-items: baseline;
    width: fit-content;
    margin: -0.2rem 0 0.65rem;
    padding: 0.28rem 0.42rem;
    border: 1px solid var(--border);
    background: var(--panel);
    color: var(--muted);
    font-size: 0.78rem;
  }

  .markup-summary strong {
    color: var(--text);
    font-size: 0.96rem;
  }

  .controls {
    position: sticky;
    top: 0;
    z-index: 2;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    align-items: end;
    padding: 0.55rem;
    margin-bottom: 0.65rem;
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: blur(10px);
  }

  .controls label {
    color: var(--muted);
    font-size: 0.74rem;
  }

  input[type="search"] {
    display: block;
    width: min(24rem, 78vw);
    margin-top: 0.18rem;
    padding: 0.38rem 0.45rem;
    border: 1px solid var(--border);
    border-radius: 0;
    background: var(--bg);
    color: var(--text);
    font: inherit;
    font-size: 0.85rem;
  }

  .checkbox {
    display: flex;
    gap: 0.28rem;
    align-items: center;
    padding-bottom: 0.38rem;
  }

  #visible-count {
    margin-left: auto;
    padding-bottom: 0.38rem;
    color: var(--muted);
    font-size: 0.78rem;
  }

  .note {
    max-width: 54rem;
    margin-bottom: 0.8rem;
    color: var(--muted);
    font-size: 0.8rem;
  }

  .group {
    margin-top: 0.8rem;
  }

  h2 {
