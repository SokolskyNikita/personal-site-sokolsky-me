  </head>
  <body>
    <main>
      <p class="home"><a href="/">sokolsky.me</a></p>

      <fieldset class="market-switch" aria-label="Choose shopping market">
        <legend>Shopping market</legend>
        <div class="market-options">
          <label>
            <input type="radio" name="market" value="argentina" checked />
            <span>Argentina</span>
          </label>
          <label>
            <input type="radio" name="market" value="usa" />
            <span>USA</span>
          </label>
        </div>
      </fieldset>

      <AriMatchMarketPanel
        market="argentina"
        title="Ari match tool"
        intro="Each item from Ari's current list is mapped to an Argentina buy. Exact domestic listings show one link. Items without domestic as-is stock show the closest ingredient matches, ranked by percent."
        markupLabel="median local markup"
        note="Prices are rough public-listing USD estimates, normalized to comparable volume when a local listing is a mini or travel size. Scores compare ingredient overlap, product role and texture notes. Mercado Libre import, aduana and puerta-a-puerta listings do not count as direct matches. For tretinoin, acids and clinic products, check with the prescriber and read the box."
        data={argentinaMarketData}
      />

      <AriMatchMarketPanel
        market="usa"
        title="Ari match tool USA"
        intro="Each item from Ari's current list is mapped to a US buy. Exact domestic listings show one link. Items without domestic as-is stock show the closest ingredient matches, ranked by percent."
        markupLabel="median US markup"
        note="Prices are rough public-listing USD estimates. Scores compare ingredient overlap, product role, texture notes and Ari's preferences. Amazon search links should still be checked for seller and shipper before buying."
        data={usaMarketData}
        hidden
      />
    </main>

    <script>
      const marketInputs = Array.from(document.querySelectorAll('input[name="market"]'));
      const marketPanels = Array.from(document.querySelectorAll("[data-market-panel]"));

      const updateCards = (panel: Element) => {
        if (!(panel instanceof HTMLElement)) return;

        const searchInput = panel.querySelector(".match-search");
        const mappedOnly = panel.querySelector(".mapped-only");
        const visibleCount = panel.querySelector(".visible-count");
        const cards = Array.from(panel.querySelectorAll(".card"));
        const groups = Array.from(panel.querySelectorAll(".group"));
        const query = searchInput instanceof HTMLInputElement ? searchInput.value.trim().toLowerCase() : "";
        const onlyMapped = mappedOnly instanceof HTMLInputElement && mappedOnly.checked;
        let shown = 0;

        cards.forEach((card) => {
          const haystack = card.getAttribute("data-haystack") ?? "";
          const status = card.getAttribute("data-status");
          const visible = haystack.includes(query) && (!onlyMapped || status === "mapped");
          card.toggleAttribute("hidden", !visible);
          if (visible) shown += 1;
        });

        groups.forEach((group) => {
          const hasVisibleCards = Boolean(group.querySelector(".card:not([hidden])"));
          group.toggleAttribute("hidden", !hasVisibleCards);
        });

        if (visibleCount) visibleCount.textContent = `${shown} shown`;
      };

      const setMarket = (market: string | undefined, updateUrl = false) => {
        const selectedMarket = market === "usa" ? "usa" : "argentina";
        document.documentElement.dataset.market = selectedMarket;

        marketInputs.forEach((input) => {
          if (input instanceof HTMLInputElement) input.checked = input.value === selectedMarket;
        });

        marketPanels.forEach((panel) => {
          const active = panel.getAttribute("data-market-panel") === selectedMarket;
          panel.toggleAttribute("hidden", !active);
          if (active) updateCards(panel);
        });

        document.title = selectedMarket === "usa" ? "Ari match tool USA" : "Ari match tool";

        if (updateUrl) {
          const url = new URL(window.location.href);
          if (selectedMarket === "usa") url.searchParams.set("market", "usa");
          else url.searchParams.delete("market");
          history.replaceState(history.state, "", `${url.pathname}${url.search}${url.hash}`);
        }
      };

      marketPanels.forEach((panel) => {
        panel.querySelector(".match-search")?.addEventListener("input", () => updateCards(panel));
        panel.querySelector(".mapped-only")?.addEventListener("change", () => updateCards(panel));
      });

      marketInputs.forEach((input) => {
        input.addEventListener("change", () => {
          if (input instanceof HTMLInputElement && input.checked) setMarket(input.value, true);
        });
      });

      setMarket(document.documentElement.dataset.market);
    </script>
  </body>
</html>

