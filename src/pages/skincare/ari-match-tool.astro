const groupedMatches = matches.reduce(
  (groups, item) => {
    if (!groups.has(item.group)) {
      groups.set(item.group, []);
    }
    groups.get(item.group)?.push(item);
    return groups;
  },
  new Map<string, ProductMatch[]>(),
);

const totalItems = matches.length;
const directItems = matches.filter((item) => item.status === "direct").length;
const mappedItems = totalItems - directItems;
