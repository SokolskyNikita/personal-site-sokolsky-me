---
import pageData from "../../data/ba-asian-stores.json";

export const prerender = true;

const pageTitle = pageData.title;
const pageDescription =
  "Buenos Aires guide to operational physical stores with verified Korean or Japanese skincare stock, checked against Google Maps and retailer evidence.";
const themeColorLight = "#f7f2ea";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
type Store = (typeof pageData.stores)[number];
const excludedStoreIds = new Set([
  "get-the-look-abasto",
  "beauty24-soho",
  "beauty24-cabildo",
  "las-margaritas-santa-fe",
  "farmacia-leloir",
  "tina-co",
  "luxodia",
  "my-little-tokyo",
]);
const stores = pageData.stores.filter(
  (store: Store) =>
    store.focus !== "food-only" && !excludedStoreIds.has(store.id),
);
const updatedDate = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
}).format(new Date(pageData.generatedAt));
const formatter = new Intl.NumberFormat("en-US", {
  maximumFractionDigits: 0,
});
const collator = new Intl.Collator("en", {
  sensitivity: "base",
  numeric: true,
});

const focusLabels: Record<string, string> = {
  "k-beauty": "K-beauty",
  "j-beauty": "J-beauty",
  both: "K + some J",
  "food-only": "Food only",
};
const visitLabels: Record<string, string> = {
  "walk-in": "Walk-in",
  pickup: "Pickup",
  showroom: "Showroom",
  online: "Online",
};
const authenticityLabels: Record<string, string> = {
  high: "High",
  medium: "Medium",
  low: "Lower",
  "n/a": "n/a",
};

const skincareStores = stores;
const walkInSkincareCount = skincareStores.filter(
  (store: Store) => store.visitType === "walk-in" && store.mapsStatus === "OPERATIONAL",
).length;

const neighborhoodCounts = stores.reduce((counts, store: Store) => {
  counts.set(store.neighborhood, (counts.get(store.neighborhood) ?? 0) + 1);
  return counts;
}, new Map<string, number>());
const neighborhoodOptions = [...neighborhoodCounts.entries()]
  .sort(
    ([nameA, countA], [nameB, countB]) =>
      countB - countA || collator.compare(nameA, nameB),
  )
  .map(([name, count]) => ({ name, count }));

const focusCounts = stores.reduce((counts, store: Store) => {
  counts.set(store.focus, (counts.get(store.focus) ?? 0) + 1);
  return counts;
}, new Map<string, number>());
const focusOptions = [...focusCounts.entries()]
  .sort(
    ([nameA, countA], [nameB, countB]) =>
      countB - countA || collator.compare(nameA, nameB),
  )
  .map(([name, count]) => ({
    name,
    label: focusLabels[name] ?? name,
    count,
  }));

const sortRank = (items: Store[], compare: (a: Store, b: Store) => number) =>
  new Map<string, number>(
    items
      .toSorted(compare)
      .map((store: Store, index: number) => [store.id, index + 1]),
  );

const nameRanks = sortRank(stores, (a, b) => collator.compare(a.name, b.name));
const ratingRanks = sortRank(stores, (a, b) => {
  const ratingA = typeof a.rating === "number" ? a.rating : -1;
  const ratingB = typeof b.rating === "number" ? b.rating : -1;
  const reviewsA = typeof a.reviewCount === "number" ? a.reviewCount : -1;
  const reviewsB = typeof b.reviewCount === "number" ? b.reviewCount : -1;
  return ratingB - ratingA || reviewsB - reviewsA || collator.compare(a.name, b.name);
});
const popularityRanks = sortRank(stores, (a, b) => {
  const reviewsA = typeof a.reviewCount === "number" ? a.reviewCount : -1;
  const reviewsB = typeof b.reviewCount === "number" ? b.reviewCount : -1;
  const ratingA = typeof a.rating === "number" ? a.rating : -1;
  const ratingB = typeof b.rating === "number" ? b.rating : -1;
  return reviewsB - reviewsA || ratingB - ratingA || collator.compare(a.name, b.name);
});
const priorityRanks = sortRank(stores, (a, b) => a.priority - b.priority);

const storesWithSort = stores.map((store: Store) => ({
  ...store,
  focusLabel: focusLabels[store.focus] ?? store.focus,
  visitLabel: visitLabels[store.visitType] ?? store.visitType,
  authenticityLabel: authenticityLabels[store.authenticity] ?? store.authenticity,
  authenticityClass: `authenticity-${String(store.authenticity).replace(/[^a-z0-9-]+/gi, "-")}`,
  reviewCountLabel:
    typeof store.reviewCount === "number" ? formatter.format(store.reviewCount) : "—",
  ratingLabel: typeof store.rating === "number" ? store.rating.toFixed(1) : "—",
  statusLabel:
    store.mapsStatus === "OPERATIONAL"
      ? "Open"
      : store.mapsStatus === "CLOSED_TEMPORARILY"
        ? "Temporarily closed"
        : store.mapsStatus === "NO_PUBLIC_PIN"
          ? "No public Maps pin"
          : store.mapsStatus,
  sortOrderStyle: [
    `--sort-priority: ${priorityRanks.get(store.id)}`,
    `--sort-name: ${nameRanks.get(store.id)}`,
    `--sort-rating: ${ratingRanks.get(store.id)}`,
    `--sort-popularity: ${popularityRanks.get(store.id)}`,
  ].join("; "),
}));

const googleMapsApiKey =
  import.meta.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
  process.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
  "";
const storeMapData = stores
  .filter((store: Store) => store.mapPin && store.location)
  .map((store: Store) => ({
    id: store.id,
    name: store.name,
    googleMapsUrl: store.googleMapsUrl,
    neighborhood: store.neighborhood,
    focus: store.focus,
    visitType: store.visitType,
    mapsStatus: store.mapsStatus,
    openSunday: store.openSunday,
    position: store.location,
  }));
const mapsIcon = `<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="#1a73e8" d="M12 2.2c3.9 0 7.1 3.1 7.1 7 0 5.1-7.1 12.6-7.1 12.6S4.9 14.3 4.9 9.2c0-3.9 3.2-7 7.1-7Z"/><path fill="#34a853" d="M7.2 14.1 12 21.8l4.8-7.7-4.8-2.8-4.8 2.8Z"/><path fill="#fbbc04" d="M4.9 9.2c0 1.8.9 3.5 2.3 4.9l4.8-2.8V2.2c-3.9 0-7.1 3.1-7.1 7Z"/><path fill="#ea4335" d="M19.1 9.2c0 1.8-.9 3.5-2.3 4.9L12 11.3V2.2c3.9 0 7.1 3.1 7.1 7Z"/><circle cx="12" cy="9.3" r="2.45" fill="#fff"/></svg>`;
const instagramIcon = `<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="currentColor" d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069ZM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0Zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324ZM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8Zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881Z"/></svg>`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  numberOfItems: stores.length,
  itemListElement: stores.map((store, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "Store",
      name: store.name,
      ...(store.officialUrl ? { url: store.officialUrl } : {}),
      ...(store.googleMapsUrl ? { sameAs: store.googleMapsUrl } : {}),
      address: store.fullAddress,
      ...(store.location
        ? {
            geo: {
              "@type": "GeoCoordinates",
              latitude: store.location.lat,
              longitude: store.location.lng,
            },
          }
        : {}),
      ...(typeof store.rating === "number" && typeof store.reviewCount === "number"
        ? {
            aggregateRating: {
              "@type": "AggregateRating",
              ratingValue: store.rating.toFixed(1),
              ratingCount: store.reviewCount,
            },
          }
        : {}),
      description: store.description,
    },
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="subject" content="Asian skincare stores Buenos Aires" />
    <meta name="application-name" content={pageTitle} />
    <meta
      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="googlebot"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="keywords"
      content="K-beauty Buenos Aires, J-beauty Buenos Aires, SKINKO Alto Palermo, Tina&Co Barrio Chino, Korean skincare Argentina, Japanese skincare Buenos Aires"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta name="msapplication-TileColor" content={themeColorLight} />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#111111" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Nikita Sokolsky" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <main class="page">
      <header class="page-header">
        <a class="home-link" href="/">Nikita Sokolsky</a>
        <div class="headline">
          <p class="eyebrow">Buenos Aires guide</p>
          <h1>{pageTitle}</h1>
          <p class="intro">
            {stores.length} operational physical venues with verified Asian skincare stock,
            including {walkInSkincareCount} walk-in options plus stocked showrooms.
          </p>
        </div>

        <section class="tldr" aria-labelledby="tldr-heading">
          <h2 id="tldr-heading">TL;DR</h2>
          <ul>
            {pageData.tldr.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <div class="toolbar" aria-label="Store guide controls">
          <fieldset class="sort-toggle">
            <legend>Sort by</legend>
            <input id="sort-priority" type="radio" name="sort" autocomplete="off" checked />
            <label for="sort-priority">Guide order</label>
            <input id="sort-name" type="radio" name="sort" autocomplete="off" />
            <label for="sort-name">Name</label>
            <input id="sort-rating" type="radio" name="sort" autocomplete="off" />
            <label for="sort-rating">GMaps rating</label>
            <input id="sort-popularity" type="radio" name="sort" autocomplete="off" />
            <label for="sort-popularity">Popularity</label>
          </fieldset>
          <fieldset class="extras-toggle">
            <legend>Filter</legend>
            <input id="filter-walk-in" type="checkbox" autocomplete="off" />
            <label for="filter-walk-in">Walk-in only</label>
          </fieldset>
          <label class="filter-dropdown" for="focus-filter">
            <span>Focus</span>
            <select id="focus-filter" name="focus" autocomplete="off">
              <option value="">All ({stores.length})</option>
              {focusOptions.map((option) => (
                <option value={option.name}>
                  {option.label} ({option.count})
                </option>
              ))}
            </select>
          </label>
          <label class="filter-dropdown" for="neighborhood-filter">
            <span>Neighborhood</span>
            <select id="neighborhood-filter" name="neighborhood" autocomplete="off">
              <option value="">All ({stores.length})</option>
              {neighborhoodOptions.map((option) => (
                <option value={option.name}>
                  {option.name} ({option.count})
                </option>
              ))}
            </select>
          </label>
          <p class="meta">
            Updated {updatedDate}. {pageData.checkedNote}
          </p>
        </div>
      </header>

      <section class="store-list" aria-label="Buenos Aires Asian skincare stores">
        <div class="store-row store-head" aria-hidden="true">
          <span>Store</span>
          <span>Map</span>
          <span>Focus</span>
          <span>Visit</span>
          <span>Address</span>
          <span>Hours</span>
          <span>GMaps rating</span>
          <span>Notes</span>
        </div>

        {storesWithSort.map((store) => (
          <article
            class="store-row"
            style={store.sortOrderStyle}
            data-neighborhood={store.neighborhood}
            data-focus={store.focus}
            data-visit-type={store.visitType}
            data-maps-status={store.mapsStatus}
            data-skincare={String(store.focus !== "food-only")}
            data-open-sunday={String(store.openSunday)}
          >
            <h2 class="store-name">
              {store.officialUrl ? (
                <a href={store.officialUrl} target="_blank" rel="noreferrer noopener">
                  {store.name}
                </a>
              ) : (
                store.name
              )}
            </h2>
            <div class="map-actions">
              {store.googleMapsUrl ? (
                <a
                  class="maps-link"
                  href={store.googleMapsUrl}
                  target="_blank"
                  rel="noreferrer noopener"
                  aria-label={`Open ${store.name} on Google Maps`}
                  title={`Open ${store.name} on Google Maps`}
                >
                  <span class="maps-icon" set:html={mapsIcon} />
                </a>
              ) : (
                <span class="maps-empty" aria-hidden="true">—</span>
              )}
              {store.instagram && (
                <a
                  class="instagram-link"
                  href={store.instagram}
                  target="_blank"
                  rel="noreferrer noopener"
                  aria-label={`Open ${store.name} on Instagram`}
                  title={`Open ${store.name} on Instagram`}
                >
                  <span class="instagram-icon" set:html={instagramIcon} />
                </a>
              )}
            </div>
            <p class="focus-cell">
              <span class={`focus-badge focus-${store.focus}`}>{store.focusLabel}</span>
              {store.mapsStatus === "CLOSED_TEMPORARILY" && (
                <span class="status-badge status-closed">{store.statusLabel}</span>
              )}
            </p>
            <p class="visit-cell">{store.visitLabel}</p>
            <p class="address">{store.address}</p>
            <p class="hours">{store.hours}</p>
            <p
              class="rating"
              aria-label={
                typeof store.rating === "number"
                  ? `${store.ratingLabel} Google Maps rating from ${store.reviewCountLabel} ratings`
                  : "No Google Maps rating"
              }
            >
              <span class="rating-score">{store.ratingLabel}</span>
              <span class="review-count">
                {typeof store.reviewCount === "number"
                  ? `${store.reviewCountLabel} ratings`
                  : "No public rating"}
              </span>
            </p>
            <p class="description">
              <span
                class={`authenticity-badge ${store.authenticityClass}`}
                title="Authenticity confidence for skincare stock"
              >
                Auth: {store.authenticityLabel}
              </span>
              {store.description}
              {store.brands && (
                <span class="brands"> Brands: {store.brands}</span>
              )}
            </p>
          </article>
        ))}
        <p class="empty-state">No stores match these filters. Try a different focus or neighborhood.</p>
      </section>

      <section class="store-map-section" aria-labelledby="store-map-heading">
        <div class="map-copy">
          <p class="eyebrow">Map</p>
          <h2 id="store-map-heading">Buenos Aires Asian skincare map</h2>
          <p id="store-map-status" class="map-status" aria-live="polite">
            Showing {storeMapData.length} mapped places with public Google pins.
          </p>
        </div>
        {googleMapsApiKey ? (
          <div
            id="store-map"
            class="store-map"
            aria-label="Google Map with pins for Buenos Aires Asian skincare stores"
          ></div>
        ) : (
          <p class="map-unavailable">
            Map unavailable because the Google Maps public key is not configured.
          </p>
        )}
      </section>

    </main>
  </body>
</html>

<script is:inline define:vars={{ googleMapsApiKey, storeMapData }}>
  if (googleMapsApiKey) {
    ((g) => {
      let h;
      let a;
      let k;
      const p = "The Google Maps JavaScript API";
      const c = "google";
      const l = "importLibrary";
      const q = "__ib__";
      const m = document;
      let b = window;
      b = b[c] || (b[c] = {});
      const d = b.maps || (b.maps = {});
      const r = new Set();
      const e = new URLSearchParams();
      const u = () =>
        h ||
        (h = new Promise(async (resolve, reject) => {
          await (a = m.createElement("script"));
          e.set("libraries", [...r] + "");
          for (k in g) {
            e.set(k.replace(/[A-Z]/g, (t) => `_${t[0].toLowerCase()}`), g[k]);
          }
          e.set("callback", `${c}.maps.${q}`);
          a.src = `https://maps.${c}apis.com/maps/api/js?${e}`;
          d[q] = resolve;
          a.onerror = () => (h = reject(Error(`${p} could not load.`)));
          a.nonce = m.querySelector("script[nonce]")?.nonce || "";
          m.head.append(a);
        }));
      d[l]
        ? console.warn(`${p} only loads once. Ignoring:`, g)
        : (d[l] = (f, ...n) => r.add(f) && u().then(() => d[l](f, ...n)));
    })({
      key: googleMapsApiKey,
      v: "weekly",
    });
  }

  const neighborhoodFilter = document.querySelector("#neighborhood-filter");
  const focusFilter = document.querySelector("#focus-filter");
  const skincareOnlyFilter = document.querySelector("#filter-skincare-only");
  const walkInFilter = document.querySelector("#filter-walk-in");
  const hideClosedFilter = document.querySelector("#filter-open-now");
  const defaultSort = document.querySelector("#sort-priority");
  const storeRows = [...document.querySelectorAll(".store-row:not(.store-head)")];
  const mapElement = document.querySelector("#store-map");
  const mapStatus = document.querySelector("#store-map-status");
  const buenosAiresCenter = { lat: -34.6037, lng: -58.3816 };
  const filterUrlParams = ["neighborhood", "focus", "skincareOnly", "walkIn", "hideClosed"];
  const markerRecords = [];
  let storeMap;
  let infoWindow;

  const escapeHtml = (value) =>
    String(value).replace(/[&<>"']/g, (character) =>
      ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      })[character],
    );

  const getVisibleStores = (selectedNeighborhood, selectedFocus, skincareOnly, walkInOnly, hideClosed) =>
    storeMapData.filter(
      (store) =>
        (!selectedNeighborhood || store.neighborhood === selectedNeighborhood) &&
        (!selectedFocus || store.focus === selectedFocus) &&
        (!skincareOnly || store.focus !== "food-only") &&
        (!walkInOnly || store.visitType === "walk-in") &&
        (!hideClosed || store.mapsStatus !== "CLOSED_TEMPORARILY"),
    );

  const updateMapStatus = (selectedNeighborhood, selectedFocus, skincareOnly, walkInOnly, hideClosed) => {
    if (!mapStatus) return;

    const visibleCount = getVisibleStores(
      selectedNeighborhood,
      selectedFocus,
      skincareOnly,
      walkInOnly,
      hideClosed,
    ).length;
    const label = visibleCount === 1 ? "mapped place" : "mapped places";
    const bits = [];
    if (skincareOnly) bits.push("skincare");
    if (walkInOnly) bits.push("walk-in");
    if (hideClosed) bits.push("excluding temporarily closed");
    const suffix = bits.length ? ` (${bits.join(", ")})` : "";

    mapStatus.textContent = selectedNeighborhood
      ? `Showing ${visibleCount} ${selectedNeighborhood} ${label}${suffix}.`
      : selectedFocus
        ? `Showing ${visibleCount} ${label} for ${selectedFocus}${suffix}.`
        : `Showing ${visibleCount} ${label}${suffix}.`;
  };

  const fitMapToMarkers = (visibleRecords) => {
    if (!storeMap || !window.google?.maps || visibleRecords.length === 0) return;

    if (visibleRecords.length === 1) {
      storeMap.setCenter(visibleRecords[0].store.position);
      storeMap.setZoom(14);
      return;
    }

    const bounds = new google.maps.LatLngBounds();
    for (const { store } of visibleRecords) {
      bounds.extend(store.position);
    }
    storeMap.fitBounds(bounds, 44);
  };

  const syncMapMarkers = (selectedNeighborhood, selectedFocus, skincareOnly, walkInOnly, hideClosed) => {
    updateMapStatus(selectedNeighborhood, selectedFocus, skincareOnly, walkInOnly, hideClosed);
    if (!storeMap) return;

    const visibleIds = new Set(
      getVisibleStores(
        selectedNeighborhood,
        selectedFocus,
        skincareOnly,
        walkInOnly,
        hideClosed,
      ).map((store) => store.id),
    );
    const visibleRecords = [];

    for (const record of markerRecords) {
      const isVisible = visibleIds.has(record.store.id);
      record.marker.setMap(isVisible ? storeMap : null);
      if (isVisible) visibleRecords.push(record);
    }

    if (mapElement) mapElement.dataset.visiblePins = String(visibleRecords.length);
    fitMapToMarkers(visibleRecords);
  };

  const updateFilterUrl = (selectedNeighborhood, selectedFocus, skincareOnly, walkInOnly, hideClosed) => {
    const url = new URL(window.location.href);
    for (const paramName of filterUrlParams) {
      url.searchParams.delete(paramName);
    }
    if (selectedNeighborhood) url.searchParams.set("neighborhood", selectedNeighborhood);
    if (selectedFocus) url.searchParams.set("focus", selectedFocus);
    if (!skincareOnly) url.searchParams.set("skincareOnly", "0");
    if (walkInOnly) url.searchParams.set("walkIn", "1");
    if (hideClosed) url.searchParams.set("hideClosed", "1");

    const nextUrl = `${url.pathname}${url.search}${url.hash}`;
    const currentUrl = `${window.location.pathname}${window.location.search}${window.location.hash}`;
    if (nextUrl !== currentUrl) {
      window.history.replaceState(null, "", nextUrl);
    }
  };

  const initStoreMap = async () => {
    if (!mapElement || !googleMapsApiKey || !window.google?.maps?.importLibrary) return;

    const { Map, InfoWindow } = await google.maps.importLibrary("maps");
    await google.maps.importLibrary("marker");

    storeMap = new Map(mapElement, {
      center: buenosAiresCenter,
      clickableIcons: false,
      fullscreenControl: true,
      mapTypeControl: false,
      streetViewControl: false,
      zoom: 12,
    });
    infoWindow = new InfoWindow();

    for (const store of storeMapData) {
      const marker = new google.maps.Marker({
        map: storeMap,
        position: store.position,
        title: store.name,
      });

      marker.addListener("click", () => {
        const mapsLink = store.googleMapsUrl
          ? `<br><a href="${escapeHtml(store.googleMapsUrl)}" target="_blank" rel="noreferrer noopener">Open in Google Maps</a>`
          : "";
        infoWindow.setContent(
          `<strong>${escapeHtml(store.name)}</strong><br>${escapeHtml(store.neighborhood)}${mapsLink}`,
        );
        infoWindow.open(storeMap, marker);
      });

      markerRecords.push({ store, marker });
    }

    syncMapMarkers(
      neighborhoodFilter?.value ?? "",
      focusFilter?.value ?? "",
      skincareOnlyFilter?.checked ?? true,
      walkInFilter?.checked ?? false,
      hideClosedFilter?.checked ?? false,
    );
  };

  const applyFilters = ({ syncUrl = true } = {}) => {
    const selectedNeighborhood = neighborhoodFilter?.value ?? "";
    const selectedFocus = focusFilter?.value ?? "";
    const skincareOnly = skincareOnlyFilter?.checked ?? true;
    const walkInOnly = walkInFilter?.checked ?? false;
    const hideClosed = hideClosedFilter?.checked ?? false;

    if (syncUrl) {
      updateFilterUrl(selectedNeighborhood, selectedFocus, skincareOnly, walkInOnly, hideClosed);
    }

    for (const row of storeRows) {
      const neighborhoodMismatch =
        Boolean(selectedNeighborhood) && row.dataset.neighborhood !== selectedNeighborhood;
      const focusMismatch = Boolean(selectedFocus) && row.dataset.focus !== selectedFocus;
      const skincareMismatch = skincareOnly && row.dataset.skincare !== "true";
      const walkInMismatch = walkInOnly && row.dataset.visitType !== "walk-in";
      const closedMismatch = hideClosed && row.dataset.mapsStatus === "CLOSED_TEMPORARILY";
      row.hidden =
        neighborhoodMismatch || focusMismatch || skincareMismatch || walkInMismatch || closedMismatch;
    }

    syncMapMarkers(selectedNeighborhood, selectedFocus, skincareOnly, walkInOnly, hideClosed);
  };

  const resetControls = () => {
    if (defaultSort) defaultSort.checked = true;
    if (neighborhoodFilter) neighborhoodFilter.value = "";
    if (focusFilter) focusFilter.value = "";
    if (skincareOnlyFilter) skincareOnlyFilter.checked = true;
    if (walkInFilter) walkInFilter.checked = false;
    if (hideClosedFilter) hideClosedFilter.checked = false;
  };

  const setSelectFromUrl = (selectElement, value) => {
    if (!selectElement || !value) return;
    const hasOption = [...selectElement.options].some((option) => option.value === value);
    if (hasOption) selectElement.value = value;
  };

  const hasEnabledUrlParam = (params, paramName) => {
    const value = params.get(paramName);
    if (value === null) return false;
    return !["0", "false", "no", "off"].includes(value.toLowerCase());
  };

  const applyFiltersFromUrl = () => {
    const params = new URLSearchParams(window.location.search);
    resetControls();
    setSelectFromUrl(neighborhoodFilter, params.get("neighborhood"));
    setSelectFromUrl(focusFilter, params.get("focus"));
    if (skincareOnlyFilter) {
      skincareOnlyFilter.checked = params.has("skincareOnly")
        ? hasEnabledUrlParam(params, "skincareOnly")
        : true;
    }
    if (walkInFilter) walkInFilter.checked = hasEnabledUrlParam(params, "walkIn");
    if (hideClosedFilter) hideClosedFilter.checked = hasEnabledUrlParam(params, "hideClosed");
    applyFilters({ syncUrl: false });
  };

  neighborhoodFilter?.addEventListener("change", applyFilters);
  focusFilter?.addEventListener("change", applyFilters);
  skincareOnlyFilter?.addEventListener("change", applyFilters);
  walkInFilter?.addEventListener("change", applyFilters);
  hideClosedFilter?.addEventListener("change", applyFilters);
  applyFiltersFromUrl();
  window.addEventListener("pageshow", applyFiltersFromUrl);
  window.addEventListener("popstate", applyFiltersFromUrl);
  initStoreMap().catch((error) => {
    console.error("Unable to initialize Asian skincare store map", error);
    if (mapStatus) mapStatus.textContent = "Map unavailable. Store list still works.";
  });
</script>

