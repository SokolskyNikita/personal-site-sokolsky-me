  "@type": "ItemList",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  numberOfItems: lipProducts.length,
  itemListElement: lipProducts.map((lipProduct) => ({
    "@type": "ListItem",
    position: lipProduct.rank,
    item: {
      "@type": "Product",
      name: lipProduct.product,
      url: lipProduct.links[0]?.url,
      description: lipProduct.bestFor,
    },
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="subject" content={pageTitle} />
    <meta name="application-name" content={pageTitle} />
    <meta
      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="googlebot"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="keywords"
      content="lip balm ranking, best lip balm, cracked lips, cerave healing ointment, vaseline lip therapy, aquaphor, bepanthen, moilip, yuskin medical lip, mentholatum medical lip nc, curel lip care balm, dhc lip cream, illiyoon ceramide lip balm, torriden solid-in lip essence, dr jart ceramidin lip balm, lanolips, cortibalm, fixmyskin, acniben, isdin, ducray keracnyl, eucerin acute lip balm, bioderma cicabio lip repair"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta
      name="theme-color"
      content={themeColorLight}
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content={themeColorDark}
      media="(prefers-color-scheme: dark)"
    />
    <meta name="msapplication-TileColor" content={themeColorDark} />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/icon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Nikita Sokolsky" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <main class="page">
      <header class="page-header">
        <a class="home-link" href="/">Nikita Sokolsky</a>
        <p class="eyebrow">Skincare notes</p>
        <h1>{pageTitle}</h1>
        <p class="summary">
          Each product scored 0-10 on four repair criteria; the rank is the weighted
          total, not brand reputation.
        </p>
      </header>

      <section class="ranking" aria-labelledby="ranking-heading">
        <h2 id="ranking-heading">Ranking</h2>
        <p class="methodology">
          Scoring: <strong>barrier repair</strong> ({weightPercent("barrier")}) - how
          strongly the base seals cracked lips against water loss, where
          petrolatum-heavy ointments set the ceiling; <strong>healing actives</strong>
          ({weightPercent("actives")}) - clinical evidence behind ingredients such as
          dexpanthenol, 1% hydrocortisone, lanolin, and urea;
          <strong>irritant-free</strong> ({weightPercent("irritantFree")}) - penalized
          for fragrance, flavor, menthol, camphor, phenol, and salicylic acid;
          <strong>daily use</strong> ({weightPercent("dailyUse")}) - safe to use
          indefinitely, which caps the steroid rescue balms.
        </p>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th scope="col" class="rank-column">Rank</th>
                <th scope="col">Product</th>
                <th scope="col">Region</th>
                <th scope="col">Type</th>
                <th scope="col">Key ingredients</th>
                <th scope="col" class="score-column">
                  Barrier repair <span class="weight">{weightPercent("barrier")}</span>
                </th>
                <th scope="col" class="score-column">
                  Healing actives <span class="weight">{weightPercent("actives")}</span>
                </th>
                <th scope="col" class="score-column">
                  Irritant-free <span class="weight">{weightPercent("irritantFree")}</span>
                </th>
                <th scope="col" class="score-column">
                  Daily use <span class="weight">{weightPercent("dailyUse")}</span>
                </th>
                <th scope="col" class="score-column">Score</th>
                <th scope="col">Best for</th>
              </tr>
            </thead>
            <tbody>
              {
                lipProducts.map((lipProduct) => (
                  <tr>
                    <td class="rank-cell">{lipProduct.rank}</td>
                    <td class="product-cell">
                      {lipProduct.links.map((link, index) => (
                        <>
                          {index > 0 && <span class="link-separator"> / </span>}
                          <a href={link.url}>{link.label}</a>
                        </>
                      ))}
                    </td>
                    <td>{lipProduct.region}</td>
                    <td>{lipProduct.productType}</td>
                    <td>{lipProduct.mainActives}</td>
                    <td class="score-cell">{lipProduct.scores.barrier}</td>
                    <td class="score-cell">{lipProduct.scores.actives}</td>
                    <td class="score-cell">{lipProduct.scores.irritantFree}</td>
                    <td class="score-cell">{lipProduct.scores.dailyUse}</td>
                    <td class="score-cell total-cell">{lipProduct.score.toFixed(2)}</td>
                    <td>{lipProduct.bestFor}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light dark;
    --bg: #f8f2ea;
    --panel: #fffaf3;
    --panel-strong: #fff3e4;
    --text: #211915;
    --muted: #6b5e54;
    --border: #dfd1c2;
    --accent: #9b4d25;
    --accent-soft: #f1d8c4;
    --shadow: 0 18px 42px rgb(65 36 18 / 0.1);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
    color: var(--text);
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background:
      radial-gradient(circle at top left, rgb(255 232 209 / 0.75), transparent 34rem),
      linear-gradient(180deg, #fff8f0 0%, var(--bg) 22rem);
    font-size: 14px;
    line-height: 1.42;
  }

  a {
    color: var(--accent);
    font-weight: 760;
    text-decoration-color: rgb(155 77 37 / 0.35);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  a:hover {
    text-decoration-color: currentColor;
  }

  .page {
    width: min(100% - 1rem, 1460px);
    margin: 0 auto;
    padding: 0.9rem 0.5rem 1.25rem;
  }

  .page-header {
    display: grid;
    gap: 0.34rem;
    margin: 0 0 0.65rem;
  }

  .home-link {
    width: fit-content;
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 720;
    letter-spacing: 0.02em;
    text-decoration: none;
  }

  .eyebrow {
    margin: 0;
    color: var(--accent);
    font-size: 0.68rem;
    font-weight: 860;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1,
  h2 {
    margin: 0;
    color: var(--text);
    line-height: 1.04;
  }

  h1 {
    max-width: 18ch;
    font-size: clamp(1.55rem, 3.2vw, 2.45rem);
    letter-spacing: -0.055em;
  }

  h2 {
    margin-bottom: 0.35rem;
    font-size: clamp(1.05rem, 1.4vw, 1.25rem);
    letter-spacing: -0.035em;
  }

  .summary {
    max-width: 58ch;
    margin: 0;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .ranking {
    margin: 0;
  }

  .methodology {
    max-width: 118ch;
    margin: 0 0 0.6rem;
    color: var(--muted);
    font-size: 0.82rem;
  }

  .methodology strong {
    color: var(--text);
    font-weight: 760;
  }

  .table-wrap {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: 18px;
    background: var(--panel);
    box-shadow: var(--shadow);
  }

  table {
    width: 100%;
    min-width: 1420px;
    border-collapse: collapse;
  }

  th,
  td {
    padding: 0.56rem 0.62rem;
    border-bottom: 1px solid var(--border);
    border-left: 1px solid rgb(223 209 194 / 0.65);
    vertical-align: top;
    text-align: left;
  }

  th:first-child,
  td:first-child {
    border-left: 0;
  }

  th {
    position: sticky;
    top: 0;
    z-index: 1;
    background: var(--panel-strong);
    color: #4b3324;
    font-size: 0.68rem;
    font-weight: 860;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  td {
    font-size: 0.8rem;
  }

  tbody tr:last-child td {
    border-bottom: 0;
  }

  tbody tr:nth-child(even) {
    background: rgb(255 246 237 / 0.66);
  }

  .rank-column {
    width: 4.8rem;
  }

  .rank-cell {
    color: var(--accent);
    font-size: 1rem;
    font-weight: 860;
    line-height: 1;
    text-align: center;
  }

  .score-column {
    width: 5.2rem;
    text-align: center;
  }

  .weight {
    display: block;
    margin-top: 0.12rem;
    color: var(--muted);
    font-size: 0.6rem;
    letter-spacing: 0.05em;
  }

  .score-cell {
    font-variant-numeric: tabular-nums;
    text-align: center;
    white-space: nowrap;
  }

  .total-cell {
    color: var(--accent);
    font-weight: 860;
  }

  .product-cell {
    width: 12rem;
    font-size: 0.86rem;
    line-height: 1.22;
  }

  .link-separator {
    color: var(--muted);
    font-weight: 560;
  }

  @media (max-width: 720px) {
    body {
      font-size: 13px;
    }

    .page {
      width: min(100% - 0.6rem, 1460px);
      padding: 0.75rem 0.2rem 1rem;
    }

    .page-header {
      margin-bottom: 0.55rem;
    }

    h1 {
      font-size: 1.62rem;
    }

    .summary {
      font-size: 0.84rem;
    }

    .table-wrap {
      border-radius: 13px;
    }

    th,
    td {
      padding: 0.48rem 0.52rem;
    }

  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #16110d;
      --panel: #221a14;
      --panel-strong: #2d2118;
      --text: #fff4e9;
      --muted: #cab8aa;
      --border: #4b3729;
      --accent: #ffb171;
      --accent-soft: #4a2c19;
      --shadow: 0 18px 42px rgb(0 0 0 / 0.35);
    }

    body {
      background:
        radial-gradient(circle at top left, rgb(105 54 24 / 0.42), transparent 34rem),
        linear-gradient(180deg, #211711 0%, var(--bg) 22rem);
    }

    th {
      color: #ffd3b0;
    }

    tbody tr:nth-child(even) {
      background: rgb(255 255 255 / 0.025);
    }

  }
</style>
