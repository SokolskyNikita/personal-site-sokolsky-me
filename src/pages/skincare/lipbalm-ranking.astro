const themeColorDark = "#16110d";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;

type ProductLink = {
  label: string;
  url: string;
};

type CriterionScores = {
  barrier: number;
  actives: number;
  irritantFree: number;
  dailyUse: number;
};

type LipProductInput = {
  product: string;
  links: ProductLink[];
  region: string;
  productType: string;
  mainActives: string;
  scores: CriterionScores;
  bestFor: string;
};

const scoreWeights: Record<keyof CriterionScores, number> = {
  barrier: 0.35,
  actives: 0.25,
  irritantFree: 0.25,
  dailyUse: 0.15,
};

const weightedTotal = ({
  barrier,
  actives,
  irritantFree,
  dailyUse,
}: CriterionScores): number =>
  barrier * scoreWeights.barrier +
  actives * scoreWeights.actives +
  irritantFree * scoreWeights.irritantFree +
  dailyUse * scoreWeights.dailyUse;

const weightPercent = (criterion: keyof CriterionScores): string =>
  `${Math.round(scoreWeights[criterion] * 100)}%`;

