---
export const prerender = true;

const pageTitle = "Lip balm ranking";
const pageDescription =
  "A global ranking of lip repair and maintenance products by real repair efficacy, not marketing.";
const themeColorLight = "#f8f2ea";
const themeColorDark = "#16110d";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const updatedDate = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
}).format(new Date());

type ProductLink = {
  label: string;
  url: string;
};

type LipProduct = {
  rank: number;
  product: string;
  links: ProductLink[];
  region: string;
  productType: string;
  keyActives: string;
  bestFor: string;
  chatGptRank: number | null;
};

type TextBlock = {
  title: string;
  text: string;
};

const lipProducts: LipProduct[] = [
  {
    rank: 1,
    product: "Dr. Dan's CortiBalm",
    links: [{ label: "Dr. Dan's CortiBalm", url: "https://drdanslipbalm.com/" }],
    region: "USA",
