const comparisonBasis = [
  "Occlusion: petrolatum, lanolin, and waxes sealing water in.",
  "Humectants/emollients: glycerin, shea, hyaluronic acid, and similar moisturizers.",
  "Active repair/anti-inflammatory ingredients: hydrocortisone, panthenol, allantoin, glycyrrhetinic acid, ceramides, and madecassoside.",
];

const divergenceNotes: TextBlock[] = [
  {
    title: "Panthenol products move up",
    text: "Dexpanthenol is among the best-evidenced barrier-repair actives, so Bepanthol moves from #12 to #6 and the Cicaplast/Eucerin panthenol cluster becomes a real repair tier.",
  },
  {
    title: "CeraVe over Aquaphor by default",
    text: "Same-class occlusion, but CeraVe adds ceramides + HA and drops lanolin and fragrance. Aquaphor wins only if you specifically like lanolin.",
  },
  {
    title: "Menthol/fragrance balms drop",
    text: 'Carmex and Burt\'s Bees are near the bottom for chronically damaged lips because the "active" sensation is often the irritant. Blistex Medicated joins that avoid tier.',
  },
  {
    title: "Added omitted standouts",
    text: "Nuxe Rêve de Miel, Lucas' Papaw, Weleda Skin Food Lip, and the K-beauty PDRN class are common enough to include, even if none crack the top tier.",
  },
  {
    title: "Podium mostly unchanged",
    text: "Dr. Dan's and Moilip stay at the top, and pure petrolatum remains the backbone of repair. The disagreement is mainly middle and bottom tiers.",
  },
];

const quickPicks: TextBlock[] = [
  {
    title: "Emergency: severely cracked / bleeding / inflamed",
    text: "Dr. Dan's CortiBalm for a few days, then step down to an ointment.",
  },
  {
    title: "Best all-round OTC treatment, non-steroid",
    text: "Shiseido Moilip.",
  },
  {
    title: "Overnight barrier rebuild",
    text: "CeraVe Healing Ointment for sensitive lips, or Aquaphor if lanolin is OK.",
  },
  {
    title: "Cheapest reliable maintenance",
    text: "Pure petrolatum / Vaseline over damp lips.",
  },
  {
    title: "Elegant daily dermocosmetic",
    text: "La Roche-Posay Cicaplast Lips or Bepanthol.",
  },
  {
    title: "Daytime outdoors",
    text: "Jack Black SPF 25. UV is a leading cause of recurrent lip damage.",
  },
  {
    title: "Angular cheilitis that won't heal",
    text: "Often fungal/bacterial, so plain balms won't fix it. It needs an antifungal/steroid combo rather than any product on this list.",
