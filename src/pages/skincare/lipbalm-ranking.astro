const sourcingNotes: TextBlock[] = [
  {
    title: "Seattle",
    text: "CeraVe, Aquaphor, Vaseline, Dr. Dan's, Jack Black, and Laneige are easy. Moilip is import/eBay/Asian-goods stores.",
  },
  {
    title: "Prague/EU",
    text: "Bepanthol, Cicaplast, Cicalfate, Uriage, Bioderma, Nuxe, Weleda, and Eucerin are pharmacy-shelf products. Dr. Dan's is import-only.",
  },
  {
    title: "Buenos Aires",
    text: "Bepanthol-family panthenol products and Vaseline/petrolatum are findable in farmacias. Most French dermocosmetics and all Japanese/Australian/Korean items are import-only.",
  },
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  numberOfItems: lipProducts.length,
  itemListElement: lipProducts.map((lipProduct) => ({
    "@type": "ListItem",
    position: lipProduct.rank,
    item: {
      "@type": "Product",
      name: lipProduct.product,
      url: lipProduct.links[0]?.url,
      description: lipProduct.bestFor,
    },
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="subject" content={pageTitle} />
    <meta name="application-name" content={pageTitle} />
    <meta
      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="googlebot"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="keywords"
      content="lip balm ranking, best lip balm, cracked lips, cortibalm, aquaphor, cerave healing ointment, vaseline lip therapy"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta
      name="theme-color"
      content={themeColorLight}
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content={themeColorDark}
      media="(prefers-color-scheme: dark)"
    />
    <meta name="msapplication-TileColor" content={themeColorDark} />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/icon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Nikita Sokolsky" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <main class="page">
      <header class="page-header">
        <a class="home-link" href="/">Nikita Sokolsky</a>
        <p class="eyebrow">Skincare notes</p>
        <h1>{pageTitle}</h1>
        <p class="summary">
          Global repair-first ranking: drug actives, real barrier repair, then maintenance.
          Updated {updatedDate}.
        </p>
        <div class="basis" aria-label="Ranking basis">
          {
            comparisonBasis.map((basisItem) => (
              <span class="basis-pill">{basisItem}</span>
            ))
          }
        </div>
      </header>

      <section class="ranking" aria-labelledby="ranking-heading">
        <h2 id="ranking-heading">Ranking</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th scope="col" class="rank-column">My rank</th>
                <th scope="col">Product</th>
                <th scope="col">Region</th>
                <th scope="col">Type</th>
                <th scope="col">Key actives</th>
                <th scope="col">Best for</th>
                <th scope="col">ChatGPT rank</th>
              </tr>
            </thead>
            <tbody>
              {
                lipProducts.map((lipProduct) => (
                  <tr>
                    <td class="rank-cell">{lipProduct.rank}</td>
                    <td class="product-cell">
                      {lipProduct.links.map((link, index) => (
                        <>
                          {index > 0 && <span class="link-separator"> / </span>}
                          <a href={link.url}>{link.label}</a>
                        </>
                      ))}
                    </td>
                    <td>{lipProduct.region}</td>
                    <td>{lipProduct.productType}</td>
                    <td>{lipProduct.keyActives}</td>
                    <td>{lipProduct.bestFor}</td>
                    <td>
                      <span class:list={["rank-badge", lipProduct.chatGptRank === null && "rank-badge-new"]}>
                        {lipProduct.chatGptRank ?? "New"}
                      </span>
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </section>

      <section class="notes-grid" aria-labelledby="divergence-heading">
        <div class="section-header">
          <h2 id="divergence-heading">Where this diverges</h2>
        </div>
        {
          divergenceNotes.map((note) => (
            <article class="note-card">
              <h3>{note.title}</h3>
              <p>{note.text}</p>
            </article>
          ))
        }
      </section>

      <section class="notes-grid quick-picks" aria-labelledby="quick-picks-heading">
        <div class="section-header">
          <h2 id="quick-picks-heading">Quick picks</h2>
        </div>
        {
          quickPicks.map((pick) => (
            <article class="note-card">
              <h3>{pick.title}</h3>
              <p>{pick.text}</p>
            </article>
          ))
        }
      </section>

      <section class="notes-grid sourcing" aria-labelledby="sourcing-heading">
        <div class="section-header">
          <h2 id="sourcing-heading">Sourcing</h2>
        </div>
        {
          sourcingNotes.map((note) => (
            <article class="note-card">
              <h3>{note.title}</h3>
              <p>{note.text}</p>
            </article>
          ))
        }
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light dark;
    --bg: #f8f2ea;
    --panel: #fffaf3;
    --panel-strong: #fff3e4;
    --text: #211915;
    --muted: #6b5e54;
    --border: #dfd1c2;
    --accent: #9b4d25;
    --accent-soft: #f1d8c4;
    --shadow: 0 18px 42px rgb(65 36 18 / 0.1);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
    color: var(--text);
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background:
      radial-gradient(circle at top left, rgb(255 232 209 / 0.75), transparent 34rem),
      linear-gradient(180deg, #fff8f0 0%, var(--bg) 22rem);
    font-size: 14px;
    line-height: 1.42;
  }

  a {
    color: var(--accent);
    font-weight: 760;
    text-decoration-color: rgb(155 77 37 / 0.35);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  a:hover {
    text-decoration-color: currentColor;
  }

  .page {
    width: min(100% - 1rem, 1460px);
    margin: 0 auto;
    padding: 0.9rem 0.5rem 1.25rem;
  }

  .page-header {
    display: grid;
    gap: 0.34rem;
    margin: 0 0 0.65rem;
  }

  .home-link {
    width: fit-content;
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 720;
    letter-spacing: 0.02em;
    text-decoration: none;
  }

  .eyebrow {
    margin: 0;
    color: var(--accent);
    font-size: 0.68rem;
    font-weight: 860;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1,
  h2 {
    margin: 0;
    color: var(--text);
    line-height: 1.04;
  }

  h1 {
    max-width: 18ch;
    font-size: clamp(1.55rem, 3.2vw, 2.45rem);
    letter-spacing: -0.055em;
  }

  h2 {
    margin-bottom: 0.35rem;
    font-size: clamp(1.05rem, 1.4vw, 1.25rem);
    letter-spacing: -0.035em;
  }

  .summary {
    max-width: 58ch;
    margin: 0;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .basis {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    max-width: 980px;
    margin-top: 0.12rem;
  }

  .basis-pill {
    border: 1px solid rgb(155 77 37 / 0.18);
    border-radius: 999px;
    padding: 0.22rem 0.48rem;
    background: rgb(255 250 243 / 0.8);
    color: #664431;
    font-size: 0.73rem;
    font-weight: 690;
    line-height: 1.2;
