    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta name="theme-color" content={themeColorLight} media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content={themeColorDark} media="(prefers-color-scheme: dark)" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  </head>
  <body>
    <main>
      <p class="home"><a href="/">sokolsky.me</a></p>

      <header class="page-head">
        <div>
          <h1>{pageTitle}</h1>
          <p>
            Each item from Ari's current list is mapped to a US buy. Exact domestic listings show one link. Items without domestic as-is stock show the closest ingredient matches, ranked by percent.
          </p>
        </div>
        <p class="count">{totalItems} items · {directItems} direct · {mappedItems} mapped</p>
      </header>

      <section class="markup-summary" aria-label="Median local markup">
        <span>median US markup</span>
        <strong>{medianLocalMarkup === undefined ? "n/a" : formatMarkup(medianLocalMarkup)}</strong>
        <span>across {localMarkupValues.length} priced items with abroad benchmarks</span>
      </section>

      <section class="controls" aria-label="Match controls">
        <label>
          Search
          <input id="match-search" type="search" placeholder="product, ingredient or category" autocomplete="off" />
        </label>
        <label class="checkbox">
          <input id="mapped-only" type="checkbox" />
          mapped only
        </label>
        <p id="visible-count">{totalItems} shown</p>
      </section>

      <p class="note">
        Prices are rough public-listing USD estimates. Scores compare ingredient overlap, product role, texture notes and Ari's preferences. Amazon search links should still be checked for seller and shipper before buying.
      </p>

      {
        Array.from(groupedMatches.entries()).map(([group, groupItems]) => (
          <section class="group" data-group={group}>
            <h2>{group}</h2>
            <div class="cards">
              {groupItems.map((item) => (
                <article
                  class={`card ${item.status}`}
                  data-status={item.status}
                  data-haystack={`${item.group} ${item.source} ${item.anchors.join(" ")} ${
                    item.direct?.label ?? ""
                  } ${(item.matches ?? [])
                    .map(
                      (match) =>
                        `${match.name} ${match.reason} ${highMarkupAlternativesFor(match.name)
                          .map((alt) => `${alt.name} ${alt.reason}`)
                          .join(" ")}`,
                    )
                    .join(" ")} ${highMarkupAlternativesFor(item.source)
                    .map((match) => `${match.name} ${match.reason}`)
                    .join(" ")}`.toLowerCase()}
                >
                  <div class="card-top">
                    <div>
                      <p class="eyebrow">{item.status === "direct" ? "direct" : "ingredient match"}</p>
                      <h3>{item.source}</h3>
                    </div>
                    <span class={`pill ${item.status}`}>{item.status === "direct" ? "as-is" : "ranked"}</span>
                  </div>

                  <ul class="anchors" aria-label={`Ingredient anchors for ${item.source}`}>
                    {item.anchors.map((anchor) => <li>{anchor}</li>)}
                  </ul>

                  {item.status === "direct" && directPriceParts(item.source).length > 0 && (
                    <p class="price-line">
                      {directPriceParts(item.source).map((part) => (
                        <span>{part}</span>
                      ))}
                    </p>
                  )}

                  {item.status === "direct" && item.direct && (
                    <p class="direct-link">
                      <a href={item.direct.url} target="_blank" rel="noreferrer noopener">
                        {item.direct.label}
                      </a>
                    </p>
                  )}

                  {item.status === "direct" && highMarkupAlternativesFor(item.source).length > 0 && (
                    <div class="direct-alts">
                      <p class="alt-heading">lower-markup alternatives</p>
                      <ol class="ranked">
                        {highMarkupAlternativesFor(item.source).map((match) => (
                          <li>
                            <div class="rank-line">
                              <strong>{match.percent}%</strong>
                              <span>{match.name}</span>
                            </div>
                            <p>{match.reason}</p>
                            {priceParts(getPrice(match.name), getPrice(item.source)).length > 0 && (
                              <p class="price-line match-price">
                                {priceParts(getPrice(match.name), getPrice(item.source)).map((part) => (
                                  <span>{part}</span>
                                ))}
                              </p>
                            )}
                            <ul class="buy">
                              {match.buy.map((link) => (
                                <li>
                                  <a href={link.url} target="_blank" rel="noreferrer noopener">
                                    {link.label}
                                  </a>
                                </li>
                              ))}
                            </ul>
                          </li>
                        ))}
                      </ol>
                    </div>
                  )}

                  {item.status === "mapped" && item.matches && (
                    <>
                      {sourcePriceParts(item.source).length > 0 && (
                        <p class="price-line source-price">
                          {sourcePriceParts(item.source).map((part) => (
                            <span>{part}</span>
                          ))}
                        </p>
                      )}
                      <ol class="ranked">
                        {item.matches.map((match) => (
                          <li>
                            <div class="rank-line">
                              <strong>{match.percent}%</strong>
                              <span>{match.name}</span>
                            </div>
                            <p>{match.reason}</p>
                            {priceParts(getPrice(match.name), getPrice(item.source)).length > 0 && (
                              <p class="price-line match-price">
                                {priceParts(getPrice(match.name), getPrice(item.source)).map((part) => (
                                  <span>{part}</span>
                                ))}
                              </p>
                            )}
                            <ul class="buy">
                              {match.buy.map((link) => (
                                <li>
                                  <a href={link.url} target="_blank" rel="noreferrer noopener">
                                    {link.label}
                                  </a>
                                </li>
                              ))}
                            </ul>
                            {highMarkupAlternativesFor(match.name).length > 0 && (
                              <div class="direct-alts">
                                <p class="alt-heading">lower-markup alternatives</p>
                                <ol class="ranked">
                                  {highMarkupAlternativesFor(match.name).map((alt) => (
                                    <li>
                                      <div class="rank-line">
                                        <strong>{alt.percent}%</strong>
                                        <span>{alt.name}</span>
                                      </div>
                                      <p>{alt.reason}</p>
                                      {priceParts(getPrice(alt.name), getPrice(match.name)).length > 0 && (
                                        <p class="price-line match-price">
                                          {priceParts(getPrice(alt.name), getPrice(match.name)).map((part) => (
                                            <span>{part}</span>
                                          ))}
                                        </p>
                                      )}
                                      <ul class="buy">
                                        {alt.buy.map((link) => (
                                          <li>
                                            <a href={link.url} target="_blank" rel="noreferrer noopener">
                                              {link.label}
                                            </a>
                                          </li>
                                        ))}
                                      </ul>
                                    </li>
                                  ))}
                                </ol>
                              </div>
                            )}
                          </li>
                        ))}
                      </ol>
                    </>
                  )}

                  {item.note && <p class="item-note">{item.note}</p>}
                </article>
              ))}
            </div>
          </section>
        ))
      }
    </main>

    <script>
      const searchInput = document.querySelector("#match-search");
      const mappedOnly = document.querySelector("#mapped-only");
      const visibleCount = document.querySelector("#visible-count");
      const cards = Array.from(document.querySelectorAll(".card"));
      const groups = Array.from(document.querySelectorAll(".group"));

      const updateCards = () => {
        const query = searchInput instanceof HTMLInputElement ? searchInput.value.trim().toLowerCase() : "";
        const onlyMapped = mappedOnly instanceof HTMLInputElement && mappedOnly.checked;
        let shown = 0;

        cards.forEach((card) => {
          const haystack = card.getAttribute("data-haystack") ?? "";
          const status = card.getAttribute("data-status");
          const visible = haystack.includes(query) && (!onlyMapped || status === "mapped");
          card.toggleAttribute("hidden", !visible);
          if (visible) shown += 1;
        });

        groups.forEach((group) => {
          const hasVisibleCards = Boolean(group.querySelector(".card:not([hidden])"));
          group.toggleAttribute("hidden", !hasVisibleCards);
        });

        if (visibleCount) {
          visibleCount.textContent = `${shown} shown`;
        }
      };

      searchInput?.addEventListener("input", updateCards);
      mappedOnly?.addEventListener("change", updateCards);
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: light dark;
    --bg: #ffffff;
    --panel: #f8f8f8;
    --text: #111111;
    --muted: #555555;
    --link: #111111;
    --border: #dddddd;
    --direct: #0f6a3d;
    --mapped: #7a4a00;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #111111;
      --panel: #181818;
      --text: #eeeeee;
      --muted: #aaaaaa;
      --link: #eeeeee;
      --border: #333333;
      --direct: #70d89c;
      --mapped: #e3b15f;
    }
  }

  html {
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    line-height: 1.35;
  }

  body {
    margin: 0;
    padding: 0.75rem;
  }

  main {
    max-width: 88rem;
  }

  h1,
  h2,
  h3,
  p,
  ul,
  ol {
    margin: 0;
  }

  a {
    color: var(--link);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.16em;
  }

  .home {
    color: var(--muted);
    font-size: 0.78rem;
    margin-bottom: 0.55rem;
  }

  .page-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.7rem;
    align-items: end;
    margin-bottom: 0.75rem;
  }

  h1 {
    font-size: 1.15rem;
    line-height: 1.1;
    margin-bottom: 0.25rem;
  }

  .page-head p {
    max-width: 48rem;
    color: var(--muted);
    font-size: 0.86rem;
  }

  .count {
    white-space: nowrap;
    font-weight: 700;
  }

  .markup-summary {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    align-items: baseline;
    width: fit-content;
    margin: -0.2rem 0 0.65rem;
    padding: 0.28rem 0.42rem;
    border: 1px solid var(--border);
    background: var(--panel);
    color: var(--muted);
    font-size: 0.78rem;
  }

  .markup-summary strong {
    color: var(--text);
    font-size: 0.96rem;
  }

  .controls {
    position: sticky;
    top: 0;
    z-index: 2;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    align-items: end;
    padding: 0.55rem;
    margin-bottom: 0.65rem;
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: blur(10px);
  }

  .controls label {
    color: var(--muted);
    font-size: 0.74rem;
  }

  input[type="search"] {
    display: block;
    width: min(24rem, 78vw);
    margin-top: 0.18rem;
    padding: 0.38rem 0.45rem;
    border: 1px solid var(--border);
    border-radius: 0;
    background: var(--bg);
    color: var(--text);
    font: inherit;
    font-size: 0.85rem;
  }

  .checkbox {
    display: flex;
    gap: 0.28rem;
    align-items: center;
    padding-bottom: 0.38rem;
  }

  #visible-count {
    margin-left: auto;
    padding-bottom: 0.38rem;
    color: var(--muted);
    font-size: 0.78rem;
  }

  .note {
    max-width: 54rem;
    margin-bottom: 0.8rem;
    color: var(--muted);
    font-size: 0.8rem;
  }

  .group {
    margin-top: 0.8rem;
  }

  h2 {
    margin-bottom: 0.45rem;
    padding-top: 0.55rem;
    border-top: 1px solid var(--border);
    font-size: 1.1rem;
    line-height: 1.2;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 22rem), 1fr));
    gap: 0.55rem;
  }

  .card {
    padding: 0.65rem;
    border: 1px solid var(--border);
    background: var(--panel);
  }

  .card.direct {
    border-left: 0.25rem solid var(--direct);
  }

  .card.mapped {
    border-left: 0.25rem solid var(--mapped);
  }

  .card-top {
    display: flex;
    gap: 0.5rem;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.42rem;
  }

  .eyebrow {
    color: var(--muted);
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h3 {
    margin-top: 0.08rem;
    font-size: 0.92rem;
    line-height: 1.18;
  }

  .pill {
    flex: 0 0 auto;
    padding: 0.12rem 0.32rem;
    border: 1px solid currentColor;
    font-size: 0.68rem;
    font-weight: 700;
  }

  .pill.direct {
    color: var(--direct);
  }

  .pill.mapped {
    color: var(--mapped);
  }

  .anchors,
  .buy {
    display: flex;
    flex-wrap: wrap;
    gap: 0.24rem;
    padding: 0;
    list-style: none;
  }

  .anchors {
    margin-bottom: 0.45rem;
  }

  .anchors li {
    padding: 0.12rem 0.28rem;
    border: 1px solid var(--border);
    color: var(--muted);
    font-size: 0.7rem;
  }

  .direct-link,
  .item-note,
  .price-line,
  .ranked p {
    font-size: 0.8rem;
  }

  .price-line {
    display: flex;
    flex-wrap: wrap;
    gap: 0.24rem;
    margin: -0.1rem 0 0.42rem;
    color: var(--muted);
  }

  .price-line span {
    padding: 0.1rem 0.28rem;
    border: 1px dotted var(--border);
    background: color-mix(in srgb, var(--bg) 58%, transparent);
  }

  .source-price {
    margin-bottom: 0.46rem;
  }

  .direct-alts {
    margin-top: 0.5rem;
    padding-top: 0.45rem;
    border-top: 1px dotted var(--border);
  }

  .alt-heading {
    margin-bottom: 0.28rem;
    color: var(--muted);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .ranked .match-price {
    margin: 0.14rem 0 0.24rem;
    font-size: 0.74rem;
  }

  .item-note {
    margin-top: 0.42rem;
    color: var(--muted);
  }

  .ranked {
    display: grid;
    gap: 0.45rem;
    padding-left: 1.1rem;
  }

  .ranked > li::marker {
    color: var(--muted);
    font-size: 0.78rem;
  }

  .rank-line {
    display: flex;
    gap: 0.38rem;
    align-items: baseline;
    font-size: 0.85rem;
    line-height: 1.2;
  }

  .rank-line strong {
    color: var(--mapped);
    font-size: 0.9rem;
  }

  .ranked p {
    margin: 0.12rem 0 0.22rem;
    color: var(--muted);
  }

  .buy a {
    font-size: 0.76rem;
  }

  [hidden] {
    display: none !important;
  }

  @media (max-width: 48rem) {
    .page-head {
      grid-template-columns: 1fr;
    }

    .count {
      white-space: normal;
    }

    #visible-count {
      width: 100%;
      margin-left: 0;
      padding-bottom: 0;
    }
  }
</style>
