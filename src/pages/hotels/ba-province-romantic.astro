---
import pageData from "../../data/hotels-ba-province-romantic.json";

export const prerender = true;

const pageTitle = "Romantic hotels in Buenos Aires province";
const pageDescription =
  "Upper-class romantic hotels and estancias in Buenos Aires Province outside the city: Relais & Châteaux, polo clubs, spa resorts and small boutiques, with Google Maps ratings, drive times and a map.";
const themeColorLight = "#f4efe6";
const themeColorDark = "#12110f";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
type Hotel = (typeof pageData.hotels)[number];
const hotels = pageData.hotels.filter((hotel: Hotel) => hotel.rating > 3.9);
const updatedDate = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
}).format(new Date(pageData.generatedAt));
const formatter = new Intl.NumberFormat("en-US", {
  maximumFractionDigits: 0,
});
const usdFormatter = new Intl.NumberFormat("en-US", {
  style: "currency",
  currency: "USD",
  maximumFractionDigits: 0,
});
const collator = new Intl.Collator("en", {
  sensitivity: "base",
  numeric: true,
});
const areaCounts = hotels.reduce((counts, hotel: Hotel) => {
  counts.set(hotel.area, (counts.get(hotel.area) ?? 0) + 1);
  return counts;
}, new Map<string, number>());
const areaOptions = [...areaCounts.entries()]
  .sort(
    ([nameA, countA], [nameB, countB]) =>
      countB - countA || collator.compare(nameA, nameB),
  )
  .map(([name, count]) => ({ name, count }));
const priceValue = (hotel: Hotel) =>
  typeof hotel.price.usd === "number" ? hotel.price.usd : Number.MAX_SAFE_INTEGER;
const sortRank = (
  items: Hotel[],
  compare: (a: Hotel, b: Hotel) => number,
) =>
  new Map<string, number>(
    items
      .toSorted(compare)
      .map((hotel: Hotel, index: number) => [hotel.id, index + 1]),
  );
const nameRanks = sortRank(hotels, (a: Hotel, b: Hotel) =>
  collator.compare(a.name, b.name),
);
const ratingRanks = sortRank(
  hotels,
  (a: Hotel, b: Hotel) =>
    b.rating - a.rating ||
    b.reviewCount - a.reviewCount ||
    collator.compare(a.name, b.name),
);
const priceRanks = sortRank(
  hotels,
  (a: Hotel, b: Hotel) =>
    priceValue(a) - priceValue(b) ||
    b.rating - a.rating ||
    collator.compare(a.name, b.name),
);
const popularityRanks = sortRank(
  hotels,
  (a: Hotel, b: Hotel) =>
    b.reviewCount - a.reviewCount ||
    b.rating - a.rating ||
    collator.compare(a.name, b.name),
);
const romanceRanks = sortRank(
  hotels,
  (a: Hotel, b: Hotel) =>
    b.romance.score - a.romance.score ||
    collator.compare(a.name, b.name),
);
const hotelsWithSort = hotels.map((hotel: Hotel) => ({
  ...hotel,
  reviewCountLabel: formatter.format(hotel.reviewCount),
  displayPriceLabel:
    hotel.price.status === "published" && typeof hotel.price.usd === "number"
      ? `from ${usdFormatter.format(hotel.price.usd)}`
      : "On request",
  priceTitle:
    hotel.price.status === "published"
      ? `Source: ${hotel.price.source}. ${hotel.price.note ?? ""}`.trim()
      : `Source: ${hotel.price.source}. ${hotel.price.note ?? ""}`.trim(),
  driveLabel: `~${hotel.driveMinutes} min`,
  romanceTitle: hotel.romance.why,
  sortOrderStyle: [
    `--sort-romance: ${romanceRanks.get(hotel.id)}`,
    `--sort-price: ${priceRanks.get(hotel.id)}`,
    `--sort-name: ${nameRanks.get(hotel.id)}`,
    `--sort-rating: ${ratingRanks.get(hotel.id)}`,
    `--sort-popularity: ${popularityRanks.get(hotel.id)}`,
  ].join("; "),
}));
const googleMapsApiKey =
  import.meta.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
  process.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
  "";
const hotelMapData = hotels.map((hotel: Hotel) => ({
  id: hotel.id,
  name: hotel.name,
  googleMapsUrl: hotel.googleMapsUrl,
  area: hotel.area,
  position: hotel.location,
}));
const mapsIcon = `<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="#1a73e8" d="M12 2.2c3.9 0 7.1 3.1 7.1 7 0 5.1-7.1 12.6-7.1 12.6S4.9 14.3 4.9 9.2c0-3.9 3.2-7 7.1-7Z"/><path fill="#34a853" d="M7.2 14.1 12 21.8l4.8-7.7-4.8-2.8-4.8 2.8Z"/><path fill="#fbbc04" d="M4.9 9.2c0 1.8.9 3.5 2.3 4.9l4.8-2.8V2.2c-3.9 0-7.1 3.1-7.1 7Z"/><path fill="#ea4335" d="M19.1 9.2c0 1.8-.9 3.5-2.3 4.9L12 11.3V2.2c3.9 0 7.1 3.1 7.1 7Z"/><circle cx="12" cy="9.3" r="2.45" fill="#fff"/></svg>`;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  numberOfItems: hotels.length,
  itemListElement: hotels.map((hotel, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "Hotel",
      name: hotel.name,
      url: hotel.officialUrl,
      sameAs: hotel.googleMapsUrl,
      address: hotel.fullAddress,
      geo: {
        "@type": "GeoCoordinates",
        latitude: hotel.location.lat,
        longitude: hotel.location.lng,
      },
      aggregateRating: {
        "@type": "AggregateRating",
        ratingValue: hotel.rating.toFixed(1),
        ratingCount: hotel.reviewCount,
      },
      ...(hotel.price.status === "published" && typeof hotel.price.usd === "number"
        ? { priceRange: `from ${usdFormatter.format(hotel.price.usd)}` }
        : {}),
    },
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="subject" content="Romantic hotels in Buenos Aires province" />
    <meta name="application-name" content={pageTitle} />
    <meta
      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="googlebot"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="keywords"
      content="romantic hotels Buenos Aires province, estancia near Buenos Aires, La Bamba de Areco, La Madrugada, Hotel del Casco San Isidro, La Candelaria Lobos, Villa Maria, Tigre delta lodge, polo hotel Argentina"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta
      name="theme-color"
      content={themeColorLight}
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content={themeColorDark}
      media="(prefers-color-scheme: dark)"
    />
    <meta name="msapplication-TileColor" content={themeColorDark} />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color={themeColorDark} />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Nikita Sokolsky" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <main class="page">
      <header class="page-header">
        <a class="home-link" href="/">Nikita Sokolsky</a>
        <div class="headline">
          <p class="eyebrow">Buenos Aires province</p>
          <h1>{pageTitle}</h1>
        </div>
        <div class="toolbar" aria-label="Hotel controls">
          <fieldset class="sort-toggle">
            <legend>Sort by</legend>
            <input id="sort-romance" type="radio" name="sort" autocomplete="off" checked />
            <label for="sort-romance">Romance</label>
            <input id="sort-price" type="radio" name="sort" autocomplete="off" />
            <label for="sort-price">Price</label>
            <input id="sort-name" type="radio" name="sort" autocomplete="off" />
            <label for="sort-name">Name</label>
            <input id="sort-rating" type="radio" name="sort" autocomplete="off" />
            <label for="sort-rating">GMaps rating</label>
            <input id="sort-popularity" type="radio" name="sort" autocomplete="off" />
            <label for="sort-popularity">Popularity</label>
          </fieldset>
          <label class="filter-dropdown" for="area-filter">
            <span>Area</span>
            <select id="area-filter" name="area" autocomplete="off">
              <option value="">All ({hotels.length})</option>
              {areaOptions.map((option) => (
                <option value={option.name}>{option.name} ({option.count})</option>
              ))}
            </select>
          </label>
          <p class="meta">
            Updated {updatedDate}. Romance order weights pedigree (Relais / palace / press), intimacy (room count), setting (campo, delta, town, spa) and couple fit (adults-only / quiet vs sports resort). Drive times are rough car minutes from central Buenos Aires (delta lodge includes boat). Prices are from-rates in USD where a public source existed; ARS quotes used 1 USD ≈ ARS {formatter.format(pageData.currency.arsPerUsd)}.
          </p>
        </div>
      </header>

      <section class="hotel-list" aria-label="Romantic hotels in Buenos Aires province">
        <div class="hotel-row hotel-head" aria-hidden="true">
          <span>Hotel</span>
          <span>Map</span>
          <span>Area</span>
          <span>From</span>
          <span>Drive (min)</span>
          <span>Romance</span>
          <span>GMaps rating</span>
          <span>Notes</span>
        </div>

        {hotelsWithSort.map((hotel) => (
          <article
            class="hotel-row"
            style={hotel.sortOrderStyle}
            data-area={hotel.area}
          >
            <h2 class="hotel-name">
              <a href={hotel.officialUrl} target="_blank" rel="noreferrer noopener">
                {hotel.name}
              </a>
              <span class="hotel-style">{hotel.style}</span>
            </h2>
            <div class="map-actions">
              <a
                class="maps-link"
                href={hotel.googleMapsUrl}
                target="_blank"
                rel="noreferrer noopener"
                aria-label={`Open ${hotel.name} on Google Maps`}
                title={`Open ${hotel.name} on Google Maps`}
              >
                <span class="maps-icon" set:html={mapsIcon} />
              </a>
            </div>
            <p class="area">
              <span class="area-name">{hotel.area}</span>
              <span class="area-address">{hotel.address}</span>
            </p>
            <div class="hotel-stats">
              <p
                class={`price ${hotel.price.status === "published" ? "" : "price-unpublished"}`}
                title={hotel.priceTitle}
              >
                <span class="price-label">{hotel.displayPriceLabel}</span>
                {hotel.price.basis && (
                  <span class="price-service">{hotel.price.basis}</span>
                )}
              </p>
              <p class="drive">{hotel.driveLabel}</p>
              <p
                class="romance"
                title={hotel.romanceTitle}
                aria-label={`Romance rank ${hotel.romance.rank}`}
              >
                <span class="romance-rank">#{hotel.romance.rank}</span>
              </p>
              <p
                class="rating"
                aria-label={`${hotel.rating.toFixed(1)} Google Maps rating from ${hotel.reviewCountLabel} ratings`}
              >
                <span class="rating-score">{hotel.rating.toFixed(1)}</span>
                <span class="review-count">{hotel.reviewCountLabel} ratings</span>
              </p>
            </div>
            <p class="description">{hotel.description}</p>
          </article>
        ))}
      </section>

      <section class="hotel-map-section" aria-labelledby="hotel-map-heading">
        <div class="map-copy">
          <p class="eyebrow">Map</p>
          <h2 id="hotel-map-heading">Province hotel map</h2>
          <p id="hotel-map-status" class="map-status">
            Showing all {hotels.length} hotels.
          </p>
        </div>
        {googleMapsApiKey ? (
          <div
            id="hotel-map"
            class="hotel-map"
            aria-label="Google Map with pins for romantic hotels in Buenos Aires province"
          ></div>
        ) : (
          <p class="map-unavailable">
            Map unavailable because the Google Maps public key is not configured.
          </p>
        )}
      </section>
    </main>
  </body>
</html>

<script is:inline define:vars={{ googleMapsApiKey, hotelMapData }}>
  if (googleMapsApiKey) {
    ((g) => {
      let h;
      let a;
      let k;
      const p = "The Google Maps JavaScript API";
      const c = "google";
      const l = "importLibrary";
      const q = "__ib__";
      const m = document;
      let b = window;
      b = b[c] || (b[c] = {});
      const d = b.maps || (b.maps = {});
      const r = new Set();
      const e = new URLSearchParams();
      const u = () =>
        h ||
        (h = new Promise(async (resolve, reject) => {
          await (a = m.createElement("script"));
          e.set("libraries", [...r] + "");
          for (k in g) {
            e.set(k.replace(/[A-Z]/g, (t) => `_${t[0].toLowerCase()}`), g[k]);
          }
          e.set("callback", `${c}.maps.${q}`);
          a.src = `https://maps.${c}apis.com/maps/api/js?${e}`;
          d[q] = resolve;
          a.onerror = () => (h = reject(Error(`${p} could not load.`)));
          a.nonce = m.querySelector("script[nonce]")?.nonce || "";
          m.head.append(a);
        }));
      d[l] ? console.warn(`${p} only loads once. Ignoring:`, g) : (d[l] = (f, ...n) => r.add(f) && u().then(() => d[l](f, ...n)));
    })({
      key: googleMapsApiKey,
      v: "weekly",
    });
  }

  const areaFilter = document.querySelector("#area-filter");
  const defaultSort = document.querySelector("#sort-romance");
  const hotelRows = [...document.querySelectorAll(".hotel-row:not(.hotel-head)")];
  const mapElement = document.querySelector("#hotel-map");
  const mapStatus = document.querySelector("#hotel-map-status");
  const provinceCenter = { lat: -34.45, lng: -58.95 };
  const filterUrlParams = ["area"];
  const markerRecords = [];
  let hotelMap;
  let infoWindow;

  const escapeHtml = (value) =>
    String(value).replace(/[&<>"']/g, (character) => ({
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#39;",
    })[character]);

  const getVisibleHotels = (selectedArea) =>
    hotelMapData.filter((hotel) => !selectedArea || hotel.area === selectedArea);

  const updateMapStatus = (selectedArea) => {
    if (!mapStatus) return;

    const visibleCount = getVisibleHotels(selectedArea).length;
    const hotelLabel = visibleCount === 1 ? "hotel" : "hotels";
    mapStatus.textContent = selectedArea
      ? `Showing ${visibleCount} ${selectedArea} ${hotelLabel}.`
      : `Showing all ${visibleCount} ${hotelLabel}.`;
  };

  const fitMapToMarkers = (visibleRecords) => {
    if (!hotelMap || !window.google?.maps || visibleRecords.length === 0) return;

    if (visibleRecords.length === 1) {
      hotelMap.setCenter(visibleRecords[0].hotel.position);
      hotelMap.setZoom(12);
      return;
    }

    const bounds = new google.maps.LatLngBounds();

    for (const { hotel } of visibleRecords) {
      bounds.extend(hotel.position);
    }

    hotelMap.fitBounds(bounds, 48);
  };

  const syncMapMarkers = (selectedArea) => {
    updateMapStatus(selectedArea);

    if (!hotelMap) return;

    const visibleIds = new Set(
      getVisibleHotels(selectedArea).map((hotel) => hotel.id),
    );
    const visibleRecords = [];

    for (const record of markerRecords) {
      const isVisible = visibleIds.has(record.hotel.id);
      record.marker.setMap(isVisible ? hotelMap : null);
      if (isVisible) visibleRecords.push(record);
    }

    if (mapElement) mapElement.dataset.visiblePins = String(visibleRecords.length);

    fitMapToMarkers(visibleRecords);
  };

  const updateFilterUrl = (selectedArea) => {
    const url = new URL(window.location.href);

    for (const paramName of filterUrlParams) {
      url.searchParams.delete(paramName);
    }

    if (selectedArea) url.searchParams.set("area", selectedArea);

    const nextUrl = `${url.pathname}${url.search}${url.hash}`;
    const currentUrl = `${window.location.pathname}${window.location.search}${window.location.hash}`;

    if (nextUrl !== currentUrl) {
      window.history.replaceState(null, "", nextUrl);
    }
  };

  const initHotelMap = async () => {
    if (!mapElement || !googleMapsApiKey || !window.google?.maps?.importLibrary) return;

    const { Map, InfoWindow } = await google.maps.importLibrary("maps");
    await google.maps.importLibrary("marker");

    hotelMap = new Map(mapElement, {
      center: provinceCenter,
      clickableIcons: false,
      fullscreenControl: true,
      mapTypeControl: false,
      streetViewControl: false,
      zoom: 9,
    });
    infoWindow = new InfoWindow();

    for (const hotel of hotelMapData) {
      const marker = new google.maps.Marker({
        map: hotelMap,
        position: hotel.position,
        title: hotel.name,
      });

      marker.addListener("click", () => {
        infoWindow.setContent(
          `<strong>${escapeHtml(hotel.name)}</strong><br>${escapeHtml(hotel.area)}<br><a href="${escapeHtml(hotel.googleMapsUrl)}" target="_blank" rel="noreferrer noopener">Open in Google Maps</a>`,
        );
        infoWindow.open(hotelMap, marker);
      });

      markerRecords.push({ hotel, marker });
    }

    syncMapMarkers(areaFilter?.value ?? "");
  };

  const applyFilters = ({ syncUrl = true } = {}) => {
    const selectedArea = areaFilter?.value ?? "";

    if (syncUrl) {
      updateFilterUrl(selectedArea);
    }

    for (const row of hotelRows) {
      const areaMismatch =
        Boolean(selectedArea) && row.dataset.area !== selectedArea;
      row.hidden = areaMismatch;
    }

    syncMapMarkers(selectedArea);
  };

  const resetControls = () => {
    if (defaultSort) defaultSort.checked = true;
    if (areaFilter) areaFilter.value = "";
  };

  const setSelectFromUrl = (selectElement, value) => {
    if (!selectElement || !value) return;

    const hasOption = [...selectElement.options].some((option) => option.value === value);
    if (hasOption) selectElement.value = value;
  };

  const applyFiltersFromUrl = () => {
    const params = new URLSearchParams(window.location.search);

    resetControls();
    setSelectFromUrl(areaFilter, params.get("area"));

    applyFilters({ syncUrl: false });
  };

  areaFilter?.addEventListener("change", applyFilters);
  applyFiltersFromUrl();
  window.addEventListener("pageshow", applyFiltersFromUrl);
  window.addEventListener("popstate", applyFiltersFromUrl);
  initHotelMap().catch((error) => {
    console.error("Unable to initialize hotel map", error);
    if (mapStatus) mapStatus.textContent = "Map unavailable. Hotel list still works.";
  });
</script>

<style>
  :root {
    color-scheme: light dark;
    --bg: #f4efe6;
    --surface: #fffdf8;
    --surface-soft: #ebe3d6;
    --text: #181612;
    --text-muted: #6f675c;
    --border: #d7cdbd;
    --border-strong: #c4b6a3;
    --accent: #3a2a22;
    --accent-soft: #e4d8c8;
    --link: #2a1f19;
    --shadow: 0 12px 36px rgba(61, 44, 22, 0.07);
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #12110f;
      --surface: #1a1815;
      --surface-soft: #24211c;
      --text: #f2eee7;
      --text-muted: #aaa297;
      --border: #343027;
      --border-strong: #4a4338;
      --accent: #e8dcc8;
      --accent-soft: #2c2720;
      --link: #f6f1e8;
      --shadow: 0 12px 36px rgba(0, 0, 0, 0.28);
    }
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    font-size: 16px;
    background: var(--bg);
    color: var(--text);
    line-height: 1.45;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at 12% 0%, color-mix(in srgb, var(--accent-soft), transparent 30%), transparent 28rem),
      var(--bg);
  }

  a {
    color: var(--link);
    text-decoration-color: color-mix(in srgb, var(--link), transparent 62%);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  a:hover {
    text-decoration-color: currentColor;
  }

  .page {
    width: min(100%, 88rem);
    margin: 0 auto;
    padding: clamp(0.55rem, 1.4vw, 1.25rem);
  }

  .page-header {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(0.45rem, 1.2vw, 0.85rem);
    align-items: start;
    padding: clamp(0.45rem, 1.4vw, 0.95rem) 0 clamp(0.45rem, 1.2vw, 0.8rem);
  }

  .home-link {
    grid-column: 1 / -1;
    width: fit-content;
    color: var(--text-muted);
    font-size: 0.84rem;
    text-decoration: none;
  }

  .home-link:hover {
    color: var(--text);
  }

  .headline {
    display: grid;
    gap: 0.28rem;
    max-width: 58rem;
  }

  .eyebrow {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    max-width: 24ch;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.35rem, 2.4vw, 1.85rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.08;
  }

  .toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: 0.4rem 0.55rem;
  }

  .sort-toggle {
    display: flex;
    width: fit-content;
    align-items: center;
    flex-wrap: wrap;
