<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <meta name="googlebot" content="noindex, nofollow, noarchive" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta name="theme-color" content={themeColorLight} media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content={themeColorDark} media="(prefers-color-scheme: dark)" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  </head>
  <body>
    <main>
      <p><a href="/">sokolsky.me</a></p>

      <h1>{pageTitle}</h1>

      <p class="count">{totalSkincareItemCount} skincare items</p>

      <p>
        Current skincare inventory from Ari's photos and notes, compiled July 2026.
        Hair oil, toothpaste, swim/clothing/photo-chat items, and other non-skincare notes are intentionally omitted.
      </p>

      <p class="small">
        Ingredient lists can change by batch and country. For prescription, clinic-dispensed,
        or region-specific products, the package label should win over this page.
      </p>

      {sections.map((section) => (
        <section>
          <h2>{section.title}</h2>
          <ul class="products">
            {section.items.map((item) => (
              <li>
                <p><strong>{item.name}</strong></p>
                <p>{item.descriptor}</p>

                {item.buy.length > 0 && (
                  <>
                    <p><strong>Buy:</strong></p>
                    <ul class="links">
                      {item.buy.map((link) => (
                        <li>
                          <a href={link.url} target="_blank" rel="noreferrer noopener">
                            {link.label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </>
                )}

                <p><strong>Ingredients:</strong> {item.ingredients}</p>
                {"ingredientsNote" in item && <p class="small">{item.ingredientsNote}</p>}
              </li>
            ))}
          </ul>
        </section>
      ))}
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light dark;
    --bg: #ffffff;
    --text: #111111;
    --muted: #555555;
    --link: #111111;
    --border: #dddddd;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #111111;
      --text: #eeeeee;
      --muted: #aaaaaa;
      --link: #eeeeee;
      --border: #333333;
    }
  }

  html {
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    line-height: 1.55;
  }

  body {
    margin: 0;
    padding: 1.25rem;
  }

  main {
    max-width: 50rem;
  }

  h1 {
    margin: 1.25rem 0 0.8rem;
    font-size: 1.7rem;
    line-height: 1.15;
  }

  h2 {
    margin: 2rem 0 0.7rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    font-size: 1.155rem;
    line-height: 1.2;
  }

  p,
  ul {
    margin: 0 0 0.9rem;
  }

  ul {
    padding-left: 1.25rem;
  }

  li {
    margin: 0.2rem 0;
  }

  .products {
    padding-left: 0;
    list-style: none;
  }

  .products > li {
    margin: 0 0 1.35rem;
    padding-left: 1rem;
    border-left: 2px solid var(--border);
  }

  .products > li > p {
    margin-bottom: 0.45rem;
  }

  .links {
    margin-bottom: 0.55rem;
  }

  .count {
    color: var(--muted);
    font-size: 0.95rem;
    font-weight: 600;
  }

  .small {
    color: var(--muted);
    font-size: 0.92rem;
  }

  a {
    color: var(--link);
  }

  body > main > p:first-child {
    color: var(--muted);
    font-size: 0.9rem;
  }

  /* Responsive editorial pass */
  :root {
    --bg: #fcfaf7;
    --surface: #fffdf8;
    --text: #1e211c;
    --muted: #64685f;
    --link: #234b35;
    --border: #d8d4c9;
    --accent: #2f7350;
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-size: 16px;
    line-height: 1.55;
  }

  body {
    padding: clamp(0.85rem, 2.4vw, 2rem);
    background:
      radial-gradient(circle at 8% 0%, color-mix(in srgb, var(--accent) 10%, transparent), transparent 30rem),
      var(--bg);
  }

  main {
