---
export const prerender = true;

const profile = {
  name: "Nikita Sokolsky",
  role: "Software Engineer at AWS",
  blurb:
    "I'm a software engineer based in Seattle. I currently build backend systems at AWS WAF.",
  location: "Seattle, WA",
  email: "sokolx@gmail.com",
};

const links = [
  { 
    label: "Substack", 
    href: "https://nsokolsky.substack.com/",
    icon: `<svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M22.539 8.242H1.46V5.406h21.08v2.836zM22.539 12.322v8.836L12 15.305l-10.539 5.853v-8.836h21.08zM22.539 0H1.46v2.836h21.08V0z"/></svg>`
  },
  { 
    label: "LinkedIn", 
    href: "https://www.linkedin.com/in/nsokolsky/",
    icon: `<svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`
  },
  { 
    label: "Twitter", 
    href: "https://twitter.com/nsokolsky/",
    icon: `<svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/></svg>`
  },
  { 
    label: "Instagram", 
    href: "https://www.instagram.com/nsokolsky/",
    icon: `<svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.359 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678c-3.405 0-6.162 2.76-6.162 6.162 0 3.405 2.757 6.162 6.162 6.162 3.405 0 6.162-2.757 6.162-6.162 0-3.402-2.757-6.162-6.162-6.162zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405c0 .795-.646 1.44-1.441 1.44-.795 0-1.439-.645-1.439-1.44 0-.795.644-1.439 1.439-1.439.796 0 1.441.644 1.441 1.439z"/></svg>`
  },
  { 
    label: "Email", 
    href: `mailto:${profile.email}`,
    icon: `<svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>`
  },
];

const pageTitle = "Nikita Sokolsky";
const pageDescription =
  "Personal website of Nikita Sokolsky, software engineer at AWS based in Seattle.";
const themeColorLight = "#ffffff";
const themeColorDark = "#111111";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(
    /\/$/,
    "",
  );
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const ogImageUrl = `${siteUrl}/og-image.jpg`;
const portraitJpgPath = "/profile-portrait-v2-640.jpg";
const portraitWebpPath = "/profile-portrait-v2-640.webp";
const profileImageUrl = `${siteUrl}${portraitJpgPath}`;
const twitterHandle = "@nsokolsky";
const socialProfiles = links
  .filter((link) => link.label !== "Email")
  .map((link) => link.href);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile.name,
  jobTitle: "Software Engineer",
  worksFor: {
    "@type": "Organization",
    name: "Amazon Web Services",
  },
  image: profileImageUrl,
  email: `mailto:${profile.email}`,
  url: canonicalUrl,
  sameAs: socialProfiles,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="author" content={profile.name} />
    <meta name="creator" content={profile.name} />
    <meta name="publisher" content={profile.name} />
    <meta name="application-name" content={profile.name} />
    <meta name="apple-mobile-web-app-title" content={profile.name} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="format-detection" content="telephone=no" />
    <meta
      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="googlebot"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="keywords"
      content="Nikita Sokolsky, software engineer, AWS WAF, backend, security engineering, photographer"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta name="theme-color" content={themeColorLight} media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content={themeColorDark} media="(prefers-color-scheme: dark)" />
    <meta name="msapplication-TileColor" content={themeColorDark} />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={canonicalUrl} />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color={themeColorDark} />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="me" href="https://www.linkedin.com/in/nsokolsky/" />
    <link rel="me" href="https://twitter.com/nsokolsky/" />
    <link rel="me" href="https://www.instagram.com/nsokolsky/" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={profile.name} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta
      property="og:image:alt"
      content="Preview card with Nikita Sokolsky name and role."
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta
      name="twitter:image:alt"
      content="Preview card with Nikita Sokolsky name and role."
    />
    <meta name="twitter:site" content={twitterHandle} />
    <meta name="twitter:creator" content={twitterHandle} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <div class="page">
      <header class="header">
        <picture class="avatar">
          <source srcset={portraitWebpPath} type="image/webp" />
          <img
            src={portraitJpgPath}
            alt={profile.name}
            width="80"
            height="80"
            decoding="async"
            fetchpriority="high"
          />
        </picture>
        <div class="title-group">
          <h1>{profile.name}</h1>
          <p class="role">{profile.role}</p>
        </div>
      </header>

      <main>
        <section class="intro">
          <p>{profile.blurb}</p>
          <p>
            I have over a decade of experience building reliable software and distributed systems, spending the last 8 years at Amazon and AWS. Outside of work, I write a newsletter about <a href="https://nsokolsky.substack.com/">first principles</a> and occasionally take photos (<a href="https://getdatingphotos.com/" target="_blank" rel="noreferrer">getdatingphotos.com</a>).
          </p>
        </section>

        <section class="connect">
          <h2>Connect</h2>
          <ul class="links">
            {links.map((link) => (
              <li>
                <a href={link.href} target="_blank" rel="noreferrer">
                  <span class="icon" set:html={link.icon} />
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </section>
      </main>
    </div>
    <script>
      type WebMcpTool = {
        name: string;
        description: string;
        inputSchema: Record<string, unknown>;
        execute: (
          input: Record<string, unknown>,
        ) => Promise<{ content: Array<{ type: "text"; text: string }> }>;
      };

      type ModelContext = {
        registerTool: (tool: WebMcpTool) => void;
        unregisterTool: (name: string) => void;
      };

      const modelContext = (
        navigator as Navigator & { modelContext?: ModelContext }
      ).modelContext;

      if (modelContext?.registerTool) {
        const tools: WebMcpTool[] = [
          {
            name: "search-site-resources",
            description:
              "Find relevant public pages and resources published on sokolsky.me.",
            inputSchema: {
              type: "object",
              properties: {
                query: {
                  type: "string",
                  description:
                    "A topic, place, project, or page name to search for.",
                },
              },
              required: ["query"],
              additionalProperties: false,
            },
            async execute(input) {
              const query =
                typeof input.query === "string"
                  ? input.query.trim().toLowerCase()
                  : "";
              if (!query) throw new Error("query is required");

              const response = await fetch("/llms.txt", {
                headers: { Accept: "text/plain" },
              });
              if (!response.ok) throw new Error("site guide is unavailable");

              const matches = (await response.text())
                .split("\n")
                .filter((line) => line.toLowerCase().includes(query))
                .slice(0, 12);

              return {
                content: [
                  {
                    type: "text",
                    text:
                      matches.length > 0
                        ? matches.join("\n")
                        : `No public site resources matched "${query}".`,
                  },
                ],
              };
            },
          },
          {
            name: "get-public-api-description",
            description:
              "Return the OpenAPI description for the read-only public sokolsky.me API.",
            inputSchema: {
              type: "object",
              properties: {},
              additionalProperties: false,
            },
            async execute() {
              const response = await fetch("/openapi.json", {
                headers: { Accept: "application/vnd.oai.openapi+json" },
              });
              if (!response.ok) throw new Error("OpenAPI description is unavailable");

              return {
                content: [{ type: "text", text: await response.text() }],
              };
            },
          },
        ];

        for (const tool of tools) modelContext.registerTool(tool);
        window.addEventListener(
          "pagehide",
          () => {
            for (const tool of tools) modelContext.unregisterTool(tool.name);
          },
          { once: true },
        );
      }
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: light dark;
    --bg: #ffffff;
    --text: #111111;
    --text-muted: #666666;
    --link: #111111;
    --link-hover: #666666;
    --border: #eaeaea;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #111111;
      --text: #ededed;
      --text-muted: #a0a0a0;
      --link: #ededed;
      --link-hover: #a0a0a0;
      --border: #333333;
    }
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    font-size: 16px;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    margin: 0;
    padding: 2rem 1.5rem;
    display: flex;
    justify-content: center;
  }

  .page {
    width: 100%;
    max-width: 38rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
    margin-top: 4rem;
    margin-bottom: 4rem;
  }

  .header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .avatar img {
    border-radius: 50%;
    width: 5rem;
    height: 5rem;
    object-fit: cover;
    border: 1px solid var(--border);
  }

  .title-group h1 {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .title-group .role {
    margin: 0.25rem 0 0 0;
    color: var(--text-muted);
    font-size: 1rem;
  }

  main {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  h2 {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  p {
    margin: 0;
    color: var(--text-muted);
    font-size: 1.05rem;
  }

  p a, li a {
    color: var(--text);
    text-decoration: underline;
    text-decoration-color: var(--border);
    text-underline-offset: 4px;
  }

  p a:hover, li a:hover {
    color: var(--link-hover);
    text-decoration-color: var(--text-muted);
  }

  ul {
    margin: 0;
    padding: 0;
    list-style: none;
    color: var(--text-muted);
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .links a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text);
    text-decoration: none;
    font-size: 0.95rem;
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    transition: all 0.2s ease;
  }

  .links a:hover {
    background: var(--text);
    color: var(--bg);
    border-color: var(--text);
  }

  .icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 600px) {
    .page {
      margin-top: 1rem;
    }
    .header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }
</style>
