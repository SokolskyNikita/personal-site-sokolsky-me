---
export const prerender = true;

const profile = {
  name: "Nikita Sokolsky",
  role: "Software Engineer @ Amazon (AWS WAF)",
  blurb:
    "I build reliable systems and thoughtful web products, then spend my off-hours shooting people and places with a camera.",
  location: "Seattle area",
  email: "sokolx@gmail.com",
};

const links = [
  { label: "LinkedIn", href: "https://www.linkedin.com/in/nsokolsky/" },
  { label: "Twitter", href: "https://twitter.com/nsokolsky/" },
  { label: "Instagram", href: "https://www.instagram.com/nsokolsky/" },
  { label: "Email", href: `mailto:${profile.email}` },
];

const focusAreas = [
  "Security-minded backend and platform engineering",
  "Performance-first frontend delivery",
  "Product thinking and developer experience",
  "Portrait and lifestyle photography",
];

const pageTitle = "Nikita Sokolsky - Software engineer and photographer";
const pageDescription =
  "Personal website of Nikita Sokolsky, software engineer at Amazon (AWS WAF) and photographer.";
const themeColorLight = "#eceff4";
const themeColorDark = "#2e3440";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky-me-temp.sokolx.workers.dev").replace(
    /\/$/,
    "",
  );
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const ogImageUrl = `${siteUrl}/og-image.jpg`;
const portraitJpgPath = "/profile-portrait-v2-640.jpg";
const portraitWebpPath = "/profile-portrait-v2-640.webp";
const profileImageUrl = `${siteUrl}${portraitJpgPath}`;
const twitterHandle = "@nsokolsky";
const socialProfiles = links
  .filter((link) => link.label !== "Email")
  .map((link) => link.href);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile.name,
  jobTitle: "Software Engineer",
  worksFor: {
    "@type": "Organization",
    name: "Amazon AWS WAF",
  },
  image: profileImageUrl,
  email: `mailto:${profile.email}`,
  url: canonicalUrl,
  sameAs: socialProfiles,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="author" content={profile.name} />
    <meta name="creator" content={profile.name} />
    <meta name="publisher" content={profile.name} />
    <meta name="application-name" content={profile.name} />
    <meta name="apple-mobile-web-app-title" content={profile.name} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="format-detection" content="telephone=no" />
    <meta
      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="googlebot"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="keywords"
      content="Nikita Sokolsky, software engineer, AWS WAF, backend, security engineering, photographer"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta name="theme-color" content={themeColorLight} media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content={themeColorDark} media="(prefers-color-scheme: dark)" />
    <meta name="msapplication-TileColor" content={themeColorDark} />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={canonicalUrl} />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color={themeColorDark} />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="me" href="https://www.linkedin.com/in/nsokolsky/" />
    <link rel="me" href="https://twitter.com/nsokolsky/" />
    <link rel="me" href="https://www.instagram.com/nsokolsky/" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={profile.name} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta
      property="og:image:alt"
      content="Preview card with Nikita Sokolsky name and role on a dark panel."
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta
      name="twitter:image:alt"
      content="Preview card with Nikita Sokolsky name and role on a dark panel."
    />
    <meta name="twitter:site" content={twitterHandle} />
    <meta name="twitter:creator" content={twitterHandle} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <div class="page">
      <header class="site-header">
        <p class="brand">{profile.name}</p>
        <nav aria-label="Primary">
          <ul class="nav-list">
            <li><a href="#about">About</a></li>
            <li><a href="#focus">Focus</a></li>
            <li><a href="#connect">Connect</a></li>
          </ul>
        </nav>
      </header>

      <main id="content">
        <section class="hero" aria-labelledby="hero-title">
          <div>
            <p class="eyebrow">{profile.role}</p>
            <h1 id="hero-title">{profile.name}</h1>
            <p class="lead">{profile.blurb}</p>
            <p class="meta">{profile.location}</p>
          </div>
          <picture>
            <source srcset={portraitWebpPath} type="image/webp" />
            <img
              src={portraitJpgPath}
              alt={`Portrait of ${profile.name}`}
              loading="eager"
              fetchpriority="high"
              decoding="async"
              width="640"
              height="640"
            />
          </picture>
        </section>

        <section id="about" aria-labelledby="about-title">
          <h2 id="about-title">About</h2>
          <p>
            I enjoy shipping clean, durable systems and simplifying things that
            should feel obvious in production. Outside of engineering, I explore
            visual storytelling through photography.
          </p>
        </section>

        <section id="focus" aria-labelledby="focus-title">
          <h2 id="focus-title">Current focus</h2>
          <ul class="focus-list">
            {
              focusAreas.map((item) => (
                <li>
                  <span aria-hidden="true">•</span>
                  {item}
                </li>
              ))
            }
          </ul>
        </section>

        <section id="connect" aria-labelledby="connect-title">
          <h2 id="connect-title">Connect</h2>
          <ul class="link-list">
            {
              links.map((link) => (
                <li>
                  <a href={link.href} target="_blank" rel="noreferrer">
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </section>
      </main>

      <footer>
        <p>
          Built with Astro + Cloudflare Workers.
        </p>
      </footer>
    </div>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --bg: #eceff4; /* nord6 */
    --surface: #e5e9f0; /* nord5 */
    --text: #2e3440; /* nord0 */
    --muted: #4c566a; /* nord3 */
    --line: #d8dee9; /* nord4 */
    --accent: #5e81ac; /* nord10 */
    --shadow: 0 12px 30px color-mix(in oklab, #3b4252 18%, transparent);
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 16px;
    background: var(--bg);
    color: var(--text);
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
  }

  .skip-link {
    position: absolute;
    left: -999px;
    top: 0;
    background: var(--text);
    color: var(--bg);
    padding: 0.6rem 0.8rem;
    z-index: 10;
  }

  .skip-link:focus-visible {
    left: 0.5rem;
    top: 0.5rem;
  }

  .page {
    width: min(72rem, 100% - clamp(1.5rem, 4vw, 3rem));
    margin-inline: auto;
    padding-block: clamp(1rem, 3vw, 2rem) clamp(2.5rem, 5vw, 5rem);
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
  }

  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    border-bottom: 1px solid var(--line);
    padding-bottom: 0.9rem;
  }

  .brand {
    margin: 0;
    font-size: 0.95rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .nav-list,
  .focus-list,
  .link-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .nav-list {
    display: flex;
    gap: clamp(0.9rem, 2vw, 1.5rem);
  }

  .hero {
    display: grid;
    gap: clamp(1.25rem, 4vw, 2.5rem);
    align-items: center;
    grid-template-columns: 1.2fr minmax(12rem, 18rem);
  }

  .eyebrow {
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
  }

  h1,
  h2 {
    font-family: "Iowan Old Style", "Palatino Linotype", Palatino, "Book Antiqua", Georgia, serif;
    letter-spacing: -0.02em;
    margin: 0;
  }

  h1 {
    font-size: clamp(2rem, 7vw, 4.5rem);
    line-height: 0.95;
    margin-top: 0.6rem;
  }

  h2 {
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    margin-bottom: 0.8rem;
  }

  p {
    margin: 0;
    max-width: 60ch;
    line-height: 1.6;
  }

  .lead {
    margin-top: 1rem;
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    color: color-mix(in oklab, var(--text) 92%, var(--muted));
  }

  .meta {
    margin-top: 0.8rem;
    color: var(--muted);
  }

  .hero img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 1.25rem;
    border: 1px solid color-mix(in oklab, var(--line) 80%, var(--text));
    box-shadow: var(--shadow);
  }

  main {
    display: grid;
    gap: clamp(1.8rem, 4vw, 2.8rem);
  }

  section {
    display: grid;
    gap: 0.75rem;
  }

  main > section:not(.hero) {
    content-visibility: auto;
    contain-intrinsic-size: 1px 320px;
  }

  .focus-list {
    display: grid;
    gap: 0.55rem;
    color: color-mix(in oklab, var(--text) 94%, var(--muted));
  }

  .focus-list li {
    display: flex;
    gap: 0.6rem;
    align-items: baseline;
  }

  .focus-list span {
    color: var(--accent);
  }

  .link-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.2rem;
  }

  a {
    color: var(--text);
    text-underline-offset: 0.15em;
    text-decoration-thickness: 0.06em;
    text-decoration-color: color-mix(in oklab, var(--accent) 55%, transparent);
    transition:
      color 160ms ease,
      text-decoration-color 160ms ease;
  }

  a:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  a:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
    border-radius: 0.2rem;
  }

  footer {
    border-top: 1px solid var(--line);
    padding-top: 1rem;
    color: var(--muted);
    font-size: 0.92rem;
  }

  @media (max-width: 56rem) {
    .hero {
      grid-template-columns: 1fr;
      max-width: 38rem;
    }

    .hero img {
      width: min(18rem, 65vw);
      justify-self: start;
    }
  }

  @media (max-width: 34rem) {
    .site-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }

    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
  }
</style>
