const getNeighborhoodGroup = (zone: string) => {
  const normalizedZone = zone
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "");

  if (normalizedZone.includes("santa teresa") || normalizedZone.includes("ycua sati")) {
    return "Santa Teresa / Ycuá Satí";
  }
  if (normalizedZone.includes("molas") || normalizedZone.includes("lomas") || normalizedZone.includes("carmelitas")) {
    return "Molas López / Las Lomas";
  }
  if (normalizedZone.includes("mburucuya") || normalizedZone.includes("trinidad")) {
    return "Mburucuyá / Trinidad";
  }
  if (normalizedZone.includes("villa morra") || normalizedZone.includes("boggiani")) {
    return "Villa Morra / Boggiani";
  }
  if (normalizedZone.includes("las mercedes")) return "Las Mercedes";
  if (normalizedZone.includes("salvador del mundo")) return "Salvador del Mundo";

  return zone.replace(/\s*\/.*$/, "");
};
const neighborhoodCounts = buildings.reduce((counts, building: Building) => {
  const neighborhood = getNeighborhoodGroup(building.zone);
  counts.set(neighborhood, (counts.get(neighborhood) ?? 0) + 1);
  return counts;
}, new Map<string, number>());
const neighborhoodOptions = [...neighborhoodCounts.entries()]
  .sort(
    ([nameA, countA], [nameB, countB]) =>
      countB - countA || collator.compare(nameA, nameB),
  )
  .map(([name, count]) => ({ name, count }));
const getCanonicalAirbnbUrl = (url: string) => {
  try {
    const parsedUrl = new URL(url);
    if (parsedUrl.hostname.includes("airbnb.")) {
      parsedUrl.protocol = "https:";
      parsedUrl.hostname = "www.airbnb.com";
      return parsedUrl.toString();
    }
  } catch {
    return url;
  }

  return url;
};
const getAirbnbSignature = (url: string) => url.match(/\/rooms\/(\d+)/)?.[1] ?? url;
const getAirbnbListings = (building: Building) => {
  const listingMap = new Map<string, AirbnbListing>();
  const addListing = (listing: AirbnbListing | null | undefined) => {
    if (!listing?.url) return;

    const signature = getAirbnbSignature(listing.url);
    if (listingMap.has(signature)) return;

    listingMap.set(signature, {
      ...listing,
      url: getCanonicalAirbnbUrl(listing.url),
    });
  };

  if (building.airbnb.confirmed && building.airbnb.url) {
    addListing({
      title: building.airbnb.evidence || `${building.name} Airbnb listing`,
      url: building.airbnb.url,
    });
  }
  for (const listing of additionalAirbnbListingsByBuilding[building.id] ?? []) {
    addListing(listing);
  }

  return [...listingMap.values()].map((listing, index, listings) => ({
    ...listing,
    label: listings.length === 1 ? "Airbnb" : `Airbnb ${index + 1}`,
  }));
};
const isDirectRentalUrl = (url: string) => {
  if (!url || url.includes("airbnb.com")) return false;
  if (url.includes("google.com/maps") || url.includes("booking.com")) return false;
  return true;
};
const getRentalSignature = (listing: RentalListing) =>
  (listing.signature ?? `${listing.source}-${listing.title}`)
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");
const getRentalListings = (building: Building) => {
  const listingMap = new Map<string, RentalListing>();
  const signatures = new Set<string>();
  const addListing = (listing: RentalListing | null | undefined) => {
    if (!listing?.url || !isDirectRentalUrl(listing.url)) return;

    const signature = getRentalSignature(listing);
    if (signatures.has(signature) || listingMap.has(listing.url)) return;

    signatures.add(signature);
    listingMap.set(listing.url, listing);
  };

  addListing(building.localRentalAd);
  if (!building.localRentalAd && building.rentalEvidence.url) {
    addListing({
      source: building.rentalEvidence.source,
      title: `${building.name} rental source`,
      url: building.rentalEvidence.url,
    });
  }
  for (const listing of additionalRentalListingsByBuilding[building.id] ?? []) {
    addListing(listing);
  }

  return [...listingMap.values()]
    .slice(0, maxRentalListingsPerBuilding)
    .map((listing, index, listings) => ({
      ...listing,
      label: listings.length === 1 ? "Rental ad" : `Rental ${index + 1}`,
    }));
};
const priceSortedBuildings = [...buildings].sort((first, second) =>
  first.longTermRentUsd.amount - second.longTermRentUsd.amount ||
  collator.compare(first.name, second.name)
);
const buildingsWithSort = priceSortedBuildings.map((building: Building, index) => {
  const airbnbListings = getAirbnbListings(building);
  const rentalListings = getRentalListings(building);
  return {
    ...building,
    airbnbListings,
    rentalListings,
    filterNeighborhood: getNeighborhoodGroup(building.zone),
    pricePerTwoBedroomSquareMeter: building.longTermRentUsd.amount / building.approxTwoBedroomAreaSqm.amount,
    listPosition: index + 1,
  };
});
const formatRent = (amount: number) => `$${amount.toLocaleString("en-US")}`;
const formatArea = (amount: number) => `~${amount.toLocaleString("en-US")} m²`;
const mapApiKey =
  import.meta.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
  process.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
  "";
const apartmentMapCenter = pageData.mapCenter;
const apartmentMapData = buildings.map((building) => {
  const airbnbListings = getAirbnbListings(building);
  const rentalListings = getRentalListings(building);
  return {
    id: building.id,
    name: building.name,
    zone: building.zone,
    neighborhood: getNeighborhoodGroup(building.zone),
    address: building.address,
    floorsAboveGround: building.floorsAboveGround,
    rentAmount: building.longTermRentUsd.amount,
    approxTwoBedroomAreaSqm: building.approxTwoBedroomAreaSqm.amount,
    airbnbConfirmed: airbnbListings.length > 0,
    airbnbListings,
    rentalListings,
    mapUrl: building.googleMapsUrl,
    position: building.location,
  };
});
const mapsIcon = `<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="#1a73e8" d="M12 2.2c3.9 0 7.1 3.1 7.1 7 0 5.1-7.1 12.6-7.1 12.6S4.9 14.3 4.9 9.2c0-3.9 3.2-7 7.1-7Z"/><path fill="#34a853" d="M7.2 14.1 12 21.8l4.8-7.7-4.8-2.8-4.8 2.8Z"/><path fill="#fbbc04" d="M4.9 9.2c0 1.8.9 3.5 2.3 4.9l4.8-2.8V2.2c-3.9 0-7.1 3.1-7.1 7Z"/><path fill="#ea4335" d="M19.1 9.2c0 1.8-.9 3.5-2.3 4.9L12 11.3V2.2c3.9 0 7.1 3.1 7.1 7Z"/><circle cx="12" cy="9.3" r="2.45" fill="#fff"/></svg>`;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  numberOfItems: buildings.length,
  itemListElement: priceSortedBuildings.map((building, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "ApartmentComplex",
      name: building.name,
      address: building.fullAddress,
      sameAs: [
        building.googleMapsUrl,
        ...(building.officialWebsiteUrl ? [building.officialWebsiteUrl] : []),
        ...getAirbnbListings(building).map((listing) => listing.url),
      ],
      geo: {
        "@type": "GeoCoordinates",
        latitude: building.location.lat,
        longitude: building.location.lng,
      },
    },
  })),
};
