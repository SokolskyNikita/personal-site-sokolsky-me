    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color={themeColorDark} />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Nikita Sokolsky" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <main class="page">
      <header class="page-header">
        <a class="home-link" href="/">Nikita Sokolsky</a>
        <div class="headline">
          <p class="eyebrow">Buenos Aires apartment guide</p>
          <h1>{pageTitle}</h1>
          <p class="intro">
            A list of Buenos Aires apartment buildings with active rental ads, exact Airbnb matches and map links. Buildings are included when they either have a gym, pool and heated floors (losa radiante), or when they have 29+ floors with a live listing found.
          </p>
        </div>
      </header>

      <section class="toolbar" aria-label="Apartment controls">
        <fieldset class="availability-toggle">
          <legend>Show</legend>
          <label for="airbnb-only">
            <input id="airbnb-only" type="checkbox" autocomplete="off" />
            <span>Has Airbnb</span>
          </label>
          <label for="multiple-offers-only">
            <input id="multiple-offers-only" type="checkbox" autocomplete="off" />
            <span>2+ Airbnb or 2+ rental links</span>
          </label>
          <label for="twenty-plus-floors-only">
            <input id="twenty-plus-floors-only" type="checkbox" autocomplete="off" />
            <span>20+ floors</span>
          </label>
          <label for="built-since-2016-only">
            <input id="built-since-2016-only" type="checkbox" autocomplete="off" />
            <span>Built since 2016</span>
          </label>
        </fieldset>
        <label class="filter-dropdown" for="neighborhood-filter">
          <span>Neighborhood</span>
          <select id="neighborhood-filter" name="neighborhood" autocomplete="off">
            <option value="" data-label="All">All ({buildings.length})</option>
            {neighborhoodOptions.map((option) => (
              <option value={option.name} data-label={option.name}>{option.name} ({option.count})</option>
            ))}
          </select>
        </label>
        <label class="filter-dropdown sort-dropdown" for="building-sort">
          <span>Sort by</span>
          <select id="building-sort" name="sort" autocomplete="off">
            <option value="price-asc">Price, asc</option>
            <option value="price-desc">Price, desc</option>
            <option value="area-desc">Area of a 2BR</option>
            <option value="price-per-sqm-asc">$$$ per square meter</option>
          </select>
        </label>
        <fieldset class="area-unit-toggle" aria-label="Area unit">
          <legend>Area unit</legend>
          <label>
            <input type="radio" name="area-unit" value="sqm" autocomplete="off" checked />
            <span>m²</span>
          </label>
          <label>
            <input type="radio" name="area-unit" value="sqft" autocomplete="off" />
            <span>ft²</span>
          </label>
        </fieldset>
      </section>

      <section class="building-list" aria-label="Buenos Aires high-rise apartment buildings">
        {buildingsWithSort.map((building) => (
          <article
            class={`building-card ${building.airbnbListings.length > 0 ? "is-airbnb" : ""}`}
            data-building-id={building.id}
            data-airbnb={building.airbnbListings.length > 0}
            data-multiple-offers={building.hasMultipleRentalOffers}
            data-twenty-plus-floors={building.has20PlusFloors}
            data-built-since-2016={building.isBuiltSince2016}
            data-neighborhood={building.filterNeighborhood}
            data-rent-amount={building.longTermRentUsd.amount}
            data-two-bedroom-area={building.approxTwoBedroomAreaSqm.amount}
            data-price-per-sqm={building.pricePerTwoBedroomSquareMeter}
          >
            <div class="building-main">
              <div class="building-title-row">
                <p class="building-position">#{building.listPosition}</p>
                <h2>
                  {building.officialWebsiteUrl ? (
                    <a
                      class="official-building-link"
                      href={building.officialWebsiteUrl}
                      target="_blank"
                      rel="noreferrer noopener"
                      aria-label={`Open official website for ${building.name}`}
                    >
                      {building.name}
                    </a>
                  ) : (
                    building.name
                  )}
                </h2>
              </div>
              <p class="building-description">{building.description}</p>
              <div class="building-tags" aria-label={`${building.name} facts`}>
                <span>{building.zone}</span>
                <span>{building.built}</span>
                {building.floorsAboveGround !== null ? (
                  <span>{building.floorsAboveGround} floors</span>
                ) : null}
              </div>
            </div>
            <div class="building-side">
              <div class="building-metrics" aria-label={`${building.name} price and area estimates`}>
                <p
                  class={`rent-estimate confidence-${building.longTermRentUsd.confidence.replace(/[^a-z]/g, "-")}`}
                  title={building.longTermRentUsd.summary}
                >
                  <span>{formatRent(building.longTermRentUsd.amount)}/mo</span>
                  <span>Est. $/month for 1BR</span>
                </p>
                <p
                  class={`area-estimate confidence-${building.approxTwoBedroomAreaSqm.confidence.replace(/[^a-z]/g, "-")}`}
                  title={building.approxTwoBedroomAreaSqm.summary}
                >
                  <span class="area-value" data-area-sqm={building.approxTwoBedroomAreaSqm.amount}>{formatArea(building.approxTwoBedroomAreaSqm.amount)}</span>
                  <span>approx. 2BR area</span>
                </p>
              </div>
              <p class="address">{building.address}</p>
              <div class="building-links">
                <a
                  class="map-link"
                  href={building.googleMapsUrl}
                  target="_blank"
                  rel="noreferrer noopener"
                  aria-label={`Open map for ${building.name}`}
                >
                  <span class="maps-icon" set:html={mapsIcon} />
                  Map
                </a>
                {building.airbnbListings.length > 0 ? (
                  <div class="link-row airbnb-link-row" aria-label={`${building.name} Airbnb links`}>
                    {building.airbnbListings.map((listing) => (
                      <a
                        href={listing.url}
                        target="_blank"
                        rel="noreferrer noopener"
                        aria-label={`Open ${listing.label} listing for ${building.name}`}
                        title={listing.title}
                      >
                        {listing.label}
                      </a>
                    ))}
                  </div>
                ) : null}
                {building.rentalListings.length > 0 ? (
                  <div class="link-row rental-link-row" aria-label={`${building.name} rental links`}>
                    {building.rentalListings.map((listing) => (
                      <a
                        href={listing.url}
                        target="_blank"
                        rel="noreferrer noopener"
                        aria-label={`Open ${listing.label} for ${building.name}`}
                        title={`${listing.source}: ${listing.title}`}
                      >
                        {listing.label}
                      </a>
                    ))}
                  </div>
                ) : null}
              </div>
            </div>
          </article>
        ))}
      </section>

      <section class="map-section" aria-labelledby="apartment-map-heading">
        <div class="map-copy">
          <p class="eyebrow">Map</p>
          <h2 id="apartment-map-heading">Where the buildings are</h2>
          <p id="apartment-map-status" class="map-status">
            Showing all {buildings.length} buildings. Gold pins have Airbnb links.
          </p>
        </div>
        {mapApiKey ? (
          <div
            id="apartment-map"
            class="apartment-map"
            aria-label="Map with pins for Buenos Aires high-rise apartment buildings"
          ></div>
        ) : (
          <p class="map-unavailable">
            Map unavailable because the public map key is not configured.
          </p>
        )}
      </section>
    </main>
  </body>
</html>

<script is:inline define:vars={{ mapApiKey, apartmentMapData }}>
  if (mapApiKey) {
    ((g) => {
      let h;
      let a;
      let k;
      const p = "The map library";
      const c = "google";
      const l = "importLibrary";
      const q = "__ib__";
      const m = document;
      let b = window;
      b = b[c] || (b[c] = {});
      const d = b.maps || (b.maps = {});
      const r = new Set();
      const e = new URLSearchParams();
      const u = () =>
        h ||
        (h = new Promise(async (resolve, reject) => {
          await (a = m.createElement("script"));
          e.set("libraries", [...r] + "");
          for (k in g) {
            e.set(k.replace(/[A-Z]/g, (t) => `_${t[0].toLowerCase()}`), g[k]);
          }
          e.set("callback", `${c}.maps.${q}`);
          a.src = `https://maps.${c}apis.com/maps/api/js?${e}`;
          d[q] = resolve;
          a.onerror = () => (h = reject(Error(`${p} could not load.`)));
          a.nonce = m.querySelector("script[nonce]")?.nonce || "";
          m.head.append(a);
        }));
      d[l] ? console.warn(`${p} only loads once. Ignoring:`, g) : (d[l] = (f, ...n) => r.add(f) && u().then(() => d[l](f, ...n)));
    })({
      key: mapApiKey,
      v: "weekly",
    });
  }

  const airbnbOnlyToggle = document.querySelector("#airbnb-only");
  const multipleOffersOnlyToggle = document.querySelector("#multiple-offers-only");
  const twentyPlusFloorsOnlyToggle = document.querySelector("#twenty-plus-floors-only");
  const builtSince2016OnlyToggle = document.querySelector("#built-since-2016-only");
  const neighborhoodFilter = document.querySelector("#neighborhood-filter");
  const buildingSort = document.querySelector("#building-sort");
  const buildingList = document.querySelector(".building-list");
  const areaUnitInputs = [...document.querySelectorAll('input[name="area-unit"]')];
  const areaValueLabels = [...document.querySelectorAll(".area-value")];
  const apartmentRows = [...document.querySelectorAll(".building-card")];
  const buildingById = new Map(apartmentMapData.map((building) => [building.id, building]));
  const mapElement = document.querySelector("#apartment-map");
  const mapStatus = document.querySelector("#apartment-map-status");
  const buenosAiresCenter = { lat: -34.595, lng: -58.435 };
  const markerRecords = [];
  let apartmentMap;
  let infoWindow;

  const escapeHtml = (value) =>
    String(value).replace(/[&<>"']/g, (character) => ({
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#39;",
    })[character]);

  const getCheckboxFilters = () => ({
    airbnbOnly: Boolean(airbnbOnlyToggle?.checked),
    multipleOffersOnly: Boolean(multipleOffersOnlyToggle?.checked),
    twentyPlusFloorsOnly: Boolean(twentyPlusFloorsOnlyToggle?.checked),
    builtSince2016Only: Boolean(builtSince2016OnlyToggle?.checked),
  });

  const matchesCheckboxFilters = (building, filters) =>
    (!filters.airbnbOnly || building.airbnbConfirmed) &&
    (!filters.multipleOffersOnly || building.hasMultipleRentalOffers) &&
    (!filters.twentyPlusFloorsOnly || building.has20PlusFloors) &&
    (!filters.builtSince2016Only || building.isBuiltSince2016);

  const formatAreaLabel = (areaSqm, unit) => {
    const amount = unit === "sqft" ? Math.round(areaSqm * 10.7639) : Math.round(areaSqm);
    const suffix = unit === "sqft" ? "ft²" : "m²";
    return `~${amount.toLocaleString("en-US")} ${suffix}`;
  };

  const selectedAreaUnit = () =>
    areaUnitInputs.find((input) => input.checked)?.value ?? "sqm";

  const updateAreaUnits = () => {
    const unit = selectedAreaUnit();
    for (const label of areaValueLabels) {
      const areaSqm = Number(label.dataset.areaSqm);
      if (Number.isFinite(areaSqm)) label.textContent = formatAreaLabel(areaSqm, unit);
    }
  };

  const numericDatasetValue = (row, key) => {
    const value = Number(row.dataset[key]);
    return Number.isFinite(value) ? value : 0;
  };

  const compareRowsByName = (firstRow, secondRow) => {
    const firstBuilding = buildingById.get(firstRow.dataset.buildingId);
    const secondBuilding = buildingById.get(secondRow.dataset.buildingId);
    return String(firstBuilding?.name ?? "").localeCompare(String(secondBuilding?.name ?? ""), "en", {
      numeric: true,
      sensitivity: "base",
    });
  };

  const compareRowsBySort = (firstRow, secondRow) => {
    const sortValue = buildingSort?.value ?? "price-asc";
    const firstRent = numericDatasetValue(firstRow, "rentAmount");
    const secondRent = numericDatasetValue(secondRow, "rentAmount");
    const firstArea = numericDatasetValue(firstRow, "twoBedroomArea");
    const secondArea = numericDatasetValue(secondRow, "twoBedroomArea");
    const firstPricePerSqm = numericDatasetValue(firstRow, "pricePerSqm");
    const secondPricePerSqm = numericDatasetValue(secondRow, "pricePerSqm");

    const primarySort =
      sortValue === "price-desc"
        ? secondRent - firstRent
        : sortValue === "area-desc"
          ? secondArea - firstArea
          : sortValue === "price-per-sqm-asc"
            ? firstPricePerSqm - secondPricePerSqm
            : firstRent - secondRent;

    return primarySort || compareRowsByName(firstRow, secondRow);
  };

  const sortRows = () => {
    const sortedRows = [...apartmentRows].sort(compareRowsBySort);
    if (buildingList) {
      for (const row of sortedRows) {
        buildingList.append(row);
      }
    }
    return sortedRows;
  };

  const updateVisiblePositions = (sortedRows) => {
    let position = 0;
    for (const row of sortedRows) {
      if (row.hidden) continue;
      position += 1;
      const positionLabel = row.querySelector(".building-position");
      if (positionLabel) positionLabel.textContent = `#${position}`;
    }
  };

  const updateNeighborhoodCounts = () => {
    if (!neighborhoodFilter) return;

    const filters = getCheckboxFilters();
    const counts = new Map();
    let total = 0;

    for (const building of apartmentMapData) {
      if (!matchesCheckboxFilters(building, filters)) continue;
      total += 1;
      counts.set(building.neighborhood, (counts.get(building.neighborhood) ?? 0) + 1);
    }

    for (const option of neighborhoodFilter.options) {
      const label = option.dataset.label ?? option.textContent?.replace(/\s*\(\d+\)$/, "") ?? "";
      const count = option.value ? counts.get(option.value) ?? 0 : total;
      option.textContent = `${label} (${count})`;
    }
  };

  const visibleMapBuildings = () => {
    const filters = getCheckboxFilters();
    const selectedNeighborhood = neighborhoodFilter?.value ?? "";

    return apartmentMapData.filter((building) =>
      (!selectedNeighborhood || building.neighborhood === selectedNeighborhood) &&
      matchesCheckboxFilters(building, filters)
    );
  };

  const updateMapStatus = () => {
    if (!mapStatus) return;

    const visibleBuildings = visibleMapBuildings();
    const airbnbCount = visibleBuildings.filter((building) => building.airbnbConfirmed).length;
    const selectedNeighborhood = neighborhoodFilter?.value ?? "";
    const buildingLabel = visibleBuildings.length === 1 ? "building" : "buildings";
    const scope = selectedNeighborhood ? ` in ${selectedNeighborhood}` : "";
    mapStatus.textContent = `Showing ${visibleBuildings.length} ${buildingLabel}${scope}. ${airbnbCount} with Airbnb links.`;
  };

  const fitMapToMarkers = (visibleRecords) => {
    if (!apartmentMap || !window.google?.maps || visibleRecords.length === 0) return;

    if (visibleRecords.length === 1) {
      apartmentMap.setCenter(visibleRecords[0].building.position);
      apartmentMap.setZoom(15);
      return;
    }

    const bounds = new google.maps.LatLngBounds();
    for (const { building } of visibleRecords) {
      bounds.extend(building.position);
    }
    apartmentMap.fitBounds(bounds, 48);
  };

  const applyFilters = () => {
    const filters = getCheckboxFilters();
    const selectedNeighborhood = neighborhoodFilter?.value ?? "";
    updateNeighborhoodCounts();
    const sortedRows = sortRows();

    for (const row of sortedRows) {
      const building = buildingById.get(row.dataset.buildingId);
      row.hidden = !(
        building &&
        (!selectedNeighborhood || building.neighborhood === selectedNeighborhood) &&
        matchesCheckboxFilters(building, filters)
      );
    }

    updateVisiblePositions(sortedRows);
    updateMapStatus();
    if (!apartmentMap) return;

    const visibleRecords = [];
    for (const record of markerRecords) {
      const isVisible =
        (!selectedNeighborhood || record.building.neighborhood === selectedNeighborhood) &&
        matchesCheckboxFilters(record.building, filters);
      record.marker.setMap(isVisible ? apartmentMap : null);
      if (isVisible) visibleRecords.push(record);
    }

    fitMapToMarkers(visibleRecords);
  };

  const initApartmentMap = async () => {
    if (!mapElement || !mapApiKey || !window.google?.maps?.importLibrary) return;

    const { Map, InfoWindow } = await google.maps.importLibrary("maps");
    await google.maps.importLibrary("marker");

    apartmentMap = new Map(mapElement, {
      center: buenosAiresCenter,
      clickableIcons: false,
      fullscreenControl: true,
      mapTypeControl: false,
      streetViewControl: false,
      zoom: 12,
    });
    infoWindow = new InfoWindow();

    for (const building of apartmentMapData) {
      const marker = new google.maps.Marker({
        icon: {
          path: google.maps.SymbolPath.CIRCLE,
          scale: building.airbnbConfirmed ? 9 : 7,
          fillColor: building.airbnbConfirmed ? "#c98a17" : "#28402f",
          fillOpacity: 0.95,
          strokeColor: "#fffdf8",
          strokeWeight: 2,
        },
        map: apartmentMap,
        position: building.position,
        title: building.name,
      });

      marker.addListener("click", () => {
        const airbnbLinks = building.airbnbListings.length > 0
          ? `<br>${building.airbnbListings.map((listing) =>
            `<a href="${escapeHtml(listing.url)}" target="_blank" rel="noreferrer noopener">${escapeHtml(listing.label)}</a>`
          ).join(" · ")}`
          : "";
        const rentalLinks = building.rentalListings.length > 0
          ? `<br>${building.rentalListings.map((listing) =>
            `<a href="${escapeHtml(listing.url)}" target="_blank" rel="noreferrer noopener">${escapeHtml(listing.label)}</a>`
          ).join(" · ")}`
          : "";
        infoWindow.setContent(
          `<strong>${escapeHtml(building.name)}</strong><br>${escapeHtml(building.zone)} · ${escapeHtml(building.address)}<br><a href="${escapeHtml(building.mapUrl)}" target="_blank" rel="noreferrer noopener">Open map</a>${airbnbLinks}${rentalLinks}`,
        );
        infoWindow.open(apartmentMap, marker);
      });

      markerRecords.push({ building, marker });
    }

    applyFilters();
  };
  airbnbOnlyToggle?.addEventListener("change", applyFilters);
  multipleOffersOnlyToggle?.addEventListener("change", applyFilters);
  twentyPlusFloorsOnlyToggle?.addEventListener("change", applyFilters);
  builtSince2016OnlyToggle?.addEventListener("change", applyFilters);
  neighborhoodFilter?.addEventListener("change", applyFilters);
  buildingSort?.addEventListener("change", applyFilters);
  for (const input of areaUnitInputs) {
    input.addEventListener("change", updateAreaUnits);
  }
  updateAreaUnits();
  applyFilters();
  window.addEventListener("pageshow", applyFilters);
  initApartmentMap().catch((error) => {
    console.error("Unable to initialize apartment map", error);
    if (mapStatus) mapStatus.textContent = "Map unavailable. Building list still works.";
  });
</script>

