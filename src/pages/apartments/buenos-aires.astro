---
import pageData from "../../data/apartments-buenos-aires.json";
import listingsData from "../../data/apartments-buenos-aires-listings.json";

export const prerender = true;

const pageTitle = pageData.title;
const pageDescription =
  "Buenos Aires apartment buildings with gym, pool and losa radiante, or 29+ floors, plus rental ads, Airbnb links and map pins.";
const themeColorLight = "#fcfaf6";
const themeColorDark = "#111111";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
type Building = (typeof pageData.buildings)[number];
type AirbnbSize = "studio" | "1br" | "2br" | "3br" | "4br" | "5br+";
type AirbnbPriceSource =
  | "monthly"
  | "weekly_extrapolated"
  | "monthly_from_stay"
  | "stay_extrapolated";
type AirbnbListing = {
  title: string;
  url: string;
  size?: AirbnbSize;
  bedrooms?: number;
  priceUsdMonthly?: number | null;
  priceSource?: AirbnbPriceSource | null;
};
type AirbnbPriceMeta = {
  priceUsdMonthly?: number | null;
  source?: AirbnbPriceSource | null;
  status?: string;
};
type RentalListing = {
  source: string;
  title: string;
  url: string;
  signature?: string;
  size?: AirbnbSize;
  bedrooms?: number;
  priceUsdMonthly?: number;
  rentUsd?: number;
  expensesUsd?: number;
  expensesIncluded?: boolean;
};
type RentalMeta = {
  size?: AirbnbSize;
  bedrooms?: number;
  priceUsdMonthly?: number;
  rentUsd?: number;
  expensesUsd?: number;
  expensesIncluded?: boolean;
};
const buildings = pageData.buildings;
// Strict: reformer / camilla / pilates machines — not yoga-mat "pilates" corners.
const buildingsWithPilates = new Set([
  "almarena-puerto-retiro",
  "forum-puerto-madero",
  "milaires",
  "palacio-alcorta",
  "town-house-soho",
]);
const buildingsWithCinema = new Set([
  "alvear-tower",
  "chateau-puerto-madero",
  "forum-puerto-madero",
  "harbour-residences",
  "la-musa-stars",
  "madero-center",
  "quartier-boulevard",
  "quartier-dorrego",
  "quartier-polo",
  "torre-bellini-palermo-chico",
  "torre-promenade",
  "torres-de-montaneses",
]);
const collator = new Intl.Collator("en", {
  sensitivity: "base",
  numeric: true,
});
const maxRentalListingsPerBuilding = listingsData.maxRentalListingsPerBuilding;
const removedAirbnbUrls = new Set(listingsData.removedAirbnbUrls);
const removedRentalUrls = new Set(
  ("removedRentalUrls" in listingsData
    ? (listingsData as { removedRentalUrls?: string[] }).removedRentalUrls
    : undefined) ?? [],
);
const additionalAirbnbListingsByBuilding = listingsData.additionalAirbnbListingsByBuilding as Record<
  string,
  AirbnbListing[]
>;
const additionalRentalListingsByBuilding = listingsData.additionalRentalListingsByBuilding as Record<
  string,
  RentalListing[]
>;
const airbnbSizesByUrl = (
  "airbnbSizesByUrl" in listingsData
    ? (listingsData as { airbnbSizesByUrl?: Record<string, { size: AirbnbSize; bedrooms: number }> })
        .airbnbSizesByUrl
    : undefined
) ?? {};
const airbnbPricesByUrl = (
  "airbnbPricesByUrl" in listingsData
    ? (listingsData as { airbnbPricesByUrl?: Record<string, AirbnbPriceMeta> }).airbnbPricesByUrl
    : undefined
) ?? {};
const rentalMetaByUrl = (
  "rentalMetaByUrl" in listingsData
    ? (listingsData as { rentalMetaByUrl?: Record<string, RentalMeta> }).rentalMetaByUrl
    : undefined
) ?? {};
const getNeighborhoodGroup = (zone: string) => {
  const normalizedZone = zone.toLowerCase();

  // Check more specific / left-side labels before broader ones so border
  // strings like "Recoleta / Palermo border" don't collapse into Palermo.
  if (normalizedZone.includes("recoleta")) return "Recoleta";
  if (normalizedZone.includes("puerto madero")) return "Puerto Madero";
  if (
    normalizedZone.includes("palermo") ||
    normalizedZone.includes("cañitas") ||
    normalizedZone.includes("canitas") ||
    normalizedZone.includes("botánico") ||
    normalizedZone.includes("botanico")
  ) {
    return "Palermo";
  }
  if (normalizedZone.includes("belgrano") || normalizedZone.includes("bajo belgrano")) {
    return "Belgrano";
  }
  if (normalizedZone.includes("núñez") || normalizedZone.includes("nunez")) return "Núñez";
  if (normalizedZone.includes("caballito")) return "Caballito";
  if (normalizedZone.includes("villa urquiza")) return "Villa Urquiza";
  if (normalizedZone.includes("villa crespo")) return "Villa Crespo";
  if (normalizedZone.includes("colegiales")) return "Colegiales";
  if (normalizedZone.includes("flores")) return "Flores";
  if (normalizedZone.includes("barracas")) return "Barracas";

  return zone.replace(/\s*\/.*$/, "").replace(/\s+edge$/i, "");
};
const neighborhoodCounts = buildings.reduce((counts, building: Building) => {
  const neighborhood = getNeighborhoodGroup(building.zone);
  counts.set(neighborhood, (counts.get(neighborhood) ?? 0) + 1);
  return counts;
}, new Map<string, number>());
const neighborhoodOptions = [...neighborhoodCounts.entries()]
  .sort(
    ([nameA, countA], [nameB, countB]) =>
      countB - countA || collator.compare(nameA, nameB),
  )
  .map(([name, count]) => ({ name, count }));
const airbnbSizeRank: Record<AirbnbSize, number> = {
  studio: 0,
  "1br": 1,
  "2br": 2,
  "3br": 3,
  "4br": 4,
  "5br+": 5,
};
const formatAirbnbSize = (size?: AirbnbSize) => {
  switch (size) {
    case "studio":
      return "Studio";
    case "1br":
      return "1BR";
    case "2br":
      return "2BR";
    case "3br":
      return "3BR";
    case "4br":
      return "4BR";
    case "5br+":
      return "5BR+";
    default:
      return null;
  }
};
const formatRentUsd = (amount?: number | null) => {
  if (amount == null || !Number.isFinite(amount)) return null;
  return new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
    maximumFractionDigits: 0,
  }).format(amount);
};
const withAirbnbMeta = (listing: AirbnbListing): AirbnbListing => {
  const knownSize = airbnbSizesByUrl[listing.url];
  const knownPrice = airbnbPricesByUrl[listing.url];
  const priceFromMeta =
    knownPrice && "priceUsdMonthly" in knownPrice ? knownPrice.priceUsdMonthly : undefined;
  return {
    ...listing,
    size: listing.size ?? knownSize?.size,
    bedrooms: listing.bedrooms ?? knownSize?.bedrooms,
    priceUsdMonthly: listing.priceUsdMonthly ?? priceFromMeta ?? null,
    priceSource: listing.priceSource ?? knownPrice?.source ?? null,
  };
};
/** Pull the real listing name out of research-note evidence ("Airbnb result titled …"). */
const refineAirbnbListingTitle = (raw: string | null | undefined, fallback: string) => {
  const text = String(raw ?? "").replace(/\s+/g, " ").trim();
  if (!text) return fallback;

  const quoted =
    text.match(/(?:result|listing)\s+(?:is\s+)?titled\s+[""]([^""]+)[""]/i) ||
    text.match(/Exact-building Airbnb\s+[""]([^""]+)[""]/i) ||
    text.match(/\bAirbnb\s+[""]([^""]+)[""]/i);
  if (quoted?.[1]) {
    const title = quoted[1].trim().replace(/[.]+$/g, "");
    if (title.length >= 3) return title;
  }

  const unquoted = text.match(/(?:result|listing)\s+(?:is\s+)?titled\s+(.+?)(?:\.|$)/i);
  if (unquoted?.[1]) {
    const title = unquoted[1]
      .trim()
      .replace(/^[""]|[""]$/g, "")
      .replace(/[.]+$/g, "")
      .replace(/\s+(?:names|states|lists|describes|priced at)\b.*$/i, "")
      .trim();
    if (title.length >= 3 && !/^no\b/i.test(title)) return title;
  }

  if (
    /^(?:no exact|previous airbnb|the \d|the inclusion|exact airbnb searches|airbnb searches)\b/i.test(
      text,
    ) ||
    (/\bairbnb\b/i.test(text) && /(?:titled|result|exact-building)/i.test(text))
  ) {
    return fallback;
  }

  return text;
};
const getAirbnbListings = (building: Building) => {
  const listingMap = new Map<string, AirbnbListing>();
  const fallbackTitle = `${building.name} listing`;

  // Include primary short-stay URL even when unconfirmed (e.g. Booking.com fallback).
  if (building.airbnb.url && !removedAirbnbUrls.has(building.airbnb.url)) {
    listingMap.set(
      building.airbnb.url,
      withAirbnbMeta({
        title: refineAirbnbListingTitle(building.airbnb.evidence, fallbackTitle),
        url: building.airbnb.url,
      }),
    );
  }

  for (const listing of additionalAirbnbListingsByBuilding[building.id] ?? []) {
    if (removedAirbnbUrls.has(listing.url)) continue;
    const existing = listingMap.get(listing.url);
    const rawTitle = listing.title || existing?.title || fallbackTitle;
    listingMap.set(
      listing.url,
      withAirbnbMeta({
        ...existing,
        ...listing,
        title: refineAirbnbListingTitle(rawTitle, fallbackTitle),
      }),
    );
  }

  return [...listingMap.values()]
    .filter((listing) => Boolean(listing.size))
    .map((listing) => {
      const priceLabel =
        listing.priceUsdMonthly != null ? formatRentUsd(listing.priceUsdMonthly) : null;
      const source = listing.url.includes("booking.com")
        ? ("Booking" as const)
        : ("Airbnb" as const);
      return {
        ...listing,
        source,
        sizeLabel: formatAirbnbSize(listing.size),
        priceLabel,
        priceUnknown: listing.priceUsdMonthly == null,
      };
    })
    .sort((first, second) => {
      const firstRank = first.size ? airbnbSizeRank[first.size] : 99;
      const secondRank = second.size ? airbnbSizeRank[second.size] : 99;
      if (firstRank !== secondRank) return firstRank - secondRank;
      const firstBeds = first.bedrooms ?? 99;
      const secondBeds = second.bedrooms ?? 99;
      if (firstBeds !== secondBeds) return firstBeds - secondBeds;
      const firstPrice = first.priceUsdMonthly ?? Number.POSITIVE_INFINITY;
      const secondPrice = second.priceUsdMonthly ?? Number.POSITIVE_INFINITY;
      if (firstPrice !== secondPrice) return firstPrice - secondPrice;
      return collator.compare(first.title, second.title);
    });
};
const isDirectRentalUrl = (url: string) => {
  if (!url || url.includes("airbnb.com")) return false;
  if (url.includes("google.com/maps") || url.includes("booking.com")) return false;
  if (url.includes("zonaprop.com.ar")) return url.includes("/propiedades/");
  if (url.includes("mercadolibre.com.ar")) {
    return url.includes("departamento.mercadolibre.com.ar/MLA-");
  }
  return true;
};
const getRentalSignature = (listing: RentalListing) =>
  (listing.signature ?? `${listing.source}-${listing.title}`)
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");
const withRentalMeta = (listing: RentalListing): RentalListing => {
  const known = rentalMetaByUrl[listing.url];
  if (!known) return listing;
  return {
    ...listing,
    size: listing.size ?? known.size,
    bedrooms: listing.bedrooms ?? known.bedrooms,
    priceUsdMonthly: listing.priceUsdMonthly ?? known.priceUsdMonthly,
    rentUsd: listing.rentUsd ?? known.rentUsd,
    expensesUsd: listing.expensesUsd ?? known.expensesUsd,
    expensesIncluded: listing.expensesIncluded ?? known.expensesIncluded,
  };
};
const getRentalListings = (building: Building) => {
  const listingMap = new Map<string, RentalListing>();
  const signatures = new Set<string>();
  const addListing = (listing: RentalListing | null | undefined) => {
    if (!listing?.url || !isDirectRentalUrl(listing.url)) return;
    if (removedRentalUrls.has(listing.url)) return;

    const enriched = withRentalMeta(listing);
    if (!enriched.size || enriched.priceUsdMonthly == null) return;
    const signature = getRentalSignature(enriched);
    if (signatures.has(signature) || listingMap.has(enriched.url)) return;

    signatures.add(signature);
    listingMap.set(enriched.url, enriched);
  };

  addListing(building.localRentalAd);
  if (!building.localRentalAd && building.rentalEvidence.url) {
    addListing({
      source: building.rentalEvidence.source,
      title: `${building.name} rental source`,
      url: building.rentalEvidence.url,
    });
  }

  for (const listing of additionalRentalListingsByBuilding[building.id] ?? []) {
    addListing(listing);
  }

  return [...listingMap.values()]
    .map((listing) => ({
      ...listing,
      sizeLabel: formatAirbnbSize(listing.size),
      priceLabel: formatRentUsd(listing.priceUsdMonthly),
    }))
    .sort((first, second) => {
      const firstRank = first.size ? airbnbSizeRank[first.size] : 99;
      const secondRank = second.size ? airbnbSizeRank[second.size] : 99;
      if (firstRank !== secondRank) return firstRank - secondRank;
      const firstBeds = first.bedrooms ?? 99;
      const secondBeds = second.bedrooms ?? 99;
      if (firstBeds !== secondBeds) return firstBeds - secondBeds;
      const firstPrice = first.priceUsdMonthly ?? Number.POSITIVE_INFINITY;
      const secondPrice = second.priceUsdMonthly ?? Number.POSITIVE_INFINITY;
      if (firstPrice !== secondPrice) return firstPrice - secondPrice;
      return collator.compare(first.title, second.title);
    })
    .slice(0, maxRentalListingsPerBuilding);
};

const maxVisibleAirbnbListings = 5;
const truncateListingTitle = (title: string, maxLength = 72) => {
  const cleaned = title.replace(/\s+/g, " ").trim();
  if (cleaned.length <= maxLength) return cleaned;
  return `${cleaned.slice(0, maxLength - 1).trimEnd()}…`;
};
const priceSortedBuildings = [...buildings].sort((first, second) =>
  first.longTermRentUsd.amount - second.longTermRentUsd.amount ||
  collator.compare(first.name, second.name)
);
const isBuiltSince2016 = (built: string) => {
  const years = [...built.matchAll(/\b(?:19|20)\d{2}\b/g)].map((match) =>
    Number(match[0])
  );
  if (years.length === 0) return false;

  return Math.max(...years) >= 2016;
};
/** Sort key for construction year: mid-decade for "1980s", midpoint for ranges, null if unknown. */
const parseConstructionSortYear = (built: string): number | null => {
  const years = [...built.matchAll(/\b(?:19|20)\d{2}\b/g)].map((match) =>
    Number(match[0]),
  );
  if (years.length > 0) {
    const minYear = Math.min(...years);
    const maxYear = Math.max(...years);
    return Math.round((minYear + maxYear) / 2);
  }
  const decadeMatch = built.match(/\b((?:19|20)\d)0s\b/i);
  if (decadeMatch) {
    return Number(`${decadeMatch[1]}0`) + 5;
  }
  return null;
};
const getLowestListingPriceUsd = (
  listings: Array<{ priceUsdMonthly?: number | null }>,
) => {
  let lowest: number | null = null;
  for (const listing of listings) {
    const price = listing.priceUsdMonthly;
    if (price == null || !Number.isFinite(price)) continue;
    if (lowest == null || price < lowest) lowest = price;
  }
  return lowest;
};
const buildingsWithSort = priceSortedBuildings.map((building: Building, index) => {
  const airbnbListings = getAirbnbListings(building);
  const rentalListings = getRentalListings(building);
  return {
    ...building,
    airbnbListings,
    rentalListings,
    has20PlusFloors:
      building.floorsAboveGround !== null && building.floorsAboveGround >= 20,
    isBuiltSince2016: isBuiltSince2016(building.built),
    constructionSortYear: parseConstructionSortYear(building.built),
    hasPilates: buildingsWithPilates.has(building.id),
    hasCinema: buildingsWithCinema.has(building.id),
    filterNeighborhood: getNeighborhoodGroup(building.zone),
    pricePerTwoBedroomSquareMeter: building.longTermRentUsd.amount / building.approxTwoBedroomAreaSqm.amount,
    lowestAirbnbPriceUsd: getLowestListingPriceUsd(airbnbListings),
    lowestRentalPriceUsd: getLowestListingPriceUsd(rentalListings),
    listPosition: index + 1,
  };
});
const formatRent = (amount: number) => `$${amount.toLocaleString("en-US")}`;
const formatArea = (amount: number) => `~${amount.toLocaleString("en-US")} m²`;
const mapApiKey =
  import.meta.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
  process.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
  "";
const apartmentMapData = buildings.map((building) => {
  const airbnbListings = getAirbnbListings(building);
  const rentalListings = getRentalListings(building);
  return {
    id: building.id,
    name: building.name,
    zone: building.zone,
    neighborhood: getNeighborhoodGroup(building.zone),
    address: building.address,
    floorsAboveGround: building.floorsAboveGround,
    rentAmount: building.longTermRentUsd.amount,
    approxTwoBedroomAreaSqm: building.approxTwoBedroomAreaSqm.amount,
    airbnbConfirmed: airbnbListings.length > 0,
    has20PlusFloors:
      building.floorsAboveGround !== null && building.floorsAboveGround >= 20,
    isBuiltSince2016: isBuiltSince2016(building.built),
    hasPilates: buildingsWithPilates.has(building.id),
    hasCinema: buildingsWithCinema.has(building.id),
    airbnbListings,
    rentalListings,
    mapUrl: building.googleMapsUrl,
    position: building.location,
  };
});
const mapsIcon = `<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="#1a73e8" d="M12 2.2c3.9 0 7.1 3.1 7.1 7 0 5.1-7.1 12.6-7.1 12.6S4.9 14.3 4.9 9.2c0-3.9 3.2-7 7.1-7Z"/><path fill="#34a853" d="M7.2 14.1 12 21.8l4.8-7.7-4.8-2.8-4.8 2.8Z"/><path fill="#fbbc04" d="M4.9 9.2c0 1.8.9 3.5 2.3 4.9l4.8-2.8V2.2c-3.9 0-7.1 3.1-7.1 7Z"/><path fill="#ea4335" d="M19.1 9.2c0 1.8-.9 3.5-2.3 4.9L12 11.3V2.2c3.9 0 7.1 3.1 7.1 7Z"/><circle cx="12" cy="9.3" r="2.45" fill="#fff"/></svg>`;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  numberOfItems: buildings.length,
  itemListElement: priceSortedBuildings.map((building, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "ApartmentComplex",
      name: building.name,
      address: building.fullAddress,
      sameAs: [
        building.googleMapsUrl,
        ...(building.officialWebsiteUrl ? [building.officialWebsiteUrl] : []),
        ...getAirbnbListings(building).map((listing) => listing.url),
      ],
      geo: {
        "@type": "GeoCoordinates",
        latitude: building.location.lat,
        longitude: building.location.lng,
      },
    },
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="subject" content="Buenos Aires high-rise apartment buildings" />
    <meta name="application-name" content={pageTitle} />
    <meta
      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="googlebot"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="keywords"
      content="Buenos Aires apartment buildings, high-rise apartment buildings Buenos Aires, luxury apartments Buenos Aires, Buenos Aires Airbnb buildings"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta
      name="theme-color"
      content={themeColorLight}
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content={themeColorDark}
      media="(prefers-color-scheme: dark)"
    />
    <meta name="msapplication-TileColor" content={themeColorDark} />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color={themeColorDark} />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Nikita Sokolsky" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <main class="page">
      <header class="page-header">
        <a class="home-link" href="/">Nikita Sokolsky</a>
        <div class="headline">
          <p class="eyebrow">Buenos Aires apartment guide</p>
          <h1>{pageTitle}</h1>
          <p class="intro">
            A list of Buenos Aires apartment buildings with active rental ads, exact Airbnb matches and map links. Buildings are included when they either have a gym, pool and heated floors (losa radiante), or when they have 29+ floors with a live listing found.
          </p>
        </div>
      </header>

      <section class="toolbar" aria-label="Apartment controls">
        <div class="toolbar-row toolbar-filters">
          <fieldset class="filter-chip-group">
            <legend>Inventory</legend>
            <div class="chip-row">
              <label for="airbnb-only">
                <input id="airbnb-only" type="checkbox" autocomplete="off" />
                <span>Airbnb</span>
              </label>
              <label for="twenty-plus-floors-only">
                <input id="twenty-plus-floors-only" type="checkbox" autocomplete="off" />
                <span>20+ floors</span>
              </label>
              <label for="built-since-2016-only">
                <input id="built-since-2016-only" type="checkbox" autocomplete="off" />
                <span>Since 2016</span>
              </label>
            </div>
          </fieldset>
          <fieldset class="filter-chip-group">
            <legend>Amenities</legend>
            <div class="chip-row">
              <label for="pilates-only">
                <input id="pilates-only" type="checkbox" autocomplete="off" />
                <span>Pilates</span>
              </label>
              <label for="cinema-only">
                <input id="cinema-only" type="checkbox" autocomplete="off" />
                <span>Has cinema</span>
              </label>
            </div>
          </fieldset>
        </div>
        <div class="toolbar-row toolbar-controls">
          <label class="filter-dropdown" for="neighborhood-filter">
            <span>Neighborhood</span>
            <select id="neighborhood-filter" name="neighborhood" autocomplete="off">
              <option value="" data-label="All">All ({buildings.length})</option>
              {neighborhoodOptions.map((option) => (
                <option value={option.name} data-label={option.name}>{option.name} ({option.count})</option>
              ))}
            </select>
          </label>
          <label class="filter-dropdown sort-dropdown" for="building-sort">
            <span>Sort by</span>
            <select id="building-sort" name="sort" autocomplete="off">
              <option value="price-asc">Price, asc</option>
              <option value="price-desc">Price, desc</option>
              <option value="listed-rental-price-asc">Listed rental price, asc</option>
              <option value="listed-rental-price-desc">Listed rental price, desc</option>
              <option value="listed-airbnb-price-asc">Listed Airbnb price, asc</option>
              <option value="listed-airbnb-price-desc">Listed Airbnb price, desc</option>
              <option value="area-desc">Area of a 2BR</option>
              <option value="price-per-sqm-asc">$$$ per square meter</option>
              <option value="airbnb-count-desc">Number of Airbnbs</option>
              <option value="rental-count-desc">Number of long-term rentals</option>
              <option value="construction-year-asc">Construction year</option>
            </select>
          </label>
          <fieldset class="area-unit-toggle" aria-label="Area unit">
            <legend>Area unit</legend>
            <div class="unit-row">
              <label>
                <input type="radio" name="area-unit" value="sqm" autocomplete="off" checked />
                <span>m²</span>
              </label>
              <label>
                <input type="radio" name="area-unit" value="sqft" autocomplete="off" />
                <span>ft²</span>
              </label>
            </div>
          </fieldset>
        </div>
      </section>

      <section class="building-list" aria-label="Buenos Aires high-rise apartment buildings">
        {buildingsWithSort.map((building) => (
          <article
            class={`building-card ${building.airbnbListings.length > 0 ? "is-airbnb" : ""}`}
            data-building-id={building.id}
            data-airbnb={building.airbnbListings.length > 0}
            data-twenty-plus-floors={building.has20PlusFloors}
            data-built-since-2016={building.isBuiltSince2016}
            data-has-pilates={building.hasPilates}
            data-has-cinema={building.hasCinema}
            data-neighborhood={building.filterNeighborhood}
            data-rent-amount={building.longTermRentUsd.amount}
            data-two-bedroom-area={building.approxTwoBedroomAreaSqm.amount}
            data-price-per-sqm={building.pricePerTwoBedroomSquareMeter}
            data-lowest-rental-price={building.lowestRentalPriceUsd ?? ""}
            data-lowest-airbnb-price={building.lowestAirbnbPriceUsd ?? ""}
            data-airbnb-count={building.airbnbListings.length}
            data-rental-count={building.rentalListings.length}
            data-construction-year={building.constructionSortYear ?? ""}
          >
            <div class="building-main">
              <div class="building-title-row">
                <p class="building-position">#{building.listPosition}</p>
                <h2>
                  {building.officialWebsiteUrl ? (
                    <a
                      class="official-building-link"
                      href={building.officialWebsiteUrl}
                      target="_blank"
                      rel="noreferrer noopener"
                      aria-label={`Open official website for ${building.name}`}
                    >
                      {building.name}
                    </a>
                  ) : (
                    building.name
                  )}
                </h2>
              </div>
              <p class="building-description">{building.description}</p>
              <div class="building-tags" aria-label={`${building.name} facts`}>
                <span>{building.zone}</span>
                <span>{building.built}</span>
                {building.floorsAboveGround !== null ? (
                  <span>{building.floorsAboveGround} floors</span>
                ) : null}
              </div>
            </div>
            <div class="building-side">
              <div class="building-metrics" aria-label={`${building.name} price and area estimates`}>
                <p
                  class={`rent-estimate confidence-${building.longTermRentUsd.confidence.replace(/[^a-z]/g, "-")}`}
                  title={building.longTermRentUsd.summary}
                >
                  <span>{formatRent(building.longTermRentUsd.amount)}/mo</span>
                  <span>Est. $/month for 1BR</span>
                </p>
                <p
                  class={`area-estimate confidence-${building.approxTwoBedroomAreaSqm.confidence.replace(/[^a-z]/g, "-")}`}
                  title={building.approxTwoBedroomAreaSqm.summary}
                >
                  <span class="area-value" data-area-sqm={building.approxTwoBedroomAreaSqm.amount}>{formatArea(building.approxTwoBedroomAreaSqm.amount)}</span>
                  <span>approx. 2BR area</span>
                </p>
              </div>
              <p class="address">{building.address}</p>
              <div class="building-links">
                <a
                  class="map-link"
                  href={building.googleMapsUrl}
                  target="_blank"
                  rel="noreferrer noopener"
                  aria-label={`Open map for ${building.name}`}
                >
                  <span class="maps-icon" set:html={mapsIcon} />
                  Map
                </a>
              </div>
            </div>
            {building.airbnbListings.length > 0 || building.rentalListings.length > 0 ? (
              <div class="building-listings">
                {building.airbnbListings.length > 0 ? (
                  <section
                    class="listing-group listing-group-airbnb"
                    aria-label={`Airbnb stays in ${building.name}`}
                  >
                    <header class="listing-group-header">
                      <h3>Airbnb stays</h3>
                      <p class="listing-count">
                        {building.airbnbListings.length === 1
                          ? "1 listing"
                          : `${building.airbnbListings.length} listings`}
                      </p>
                    </header>
                    <ul class="listing-list">
                      {building.airbnbListings.slice(0, maxVisibleAirbnbListings).map((listing) => (
                        <li>
                          <a
                            class={`listing-link listing-link-airbnb${listing.priceUnknown ? " is-unpriced" : ""}`}
                            href={listing.url}
                            target="_blank"
                            rel="noreferrer noopener"
                            title={[
                              listing.sizeLabel,
                              listing.priceLabel
                                ? `${listing.priceLabel}/mo${
                                    listing.priceSource === "weekly_extrapolated"
                                      ? " (from weekly)"
                                      : ""
                                  }`
                                : "Price unknown",
                              listing.title,
                            ]
                              .filter(Boolean)
                              .join(" · ")}
                          >
                            <span class="listing-meta">
                              {listing.sizeLabel ? (
                                <span class="listing-source listing-size">{listing.sizeLabel}</span>
                              ) : (
                                <span class="listing-source">Airbnb</span>
                              )}
                              {listing.priceLabel ? (
                                <span class="listing-price">{listing.priceLabel}</span>
                              ) : (
                                <span class="listing-price listing-price-unknown">Price unknown</span>
                              )}
                            </span>
                            <span class="listing-title">{truncateListingTitle(listing.title)}</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                    {building.airbnbListings.length > maxVisibleAirbnbListings ? (
                      <details class="listing-more">
                        <summary>
                          Show {building.airbnbListings.length - maxVisibleAirbnbListings} more Airbnb
                          {building.airbnbListings.length - maxVisibleAirbnbListings === 1
                            ? " listing"
                            : " listings"}
                        </summary>
                        <ul class="listing-list">
                          {building.airbnbListings.slice(maxVisibleAirbnbListings).map((listing) => (
                            <li>
                              <a
                                class={`listing-link listing-link-airbnb${listing.priceUnknown ? " is-unpriced" : ""}`}
                                href={listing.url}
                                target="_blank"
                                rel="noreferrer noopener"
                                title={[
                                  listing.sizeLabel,
                                  listing.priceLabel
                                    ? `${listing.priceLabel}/mo${
                                        listing.priceSource === "weekly_extrapolated"
                                          ? " (from weekly)"
                                          : ""
                                      }`
                                    : "Price unknown",
                                  listing.title,
                                ]
                                  .filter(Boolean)
                                  .join(" · ")}
                              >
                                <span class="listing-meta">
                                  {listing.sizeLabel ? (
                                    <span class="listing-source listing-size">{listing.sizeLabel}</span>
                                  ) : (
                                    <span class="listing-source">Airbnb</span>
                                  )}
                                  {listing.priceLabel ? (
                                    <span class="listing-price">{listing.priceLabel}</span>
                                  ) : (
                                    <span class="listing-price listing-price-unknown">Price unknown</span>
                                  )}
                                </span>
                                <span class="listing-title">{truncateListingTitle(listing.title)}</span>
                              </a>
                            </li>
                          ))}
                        </ul>
                      </details>
                    ) : null}
                  </section>
                ) : null}
                {building.rentalListings.length > 0 ? (
                  <section
                    class="listing-group listing-group-rentals"
                    aria-label={`Long-term rentals in ${building.name}`}
                  >
                    <header class="listing-group-header">
                      <h3>Long-term rentals</h3>
                      <p class="listing-count">
                        {building.rentalListings.length === 1
                          ? "1 ad"
                          : `${building.rentalListings.length} ads`}
                      </p>
                    </header>
                    <ul class="listing-list">
                      {building.rentalListings.map((listing) => (
                        <li>
                          <a
                            class={`listing-link listing-link-rental${listing.priceLabel ? "" : " is-unpriced"}`}
                            href={listing.url}
                            target="_blank"
                            rel="noreferrer noopener"
                            title={[
                              listing.sizeLabel,
                              listing.priceLabel
                                ? `${listing.priceLabel}/mo${listing.expensesIncluded === false ? " incl. expenses" : ""}`
                                : null,
                              `${listing.source}: ${listing.title}`,
                            ]
                              .filter(Boolean)
                              .join(" · ")}
                          >
                            <span class="listing-meta">
                              {listing.sizeLabel ? (
                                <span class="listing-source listing-size">{listing.sizeLabel}</span>
                              ) : (
                                <span class="listing-source">{listing.source}</span>
                              )}
                              {listing.priceLabel ? (
                                <span class="listing-price">{listing.priceLabel}</span>
                              ) : null}
                            </span>
                            <span class="listing-title">{truncateListingTitle(listing.title)}</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </section>
                ) : null}
              </div>
            ) : null}
          </article>
        ))}
      </section>

      <section class="map-section" aria-labelledby="apartment-map-heading">
        <div class="map-copy">
          <p class="eyebrow">Map</p>
          <h2 id="apartment-map-heading">Where the buildings are</h2>
          <p id="apartment-map-status" class="map-status">
            Showing all {buildings.length} buildings. Gold pins have Airbnb links.
          </p>
        </div>
        {mapApiKey ? (
          <div
            id="apartment-map"
            class="apartment-map"
            aria-label="Map with pins for Buenos Aires high-rise apartment buildings"
          ></div>
        ) : (
          <p class="map-unavailable">
            Map unavailable because the public map key is not configured.
          </p>
        )}
      </section>
    </main>
  </body>
</html>

<script is:inline define:vars={{ mapApiKey, apartmentMapData }}>
  if (mapApiKey) {
    ((g) => {
      let h;
      let a;
      let k;
      const p = "The map library";
      const c = "google";
      const l = "importLibrary";
      const q = "__ib__";
      const m = document;
      let b = window;
      b = b[c] || (b[c] = {});
      const d = b.maps || (b.maps = {});
      const r = new Set();
      const e = new URLSearchParams();
      const u = () =>
        h ||
        (h = new Promise(async (resolve, reject) => {
          await (a = m.createElement("script"));
          e.set("libraries", [...r] + "");
          for (k in g) {
            e.set(k.replace(/[A-Z]/g, (t) => `_${t[0].toLowerCase()}`), g[k]);
          }
          e.set("callback", `${c}.maps.${q}`);
          a.src = `https://maps.${c}apis.com/maps/api/js?${e}`;
          d[q] = resolve;
          a.onerror = () => (h = reject(Error(`${p} could not load.`)));
          a.nonce = m.querySelector("script[nonce]")?.nonce || "";
          m.head.append(a);
        }));
      d[l] ? console.warn(`${p} only loads once. Ignoring:`, g) : (d[l] = (f, ...n) => r.add(f) && u().then(() => d[l](f, ...n)));
    })({
      key: mapApiKey,
      v: "weekly",
    });
  }

  const airbnbOnlyToggle = document.querySelector("#airbnb-only");
  const twentyPlusFloorsOnlyToggle = document.querySelector("#twenty-plus-floors-only");
  const builtSince2016OnlyToggle = document.querySelector("#built-since-2016-only");
  const pilatesOnlyToggle = document.querySelector("#pilates-only");
  const cinemaOnlyToggle = document.querySelector("#cinema-only");
  const neighborhoodFilter = document.querySelector("#neighborhood-filter");
  const buildingSort = document.querySelector("#building-sort");
  const buildingList = document.querySelector(".building-list");
  const areaUnitInputs = [...document.querySelectorAll('input[name="area-unit"]')];
  const areaValueLabels = [...document.querySelectorAll(".area-value")];
  const apartmentRows = [...document.querySelectorAll(".building-card")];
  const buildingById = new Map(apartmentMapData.map((building) => [building.id, building]));
  const mapElement = document.querySelector("#apartment-map");
  const mapStatus = document.querySelector("#apartment-map-status");
  const buenosAiresCenter = { lat: -34.595, lng: -58.435 };
  const markerRecords = [];
  let apartmentMap;
  let infoWindow;

  const escapeHtml = (value) =>
    String(value).replace(/[&<>"']/g, (character) => ({
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#39;",
    })[character]);

  const getCheckboxFilters = () => ({
    airbnbOnly: Boolean(airbnbOnlyToggle?.checked),
    twentyPlusFloorsOnly: Boolean(twentyPlusFloorsOnlyToggle?.checked),
    builtSince2016Only: Boolean(builtSince2016OnlyToggle?.checked),
    pilatesOnly: Boolean(pilatesOnlyToggle?.checked),
    cinemaOnly: Boolean(cinemaOnlyToggle?.checked),
  });

  const matchesCheckboxFilters = (building, filters) =>
    (!filters.airbnbOnly || building.airbnbConfirmed) &&
    (!filters.twentyPlusFloorsOnly || building.has20PlusFloors) &&
    (!filters.builtSince2016Only || building.isBuiltSince2016) &&
    (!filters.pilatesOnly || building.hasPilates) &&
    (!filters.cinemaOnly || building.hasCinema);

  const formatAreaLabel = (areaSqm, unit) => {
    const amount = unit === "sqft" ? Math.round(areaSqm * 10.7639) : Math.round(areaSqm);
    const suffix = unit === "sqft" ? "ft²" : "m²";
    return `~${amount.toLocaleString("en-US")} ${suffix}`;
  };

  const selectedAreaUnit = () =>
    areaUnitInputs.find((input) => input.checked)?.value ?? "sqm";

  const updateAreaUnits = () => {
    const unit = selectedAreaUnit();
    for (const label of areaValueLabels) {
      const areaSqm = Number(label.dataset.areaSqm);
      if (Number.isFinite(areaSqm)) label.textContent = formatAreaLabel(areaSqm, unit);
    }
  };

  const numericDatasetValue = (row, key) => {
    const value = Number(row.dataset[key]);
    return Number.isFinite(value) ? value : 0;
  };

  const optionalNumericDatasetValue = (row, key) => {
    const raw = row.dataset[key];
    if (raw == null || raw === "") return null;
    const value = Number(raw);
    return Number.isFinite(value) ? value : null;
  };

  const compareRowsByName = (firstRow, secondRow) => {
    const firstBuilding = buildingById.get(firstRow.dataset.buildingId);
    const secondBuilding = buildingById.get(secondRow.dataset.buildingId);
    return String(firstBuilding?.name ?? "").localeCompare(String(secondBuilding?.name ?? ""), "en", {
      numeric: true,
      sensitivity: "base",
    });
  };

  const compareOptionalPrices = (firstPrice, secondPrice, direction) => {
    const firstMissing = firstPrice == null;
    const secondMissing = secondPrice == null;
    if (firstMissing && secondMissing) return 0;
    if (firstMissing) return 1;
    if (secondMissing) return -1;
    return direction === "desc" ? secondPrice - firstPrice : firstPrice - secondPrice;
  };

  const compareConstructionYears = (firstYear, secondYear) => {
    const firstMissing = firstYear == null;
    const secondMissing = secondYear == null;
    if (firstMissing && secondMissing) return 0;
    if (firstMissing) return -1;
    if (secondMissing) return 1;
    return firstYear - secondYear;
  };

  const compareRowsBySort = (firstRow, secondRow) => {
    const sortValue = buildingSort?.value ?? "price-asc";
    const firstRent = numericDatasetValue(firstRow, "rentAmount");
    const secondRent = numericDatasetValue(secondRow, "rentAmount");
    const firstArea = numericDatasetValue(firstRow, "twoBedroomArea");
    const secondArea = numericDatasetValue(secondRow, "twoBedroomArea");
    const firstPricePerSqm = numericDatasetValue(firstRow, "pricePerSqm");
    const secondPricePerSqm = numericDatasetValue(secondRow, "pricePerSqm");
    const firstAirbnbCount = numericDatasetValue(firstRow, "airbnbCount");
    const secondAirbnbCount = numericDatasetValue(secondRow, "airbnbCount");
    const firstRentalCount = numericDatasetValue(firstRow, "rentalCount");
    const secondRentalCount = numericDatasetValue(secondRow, "rentalCount");
    const firstListedRentalPrice = optionalNumericDatasetValue(firstRow, "lowestRentalPrice");
    const secondListedRentalPrice = optionalNumericDatasetValue(secondRow, "lowestRentalPrice");
    const firstListedAirbnbPrice = optionalNumericDatasetValue(firstRow, "lowestAirbnbPrice");
    const secondListedAirbnbPrice = optionalNumericDatasetValue(secondRow, "lowestAirbnbPrice");
    const firstConstructionYear = optionalNumericDatasetValue(firstRow, "constructionYear");
    const secondConstructionYear = optionalNumericDatasetValue(secondRow, "constructionYear");

    const primarySort =
      sortValue === "price-desc"
        ? secondRent - firstRent
        : sortValue === "listed-rental-price-asc"
          ? compareOptionalPrices(firstListedRentalPrice, secondListedRentalPrice, "asc")
          : sortValue === "listed-rental-price-desc"
            ? compareOptionalPrices(firstListedRentalPrice, secondListedRentalPrice, "desc")
            : sortValue === "listed-airbnb-price-asc"
              ? compareOptionalPrices(firstListedAirbnbPrice, secondListedAirbnbPrice, "asc")
              : sortValue === "listed-airbnb-price-desc"
                ? compareOptionalPrices(firstListedAirbnbPrice, secondListedAirbnbPrice, "desc")
                : sortValue === "area-desc"
                  ? secondArea - firstArea
                  : sortValue === "price-per-sqm-asc"
                    ? firstPricePerSqm - secondPricePerSqm
                    : sortValue === "airbnb-count-desc"
                      ? secondAirbnbCount - firstAirbnbCount
                      : sortValue === "rental-count-desc"
                        ? secondRentalCount - firstRentalCount
                        : sortValue === "construction-year-asc"
                          ? compareConstructionYears(firstConstructionYear, secondConstructionYear)
                          : firstRent - secondRent;

    return primarySort || compareRowsByName(firstRow, secondRow);
  };

  const sortRows = () => {
    const sortedRows = [...apartmentRows].sort(compareRowsBySort);
    if (buildingList) {
      for (const row of sortedRows) {
        buildingList.append(row);
      }
    }
    return sortedRows;
  };

  const updateVisiblePositions = (sortedRows) => {
    let position = 0;
    for (const row of sortedRows) {
      if (row.hidden) continue;
      position += 1;
      const positionLabel = row.querySelector(".building-position");
      if (positionLabel) positionLabel.textContent = `#${position}`;
    }
  };

  const updateNeighborhoodCounts = () => {
    if (!neighborhoodFilter) return;

    const filters = getCheckboxFilters();
    const counts = new Map();
    let total = 0;

    for (const building of apartmentMapData) {
      if (!matchesCheckboxFilters(building, filters)) continue;
      total += 1;
      counts.set(building.neighborhood, (counts.get(building.neighborhood) ?? 0) + 1);
    }

    for (const option of neighborhoodFilter.options) {
      const label = option.dataset.label ?? option.textContent?.replace(/\s*\(\d+\)$/, "") ?? "";
      const count = option.value ? counts.get(option.value) ?? 0 : total;
      option.textContent = `${label} (${count})`;
    }
  };

  const visibleMapBuildings = () => {
    const filters = getCheckboxFilters();
    const selectedNeighborhood = neighborhoodFilter?.value ?? "";

    return apartmentMapData.filter((building) =>
      (!selectedNeighborhood || building.neighborhood === selectedNeighborhood) &&
      matchesCheckboxFilters(building, filters)
    );
  };

  const updateMapStatus = () => {
    if (!mapStatus) return;

    const visibleBuildings = visibleMapBuildings();
    const airbnbCount = visibleBuildings.filter((building) => building.airbnbConfirmed).length;
    const selectedNeighborhood = neighborhoodFilter?.value ?? "";
    const buildingLabel = visibleBuildings.length === 1 ? "building" : "buildings";
    const scope = selectedNeighborhood ? ` in ${selectedNeighborhood}` : "";
    mapStatus.textContent = `Showing ${visibleBuildings.length} ${buildingLabel}${scope}. ${airbnbCount} with Airbnb links.`;
  };

  const fitMapToMarkers = (visibleRecords) => {
    if (!apartmentMap || !window.google?.maps || visibleRecords.length === 0) return;

    if (visibleRecords.length === 1) {
      apartmentMap.setCenter(visibleRecords[0].building.position);
      apartmentMap.setZoom(15);
      return;
    }

    const bounds = new google.maps.LatLngBounds();
    for (const { building } of visibleRecords) {
      bounds.extend(building.position);
    }
    apartmentMap.fitBounds(bounds, 48);
  };

  const applyFilters = () => {
    const filters = getCheckboxFilters();
    const selectedNeighborhood = neighborhoodFilter?.value ?? "";
    updateNeighborhoodCounts();
    const sortedRows = sortRows();

    for (const row of sortedRows) {
      const building = buildingById.get(row.dataset.buildingId);
      row.hidden = !(
        building &&
        (!selectedNeighborhood || building.neighborhood === selectedNeighborhood) &&
        matchesCheckboxFilters(building, filters)
      );
    }

    updateVisiblePositions(sortedRows);
    updateMapStatus();
    if (!apartmentMap) return;

    const visibleRecords = [];
    for (const record of markerRecords) {
      const isVisible =
        (!selectedNeighborhood || record.building.neighborhood === selectedNeighborhood) &&
        matchesCheckboxFilters(record.building, filters);
      record.marker.setMap(isVisible ? apartmentMap : null);
      if (isVisible) visibleRecords.push(record);
    }

    fitMapToMarkers(visibleRecords);
  };

  const initApartmentMap = async () => {
    if (!mapElement || !mapApiKey || !window.google?.maps?.importLibrary) return;

    const { Map, InfoWindow } = await google.maps.importLibrary("maps");
    await google.maps.importLibrary("marker");

    apartmentMap = new Map(mapElement, {
      center: buenosAiresCenter,
      clickableIcons: false,
      fullscreenControl: true,
      mapTypeControl: false,
      streetViewControl: false,
      zoom: 12,
    });
    infoWindow = new InfoWindow();

    for (const building of apartmentMapData) {
      const marker = new google.maps.Marker({
        icon: {
          path: google.maps.SymbolPath.CIRCLE,
          scale: building.airbnbConfirmed ? 9 : 7,
          fillColor: building.airbnbConfirmed ? "#c98a17" : "#28402f",
          fillOpacity: 0.95,
          strokeColor: "#fffdf8",
          strokeWeight: 2,
        },
        map: apartmentMap,
        position: building.position,
        title: building.name,
      });

      marker.addListener("click", () => {
        const renderListingLinks = (listings, heading) => {
          if (!listings.length) return "";
          const items = listings.slice(0, 3).map((listing) => {
            const bits = [];
            if (listing.sizeLabel) bits.push(listing.sizeLabel);
            if (listing.priceLabel) bits.push(listing.priceLabel);
            const prefix = bits.length ? `${bits.join(" · ")} · ` : "";
            const label = `${prefix}${listing.title}`;
            const shortLabel = label.length > 56 ? `${label.slice(0, 55)}…` : label;
            return `<li><a href="${escapeHtml(listing.url)}" target="_blank" rel="noreferrer noopener">${escapeHtml(shortLabel)}</a></li>`;
          }).join("");
          const more =
            listings.length > 3
              ? `<li>${listings.length - 3} more in the list below</li>`
              : "";
          return `<div style="margin-top:0.45rem"><strong>${escapeHtml(heading)}</strong><ul style="margin:0.25rem 0 0;padding-left:1.1rem">${items}${more}</ul></div>`;
        };
        infoWindow.setContent(
          `<strong>${escapeHtml(building.name)}</strong><br>${escapeHtml(building.zone)} · ${escapeHtml(building.address)}<br><a href="${escapeHtml(building.mapUrl)}" target="_blank" rel="noreferrer noopener">Open map</a>${renderListingLinks(building.airbnbListings, "Airbnb stays")}${renderListingLinks(building.rentalListings, "Long-term rentals")}`,
        );
        infoWindow.open(apartmentMap, marker);
      });

      markerRecords.push({ building, marker });
    }

    applyFilters();
  };
  airbnbOnlyToggle?.addEventListener("change", applyFilters);
  twentyPlusFloorsOnlyToggle?.addEventListener("change", applyFilters);
  builtSince2016OnlyToggle?.addEventListener("change", applyFilters);
  pilatesOnlyToggle?.addEventListener("change", applyFilters);
  cinemaOnlyToggle?.addEventListener("change", applyFilters);
  neighborhoodFilter?.addEventListener("change", applyFilters);
  buildingSort?.addEventListener("change", applyFilters);
  for (const input of areaUnitInputs) {
    input.addEventListener("change", updateAreaUnits);
  }
  updateAreaUnits();
  applyFilters();
  window.addEventListener("pageshow", applyFilters);
  initApartmentMap().catch((error) => {
    console.error("Unable to initialize apartment map", error);
    if (mapStatus) mapStatus.textContent = "Map unavailable. Building list still works.";
  });
</script>

