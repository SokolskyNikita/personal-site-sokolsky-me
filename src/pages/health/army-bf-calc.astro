// Table B-2, AR 600-9: maximum allowable percent body fat by age group.
const bodyFatStandards = [
  { group: "17\u201320", male: 20, female: 30 },
  { group: "21\u201327", male: 22, female: 32 },
  { group: "28\u201339", male: 24, female: 34 },
  { group: "40 and over", male: 26, female: 36 },
];
