---
export const prerender = true;

const pageTitle = "Army Body Fat Calculator";
const pageDescription =
  "Estimate body fat with the current U.S. Army one-site tape equation or the older neck-based tape method, then compare the result with Army age standards, the weight-for-height table and the 2026 DoD waist-to-height ratio.";
const themeColorLight = "#fbfaf6";
const themeColorDark = "#171410";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  applicationCategory: "HealthApplication",
  operatingSystem: "Any",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  author: {
    "@type": "Person",
    name: "Nikita Sokolsky"
  }
};

// Table B-1, AR 600-9 (screening table weight), as republished in ALARACT 032/2025.
// [height in inches, minimum weight, M 17-20, M 21-27, M 28-39, M 40+, F 17-20, F 21-27, F 28-39, F 40+]
// null = no male screening weight listed for that height.
const screeningTable = [
  [58, 91, null, null, null, null, 119, 121, 122, 124],
  [59, 94, null, null, null, null, 124, 125, 126, 128],
  [60, 97, 132, 136, 139, 141, 128, 129, 131, 133],
  [61, 100, 136, 140, 144, 146, 132, 134, 135, 137],
  [62, 104, 141, 144, 148, 150, 136, 138, 140, 142],
  [63, 107, 145, 149, 153, 155, 141, 143, 144, 146],
  [64, 110, 150, 154, 158, 160, 145, 147, 149, 151],
  [65, 114, 155, 159, 163, 165, 150, 152, 154, 156],
  [66, 117, 160, 163, 168, 170, 155, 156, 158, 161],
  [67, 121, 165, 169, 174, 176, 159, 161, 163, 166],
  [68, 125, 170, 174, 179, 181, 164, 166, 168, 171],
  [69, 128, 175, 179, 184, 186, 169, 171, 173, 176],
  [70, 132, 180, 185, 189, 192, 174, 176, 178, 181],
  [71, 136, 185, 189, 194, 197, 179, 181, 183, 186],
  [72, 140, 190, 195, 200, 203, 184, 186, 188, 191],
  [73, 144, 195, 200, 205, 208, 189, 191, 194, 197],
  [74, 148, 201, 206, 211, 214, 194, 197, 199, 202],
  [75, 152, 206, 212, 217, 220, 200, 202, 204, 208],
  [76, 156, 212, 217, 223, 226, 205, 207, 210, 213],
  [77, 160, 218, 223, 229, 232, 210, 213, 215, 219],
  [78, 164, 223, 229, 235, 238, 216, 218, 221, 225],
  [79, 168, 229, 235, 241, 244, 221, 224, 227, 230],
  [80, 173, 234, 240, 247, 250, 227, 230, 233, 236],
