            </li>
            <li>
              <a href="https://armypubs.army.mil/epubs/DR_pubs/DR_a/ARN30802-AR_600-9-000-WEB-1.pdf" target="_blank" rel="noreferrer noopener">AR 600-9, The Army Body Composition Program</a>. Department of the Army. The governing regulation; Appendix B defines the standard methods for determining body fat.
            </li>
            <li>
              <a href="https://recruiting.army.mil/Portals/15/DA5500.pdf" target="_blank" rel="noreferrer noopener">DA Form 5500, Body Fat Content Worksheet (Male)</a>. The worksheet prints the male equation: % body fat = &minus;26.97 &minus; (0.12 &times; weight) + (1.99 &times; abdomen). The female equation appears on DA Form 5501 and in ALARACT 032/2025: % body fat = &minus;9.15 &minus; (0.015 &times; weight) + (1.27 &times; abdomen).
            </li>
            <li>
              <a href="https://www.usarcent.army.mil/Portals/1/Documents/regs/Army%20Directive%202025-17%20(Army%20Body%20Fat%20Standard%20for%20Army%20Fitness%20Test%20Score).pdf" target="_blank" rel="noreferrer noopener">Army Directive 2025-17: Army Body Fat Standard for Army Fitness Test Score</a>. September 2025. The AFT 465-point / 80-per-event compliance rule and validity windows; rescinds AD 2023-08 effective May 31, 2026.
            </li>
            <li>
              <a href="https://www.army.mil/article/288357/army_exempts_soldiers_who_score_465_on_the_aft_from_body_fat_standards" target="_blank" rel="noreferrer noopener">Army exempts Soldiers who score 465+ on the AFT from body fat standards</a>. U.S. Army, September 2025.
            </li>
            <li>
              <a href="https://www.armyresilience.army.mil/ABCP/BodyFatCalculator.html" target="_blank" rel="noreferrer noopener">ABCP Body Fat Calculator</a>. Army Resilience Directorate. The Army's online calculator for the 2023 one-site method, used to cross-check this page's results.
            </li>
            <li>
              <a href="https://media.defense.gov/2026/Jan/12/2003855613/-1/-1/1/ADDITIONAL-GUIDANCE-ON-MILITARY-FITNESS-STANDARDS.PDF" target="_blank" rel="noreferrer noopener">Additional Guidance on Military Fitness Standards</a>. Department of War memo, December 18, 2025 (effective January 1, 2026). Source for the waist-to-height ratio limit of &lt;0.55 and the 18&ndash;26% / 26&ndash;36% body fat bands.
            </li>
            <li>
              <a href="https://www.ausa.org/news/pentagon-unveils-new-body-composition-rules" target="_blank" rel="noreferrer noopener">Pentagon Unveils New Body Composition Rules</a>. Association of the United States Army, January 29, 2026. Reporting on the WHtR transition and the Army's pending policy.
            </li>
            <li>
              <a href="https://pmc.ncbi.nlm.nih.gov/articles/PMC11999870/" target="_blank" rel="noreferrer noopener">McClung HL, et al. Implementing a modern circumference-based body fat equation with a physical fitness threshold is associated with lower musculoskeletal injury risk</a>. 2025. Peer-reviewed background on the USARIEM one-site equation and its validation against DXA.
            </li>
          </ol>
          <p class="disclaimer">
            This page is an independent tool. It is not affiliated with or endorsed by the U.S. Army or the Department of War. It reproduces published formulas for informational purposes only; trained unit personnel make AR&nbsp;600-9 determinations. Nothing here is medical advice.
          </p>
        </section>
      </article>
    </main>

    <script is:inline>
      // Table B-1 screening weights, mirrored from the frontmatter for client-side use.
      const SCREENING = [
        [58, 91, null, null, null, null, 119, 121, 122, 124],
        [59, 94, null, null, null, null, 124, 125, 126, 128],
        [60, 97, 132, 136, 139, 141, 128, 129, 131, 133],
        [61, 100, 136, 140, 144, 146, 132, 134, 135, 137],
        [62, 104, 141, 144, 148, 150, 136, 138, 140, 142],
        [63, 107, 145, 149, 153, 155, 141, 143, 144, 146],
        [64, 110, 150, 154, 158, 160, 145, 147, 149, 151],
        [65, 114, 155, 159, 163, 165, 150, 152, 154, 156],
        [66, 117, 160, 163, 168, 170, 155, 156, 158, 161],
        [67, 121, 165, 169, 174, 176, 159, 161, 163, 166],
        [68, 125, 170, 174, 179, 181, 164, 166, 168, 171],
        [69, 128, 175, 179, 184, 186, 169, 171, 173, 176],
        [70, 132, 180, 185, 189, 192, 174, 176, 178, 181],
        [71, 136, 185, 189, 194, 197, 179, 181, 183, 186],
        [72, 140, 190, 195, 200, 203, 184, 186, 188, 191],
        [73, 144, 195, 200, 205, 208, 189, 191, 194, 197],
        [74, 148, 201, 206, 211, 214, 194, 197, 199, 202],
        [75, 152, 206, 212, 217, 220, 200, 202, 204, 208],
        [76, 156, 212, 217, 223, 226, 205, 207, 210, 213],
        [77, 160, 218, 223, 229, 232, 210, 213, 215, 219],
        [78, 164, 223, 229, 235, 238, 216, 218, 221, 225],
        [79, 168, 229, 235, 241, 244, 221, 224, 227, 230],
        [80, 173, 234, 240, 247, 250, 227, 230, 233, 236],
      ];

      const MAX_BF = {
        male: [20, 22, 24, 26],
        female: [30, 32, 34, 36],
      };

      function ageGroupIndex(age) {
        if (age <= 20) return 0;
        if (age <= 27) return 1;
        if (age <= 39) return 2;
        return 3;
      }

      const AGE_GROUP_LABELS = ["17\u201320", "21\u201327", "28\u201339", "40 and over"];

      function screeningWeight(sex, heightInches, age) {
        // Table lookup uses height rounded to the nearest whole inch (>= .5 rounds up).
        const h = Math.round(heightInches);
        const idx = ageGroupIndex(age);
        const col = (sex === "male" ? 2 : 6) + idx;
        if (h > 80) {
          const base = SCREENING[SCREENING.length - 1][col];
          if (base == null) return null;
          return base + (h - 80) * (sex === "male" ? 6 : 5);
        }
        const row = SCREENING.find((r) => r[0] === h);
        if (!row) return null;
        return row[col];
      }

      function computeCurrentBodyFat(sex, weightLb, abdomenIn) {
        if (sex === "male") {
          return -26.97 - 0.12 * weightLb + 1.99 * abdomenIn;
        }
        return -9.15 - 0.015 * weightLb + 1.27 * abdomenIn;
      }

      function computeLegacyBodyFat(sex, heightIn, waistIn, neckIn, hipIn) {
        if (sex === "male") {
          const circumferenceValue = waistIn - neckIn;
          if (circumferenceValue <= 0) return null;
          return 86.01 * Math.log10(circumferenceValue) - 70.041 * Math.log10(heightIn) + 36.76;
        }
        const circumferenceValue = waistIn + hipIn - neckIn;
        if (circumferenceValue <= 0) return null;
        return 163.205 * Math.log10(circumferenceValue) - 97.684 * Math.log10(heightIn) - 78.387;
      }

      const CM_PER_IN = 2.54;
      const LB_PER_KG = 2.2046226218;
      let currentUnits = "imperial";

      const form = document.getElementById("calc-form");
      const bfValueEl = document.getElementById("bf-value");
      const bfVerdictEl = document.getElementById("bf-verdict");
      const bfMaxEl = document.getElementById("bf-max");
      const bfExactEl = document.getElementById("bf-exact");
      const screenEl = document.getElementById("screen-result");
      const whtrEl = document.getElementById("whtr-result");
      const heightFtEl = document.getElementById("height-ft");
      const heightInEl = document.getElementById("height-in");
      const heightCmEl = document.getElementById("height-cm");
      const weightEl = document.getElementById("weight");
      const waistEl = document.getElementById("waist");
      const neckEl = document.getElementById("neck");
      const hipEl = document.getElementById("hip");
      const weightUnitEl = document.querySelector("[data-weight-unit]");
      const waistLabelEl = document.querySelector("[data-waist-label]");
      const waistUnitEl = document.querySelector("[data-waist-unit]");
      const neckUnitEl = document.querySelector("[data-neck-unit]");
      const hipUnitEl = document.querySelector("[data-hip-unit]");

      function numberFrom(el) {
        const value = parseFloat(el.value);
        return Number.isFinite(value) ? value : null;
      }

      function formatNumber(value, decimals = 1) {
        return value.toFixed(decimals).replace(/\.0$/, "");
      }

      function setNumber(el, value, decimals = 1) {
        el.value = formatNumber(value, decimals);
      }

      function totalImperialHeightInches() {
        const feet = numberFrom(heightFtEl);
        const inches = numberFrom(heightInEl);
        if (feet == null && inches == null) return null;
        return (feet ?? 0) * 12 + (inches ?? 0);
      }

      function setImperialHeight(totalInches) {
        let feet = Math.floor(totalInches / 12);
        let inches = Math.round((totalInches - feet * 12) * 2) / 2;
        if (inches >= 12) {
          feet += 1;
          inches -= 12;
        }
        heightFtEl.value = String(feet);
        setNumber(heightInEl, inches, inches % 1 === 0 ? 0 : 1);
      }

      function roundDownHalf(value) {
        return Math.floor(value * 2) / 2;
      }

      function roundUpHalf(value) {
        return Math.ceil(value * 2) / 2;
      }

      function syncMethodDisplay() {
        const method = form.querySelector('input[name="method"]:checked').value;
        const sex = form.querySelector('input[name="sex"]:checked').value;
        form.dataset.method = method;
        form.dataset.sex = sex;

        if (method === "legacy" && sex === "female") {
          waistLabelEl.textContent = "Waist circumference";
          waistUnitEl.textContent = currentUnits === "metric" ? "cm, at the natural waist" : "in, at the natural waist";
        } else {
          waistLabelEl.textContent = "Abdominal circumference";
          waistUnitEl.textContent = currentUnits === "metric" ? "cm, at the navel" : "in, at the navel";
        }
      }

      function syncUnitDisplay(units) {
        form.dataset.units = units;
        if (units === "metric") {
          weightUnitEl.textContent = "kg";
          neckUnitEl.textContent = "cm";
          hipUnitEl.textContent = "cm";
          weightEl.min = "30";
          weightEl.max = "270";
          weightEl.step = "0.1";
          waistEl.min = "45";
          waistEl.max = "180";
          waistEl.step = "0.1";
          neckEl.min = "25";
          neckEl.max = "80";
          neckEl.step = "0.1";
          hipEl.min = "50";
          hipEl.max = "205";
          hipEl.step = "0.1";
          syncMethodDisplay();
          return;
        }
        weightUnitEl.textContent = "lb";
        neckUnitEl.textContent = "in";
        hipUnitEl.textContent = "in";
        weightEl.min = "70";
        weightEl.max = "500";
        weightEl.step = "0.5";
        waistEl.min = "18";
        waistEl.max = "70";
        waistEl.step = "0.5";
        neckEl.min = "10";
        neckEl.max = "30";
        neckEl.step = "0.5";
        hipEl.min = "20";
        hipEl.max = "80";
        hipEl.step = "0.5";
        syncMethodDisplay();
      }

      function switchUnits(nextUnits) {
        if (nextUnits === currentUnits) return;

        if (currentUnits === "imperial") {
          const heightIn = totalImperialHeightInches();
          const weightLb = numberFrom(weightEl);
          const waistIn = numberFrom(waistEl);
          const neckIn = numberFrom(neckEl);
          const hipIn = numberFrom(hipEl);
          if (heightIn != null && heightIn > 0) setNumber(heightCmEl, heightIn * CM_PER_IN, 1);
          if (weightLb != null) setNumber(weightEl, weightLb / LB_PER_KG, 1);
          if (waistIn != null) setNumber(waistEl, waistIn * CM_PER_IN, 1);
          if (neckIn != null) setNumber(neckEl, neckIn * CM_PER_IN, 1);
          if (hipIn != null) setNumber(hipEl, hipIn * CM_PER_IN, 1);
        } else {
          const heightCm = numberFrom(heightCmEl);
          const weightKg = numberFrom(weightEl);
          const waistCm = numberFrom(waistEl);
          const neckCm = numberFrom(neckEl);
          const hipCm = numberFrom(hipEl);
          if (heightCm != null && heightCm > 0) setImperialHeight(heightCm / CM_PER_IN);
          if (weightKg != null) setNumber(weightEl, weightKg * LB_PER_KG, 0);
          if (waistCm != null) {
            const waistIn = Math.round((waistCm / CM_PER_IN) * 2) / 2;
            setNumber(waistEl, waistIn, waistIn % 1 === 0 ? 0 : 1);
          }
          if (neckCm != null) {
            const neckIn = Math.round((neckCm / CM_PER_IN) * 2) / 2;
            setNumber(neckEl, neckIn, neckIn % 1 === 0 ? 0 : 1);
          }
          if (hipCm != null) {
            const hipIn = Math.round((hipCm / CM_PER_IN) * 2) / 2;
            setNumber(hipEl, hipIn, hipIn % 1 === 0 ? 0 : 1);
          }
        }

        currentUnits = nextUnits;
        syncUnitDisplay(currentUnits);
        update();
      }

      function formatWeight(lb) {
        if (currentUnits === "metric") return `${formatNumber(lb / LB_PER_KG)} kg (${Math.round(lb)} lb)`;
        return `${Math.round(lb)} lb`;
      }

      function formatWeightDelta(lb) {
        if (currentUnits === "metric") return `${formatNumber(lb / LB_PER_KG)} kg (${Math.round(lb)} lb)`;
        return `${Math.round(lb)} lb`;
      }

      function formatWaist(inches) {
        if (currentUnits === "metric") return `${formatNumber(inches * CM_PER_IN)} cm (${inches.toFixed(1)}\u2033)`;
        return `${inches.toFixed(1)}\u2033`;
      }

      function formatLength(inches) {
        if (currentUnits === "metric") return `${formatNumber(inches * CM_PER_IN)} cm (${inches.toFixed(1)}\u2033)`;
        return `${inches.toFixed(1)}\u2033`;
      }

      function resetResults() {
        bfValueEl.textContent = "\u2013%";
        bfVerdictEl.textContent = "Fill in the fields above to calculate your estimate.";
        bfVerdictEl.className = "result-verdict is-pending";
        bfMaxEl.textContent = "Waiting for age and sex";
        bfExactEl.textContent = "Waiting for the selected tape measurements";
        screenEl.textContent = "Waiting for height, weight, age and sex";
        screenEl.className = "is-pending";
        whtrEl.textContent = "Waiting for height and abdominal or waist circumference";
        whtrEl.className = "is-pending";
      }

      function readInputs() {
        const units = form.querySelector('input[name="units"]:checked').value;
        const method = form.querySelector('input[name="method"]:checked').value;
        const sex = form.querySelector('input[name="sex"]:checked').value;
        const age = parseFloat(document.getElementById("age").value);
        const weightRaw = numberFrom(weightEl);
        const waistRaw = numberFrom(waistEl);
        const neckRaw = numberFrom(neckEl);
        const hipRaw = numberFrom(hipEl);
        let heightIn;
        let weight;
        let waist;
        let neck;
        let hip;

        if (units === "metric") {
          const heightCm = numberFrom(heightCmEl);
          if (heightCm == null || heightCm < 90 || heightCm > 260) return null;
          if (waistRaw == null || waistRaw < 35 || waistRaw > 205) return null;
          if (weightRaw != null && (weightRaw < 25 || weightRaw > 275)) return null;
          if (method === "current" && weightRaw == null) return null;
          if (method === "legacy" && (neckRaw == null || neckRaw < 20 || neckRaw > 90)) return null;
          if (method === "legacy" && sex === "female" && (hipRaw == null || hipRaw < 45 || hipRaw > 220)) return null;
          heightIn = heightCm / CM_PER_IN;
          weight = weightRaw == null ? null : weightRaw * LB_PER_KG;
          waist = waistRaw / CM_PER_IN;
          neck = neckRaw == null ? null : neckRaw / CM_PER_IN;
          hip = hipRaw == null ? null : hipRaw / CM_PER_IN;
        } else {
          const feet = numberFrom(heightFtEl);
          const extraIn = numberFrom(heightInEl);
          if (feet == null || feet < 3 || feet > 8) return null;
          if (extraIn == null || extraIn < 0 || extraIn >= 12) return null;
          if (waistRaw == null || waistRaw < 15 || waistRaw > 80) return null;
          if (weightRaw != null && (weightRaw < 50 || weightRaw > 600)) return null;
          if (method === "current" && weightRaw == null) return null;
          if (method === "legacy" && (neckRaw == null || neckRaw < 8 || neckRaw > 36)) return null;
          if (method === "legacy" && sex === "female" && (hipRaw == null || hipRaw < 18 || hipRaw > 88)) return null;
          heightIn = feet * 12 + extraIn;
          weight = weightRaw;
          waist = waistRaw;
          neck = neckRaw;
          hip = hipRaw;
        }

        if (
          !Number.isFinite(age) || age < 17 || age > 100 ||
          !Number.isFinite(heightIn) || heightIn < 36 || heightIn > 102 ||
          !Number.isFinite(waist) || waist < 15 || waist > 80
        ) {
          return null;
        }
        if (weight != null && (!Number.isFinite(weight) || weight < 50 || weight > 600)) return null;
        if (method === "legacy" && (!Number.isFinite(neck) || neck < 8 || neck > 36)) return null;
        if (method === "legacy" && sex === "female" && (!Number.isFinite(hip) || hip < 18 || hip > 88)) return null;
        return { method, sex, age, heightIn, weight, waist, neck, hip };
      }

      function update() {
        const input = readInputs();
        if (!input) {
          resetResults();
          return;
        }
        const { method, sex, age, heightIn, weight, waist, neck, hip } = input;

        const weightRounded = weight == null ? null : Math.round(weight);
        const waistRounded = roundDownHalf(waist);
        const neckRounded = neck == null ? null : roundUpHalf(neck);
        const hipRounded = hip == null ? null : roundDownHalf(hip);

        const exact = method === "legacy"
          ? computeLegacyBodyFat(sex, heightIn, waistRounded, neckRounded, hipRounded)
          : computeCurrentBodyFat(sex, weightRounded, waistRounded);
        if (exact == null || !Number.isFinite(exact)) {
          resetResults();
          bfExactEl.textContent = "Check the tape values. The old method needs circumference values that produce a positive circumference value.";
          return;
        }

        const rounded = Math.round(exact);
        const idx = ageGroupIndex(age);
        const maxAllowed = MAX_BF[sex][idx];
        const passes = rounded <= maxAllowed;

        bfValueEl.textContent = `${rounded}%`;
        if (method === "legacy" && sex === "male") {
          bfExactEl.textContent = `${exact.toFixed(2)}% (old tape method using ${formatLength(heightIn)} height, ${formatWaist(waistRounded)} abdomen and ${formatLength(neckRounded)} neck after regulation rounding)`;
        } else if (method === "legacy") {
          bfExactEl.textContent = `${exact.toFixed(2)}% (old tape method using ${formatLength(heightIn)} height, ${formatWaist(waistRounded)} waist, ${formatLength(hipRounded)} hip and ${formatLength(neckRounded)} neck after regulation rounding)`;
        } else {
          bfExactEl.textContent = `${exact.toFixed(2)}% (using ${formatWeight(weightRounded)} and a ${formatWaist(waistRounded)} abdomen after regulation rounding)`;
        }
        bfMaxEl.textContent = `${maxAllowed}% (${sex}, age group ${AGE_GROUP_LABELS[idx]})`;

        bfVerdictEl.textContent = passes
          ? `Within the standard: ${maxAllowed - rounded} percentage point${maxAllowed - rounded === 1 ? "" : "s"} under the ${maxAllowed}% limit.`
          : `Over the standard by ${rounded - maxAllowed} percentage point${rounded - maxAllowed === 1 ? "" : "s"} (limit ${maxAllowed}%).`;
        bfVerdictEl.className = `result-verdict ${passes ? "is-pass" : "is-fail"}`;

        const screenMax = screeningWeight(sex, heightIn, age);
        const minWeightRow = SCREENING.find((r) => r[0] === Math.min(Math.max(Math.round(heightIn), 58), 80));
        const minWeight = minWeightRow ? minWeightRow[1] : null;
        if (weightRounded == null) {
          screenEl.textContent = "Waiting for weight to compare against Table B-1.";
          screenEl.className = "is-pending";
        } else if (screenMax == null) {
          screenEl.textContent = "No screening weight listed for this height and sex in Table B-1.";
          screenEl.className = "";
        } else if (minWeight != null && weightRounded < minWeight) {
          screenEl.textContent = `${formatWeight(weightRounded)} is below the ${formatWeight(minWeight)} minimum. The regulation calls for a medical evaluation referral.`;
          screenEl.className = "is-fail";
        } else if (weightRounded <= screenMax) {
          screenEl.textContent = `Passes: ${formatWeight(weightRounded)} is at or under the ${formatWeight(screenMax)} screening weight, so no tape test would be required.`;
          screenEl.className = "is-pass";
        } else {
          screenEl.textContent = `Exceeds the ${formatWeight(screenMax)} screening weight by ${formatWeightDelta(weightRounded - screenMax)}. A tape test would be required.`;
          screenEl.className = "is-fail";
        }

        const whtr = waist / heightIn;
        const whtrPass = whtr < 0.55;
        whtrEl.textContent = `${whtr.toFixed(3)}: ${whtrPass ? "under" : "at or over"} the 0.55 limit.`;
        whtrEl.className = whtrPass ? "is-pass" : "is-fail";
      }

      form.addEventListener("input", (event) => {
        if (event.target?.name === "units") switchUnits(event.target.value);
        else {
          if (event.target?.name === "method" || event.target?.name === "sex") syncMethodDisplay();
          update();
        }
      });
      form.addEventListener("submit", (e) => e.preventDefault());
      syncUnitDisplay(currentUnits);
      resetResults();
    </script>
  </body>
</html>

