        const marginalSexAttributableAnnualCases = BACTERIAL_VAGINOSIS.marginalSexAttributableAnnualCases[context.tier][context.perspective] ?? 0;
        const expectedCases = marginalSexAttributableAnnualCases * YEARS * (withCondom ? BACTERIAL_VAGINOSIS.condomMultiplier : 1);
        const probability = expectedCases <= 0 ? 0 : 1 - Math.exp(-expectedCases);
        const qaly = expectedCases * BACTERIAL_VAGINOSIS.qalyPerCase;

        return { probability, expectedCases, qaly };
      }

      function antibioticYeastOutcome(context, sexRelatedAntibioticCourses) {
        const scenario = context.yeastProne ? "prone" : "default";
        const riskPerCourse = ANTIBIOTIC_ASSOCIATED_YEAST.riskPerAntibioticCourse[scenario][context.perspective] ?? 0;
        const expectedCases = sexRelatedAntibioticCourses * riskPerCourse;
        const probability = sexRelatedAntibioticCourses <= 0 || riskPerCourse <= 0
          ? 0
          : 1 - Math.pow(1 - riskPerCourse, sexRelatedAntibioticCourses);
        const qaly = expectedCases * ANTIBIOTIC_ASSOCIATED_YEAST.qalyPerCase;

        return { probability, expectedCases, qaly };
