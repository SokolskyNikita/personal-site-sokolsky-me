---
export const prerender = true;

const pageTitle = "STD risk QALY calculator";
const pageDescription =
  "Calculator comparing STI and pregnancy risk with and without condoms in a low-risk heterosexual U.S. partner pool.";
const themeColorLight = "#f7f2ea";
const themeColorDark = "#171310";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index,follow,max-snippet:-1" />
    <meta name="googlebot" content="index,follow,max-snippet:-1" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta name="theme-color" content={themeColorLight} media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content={themeColorDark} media="(prefers-color-scheme: dark)" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  </head>
  <body>
    <main class="page">
      <header class="hero">
        <a class="home-link" href="/">sokolsky.me/health</a>
        <div>
          <p class="eyebrow">Health decision model</p>
          <h1>STD risk QALY calculator</h1>
          <p class="summary">
            The calculation assumes one is a cishet Caucasian person in the United States. The numbers will be different for other groups/countries and ages. The calculations are for vaginal/oral sex only, with the base model closer to vaginal exposure than oral-heavy exposure.
          </p>
        </div>
      </header>

      <section class="calculator" aria-label="Risk calculator">
        <form class="controls" id="risk-controls">
          <fieldset class="control control-perspective">
            <legend>Perspective</legend>
            <div class="segmented" role="radiogroup" aria-label="Perspective">
              <label><input type="radio" name="perspective" value="male" checked /><span>Male</span></label>
              <label><input type="radio" name="perspective" value="female" /><span>Female</span></label>
            </div>
          </fieldset>

          <div class="control control-partners">
            <div class="label-row">
              <label for="partners-range">Partners over 10 years</label>
              <input id="partners-number" name="partners-number" type="number" min="1" max="200" step="1" value="10" inputmode="numeric" />
            </div>
            <input id="partners-range" name="partners-range" type="range" min="1" max="200" step="1" value="10" />
            <p class="hint">
              STI exposure splits 3 acts/week across partners. Pregnancy uses 10-year contraceptive failure and fertility-pause assumptions, not a full first-year failure rate per partner.
            </p>
          </div>

          <label class="control checkbox">
            <input id="college-only" name="college-only" type="checkbox" checked />
            <span>
              <strong>Only partners with a college degree</strong>
              <small>Unchecking raises HIV and bacterial STI background rates. HSV-2 moves a little too.</small>
            </span>
          </label>

          <fieldset class="control control-use-mode">
            <legend>Pregnancy prevention use</legend>
            <div class="segmented" role="radiogroup" aria-label="Pregnancy prevention use">
              <label><input type="radio" name="use-mode" value="perfect" checked /><span>Perfect use</span></label>
              <label><input type="radio" name="use-mode" value="typical" /><span>Typical use</span></label>
            </div>
            <p class="hint">
              Applies to both the selected no-condom method and the condom comparison.
            </p>
          </fieldset>

          <label class="control select-control" for="birth-control">
            <span>Birth control when no condoms are used</span>
            <select id="birth-control" name="birth-control">
              <option value="none">None</option>
              <option value="withdrawal" selected>Pull out</option>
              <option value="pill">Birth control pill</option>
              <option value="implant">Contraceptive implant</option>
            </select>
          </label>

          <label class="control select-control" for="condom-pregnancy-mode">
            <span>When a condom is used, assume...</span>
            <select id="condom-pregnancy-mode" name="condom-pregnancy-mode">
              <option value="condom-only" selected>No other birth control method is used</option>
              <option value="stacked">The birth control method above (the no condom scenario) is used</option>
            </select>
            <small>When the method above is also used, stacked use is a simple independent-failure approximation.</small>
          </label>

          <div class="control control-child-rate">
            <div class="label-row">
              <label for="child-rate-range">Unintended pregnancies resulting in a child (%)</label>
              <input id="child-rate-number" name="child-rate-number" type="number" min="0" max="100" step="5" value="50" inputmode="numeric" />
            </div>
            <input id="child-rate-range" name="child-rate-range" type="range" min="0" max="100" step="5" value="50" />
            <p class="hint">This parameter varies a lot, so make a pick based off what makes sense for you.</p>
          </div>

          <label class="control select-control" for="hpv-vaccine-scenario">
            <span>HPV vaccine benefit assumption</span>
            <select id="hpv-vaccine-scenario" name="hpv-vaccine-scenario">
              <option value="preExposure" selected>Pre-exposure / catch-up: 90%</option>
              <option value="adultPriorExposure">Adult with likely prior exposure: 40%</option>
              <option value="none">No HPV vaccine benefit</option>
            </select>
          </label>

          <label class="control select-control" for="uncertainty-scenario">
            <span>STI sensitivity scenario</span>
            <select id="uncertainty-scenario" name="uncertainty-scenario">
              <option value="base" selected>Base point estimates</option>
              <option value="low">Lower estimate for uncertain inputs</option>
              <option value="high">Higher estimate for uncertain inputs</option>
            </select>
          </label>
        </form>

        <section class="results" aria-live="polite" aria-label="Calculated results">
          <div class="headline">
            <div>
              <p class="kicker">STI QALYs saved by using condoms</p>
              <p class="headline-value" id="condom-benefit">-</p>
              <p class="headline-note" id="benefit-note">Waiting for inputs</p>
            </div>
            <div class="mini-facts">
              <span id="acts-per-partner">- acts/partner</span>
              <span>10 years</span>
              <span>3 sex acts/week</span>
            </div>
          </div>

          <div class="comparison-grid">
            <div class="comparison-row">
              <h3>Modeled STI healthy weeks lost</h3>
              <div class="comparison-value without">
                <span>Without condoms</span>
                <strong id="no-total">-</strong>
              </div>
              <div class="comparison-value with">
                <span>With condoms</span>
                <strong id="condom-total">-</strong>
              </div>
            </div>
            <div class="comparison-row benefit-row">
              <h3>STI QALYs saved by using condoms</h3>
              <div class="comparison-value benefit">
                <span>Compared with no condoms</span>
                <strong id="condom-saved">-</strong>
              </div>
            </div>
            <div class="comparison-row benefit-row">
              <h3>Selected HPV vaccine scenario reduces by</h3>
              <div class="comparison-value benefit">
                <span>HPV-preventable burden</span>
                <strong id="vaccine-benefit">-</strong>
              </div>
            </div>
            <div class="comparison-row">
              <h3>Odds of at least 1 pregnancy</h3>
              <div class="comparison-value without">
                <span>Without condoms</span>
                <strong id="no-preg-risk">-</strong>
              </div>
              <div class="comparison-value with">
                <span>With condoms</span>
                <strong id="condom-preg-risk">-</strong>
              </div>
            </div>
            <div class="comparison-row">
              <h3>Projected children</h3>
              <div class="comparison-value without">
                <span>Without condoms</span>
                <strong id="no-projected-children">-</strong>
              </div>
              <div class="comparison-value with">
                <span>With condoms</span>
                <strong id="condom-projected-children">-</strong>
              </div>
            </div>
          </div>
        </section>
      </section>

      <section class="detail-grid">
        <article class="panel">
          <div class="section-heading">
            <p class="eyebrow">STI breakdown</p>
            <h2>Modeled lifetime healthy weeks lost by disease</h2>
          </div>
          <div class="breakdown-head" aria-hidden="true">
            <span>Disease</span>
            <span>Without condoms</span>
            <span>With condoms</span>
            <span>Benefit</span>
          </div>
          <div class="breakdown-list" id="disease-breakdown"></div>
        </article>

        <aside class="panel assumptions">
          <div class="section-heading">
            <p class="eyebrow">Assumptions</p>
          </div>
          <div class="assumption-groups">
            <section class="assumption-group">
              <h3>What the calculator is estimating</h3>
              <ul>
                <li>Each STI row estimates: how likely a partner is to be infectious, how likely transmission is during the 10-year exposure window, and how much healthy time one infection is expected to cost.</li>
                <li>The STI totals are a rough expected-value model of direct physical health burden. They are not a clinical prediction for one specific person, and pregnancy is shown separately instead of being folded into STI QALYs.</li>
              </ul>
            </section>

            <section class="assumption-group">
              <h3>Partners, age and sex acts</h3>
              <ul>
                <li>The college-degree checkbox is only a broad proxy for a lower-risk partner pool. Recent testing, number of recent partners, geography, age, partner network and injection-drug history can matter more.</li>
                <li>Partner risk is not truly independent. Ten partners from the same tested friend-of-friends network is different from ten unrelated partners from a broad national pool.</li>
                <li>Age is not modeled. HSV rates, HPV vaccine benefit, pregnancy risk and oral-cancer risk can change a lot by age and birth cohort.</li>
                <li>Oral and vaginal sex are combined into one exposure window. The base model is closer to vaginal sex, so oral-heavy sex can overstate HIV risk and misplace some oral HPV, HSV and gonorrhea risk.</li>
              </ul>
            </section>

            <section class="assumption-group">
              <h3>Pregnancy</h3>
              <ul>
                <li>Pregnancy uses standard first-year contraceptive failure rates, spread across the 10-year horizon. Typical use: none 85%, pull out 20%, pill 7%, implant 0.1%, male condom 13%. Perfect use: pull out 4%, pill 0.3%, implant 0.1%, male condom 2%.</li>
                <li>The condom scenario can either mean switching to condoms alone or using condoms plus the selected no-condom method. When methods are stacked, the calculator multiplies failure rates as a simple approximation; in real life, people who miss pills may also use condoms inconsistently.</li>
                <li>Each pregnancy creates a fixed 1.25-year pause in pregnancy exposure. This is a middle-ground spacing assumption, not a claim that breastfeeding makes someone infertile for 1.25 years.</li>
                <li>Projected children uses the expected number of pregnancies and the user-selected share of unintended pregnancies that result in a child.</li>
              </ul>
            </section>

            <section class="assumption-group">
              <h3>HPV and vaccines</h3>
              <ul>
                <li>The HPV vaccine setting only changes HPV-related rows. The 90% setting is meant for vaccination before exposure; the adult prior-exposure setting is an illustrative lower-benefit scenario, not a precise CDC number.</li>
                <li>The HPV-attributable oropharyngeal-cancer row is only order-of-magnitude. It turns a lifetime cancer-risk estimate into a per-partner-equivalent estimate so the partner slider can move it, but real cancer risk depends on sex, age, smoking, oral-sex history, vaccination and HPV type.</li>
                <li>Existing HPV status is not modeled. If someone is already vaccinated or already exposed to a vaccine-covered HPV type, the marginal benefit can differ from the default.</li>
              </ul>
            </section>

            <section class="assumption-group">
              <h3>HSV</h3>
              <ul>
                <li>HSV rows use adult population anchors, then remove the roughly 40% post-diagnosis psychosocial share. The calculator is trying to count physical morbidity, not stigma, disclosure anxiety, neonatal HSV or HSV-attributable HIV.</li>
                <li>HSV-2 condom protection is sex/direction-specific in the model.</li>
                <li>Genital HSV-1 is a rough proxy for oral-acquired genital HSV-1. HSV-1 blood tests do not tell whether infection is oral or genital, and prior HSV-1 or HSV-2 infection is not modeled.</li>
              </ul>
            </section>

            <section class="assumption-group">
              <h3>HIV</h3>
              <ul>
                <li>The HIV row uses the chance that a partner has transmissible HIV, not just any HIV. Virally suppressed partners are treated as effectively non-transmitting for sex.</li>
                <li>The HIV transmission rates are CDC vaginal-sex estimates. Oral-heavy sex can make the HIV row too high.</li>
              </ul>
            </section>

            <section class="assumption-group">
              <h3>Bacterial STIs, M. genitalium and Ureaplasma</h3>
              <ul>
                <li>Chlamydia, gonorrhea, trichomoniasis and syphilis use low-risk prevalence anchors rather than raw national reported case rates, because reported cases depend heavily on who gets tested.</li>
                <li>M. genitalium is one of the least certain rows. Female burden is scaled from chlamydia using a PID-progression proxy, and male burden is a urethritis-only proxy because long-term male complication data are weak.</li>
                <li>M. genitalium resistance, repeat treatment, persistence and medication side effects are not separately modeled.</li>
                <li>Ureaplasma only represents possible high-load U. urealyticum nongonococcal urethritis in men, not ordinary Ureaplasma carriage. Female burden is set to zero because guidelines do not support a cervicitis/PID/infertility estimate.</li>
              </ul>
            </section>

            <section class="assumption-group">
              <h3>Uncertainty controls</h3>
              <ul>
                <li>The sensitivity control scales the least certain STI inputs: HPV progression, HSV physical-only burden, bacterial STI burden, M. genitalium and high-load Ureaplasma.</li>
                <li>These scenarios are not formal confidence intervals. They are a quick way to see whether the conclusion changes when the weakest assumptions are moved up or down.</li>
              </ul>
            </section>
          </div>
        </aside>
      </section>

      <section class="sources" aria-labelledby="sources-heading">
        <h2 id="sources-heading">Sources and anchors</h2>
        <p>
          This is a calculator, not a clinical forecast. It uses CDC and Guttmacher contraception tables, CDC HIV and HPV vaccination tables, NHANES HPV/HSV/M. genitalium prevalence, Li et al. bacterial STI QALY estimates, You et al. genital HSV QALY estimates, Fisman genital-herpes utility data, GBD genital-herpes disability weights, D'Souza et al. oral HPV/OPC risk, Martin/Magaret HSV condom studies, Ureaplasma position statements and Winer NEJM genital HPV condom data.
        </p>
        <ul>
          <li><a href="https://www.cdc.gov/mmwr/preview/mmwrhtml/rr6304a5.htm" target="_blank" rel="noreferrer noopener">CDC contraceptive effectiveness table</a></li>
          <li><a href="https://www.guttmacher.org/fact-sheet/contraceptive-effectiveness-united-states" target="_blank" rel="noreferrer noopener">Guttmacher typical-use and perfect-use contraceptive failure rates</a></li>
          <li><a href="https://www.cdc.gov/hivpartners/php/riskandprevention/index.html" target="_blank" rel="noreferrer noopener">CDC HIV risk and prevention estimates</a></li>
          <li><a href="https://www.cdc.gov/sti/about/about-sti-risk-and-oral-sex.html" target="_blank" rel="noreferrer noopener">CDC STI risk and oral sex</a></li>
          <li><a href="https://www.cdc.gov/sti-statistics/annual/index.html" target="_blank" rel="noreferrer noopener">CDC 2024 STI surveillance</a></li>
          <li><a href="https://www.cdc.gov/nchs/products/databriefs/db280.htm" target="_blank" rel="noreferrer noopener">CDC NCHS HPV prevalence data brief</a></li>
          <li><a href="https://www.cdc.gov/hpv/vaccines/index.html" target="_blank" rel="noreferrer noopener">CDC HPV vaccine prevention summary</a></li>
          <li><a href="https://www.cdc.gov/nchs/products/databriefs/db304.htm" target="_blank" rel="noreferrer noopener">CDC NCHS HSV-1/HSV-2 prevalence data brief</a></li>
          <li><a href="https://pmc.ncbi.nlm.nih.gov/articles/PMC10112678/" target="_blank" rel="noreferrer noopener">QALYs lost from chlamydia, gonorrhea and trichomoniasis</a></li>
          <li><a href="https://pmc.ncbi.nlm.nih.gov/articles/PMC10025423/" target="_blank" rel="noreferrer noopener">QALYs lost from genital HSV-1 and HSV-2</a></li>
          <li><a href="https://www.who.int/news-room/fact-sheets/detail/herpes-simplex-virus" target="_blank" rel="noreferrer noopener">WHO herpes simplex virus fact sheet</a></li>
          <li><a href="https://pubmed.ncbi.nlm.nih.gov/15923297/" target="_blank" rel="noreferrer noopener">Fisman genital herpes quality-of-life pilot</a></li>
          <li><a href="https://pmc.ncbi.nlm.nih.gov/articles/PMC8848826/" target="_blank" rel="noreferrer noopener">Genital herpes utility weights systematic review</a></li>
          <li><a href="https://weekly.chinacdc.cn/fileCCDCW/journal/article/ccdcw/2024/40/PDF/CCDCW230408.pdf" target="_blank" rel="noreferrer noopener">GBD genital herpes disability weights</a></li>
          <li><a href="https://www.cdc.gov/std/treatment-guidelines/herpes.htm" target="_blank" rel="noreferrer noopener">CDC genital herpes treatment guidelines</a></li>
          <li><a href="https://www.cdc.gov/std/treatment-guidelines/mycoplasmagenitalium.htm" target="_blank" rel="noreferrer noopener">CDC Mycoplasma genitalium treatment guidelines</a></li>
          <li><a href="https://doi.org/10.1097/olq.0000000000001394" target="_blank" rel="noreferrer noopener">NHANES Mycoplasma genitalium prevalence, U.S. 2017-2018</a></li>
          <li><a href="https://pmc.ncbi.nlm.nih.gov/articles/PMC6678058/" target="_blank" rel="noreferrer noopener">Mycoplasma genitalium incidence, persistence and partner concordance</a></li>
          <li><a href="https://wwwnc.cdc.gov/eid/article/23/11/17-0998_article" target="_blank" rel="noreferrer noopener">CDC Emerging Infectious Diseases: Mycoplasma genitalium in exposed partners</a></li>
          <li><a href="https://pmc.ncbi.nlm.nih.gov/articles/PMC7744984/" target="_blank" rel="noreferrer noopener">Mycoplasma genitalium PID progression evidence synthesis</a></li>
          <li><a href="https://www.cdc.gov/std/treatment-guidelines/urethritis-and-cervicitis.htm" target="_blank" rel="noreferrer noopener">CDC urethritis and cervicitis guidance for Ureaplasma</a></li>
          <li><a href="https://pubmed.ncbi.nlm.nih.gov/29924422/" target="_blank" rel="noreferrer noopener">European STI Guidelines position statement on Ureaplasma testing</a></li>
          <li><a href="https://journals.asm.org/doi/10.1128/cmr.00137-18" target="_blank" rel="noreferrer noopener">Clinical Microbiology Reviews: Ureaplasma and male NGU</a></li>
          <li><a href="https://pmc.ncbi.nlm.nih.gov/articles/PMC5834136/" target="_blank" rel="noreferrer noopener">Oral HPV prevalence and OPC lifetime risk</a></li>
        </ul>
      </section>
    </main>

    <script is:inline>
      const YEARS = 10;
      const ACTS_PER_WEEK = 3;
      const WEEKS_PER_YEAR = 52;
      const TOTAL_ACTS = YEARS * WEEKS_PER_YEAR * ACTS_PER_WEEK;
      const BASELINE_PARTNERS = 10;
      const DAYS_PER_QALY = 365.25;
      const WEEKS_PER_QALY = DAYS_PER_QALY / 7;
      const PREGNANCY_SLOTS_PER_YEAR = 4;
      const DEFAULT_PREGNANCY_PAUSE_YEARS = 1.25;
      const DEFAULT_CHILD_PER_PREGNANCY = 0.5;
      const HPV_VACCINE_SCENARIOS = {
        none: 0,
        adultPriorExposure: 0.4,
        preExposure: 0.9
      };
      // You et al.: removing post-diagnosis psychosocial distress cuts HSV losses by about 40%.
      const HSV_PHYSICAL_ONLY_MULTIPLIER = 0.6;

      const DISEASES = [
        {
          name: "HPV-attributable OPC",
          route: "lifetime",
          repeatable: false,
          note: "Order-of-magnitude lifetime oropharyngeal-cancer burden, calibrated to the default partner count. Condoms do not change this term; male OPC risk is much higher than female OPC risk.",
          baselinePartners: BASELINE_PARTNERS,
          lifetimeRisk: {
            college: { female: 0.0035, male: 0.0095 },
            broad: { female: 0.0045, male: 0.011 }
          },
          condomEffectiveness: { female: 0, male: 0 },
          vaccinePreventableShare: 1,
          uncertainty: { low: 0.35, high: 3 },
          qalyPerCase: { female: 0.025, male: 0.041 }
        },
        {
          name: "Genital HPV",
          route: "perPartner",
          repeatable: false,
          note: "Genital high-risk HPV plus wart/dysplasia burden. Condoms reduce skin-contact exposure but do not remove it.",
          perPartner: {
            college: { female: 0.02, male: 0.018 },
            broad: { female: 0.03, male: 0.027 }
          },
          condomEffectiveness: { female: 0.55, male: 0.55 },
          vaccinePreventableShare: 1,
          uncertainty: { low: 0.5, high: 2 },
          qalyPerCase: { female: 0.012, male: 0.003 }
        },
        {
          name: "HSV-2",
          route: "perAct",
          repeatable: false,
          note: "HSV-2 prevalence starts from NHANES white HSV-2 rates, then drops for the college-pool setting.",
          prevalence: {
            college: { male: 0.055, female: 0.04 },
            broad: { male: 0.085, female: 0.065 }
          },
          perAct: { female: 0.0011, male: 0.00065 },
          condomEffectiveness: { female: 0.96, male: 0.65 },
          uncertainty: { low: 0.6, high: 1.8 },
          qalyPerCase: {
            female: 0.05 * HSV_PHYSICAL_ONLY_MULTIPLIER,
            male: 0.05 * HSV_PHYSICAL_ONLY_MULTIPLIER
          }
        },
        {
          name: "HSV-1 genital",
          route: "perPartner",
          repeatable: false,
          note: "Proxy for oral-acquired genital HSV-1. HSV-1 serology does not identify infection site; condoms do not change this term when oral sex is unbarriered.",
          perPartner: {
            college: { female: 0.0009, male: 0.0007 },
            broad: { female: 0.0012, male: 0.001 }
          },
          condomEffectiveness: { female: 0, male: 0 },
          uncertainty: { low: 0.6, high: 1.8 },
          qalyPerCase: {
            female: 0.01 * HSV_PHYSICAL_ONLY_MULTIPLIER,
            male: 0.01 * HSV_PHYSICAL_ONLY_MULTIPLIER
          }
        },
        {
          name: "Chlamydia",
          route: "perAct",
          repeatable: true,
          maxExposureActs: 20,
          note: "Female QALY/case uses Li et al.'s PID, chronic pelvic pain, tubal-factor infertility and ectopic-pregnancy model.",
          prevalence: {
            college: { male: 0.004, female: 0.005 },
            broad: { male: 0.012, female: 0.014 }
          },
          perAct: { female: 0.04, male: 0.032 },
          condomEffectiveness: { female: 0.6, male: 0.6 },
          uncertainty: { low: 0.5, high: 2 },
          qalyPerCase: { female: 0.04698, male: 0.00094 }
        },
        {
          name: "Gonorrhea",
          route: "perAct",
          repeatable: true,
          maxExposureActs: 12,
          note: "Shorter infectious window than chlamydia. Female sequelae still drive most QALY loss.",
          prevalence: {
            college: { male: 0.0009, female: 0.0008 },
            broad: { male: 0.0035, female: 0.003 }
          },
          perAct: { female: 0.09, male: 0.07 },
          condomEffectiveness: { female: 0.65, male: 0.65 },
          uncertainty: { low: 0.5, high: 2 },
          qalyPerCase: { female: 0.01422, male: 0.00143 }
        },
        {
          name: "Trichomoniasis",
          route: "perAct",
          repeatable: true,
          maxExposureActs: 20,
          note: "White-pool prevalence is much lower than general U.S. prevalence. QALY/case comes from Li et al.",
          prevalence: {
            college: { male: 0.002, female: 0.004 },
            broad: { male: 0.005, female: 0.008 }
          },
          perAct: { female: 0.07, male: 0.055 },
          condomEffectiveness: { female: 0.6, male: 0.6 },
          uncertainty: { low: 0.5, high: 2 },
          qalyPerCase: { female: 0.00135, male: 0.00012 }
        },
        {
          name: "Mycoplasma genitalium",
          route: "perPartner",
          repeatable: true,
          note: "Mgen is often missed by standard STI panels. Per-partner risk uses NHANES sex/race prevalence scaled by exposed-partner infection rates; female QALY/case is a chlamydia-scaled PID proxy.",
          perPartner: {
            college: { female: 0.00675, male: 0.00465 },
            broad: { female: 0.00868, male: 0.00527 }
          },
          condomEffectiveness: { female: 0.5, male: 0.5 },
          uncertainty: { low: 0.3, high: 3 },
          qalyPerCase: { female: 0.016, male: 0.001 }
        },
        {
          name: "Ureaplasma urealyticum high-load NGU",
          route: "perPartner",
          repeatable: true,
          note: "Ureaplasma is usually carriage, not disease. This row only approximates possible high-load U. urealyticum nongonococcal urethritis in men; routine testing is not recommended.",
          perPartner: {
            college: { female: 0, male: 0.0035 },
            broad: { female: 0, male: 0.007 }
          },
          condomEffectiveness: { female: 0.5, male: 0.5 },
          uncertainty: { low: 0.25, high: 4 },
          qalyPerCase: { female: 0, male: 0.002 }
        },
        {
          name: "Syphilis",
          route: "perAct",
          repeatable: true,
          maxExposureActs: 10,
          note: "Very low in this non-IDU heterosexual pool. QALY/case is high if acquired.",
          prevalence: {
            college: { male: 0.00012, female: 0.00006 },
            broad: { male: 0.0005, female: 0.00018 }
          },
          perAct: { female: 0.02, male: 0.016 },
          condomEffectiveness: { female: 0.5, male: 0.5 },
          uncertainty: { low: 0.5, high: 2 },
          qalyPerCase: { female: 0.09, male: 0.09 }
        },
        {
          name: "HIV",
          route: "perAct",
          repeatable: false,
          note: "Uses CDC per-act vaginal risk with an infectious/unsuppressed-source prevalence term, filtered to a low-prevalence heterosexual white non-IDU pool.",
          prevalence: {
            college: { male: 0.00004, female: 0.000025 },
            broad: { male: 0.00018, female: 0.0001 }
          },
          perAct: { female: 0.0008, male: 0.0004 },
          condomEffectiveness: { female: 0.8, male: 0.8 },
          qalyPerCase: { female: 6, male: 6 }
        }
      ];

      const BIRTH_CONTROL = {
        none: { label: "None", annualFailure: { typical: 0.85, perfect: 0.85 } },
        withdrawal: { label: "Pull out", annualFailure: { typical: 0.2, perfect: 0.04 } },
        pill: { label: "Birth control pill", annualFailure: { typical: 0.07, perfect: 0.003 } },
        implant: { label: "Contraceptive implant", annualFailure: { typical: 0.001, perfect: 0.001 } }
      };

      const CONDOM_ANNUAL_FAILURE = { typical: 0.13, perfect: 0.02 };

      const form = document.querySelector("#risk-controls");
      const partnersRange = document.querySelector("#partners-range");
      const partnersNumber = document.querySelector("#partners-number");
      const collegeOnly = document.querySelector("#college-only");
      const birthControl = document.querySelector("#birth-control");
      const condomPregnancyMode = document.querySelector("#condom-pregnancy-mode");
      const childRateRange = document.querySelector("#child-rate-range");
      const childRateNumber = document.querySelector("#child-rate-number");
      const hpvVaccineScenario = document.querySelector("#hpv-vaccine-scenario");
      const uncertaintyScenario = document.querySelector("#uncertainty-scenario");
      const diseaseBreakdown = document.querySelector("#disease-breakdown");

      const ids = {
        condomBenefit: document.querySelector("#condom-benefit"),
        benefitNote: document.querySelector("#benefit-note"),
        actsPerPartner: document.querySelector("#acts-per-partner"),
        noTotal: document.querySelector("#no-total"),
        noPregRisk: document.querySelector("#no-preg-risk"),
        noProjectedChildren: document.querySelector("#no-projected-children"),
        condomTotal: document.querySelector("#condom-total"),
        condomSaved: document.querySelector("#condom-saved"),
        vaccineBenefit: document.querySelector("#vaccine-benefit"),
        condomPregRisk: document.querySelector("#condom-preg-risk"),
        condomProjectedChildren: document.querySelector("#condom-projected-children")
      };

      function clampPartners(value) {
        const parsed = Number.parseInt(value, 10);
        if (Number.isNaN(parsed)) return 10;
        return Math.min(200, Math.max(1, parsed));
      }

      function clampNumber(value, min, max, fallback) {
        const parsed = Number.parseFloat(value);
        if (Number.isNaN(parsed)) return fallback;
        return Math.min(max, Math.max(min, parsed));
      }

      function failureProbabilityForYears(annualFailure, years) {
        return 1 - Math.pow(1 - annualFailure, years);
      }

      function probabilityAcrossPartners(perPartnerRisk, partners) {
        return 1 - Math.pow(1 - perPartnerRisk, partners);
      }

      function perActPartnerRisk(disease, perspective, partnerSex, tier, actsPerPartner, withCondom) {
        const infectiousPrevalence = disease.prevalence[tier][partnerSex];
        const effectiveActs = Math.min(actsPerPartner, disease.maxExposureActs ?? actsPerPartner);
        const condomMultiplier = withCondom ? 1 - disease.condomEffectiveness[perspective] : 1;
        const perActRisk = disease.perAct[perspective] * condomMultiplier;
        const transmissionIfInfectious = 1 - Math.pow(1 - perActRisk, effectiveActs);

        return infectiousPrevalence * transmissionIfInfectious;
      }

      function perPartnerRisk(disease, perspective, withCondom, tier) {
        const baseRisk = disease.perPartner[tier][perspective];
        const condomMultiplier = withCondom ? 1 - disease.condomEffectiveness[perspective] : 1;
        return baseRisk * condomMultiplier;
      }

      function lifetimeRisk(disease, perspective, withCondom, tier) {
        const baseRisk = disease.lifetimeRisk[tier][perspective];
        const baselinePartners = disease.baselinePartners ?? BASELINE_PARTNERS;
        const perPartnerEquivalent = 1 - Math.pow(1 - baseRisk, 1 / baselinePartners);
        const condomMultiplier = withCondom ? 1 - disease.condomEffectiveness[perspective] : 1;
        return perPartnerEquivalent * condomMultiplier;
      }

      function diseaseOutcome(disease, context, withCondom) {
        const perPartner = disease.route === "perAct"
          ? perActPartnerRisk(
              disease,
              context.perspective,
              context.partnerSex,
              context.tier,
              context.actsPerPartner,
              withCondom
            )
          : disease.route === "lifetime"
            ? lifetimeRisk(disease, context.perspective, withCondom, context.tier)
            : perPartnerRisk(disease, context.perspective, withCondom, context.tier);
        const probability = probabilityAcrossPartners(perPartner, context.partners);
        const expectedCases = disease.repeatable ? perPartner * context.partners : probability;
        const uncertaintyMultiplier = disease.uncertainty?.[context.uncertaintyScenario] ?? 1;
        const qaly = expectedCases * disease.qalyPerCase[context.perspective] * uncertaintyMultiplier;

        return { perPartner, probability, expectedCases, qaly };
      }

      function pregnancyTrajectory(annualFailure, exposureYears, pauseYears) {
        const totalSlots = Math.max(1, Math.ceil(exposureYears * PREGNANCY_SLOTS_PER_YEAR));
        const slotYears = exposureYears / totalSlots;
        const failurePerSlot = failureProbabilityForYears(annualFailure, slotYears);
        const cooldownSlots = Math.max(0, Math.ceil(pauseYears / slotYears));
        let states = new Array(cooldownSlots + 1).fill(0);
        let expectedPregnancies = 0;
        states[0] = 1;

        for (let slotIndex = 0; slotIndex < totalSlots; slotIndex += 1) {
          const nextStates = new Array(cooldownSlots + 1).fill(0);

          states.forEach((probability, cooldown) => {
            if (probability === 0) return;

            if (cooldown > 0) {
              nextStates[cooldown - 1] += probability;
              return;
            }

            const pregnancyProbability = probability * failurePerSlot;
            expectedPregnancies += pregnancyProbability;
            nextStates[cooldownSlots] += pregnancyProbability;
            nextStates[0] += probability * (1 - failurePerSlot);
          });

          states = nextStates;
        }

        return {
          probability: failureProbabilityForYears(annualFailure, exposureYears),
          expected: expectedPregnancies
        };
      }

      function pregnancyFor(annualFailure, perspective, partners, pauseYears, childPerPregnancy) {
        const singleClock = perspective === "female"
          ? pregnancyTrajectory(annualFailure, YEARS, pauseYears)
          : pregnancyTrajectory(annualFailure, YEARS / partners, pauseYears);
        const expectedPregnancies = perspective === "female"
          ? singleClock.expected
          : singleClock.expected * partners;
        const atLeastOne = perspective === "female"
          ? singleClock.probability
          : probabilityAcrossPartners(singleClock.probability, partners);
        const projectedChildren = expectedPregnancies * childPerPregnancy;

        return {
          probability: atLeastOne,
          expected: expectedPregnancies,
          projectedChildren
        };
      }

      function annualFailureWithCondoms(methodKey, methodFailure, condomFailure, condomMode) {
        if (condomMode === "condom-only" || methodKey === "none") return condomFailure;
        return methodFailure * condomFailure;
      }

      function weeksText(qaly) {
        const weeks = qaly * WEEKS_PER_QALY;
        if (weeks === 0) return "0 weeks";
        if (weeks < 0.001) return `${weeks.toFixed(5)} weeks`;
        if (weeks < 0.01) return `${weeks.toFixed(4)} weeks`;
        if (weeks < 0.1) return `${weeks.toFixed(3)} weeks`;
        if (weeks < 10) return `${weeks.toFixed(2)} weeks`;
        return `${weeks.toFixed(1)} weeks`;
      }

      function timeText(qaly) {
        return weeksText(qaly);
      }

      function percentText(value) {
        if (value < 0.0001) return `${(value * 100).toFixed(3)}%`;
        if (value < 0.001) return `${(value * 100).toFixed(2)}%`;
        if (value < 0.01) return `${(value * 100).toFixed(1)}%`;
        return `${(value * 100).toFixed(0)}%`;
      }

      function signedTimeText(value) {
        const abs = Math.abs(value);
        const label = timeText(abs);
        if (value > 0) return `${label} saved`;
        if (value < 0) return `${label} worse`;
        return "No modeled benefit";
      }

      function childrenText(value) {
        return value.toFixed(2);
      }

      function calculateDiseaseTotals({ perspective, partners, onlyCollege, hpvVaccineEffectiveness, uncertaintyScenario }) {
        const context = {
          perspective,
          partners,
          partnerSex: perspective === "female" ? "male" : "female",
          tier: onlyCollege ? "college" : "broad",
          actsPerPartner: TOTAL_ACTS / partners,
          uncertaintyScenario
        };

        return DISEASES.map((disease) => {
          const noCondom = diseaseOutcome(disease, context, false);
          const condom = diseaseOutcome(disease, context, true);

          return {
            name: disease.name,
            note: disease.note,
            noRisk: noCondom.probability,
            condomRisk: condom.probability,
            noCases: noCondom.expectedCases,
            condomCases: condom.expectedCases,
            noCondom: noCondom.qaly,
            condom: condom.qaly,
            vaccineBenefit: noCondom.qaly * (disease.vaccinePreventableShare ?? 0) * hpvVaccineEffectiveness,
            benefit: noCondom.qaly - condom.qaly
          };
        });
      }

      function renderBreakdown(rows) {
        diseaseBreakdown.innerHTML = rows
          .map((row) => `
            <article class="breakdown-row">
              <div class="disease-name">
                <strong>${row.name}</strong>
                <span>${row.note}</span>
              </div>
              <div><span class="mobile-label">Without condoms</span> ${weeksText(row.noCondom)}</div>
              <div><span class="mobile-label">With condoms</span> ${weeksText(row.condom)}</div>
              <div><span class="mobile-label">Benefit</span> ${weeksText(row.benefit)}</div>
            </article>
          `)
          .join("");
      }

      function setText(node, text) {
        if (node) node.textContent = text;
      }

      function update() {
        const partners = clampPartners(partnersRange.value);
        const perspective = new FormData(form).get("perspective") || "male";
        const onlyCollege = collegeOnly.checked;
        const birthControlKey = birthControl.value;
        const useMode = new FormData(form).get("use-mode") || "perfect";
        const noCondomBirthControl = BIRTH_CONTROL[birthControlKey] || BIRTH_CONTROL.withdrawal;
        const condomMode = condomPregnancyMode.value;
        const childRatePercent = clampNumber(childRateRange.value, 0, 100, DEFAULT_CHILD_PER_PREGNANCY * 100);
        const pregnancyPauseYears = DEFAULT_PREGNANCY_PAUSE_YEARS;
        const hpvVaccineEffectiveness = HPV_VACCINE_SCENARIOS[hpvVaccineScenario.value] ?? HPV_VACCINE_SCENARIOS.preExposure;
        const selectedUncertaintyScenario = uncertaintyScenario.value || "base";
        const noCondomAnnualFailure = noCondomBirthControl.annualFailure[useMode];
        const condomAnnualFailure = annualFailureWithCondoms(
          birthControlKey,
          noCondomAnnualFailure,
          CONDOM_ANNUAL_FAILURE[useMode],
          condomMode
        );

        partnersRange.value = String(partners);
        partnersNumber.value = String(partners);
        childRateRange.value = String(childRatePercent);
        childRateNumber.value = String(childRatePercent);
        const diseaseRows = calculateDiseaseTotals({
          perspective,
          partners,
          onlyCollege,
          hpvVaccineEffectiveness,
          uncertaintyScenario: selectedUncertaintyScenario
        });
        const noCondomSti = diseaseRows.reduce((total, row) => total + row.noCondom, 0);
        const condomSti = diseaseRows.reduce((total, row) => total + row.condom, 0);
        const vaccineBenefit = diseaseRows.reduce((total, row) => total + row.vaccineBenefit, 0);
        const noCondomPregnancy = pregnancyFor(
          noCondomAnnualFailure,
          perspective,
          partners,
          pregnancyPauseYears,
          childRatePercent / 100
        );
        const condomPregnancy = pregnancyFor(
          condomAnnualFailure,
          perspective,
          partners,
          pregnancyPauseYears,
          childRatePercent / 100
        );
        const noCondomTotal = noCondomSti;
        const condomTotal = condomSti;
        const benefit = noCondomTotal - condomTotal;
        const actsPerPartner = TOTAL_ACTS / partners;

        setText(ids.actsPerPartner, `${actsPerPartner.toFixed(actsPerPartner < 10 ? 1 : 0)} acts/partner`);
        setText(ids.condomBenefit, signedTimeText(benefit));
        setText(
          ids.benefitNote,
          benefit >= 0
            ? `Using condoms saves ${weeksText(Math.abs(benefit))} in this STI morbidity model. Pregnancy is excluded from QALY totals.`
            : `Condoms add no modeled STI/QALY benefit in this input set. Pregnancy is excluded from QALY totals.`
        );

        setText(ids.noTotal, weeksText(noCondomTotal));
        setText(ids.noPregRisk, percentText(noCondomPregnancy.probability));
        setText(ids.noProjectedChildren, childrenText(noCondomPregnancy.projectedChildren));

        setText(ids.condomTotal, weeksText(condomTotal));
        setText(ids.condomSaved, signedTimeText(benefit));
        setText(ids.vaccineBenefit, weeksText(vaccineBenefit));
        setText(ids.condomPregRisk, percentText(condomPregnancy.probability));
        setText(ids.condomProjectedChildren, childrenText(condomPregnancy.projectedChildren));

        renderBreakdown(diseaseRows);
      }

      partnersRange.addEventListener("input", () => {
        partnersNumber.value = partnersRange.value;
        update();
      });

      partnersNumber.addEventListener("input", () => {
        const value = clampPartners(partnersNumber.value);
        partnersRange.value = String(value);
        update();
      });

      childRateRange.addEventListener("input", () => {
        childRateNumber.value = childRateRange.value;
        update();
      });

      childRateNumber.addEventListener("input", () => {
        const value = clampNumber(childRateNumber.value, 0, 100, DEFAULT_CHILD_PER_PREGNANCY * 100);
        childRateRange.value = String(value);
        update();
      });

      form.addEventListener("input", update);
      form.addEventListener("change", update);

      update();
    </script>
  </body>
</html>

