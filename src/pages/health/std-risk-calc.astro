      function sexRelatedBacterialStiAntibioticCourses(stiRows) {
        return stiRows.reduce(
          (totals, row) => {
            const coursesPerCase = SEX_RELATED_BACTERIAL_STI_ANTIBIOTIC_COURSES_PER_CASE[row.name] ?? 0;
            return {
              noCondom: totals.noCondom + row.noCases * coursesPerCase,
              condom: totals.condom + row.condomCases * coursesPerCase
            };
          },
          { noCondom: 0, condom: 0 }
        );
      }

      function calculateDownstreamBurdenRows(stiRows, context) {
        const noCondomUti = postSexUtiOutcome(context, false);
        const condomUti = postSexUtiOutcome(context, true);
        const noCondomBv = marginalBacterialVaginosisOutcome(context, false);
        const condomBv = marginalBacterialVaginosisOutcome(context, true);
        const stiAntibioticCourses = sexRelatedBacterialStiAntibioticCourses(stiRows);
