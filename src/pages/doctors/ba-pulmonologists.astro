---
export const prerender = true;

const pageTitle = "Best pulmonologists in Buenos Aires";
const pageDescription =
  "Ranked pulmonologists in Buenos Aires by reputation, institutional role and ease of access, with Medifé coverage notes.";
const themeColorLight = "#fcfaf7";
const themeColorDark = "#111111";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const updatedDate = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
}).format(new Date());

type MedifeStatus = "yes" | "verify" | "private";

type Pulmonologist = {
  rank: number;
  name: string;
  where: string;
  notes: string;
  medifeLabel: string;
  medifeStatus: MedifeStatus;
};

const doctors: Pulmonologist[] = [
  {
    rank: 1,
    name: "Víctor Daniel Pascansky",
    where: "Sanatorio Finochietto; own office at Av. Acoyte 25, Caballito",
    notes:
      "Heads the pulmonology service at Medifé's own sanatorio, runs its clinical and teaching program on airway disease",
    medifeLabel: "Yes, all plans including Bronce",
    medifeStatus: "yes",
  },
  {
    rank: 2,
    name: "Eduardo Rubén Guzmán",
    where: "Céspedes 2646, Colegiales",
    notes:
      "Pulmonology plus allergy and immunology, 5.0 rating across ~147 reviews, US-trained, speaks English",
    medifeLabel: "Yes, all plans including Bronce",
    medifeStatus: "yes",
  },
  {
    rank: 3,
    name: "Hernán Ariel Iannella",
    where: "Sanatorio Otamendi, Recoleta",
    notes: "Adult asthma, bronchospasm and full respiratory function testing",
    medifeLabel: "Yes, Oro, Plata and Platinum only",
    medifeStatus: "yes",
  },
  {
    rank: 4,
    name: "Carlos Alberto Nigro",
    where: "Hospital Alemán",
    notes:
      "Head of the pulmonology service at one of the city's top private hospitals",
    medifeLabel: "Verify by plan",
    medifeStatus: "verify",
  },
  {
    rank: 5,
    name: "Jorge Cáneva",
    where: "Fundación Favaloro",
    notes:
      "Head of pulmonology, access to advanced cardiopulmonary exercise testing (ergoespirometría)",
    medifeLabel: "Verify by plan",
    medifeStatus: "verify",
  },
  {
    rank: 6,
    name: "Pablo Rodríguez",
    where: "CEMIC, Finochietto and a private office in Belgrano",
    notes:
      "5.0 rating across ~85 reviews, former head of pulmonology at CEMIC",
    medifeLabel:
      "Private pay at his office, possibly covered via CEMIC or Finochietto",
    medifeStatus: "private",
  },
  {
    rank: 7,
    name: "Juan Facundo Nogueira",
    where: "Hospital de Clínicas, Finochietto, Otamendi",
    notes:
      "Strong academic profile, though his subspecialty leans toward sleep medicine",
    medifeLabel: "Private pay at his office",
    medifeStatus: "private",
  },
];

const acceptsMedifeCount = doctors.filter(
  (doctor) => doctor.medifeStatus === "yes",
).length;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  numberOfItems: doctors.length,
  itemListElement: doctors.map((doctor) => ({
    "@type": "ListItem",
    position: doctor.rank,
    item: {
      "@type": "Physician",
      name: doctor.name,
      medicalSpecialty: "Pulmonary Disease",
      description: doctor.notes,
      address: doctor.where,
    },
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="subject" content="Best pulmonologists in Buenos Aires" />
    <meta name="application-name" content={pageTitle} />
    <meta
      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="googlebot"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="keywords"
      content="pulmonologist Buenos Aires, best pulmonologists Buenos Aires, neumólogo Buenos Aires, Medifé pulmonologist, asthma doctor Buenos Aires"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta
      name="theme-color"
      content={themeColorLight}
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content={themeColorDark}
      media="(prefers-color-scheme: dark)"
    />
    <meta name="msapplication-TileColor" content={themeColorDark} />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color={themeColorDark} />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Nikita Sokolsky" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <main class="page">
      <header class="page-header">
        <a class="home-link" href="/">Nikita Sokolsky</a>
        <div class="headline">
          <p class="eyebrow">Buenos Aires guide</p>
          <h1>{pageTitle}</h1>
          <p class="intro">
            Ranked by reputation, institutional role and ease of access. Medifé
            coverage varies by plan and by address, so confirm with the provider
            before booking.
          </p>
        </div>
        <div class="toolbar" aria-label="Pulmonologist filters">
          <fieldset class="extras-toggle">
            <legend>Filter</legend>
            <input id="filter-accepts-medife" type="checkbox" autocomplete="off" />
            <label for="filter-accepts-medife"
              >Accepts Medifé ({acceptsMedifeCount})</label
            >
          </fieldset>
          <p class="meta" id="list-status">
            Updated {updatedDate}. Showing all {doctors.length} pulmonologists.
          </p>
        </div>
      </header>

      <section class="doctor-list" aria-label="Buenos Aires pulmonologists">
        <div class="doctor-row doctor-head" aria-hidden="true">
          <span>Rank</span>
          <span>Doctor</span>
          <span>Where</span>
          <span>Notes</span>
          <span>Medifé</span>
        </div>

        {
          doctors.map((doctor) => (
            <article
              class="doctor-row"
              data-accepts-medife={String(doctor.medifeStatus === "yes")}
            >
              <p class="rank" aria-label={`Rank ${doctor.rank}`}>
                {doctor.rank}
              </p>
              <h2 class="doctor-name">{doctor.name}</h2>
              <p class="where">{doctor.where}</p>
              <p class="notes">{doctor.notes}</p>
              <p
                class:list={[
                  "medife",
                  doctor.medifeStatus === "yes" && "medife-yes",
                  doctor.medifeStatus === "verify" && "medife-verify",
                  doctor.medifeStatus === "private" && "medife-private",
                ]}
              >
                {doctor.medifeLabel}
              </p>
            </article>
          ))
        }
      </section>
    </main>
  </body>
</html>

<script is:inline>
  const medifeFilter = document.querySelector("#filter-accepts-medife");
  const listStatus = document.querySelector("#list-status");
  const doctorRows = [...document.querySelectorAll(".doctor-row:not(.doctor-head)")];
  const totalCount = doctorRows.length;

  const hasEnabledUrlParam = (params, key) => {
    const value = params.get(key);
    return value === "1" || value === "true" || value === "yes";
  };

  const updateFilterUrl = (acceptsMedifeOnly) => {
    const url = new URL(window.location.href);
    url.searchParams.delete("medife");
    if (acceptsMedifeOnly) url.searchParams.set("medife", "1");

    const nextUrl = `${url.pathname}${url.search}${url.hash}`;
    const currentUrl = `${window.location.pathname}${window.location.search}${window.location.hash}`;
    if (nextUrl !== currentUrl) {
      window.history.replaceState(null, "", nextUrl);
    }
  };

  const applyFilters = ({ syncUrl = true } = {}) => {
    const acceptsMedifeOnly = Boolean(medifeFilter?.checked);
    let visibleCount = 0;

    for (const row of doctorRows) {
      const accepts = row.dataset.acceptsMedife === "true";
      const visible = !acceptsMedifeOnly || accepts;
      row.hidden = !visible;
      if (visible) visibleCount += 1;
    }

    if (listStatus) {
      listStatus.textContent = acceptsMedifeOnly
        ? `Showing ${visibleCount} pulmonologist${visibleCount === 1 ? "" : "s"} who accept Medifé.`
        : `Showing all ${totalCount} pulmonologists.`;
    }

    if (syncUrl) updateFilterUrl(acceptsMedifeOnly);
  };

  const applyFiltersFromUrl = () => {
    const params = new URLSearchParams(window.location.search);
    if (medifeFilter) {
      medifeFilter.checked = hasEnabledUrlParam(params, "medife");
    }
    applyFilters({ syncUrl: false });
  };

  medifeFilter?.addEventListener("change", () => applyFilters());
  applyFiltersFromUrl();
  window.addEventListener("pageshow", applyFiltersFromUrl);
  window.addEventListener("popstate", applyFiltersFromUrl);
</script>

<style>
  :root {
    color-scheme: light dark;
    --bg: #fcfaf7;
    --surface: #fffdf8;
    --surface-soft: #efe7db;
    --text: #181612;
    --text-muted: #6f675c;
    --border: #d9cfc0;
    --border-strong: #c8baa8;
    --accent: #28402f;
    --accent-soft: #dfe8d7;
    --link: #17281d;
    --shadow: 0 20px 60px rgba(61, 44, 22, 0.08);
    --yes: #2f5d3a;
    --yes-soft: #dcead9;
    --verify: #8a6a2f;
    --verify-soft: #f3e7c8;
    --private: #6f675c;
    --private-soft: #ebe4d8;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #10100e;
      --surface: #171613;
      --surface-soft: #211f1a;
      --text: #f2eee7;
      --text-muted: #aaa297;
      --border: #343027;
      --border-strong: #4a4338;
      --accent: #dce8d2;
      --accent-soft: #263022;
      --link: #f6f1e8;
      --shadow: none;
      --yes: #b7d4b8;
      --yes-soft: #243126;
      --verify: #e2c788;
      --verify-soft: #332914;
      --private: #aaa297;
      --private-soft: #26231e;
    }
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-family:
      -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial,
      sans-serif;
    font-size: 16px;
    background: var(--bg);
    color: var(--text);
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    margin: 0;
    background:
      radial-gradient(
        circle at 15% 0%,
        color-mix(in srgb, var(--accent-soft), transparent 35%),
        transparent 32rem
      ),
      var(--bg);
  }

  a {
    color: var(--link);
    text-decoration-color: color-mix(in srgb, var(--link), transparent 62%);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
  }

  a:hover {
    text-decoration-color: currentColor;
  }

  .page {
    width: min(100%, 72rem);
    margin: 0 auto;
    padding: 0.75rem clamp(0.7rem, 1.6vw, 1.25rem) 1.25rem;
  }

  .page-header {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.55rem;
    align-items: start;
    padding: 0.35rem 0 0.65rem;
  }

  .home-link {
    width: fit-content;
    color: var(--text-muted);
    font-size: 0.82rem;
    text-decoration: none;
  }

  .home-link:hover {
    color: var(--text);
  }

  .headline {
    display: grid;
    gap: 0.28rem;
  }

  .eyebrow {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.35rem, 2.4vw, 1.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
  }

  .intro {
    margin: 0;
    max-width: 42rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.55rem;
  }

  .extras-toggle {
    display: flex;
    width: fit-content;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin: 0;
    padding: 0.28rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: color-mix(in srgb, var(--surface), transparent 6%);
    box-shadow: var(--shadow);
  }

  .extras-toggle legend {
    margin: 0 0.2rem 0 0.15rem;
    padding: 0;
    color: var(--text-muted);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1.75rem;
    text-transform: uppercase;
  }

  .extras-toggle input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .extras-toggle label {
    display: inline-flex;
    min-height: 1.75rem;
    align-items: center;
    gap: 0.35rem;
    justify-content: center;
    border-radius: 999px;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 0.78rem;
    font-weight: 700;
    padding: 0 0.6rem;
    transition:
      background 0.18s ease,
      color 0.18s ease;
  }

  .extras-toggle label::before {
    content: "";
    width: 0.5rem;
    height: 0.5rem;
    border: 1.5px solid currentColor;
    border-radius: 999px;
    opacity: 0.75;
  }

  #filter-accepts-medife:checked ~ label[for="filter-accepts-medife"] {
    background: var(--accent);
    color: var(--bg);
  }

  #filter-accepts-medife:checked ~ label[for="filter-accepts-medife"]::before {
    background: currentColor;
    box-shadow: inset 0 0 0 3px var(--accent);
    opacity: 1;
  }

  .meta {
    margin: 0;
    flex-basis: 100%;
    max-width: 42rem;
    color: var(--text-muted);
    font-size: 0.76rem;
    text-align: left;
  }

  .doctor-list {
    display: grid;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 1rem;
    background: var(--surface);
    box-shadow: var(--shadow);
  }

  .doctor-row {
    display: grid;
    grid-template-columns:
      3.4rem
      minmax(8.5rem, 1.05fr)
      minmax(9.5rem, 1.2fr)
      minmax(13rem, 1.7fr)
      minmax(9.5rem, 1.15fr);
    gap: 0;
    align-items: stretch;
    border-top: 1px solid var(--border);
  }

  .doctor-row[hidden] {
    display: none;
  }

  .doctor-head {
    border-top: 0;
    background: var(--surface-soft);
    color: var(--text-muted);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .doctor-row > * {
    min-width: 0;
    margin: 0;
    padding: 0.5rem 0.55rem;
    border-left: 1px solid var(--border);
    overflow-wrap: anywhere;
  }

  .doctor-row > *:first-child {
    border-left: 0;
  }

  .rank {
    color: var(--text-muted);
    font-size: 0.88rem;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
  }

  .doctor-name {
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .where,
  .notes {
    color: var(--text-muted);
    font-size: 0.84rem;
    line-height: 1.35;
  }

  .medife {
    font-size: 0.82rem;
    font-weight: 650;
    line-height: 1.3;
  }

  .medife-yes {
    color: var(--yes);
  }

  .medife-verify {
    color: var(--verify);
  }

  .medife-private {
    color: var(--private);
  }

  @media (max-width: 900px) {
    .page {
      padding: 0.55rem 0.6rem 1rem;
    }

    .page-header {
      padding: 0.15rem 0 0.5rem;
      gap: 0.45rem;
    }

    h1 {
      font-size: 1.35rem;
      line-height: 1.15;
    }

    .intro {
      font-size: 0.86rem;
      line-height: 1.38;
    }

    .doctor-list {
      border-radius: 0.9rem;
      background: transparent;
      border-color: var(--border-strong);
    }

    .doctor-head {
      display: none;
    }

    .doctor-row {
      grid-template-columns: auto 1fr;
      grid-template-areas:
        "rank name"
        "where where"
        "notes notes"
        "medife medife";
      gap: 0.12rem 0.5rem;
      align-items: start;
      border-top: 1px solid var(--border);
      background: var(--surface);
      padding: 0.55rem 0.65rem;
    }

    .doctor-row:first-of-type {
      border-top: 0;
    }

    .doctor-row > * {
      padding: 0;
      border-left: 0;
    }

    .rank {
      grid-area: rank;
      font-size: 0.82rem;
      line-height: 1.3;
    }

    .doctor-name {
      grid-area: name;
      font-size: 0.9rem;
      line-height: 1.25;
    }

    .where {
      grid-area: where;
      margin-top: 0.1rem;
      font-size: 0.82rem;
    }

    .notes {
      grid-area: notes;
      font-size: 0.84rem;
      line-height: 1.32;
    }

    .medife {
      grid-area: medife;
      margin-top: 0.12rem;
      width: fit-content;
      max-width: 100%;
      padding: 0.18rem 0.45rem;
      border-radius: 999px;
      font-size: 0.74rem;
    }

    .medife-yes {
      background: var(--yes-soft);
    }

    .medife-verify {
      background: var(--verify-soft);
    }

    .medife-private {
      background: var(--private-soft);
    }
  }
</style>
