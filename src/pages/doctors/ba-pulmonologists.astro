---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="subject" content="Best pulmonologists in Buenos Aires" />
    <meta name="application-name" content={pageTitle} />
    <meta
      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="googlebot"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="keywords"
      content="pulmonologist Buenos Aires, best pulmonologists Buenos Aires, neumólogo Buenos Aires, Medifé pulmonologist, asthma doctor Buenos Aires"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta
      name="theme-color"
      content={themeColorLight}
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content={themeColorDark}
      media="(prefers-color-scheme: dark)"
    />
    <meta name="msapplication-TileColor" content={themeColorDark} />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color={themeColorDark} />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Nikita Sokolsky" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <main class="page">
      <header class="page-header">
        <a class="home-link" href="/">Nikita Sokolsky</a>
        <div class="headline">
          <p class="eyebrow">Buenos Aires guide</p>
          <h1>{pageTitle}</h1>
          <p class="intro">
            Ranked by reputation, institutional role and ease of access. Medifé
            coverage varies by plan and by address, so confirm with the provider
            before booking.
          </p>
        </div>
        <div class="toolbar" aria-label="Pulmonologist filters">
          <fieldset class="extras-toggle">
            <legend>Filter</legend>
            <input id="filter-accepts-medife" type="checkbox" autocomplete="off" />
            <label for="filter-accepts-medife"
              >Accepts Medifé ({acceptsMedifeCount})</label
            >
          </fieldset>
          <p class="meta" id="list-status">
            Updated {updatedDate}. Showing all {doctors.length} pulmonologists.
          </p>
        </div>
      </header>

      <section class="doctor-list" aria-label="Buenos Aires pulmonologists">
        <div class="doctor-row doctor-head" aria-hidden="true">
          <span>Rank</span>
          <span>Doctor</span>
          <span>How to book</span>
          <span>Notes</span>
          <span>Medifé</span>
        </div>

        {
          doctors.map((doctor) => (
            <article
              class="doctor-row"
              data-accepts-medife={String(doctor.medifeStatus === "yes")}
            >
              <p class="rank" aria-label={`Rank ${doctor.rank}`}>
                {doctor.rank}
              </p>
              <h2 class="doctor-name">
                <a href={doctor.url} target="_blank" rel="noreferrer noopener">
                  {doctor.name}
                </a>
              </h2>
              <div class="booking">
                <p class="booking-lead">{doctor.bookingLead}</p>
                {
                  doctor.bookingLinks.length > 0 && (
                    <p class="booking-links">
                      {doctor.bookingLinks.map((link, index) => (
                        <>
                          {index > 0 && <span class="booking-sep"> · </span>}
                          <a
                            href={link.href}
                            target="_blank"
                            rel="noreferrer noopener"
                          >
                            {link.label}
                          </a>
                        </>
                      ))}
                    </p>
                  )
                }
              </div>
              <p class="notes">{doctor.notes}</p>
              <p
                class:list={[
                  "medife",
                  doctor.medifeStatus === "yes" && "medife-yes",
                  doctor.medifeStatus === "verify" && "medife-verify",
                  doctor.medifeStatus === "private" && "medife-private",
                ]}
              >
                {doctor.medifeLabel}
              </p>
            </article>
          ))
        }
      </section>
    </main>
  </body>
</html>

<script is:inline>
  const medifeFilter = document.querySelector("#filter-accepts-medife");
  const listStatus = document.querySelector("#list-status");
  const doctorRows = [...document.querySelectorAll(".doctor-row:not(.doctor-head)")];
  const totalCount = doctorRows.length;

  const hasEnabledUrlParam = (params, key) => {
    const value = params.get(key);
    return value === "1" || value === "true" || value === "yes";
  };

  const updateFilterUrl = (acceptsMedifeOnly) => {
    const url = new URL(window.location.href);
    url.searchParams.delete("medife");
    if (acceptsMedifeOnly) url.searchParams.set("medife", "1");

    const nextUrl = `${url.pathname}${url.search}${url.hash}`;
    const currentUrl = `${window.location.pathname}${window.location.search}${window.location.hash}`;
    if (nextUrl !== currentUrl) {
      window.history.replaceState(null, "", nextUrl);
    }
  };

  const applyFilters = ({ syncUrl = true } = {}) => {
    const acceptsMedifeOnly = Boolean(medifeFilter?.checked);
    let visibleCount = 0;

    for (const row of doctorRows) {
      const accepts = row.dataset.acceptsMedife === "true";
      const visible = !acceptsMedifeOnly || accepts;
      row.hidden = !visible;
      if (visible) visibleCount += 1;
    }

    if (listStatus) {
      listStatus.textContent = acceptsMedifeOnly
        ? `Showing ${visibleCount} pulmonologist${visibleCount === 1 ? "" : "s"} who accept Medifé.`
        : `Showing all ${totalCount} pulmonologists.`;
    }

    if (syncUrl) updateFilterUrl(acceptsMedifeOnly);
  };

  const applyFiltersFromUrl = () => {
    const params = new URLSearchParams(window.location.search);
    if (medifeFilter) {
      medifeFilter.checked = hasEnabledUrlParam(params, "medife");
    }
    applyFilters({ syncUrl: false });
  };

  medifeFilter?.addEventListener("change", () => applyFilters());
  applyFiltersFromUrl();
  window.addEventListener("pageshow", applyFiltersFromUrl);
  window.addEventListener("popstate", applyFiltersFromUrl);
</script>

<style>
  :root {
    color-scheme: light dark;
    --bg: #fcfaf7;
    --surface: #fffdf8;
    --surface-soft: #efe7db;
    --text: #181612;
    --text-muted: #6f675c;
    --border: #d9cfc0;
    --border-strong: #c8baa8;
    --accent: #28402f;
    --accent-soft: #dfe8d7;
    --link: #17281d;
    --shadow: 0 20px 60px rgba(61, 44, 22, 0.08);
    --yes: #2f5d3a;
    --yes-soft: #dcead9;
    --verify: #8a6a2f;
    --verify-soft: #f3e7c8;
    --private: #6f675c;
    --private-soft: #ebe4d8;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #10100e;
      --surface: #171613;
      --surface-soft: #211f1a;
      --text: #f2eee7;
      --text-muted: #aaa297;
      --border: #343027;
      --border-strong: #4a4338;
      --accent: #dce8d2;
      --accent-soft: #263022;
      --link: #f6f1e8;
      --shadow: none;
      --yes: #b7d4b8;
      --yes-soft: #243126;
      --verify: #e2c788;
      --verify-soft: #332914;
      --private: #aaa297;
      --private-soft: #26231e;
    }
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-family:
      -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial,
      sans-serif;
    font-size: 16px;
    background: var(--bg);
    color: var(--text);
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    margin: 0;
    background:
      radial-gradient(
        circle at 15% 0%,
        color-mix(in srgb, var(--accent-soft), transparent 35%),
        transparent 32rem
      ),
      var(--bg);
  }

  a {
    color: var(--link);
    text-decoration-color: color-mix(in srgb, var(--link), transparent 62%);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
  }

  a:hover {
    text-decoration-color: currentColor;
  }

  .page {
    width: min(100%, 72rem);
    margin: 0 auto;
    padding: 0.75rem clamp(0.7rem, 1.6vw, 1.25rem) 1.25rem;
  }

  .page-header {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.55rem;
    align-items: start;
    padding: 0.35rem 0 0.65rem;
  }

  .home-link {
    width: fit-content;
    color: var(--text-muted);
    font-size: 0.82rem;
    text-decoration: none;
  }

  .home-link:hover {
    color: var(--text);
  }

  .headline {
    display: grid;
    gap: 0.28rem;
  }

  .eyebrow {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
