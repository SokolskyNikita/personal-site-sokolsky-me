---
import pageData from "../../data/imdb-scores.json";

export const prerender = true;

const pageTitle = "IMDb ratings";
const pageDescription =
  "Personal IMDb ratings for movies and TV, sorted by year of release.";
const themeColorLight = "#f3f5f7";
const themeColorDark = "#12151a";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const ratings = pageData.ratings.map((rating) => ({
  ...rating,
  diff:
    rating.myRating == null || rating.imdbRating == null
      ? null
      : Math.round((rating.myRating - rating.imdbRating) * 10) / 10,
}));
const updatedDate = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
}).format(new Date(pageData.generatedAt));
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
};

const formatImdb = (value: number | null) =>
  value == null
    ? "—"
    : new Intl.NumberFormat("en-US", {
        minimumFractionDigits: 1,
        maximumFractionDigits: 1,
      }).format(value);
const formatDiff = (value: number | null) =>
  value == null ? "—" : `${value > 0 ? "+" : ""}${value.toFixed(1)}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta
      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="googlebot"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta
      name="theme-color"
      content={themeColorLight}
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content={themeColorDark}
      media="(prefers-color-scheme: dark)"
    />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&family=Newsreader:opsz,wght@6..72,500&display=swap"
      rel="stylesheet"
    />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Nikita Sokolsky" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    ></script>
  </head>
  <body>
    <main class="page">
      <header class="page-header">
        <a class="home-link" href="/">
          <span aria-hidden="true">←</span>
          Nikita Sokolsky
        </a>
        <div class="header-grid">
          <div class="headline">
            <p class="eyebrow">Watch log</p>
            <h1>{pageTitle}</h1>
            <p class="intro">
              Films and series I’ve rated, from newest releases to oldest.
            </p>
          </div>
          <dl class="summary" aria-label="Ratings summary">
            <div>
              <dt>Titles</dt>
              <dd>{ratings.length}</dd>
            </div>
            <div>
              <dt>Updated</dt>
              <dd>{updatedDate}</dd>
            </div>
          </dl>
        </div>

        <label class="mobile-sort" for="mobile-sort">
          <span>Sort by</span>
          <select id="mobile-sort" name="sort" autocomplete="off">
            <option value="year:desc" selected>Year · newest</option>
            <option value="year:asc">Year · oldest</option>
            <option value="title:asc">Title · A–Z</option>
            <option value="title:desc">Title · Z–A</option>
            <option value="myRating:desc">My rating · high</option>
            <option value="myRating:asc">My rating · low</option>
            <option value="imdbRating:desc">IMDb · high</option>
            <option value="imdbRating:asc">IMDb · low</option>
            <option value="diff:desc">Difference · high</option>
            <option value="diff:asc">Difference · low</option>
          </select>
        </label>
      </header>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th scope="col" aria-sort="none">
                <button
                  class="sort-button"
                  type="button"
                  data-sort-key="title"
                  data-sort-default="asc"
                >
                  Title
                </button>
              </th>
              <th scope="col" aria-sort="descending">
                <button
                  class="sort-button"
                  type="button"
                  data-sort-key="year"
                  data-sort-default="desc"
                >
                  Year
                </button>
              </th>
              <th scope="col" aria-sort="none">
                <button
                  class="sort-button"
                  type="button"
                  data-sort-key="myRating"
                  data-sort-default="desc"
                >
                  Mine
                </button>
              </th>
              <th scope="col" aria-sort="none">
                <button
                  class="sort-button"
                  type="button"
                  data-sort-key="imdbRating"
                  data-sort-default="desc"
                >
                  IMDb
                </button>
              </th>
              <th scope="col" aria-sort="none">
                <button
                  class="sort-button"
                  type="button"
                  data-sort-key="diff"
                  data-sort-default="desc"
                >
                  Diff
                </button>
              </th>
            </tr>
          </thead>
          <tbody>
            {
              ratings.map((rating) => (
                <tr
                  data-title={rating.title}
                  data-year={rating.year}
                  data-my-rating={rating.myRating ?? ""}
                  data-imdb-rating={rating.imdbRating ?? ""}
                  data-diff={rating.diff ?? ""}
                >
                  <td class="title-cell">
                    <a
                      href={rating.url}
                      target="_blank"
                      rel="noreferrer noopener"
                    >
                      {rating.title}
                    </a>
                    {rating.titleType !== "Movie" && (
                      <span class="type-tag">{rating.titleType}</span>
                    )}
                  </td>
                  <td class="num-cell year-cell">{rating.year}</td>
                  <td class="num-cell mine-cell">{rating.myRating ?? "—"}</td>
                  <td class="num-cell imdb-cell">
                    {formatImdb(rating.imdbRating)}
                  </td>
                  <td
                    class:list={[
                      "num-cell",
                      "diff-cell",
                      rating.diff != null && rating.diff > 0 && "diff-positive",
                      rating.diff != null && rating.diff < 0 && "diff-negative",
                      rating.diff === 0 && "diff-neutral",
                    ]}
                  >
                    {formatDiff(rating.diff)}
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </main>
  </body>
</html>

<script is:inline>
  const tableBody = document.querySelector("tbody");
  const rows = [...document.querySelectorAll("tbody tr")];
  const sortButtons = [...document.querySelectorAll(".sort-button")];
  const mobileSort = document.querySelector("#mobile-sort");
  const collator = new Intl.Collator("en", {
    sensitivity: "base",
    numeric: true,
  });

  let currentSort = {
    key: "year",
    direction: "desc",
  };

  const getSortValue = (row, key) => {
    if (key === "title") return row.dataset.title ?? "";
    if (key === "year") return Number(row.dataset.year ?? 0);
    if (key === "myRating") {
      const value = row.dataset.myRating;
      return value === "" ? Number.NEGATIVE_INFINITY : Number(value);
    }
    if (key === "diff") {
      const value = row.dataset.diff;
      return value === "" ? Number.NEGATIVE_INFINITY : Number(value);
    }
    const value = row.dataset.imdbRating;
    return value === "" ? Number.NEGATIVE_INFINITY : Number(value);
  };

  const compareRows = (firstRow, secondRow) => {
    const firstValue = getSortValue(firstRow, currentSort.key);
    const secondValue = getSortValue(secondRow, currentSort.key);
    const multiplier = currentSort.direction === "asc" ? 1 : -1;

    if (currentSort.key === "title") {
      const byTitle =
        multiplier *
        collator.compare(String(firstValue), String(secondValue));
      if (byTitle !== 0) return byTitle;
      return Number(secondRow.dataset.year ?? 0) - Number(firstRow.dataset.year ?? 0);
    }

    const numericDifference = Number(firstValue) - Number(secondValue);
    if (numericDifference !== 0) return multiplier * numericDifference;

    return collator.compare(
      firstRow.dataset.title ?? "",
      secondRow.dataset.title ?? "",
    );
  };

  const syncMobileSelect = () => {
    if (!mobileSort) return;
    mobileSort.value = `${currentSort.key}:${currentSort.direction}`;
  };

  const updateSortState = () => {
    for (const button of sortButtons) {
      const isActive = button.dataset.sortKey === currentSort.key;
      button.dataset.sortDirection = isActive ? currentSort.direction : "";
      button.closest("th")?.setAttribute(
        "aria-sort",
        isActive
          ? currentSort.direction === "asc"
            ? "ascending"
            : "descending"
          : "none",
      );
    }
    syncMobileSelect();
  };

  const sortRows = () => {
    if (!tableBody) return;
    const sortedRows = [...rows].sort(compareRows);
    for (const row of sortedRows) {
      tableBody.append(row);
    }
    updateSortState();
  };

  for (const button of sortButtons) {
    button.addEventListener("click", () => {
      const sortKey = button.dataset.sortKey;
      if (!sortKey) return;

      const defaultDirection = button.dataset.sortDefault ?? "desc";
      currentSort =
        currentSort.key === sortKey
          ? {
              key: sortKey,
              direction: currentSort.direction === "asc" ? "desc" : "asc",
            }
          : {
              key: sortKey,
              direction: defaultDirection,
            };

      sortRows();
    });
  }

  mobileSort?.addEventListener("change", () => {
    const [key, direction] = (mobileSort.value || "year:desc").split(":");
    currentSort = { key, direction };
    sortRows();
  });

  updateSortState();
</script>

<style>
  :root {
    color-scheme: light dark;
    --bg: #f3f4f1;
    --surface: #fafaf7;
    --surface-hover: #f0f2ed;
    --text: #20251f;
    --muted: #687064;
    --line: #d8dcd3;
    --line-strong: #b9c0b5;
    --accent: #315f49;
    --accent-soft: #dfe9e1;
    --mine: #226847;
    --lower: #a44138;
    --focus: #2c7151;
    --shadow: 0 14px 36px rgb(42 52 43 / 7%);
    --space-xs: 0.375rem;
    --space-sm: 0.75rem;
    --space-md: 1.25rem;
    --space-lg: 2rem;
    --space-xl: 3.5rem;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #151814;
      --surface: #1c211c;
      --surface-hover: #232a23;
      --text: #edf0e9;
      --muted: #a4ada0;
      --line: #343c33;
      --line-strong: #505b4e;
      --accent: #9bc8aa;
      --accent-soft: #26382c;
      --mine: #8ed3a5;
      --lower: #f09a8d;
      --focus: #a8dbb8;
      --shadow: 0 18px 42px rgb(0 0 0 / 28%);
    }
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
    color: var(--text);
    font-family: "IBM Plex Sans", ui-sans-serif, system-ui, sans-serif;
    line-height: 1.45;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    margin: 0;
    min-height: 100vh;
  }

  a {
    color: inherit;
    text-decoration-color: color-mix(in srgb, var(--accent) 45%, transparent);
    text-underline-offset: 0.14em;
  }

  a:hover {
    color: var(--accent);
  }

  :focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 3px;
  }

  .page {
    width: min(56rem, calc(100% - 2rem));
    margin: 0 auto;
    padding: 1rem 0 clamp(3rem, 7vw, 5rem);
  }

  .page-header {
    display: grid;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .home-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    width: max-content;
    color: var(--muted);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.035em;
    text-decoration: none;
  }

  .home-link span {
    transition: transform 180ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .home-link:hover span {
    transform: translateX(-3px);
  }

  .header-grid {
    display: grid;
    gap: 1rem;
  }

  .headline {
    display: grid;
    gap: var(--space-xs);
  }

  .eyebrow {
    margin: 0 0 0.15rem;
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-family: "Newsreader", Georgia, serif;
    font-size: clamp(2.25rem, 10vw, 3rem);
    font-weight: 500;
    letter-spacing: -0.035em;
    line-height: 0.98;
  }

  .intro {
    margin: 0;
    max-width: 36rem;
    color: var(--muted);
    font-size: 0.9rem;
    text-wrap: pretty;
  }

  .summary {
    display: flex;
    gap: 1.5rem;
    margin: 0;
    padding: var(--space-sm) 0 0;
    border-top: 1px solid var(--line);
  }

  .summary div {
    display: grid;
    gap: 0.1rem;
  }

  .summary dt {
    color: var(--muted);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .summary dd {
    margin: 0;
    font-size: 0.86rem;
    font-variant-numeric: tabular-nums;
    font-weight: 500;
  }

  .mobile-sort {
    display: grid;
    gap: var(--space-xs);
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 600;
  }

  .mobile-sort select {
    appearance: none;
    width: 100%;
    min-height: 44px;
    padding: 0.7rem 2.5rem 0.7rem 0.85rem;
    border: 1px solid var(--line);
    border-radius: 0.6rem;
    background:
      linear-gradient(45deg, transparent 50%, var(--muted) 50%) calc(100% - 16px) / 5px 5px no-repeat,
      linear-gradient(135deg, var(--muted) 50%, transparent 50%) calc(100% - 11px) / 5px 5px no-repeat,
      var(--surface);
    color: var(--text);
    font: inherit;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .table-wrap {
    overflow: clip;
    border: 1px solid var(--line);
    border-radius: 0.85rem;
    background: var(--surface);
    box-shadow: var(--shadow);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  thead {
    display: none;
  }

  th,
  td {
    padding: 7px 10px;
    text-align: left;
    vertical-align: baseline;
    border-bottom: 1px solid var(--line);
  }

  tbody tr:last-child td {
    border-bottom: 0;
  }

  tbody tr {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    column-gap: 0.7rem;
    row-gap: 0.2rem;
    padding: 0.8rem 0.9rem;
    border-bottom: 1px solid var(--line);
    transition: background-color 140ms ease-out;
  }

  tbody tr:last-child {
    border-bottom: 0;
  }

  tbody td {
    padding: 0;
    border: 0;
  }

  .title-cell {
    flex: 1 1 100%;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-xs);
    min-width: 0;
    font-weight: 500;
    line-height: 1.35;
  }

  .title-cell a {
    text-decoration: none;
  }

  .title-cell a:hover {
    text-decoration: underline;
  }

  .type-tag {
    color: var(--muted);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.045em;
    text-transform: uppercase;
  }

  .year-cell {
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }

  .mine-cell,
  .imdb-cell,
  .diff-cell {
    font-variant-numeric: tabular-nums;
  }

  .mine-cell::before {
    content: "mine ";
    color: var(--muted);
    font-weight: 400;
  }

  .imdb-cell::before {
    content: "imdb ";
    color: var(--muted);
    font-weight: 400;
  }

  .diff-cell::before {
    content: "diff ";
    color: var(--muted);
    font-weight: 400;
  }

  .mine-cell {
    color: var(--mine);
    font-weight: 600;
  }

  .diff-cell {
    font-weight: 600;
  }

  .diff-positive {
    color: var(--mine);
  }

  .diff-negative {
    color: var(--lower);
  }

  .diff-neutral {
    color: var(--muted);
  }

  .sort-button {
    display: inline-flex;
    align-items: center;
    justify-content: inherit;
    gap: 0.3rem;
    min-height: 32px;
    margin: -0.35rem 0;
    padding: 0.35rem 0;
    border: 0;
    background: transparent;
    color: inherit;
    font: inherit;
    font-weight: 600;
    letter-spacing: 0.055em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .sort-button:hover {
    color: var(--text);
  }

  .sort-button:active {
    transform: translateY(1px);
  }

  .sort-button::after {
    content: "↕";
    opacity: 0.32;
    font-size: 0.8em;
  }

  .sort-button[data-sort-direction="asc"]::after {
    content: "↑";
    opacity: 1;
  }

  .sort-button[data-sort-direction="desc"]::after {
    content: "↓";
    opacity: 1;
  }

  @media (hover: hover) {
    tbody tr:hover {
      background: var(--surface-hover);
    }
  }

  @media (min-width: 640px) {
    .page {
      padding-top: clamp(1.75rem, 4vw, 3.25rem);
    }

    .page-header {
      gap: clamp(1.75rem, 3vw, 2.5rem);
      margin-bottom: 1.5rem;
    }

    .header-grid {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: end;
      gap: var(--space-lg);
    }

    .summary {
      display: grid;
      grid-template-columns: repeat(2, auto);
      gap: var(--space-lg);
      padding: 0 0 0.2rem;
      border-top: 0;
    }

    .mobile-sort {
      display: none;
    }

    thead {
      display: table-header-group;
    }

    table {
      table-layout: fixed;
    }

    thead th {
      position: sticky;
      top: 0;
      z-index: 1;
      height: 2.75rem;
      padding: 0.45rem 0.75rem;
      background: color-mix(in srgb, var(--surface) 88%, var(--accent-soft));
      color: var(--muted);
      font-size: 0.67rem;
      border-bottom: 1px solid var(--line-strong);
    }

    thead th:not(:first-child) .sort-button {
      width: 100%;
      justify-content: flex-end;
    }

    tbody tr {
      display: table-row;
      padding: 0;
      border-bottom: 0;
    }

    tbody td {
      padding: 0.48rem 0.75rem;
      border-bottom: 1px solid var(--line);
    }

    thead th:first-child,
    .title-cell {
      width: 54%;
      display: table-cell;
      flex: initial;
    }

    .num-cell {
      width: 11.5%;
      text-align: right;
      font-variant-numeric: tabular-nums;
    }

    .year-cell {
      color: var(--text);
    }

    .mine-cell::before,
    .imdb-cell::before,
    .diff-cell::before {
      content: none;
    }

    .mine-cell {
      color: var(--mine);
    }

    .imdb-cell {
      color: var(--text);
      font-weight: 500;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-link span,
    tbody tr {
      transition: none;
    }
  }
</style>
