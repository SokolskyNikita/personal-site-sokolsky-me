---
import pageData from "../../data/restaurants-buenos-aires.json";

export const prerender = true;

const pageTitle = "Best restaurants in Buenos Aires";
const pageDescription =
  "Buenos Aires restaurants checked against Google Maps, with ratings, prices, addresses and official links.";
const themeColorLight = "#f7f2ea";
const themeColorDark = "#111111";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
type Restaurant = (typeof pageData.restaurants)[number];
const restaurants = pageData.restaurants;
const updatedDate = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
}).format(new Date(pageData.generatedAt));
const formatter = new Intl.NumberFormat("en-US", {
  maximumFractionDigits: 0,
});
const exchangeRateLabel = `1 USD ≈ ARS ${formatter.format(
  pageData.currency.arsPerUsd,
)}`;
const collator = new Intl.Collator("en", {
  sensitivity: "base",
  numeric: true,
});
const cuisineCounts = restaurants.reduce((counts, restaurant: Restaurant) => {
  for (const cuisineType of restaurant.cuisineTypes) {
    counts.set(cuisineType, (counts.get(cuisineType) ?? 0) + 1);
  }

  return counts;
}, new Map<string, number>());
const cuisineOptions = [...cuisineCounts.entries()]
  .sort(([first], [second]) => collator.compare(first, second))
  .map(([name, count]) => ({ name, count }));
const neighborhoodCounts = restaurants.reduce((counts, restaurant: Restaurant) => {
  counts.set(restaurant.neighborhood, (counts.get(restaurant.neighborhood) ?? 0) + 1);
  return counts;
}, new Map<string, number>());
const neighborhoodOptions = [...neighborhoodCounts.entries()]
  .sort(
    ([nameA, countA], [nameB, countB]) =>
      countB - countA || collator.compare(nameA, nameB),
  )
  .map(([name, count]) => ({ name, count }));
const hasDelivery = (restaurant: Restaurant) => Boolean(restaurant.delivery?.available);
const servesBreakfast = (restaurant: Restaurant) => Boolean(restaurant.breakfast?.available);
const servesBrunch = (restaurant: Restaurant) => Boolean(restaurant.brunch?.available);
const isHotelRestaurant = (restaurant: Restaurant) =>
  restaurant.cuisineTypes.includes("Hotel dining");
const deliveryCount = restaurants.filter(hasDelivery).length;
const breakfastCount = restaurants.filter(servesBreakfast).length;
const brunchCount = restaurants.filter(servesBrunch).length;
const hotelRestaurantCount = restaurants.filter(isHotelRestaurant).length;
const priceValue = (restaurant: Restaurant) =>
  restaurant.price.usd.estimate ?? Number.MAX_SAFE_INTEGER;
const sortRank = (
  items: Restaurant[],
  compare: (a: Restaurant, b: Restaurant) => number,
) =>
  new Map<string, number>(
    items
      .toSorted(compare)
      .map((restaurant: Restaurant, index: number) => [
        restaurant.id,
        index + 1,
      ]),
  );
const nameRanks = sortRank(restaurants, (a: Restaurant, b: Restaurant) =>
  collator.compare(a.name, b.name),
);
const ratingRanks = sortRank(
  restaurants,
  (a: Restaurant, b: Restaurant) =>
    b.rating - a.rating ||
    b.reviewCount - a.reviewCount ||
    collator.compare(a.name, b.name),
);
const priceRanks = sortRank(
  restaurants,
  (a: Restaurant, b: Restaurant) =>
    priceValue(a) - priceValue(b) ||
    collator.compare(a.name, b.name),
);
const popularityRanks = sortRank(
  restaurants,
  (a: Restaurant, b: Restaurant) =>
    b.reviewCount - a.reviewCount ||
    b.rating - a.rating ||
    collator.compare(a.name, b.name),
);
const restaurantsWithSort = restaurants.map((restaurant: Restaurant) => ({
  ...restaurant,
  cuisineTypesAttribute: restaurant.cuisineTypes.join("|"),
  doesDelivery: hasDelivery(restaurant),
  servesBreakfast: servesBreakfast(restaurant),
  servesBrunch: servesBrunch(restaurant),
  isHotelRestaurant: isHotelRestaurant(restaurant),
  deliveryServicesLabel:
    restaurant.delivery?.services.map((service) => service.name).join(", ") ?? "",
  reviewCountLabel: formatter.format(restaurant.reviewCount),
  sortOrderStyle: [
    `--sort-name: ${nameRanks.get(restaurant.id)}`,
    `--sort-rating: ${ratingRanks.get(restaurant.id)}`,
    `--sort-price: ${priceRanks.get(restaurant.id)}`,
    `--sort-popularity: ${popularityRanks.get(restaurant.id)}`,
  ].join("; "),
}));
const googleMapsApiKey =
  import.meta.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
  process.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
  "";
const restaurantMapData = restaurants.map((restaurant: Restaurant) => ({
  id: restaurant.id,
  name: restaurant.name,
  googleMapsUrl: restaurant.googleMapsUrl,
  cuisineTypes: restaurant.cuisineTypes,
  neighborhood: restaurant.neighborhood,
  doesDelivery: hasDelivery(restaurant),
  servesBreakfast: servesBreakfast(restaurant),
  servesBrunch: servesBrunch(restaurant),
  isHotelRestaurant: isHotelRestaurant(restaurant),
  position: restaurant.location,
}));
const mapsIcon = `<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="#1a73e8" d="M12 2.2c3.9 0 7.1 3.1 7.1 7 0 5.1-7.1 12.6-7.1 12.6S4.9 14.3 4.9 9.2c0-3.9 3.2-7 7.1-7Z"/><path fill="#34a853" d="M7.2 14.1 12 21.8l4.8-7.7-4.8-2.8-4.8 2.8Z"/><path fill="#fbbc04" d="M4.9 9.2c0 1.8.9 3.5 2.3 4.9l4.8-2.8V2.2c-3.9 0-7.1 3.1-7.1 7Z"/><path fill="#ea4335" d="M19.1 9.2c0 1.8-.9 3.5-2.3 4.9L12 11.3V2.2c3.9 0 7.1 3.1 7.1 7Z"/><circle cx="12" cy="9.3" r="2.45" fill="#fff"/></svg>`;
const deliveryIconSvgs: Record<string, string> = {
  Rappi: `<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="12" fill="#FF441F"/><path fill="#fff" d="M8.2 16.2V7.8h2.6c1.8 0 2.9.9 2.9 2.3 0 .9-.5 1.6-1.3 2l1.8 2.4h-1.9l-1.6-2.2H10V16.2H8.2zm1.6-3.8h1c.8 0 1.2-.3 1.2-.9s-.4-.9-1.2-.9h-1v1.8z"/></svg>`,
  PedidosYa: `<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><rect width="24" height="24" rx="7" fill="#FA0050"/><path fill="none" stroke="#fff" stroke-width="1.6" stroke-linecap="round" d="M9 7v10M9 7a2.2 2.2 0 014.4 0v3.2A2.2 2.2 0 019 12.4V7zm5.6 0v10"/></svg>`,
};
const deliveryIconFor = (serviceName: string) =>
  deliveryIconSvgs[serviceName] ??
  `<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="12" fill="#6f675c"/><path fill="#fff" d="M8 7h8v2H8V7zm0 4h8v2H8v-2zm0 4h5v2H8v-2z"/></svg>`;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  numberOfItems: restaurants.length,
  itemListElement: restaurants.map((restaurant, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "Restaurant",
      name: restaurant.name,
      url: restaurant.officialUrl,
      sameAs: restaurant.googleMapsUrl,
      address: restaurant.fullAddress,
      geo: {
        "@type": "GeoCoordinates",
        latitude: restaurant.location.lat,
        longitude: restaurant.location.lng,
      },
      aggregateRating: {
        "@type": "AggregateRating",
        ratingValue: restaurant.rating.toFixed(1),
        ratingCount: restaurant.reviewCount,
      },
    },
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="subject" content="Best restaurants in Buenos Aires" />
    <meta name="application-name" content={pageTitle} />
    <meta
      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="googlebot"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="keywords"
      content="Buenos Aires restaurants, best restaurants Buenos Aires, Michelin Buenos Aires, Buenos Aires fine dining"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta
      name="theme-color"
      content={themeColorLight}
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content={themeColorDark}
      media="(prefers-color-scheme: dark)"
    />
    <meta name="msapplication-TileColor" content={themeColorDark} />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color={themeColorDark} />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Nikita Sokolsky" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <main class="page">
      <header class="page-header">
        <a class="home-link" href="/">Nikita Sokolsky</a>
        <div class="headline">
          <p class="eyebrow">Buenos Aires guide</p>
          <h1>{pageTitle}</h1>
          <p class="intro">
            {restaurants.length} restaurants listed as open in Google Maps, linked to official websites or Instagram.
          </p>
        </div>
        <div class="toolbar" aria-label="Restaurant controls">
          <fieldset class="sort-toggle">
            <legend>Sort by</legend>
            <input id="sort-name" type="radio" name="sort" autocomplete="off" checked />
            <label for="sort-name">Name</label>
            <input id="sort-rating" type="radio" name="sort" autocomplete="off" />
            <label for="sort-rating">GMaps rating</label>
            <input id="sort-price" type="radio" name="sort" autocomplete="off" />
            <label for="sort-price">Price</label>
            <input id="sort-popularity" type="radio" name="sort" autocomplete="off" />
            <label for="sort-popularity">Popularity</label>
          </fieldset>
          <fieldset class="currency-toggle">
            <legend>Price currency</legend>
            <input id="currency-usd" type="radio" name="currency" autocomplete="off" checked />
            <label for="currency-usd">USD</label>
            <input id="currency-ars" type="radio" name="currency" autocomplete="off" />
            <label for="currency-ars">ARS</label>
          </fieldset>
          <fieldset class="delivery-toggle">
            <legend>Filter</legend>
            <input id="filter-delivery" type="checkbox" autocomplete="off" />
            <label for="filter-delivery">Does delivery ({deliveryCount})</label>
            <input id="filter-breakfast" type="checkbox" autocomplete="off" />
            <label for="filter-breakfast">Serves breakfast ({breakfastCount})</label>
            <input id="filter-brunch" type="checkbox" autocomplete="off" />
            <label for="filter-brunch">Serves brunch ({brunchCount})</label>
            <input id="filter-exclude-hotels" type="checkbox" autocomplete="off" />
            <label for="filter-exclude-hotels">Exclude hotel restaurants ({hotelRestaurantCount})</label>
          </fieldset>
          <label class="filter-dropdown" for="neighborhood-filter">
            <span>Neighborhood</span>
            <select id="neighborhood-filter" name="neighborhood" autocomplete="off">
              <option value="">All ({restaurants.length})</option>
              {neighborhoodOptions.map((option) => (
                <option value={option.name}>{option.name} ({option.count})</option>
              ))}
            </select>
          </label>
          <label class="filter-dropdown" for="cuisine-filter">
            <span>Cuisine type</span>
            <select id="cuisine-filter" name="cuisine" autocomplete="off">
              <option value="">All ({restaurants.length})</option>
              {cuisineOptions.map((option) => (
                <option value={option.name}>{option.name} ({option.count})</option>
              ))}
            </select>
          </label>
          <p class="meta">
            Updated {updatedDate}. {exchangeRateLabel}.
          </p>
        </div>
      </header>

      <section class="restaurant-list" aria-label="Buenos Aires restaurants">
        <div class="restaurant-row restaurant-head" aria-hidden="true">
          <span>Restaurant</span>
          <span>Map</span>
          <span>Address</span>
          <span>Per person</span>
          <span>GMaps rating</span>
          <span>Description</span>
        </div>

        {restaurantsWithSort.map((restaurant) => (
          <article
            class="restaurant-row"
            style={restaurant.sortOrderStyle}
            data-neighborhood={restaurant.neighborhood}
            data-cuisine-types={restaurant.cuisineTypesAttribute}
            data-does-delivery={String(restaurant.doesDelivery)}
            data-serves-breakfast={String(restaurant.servesBreakfast)}
            data-serves-brunch={String(restaurant.servesBrunch)}
            data-is-hotel-restaurant={String(restaurant.isHotelRestaurant)}
          >
            <h2 class="restaurant-name">
              <a href={restaurant.officialUrl} target="_blank" rel="noreferrer noopener">
                {restaurant.name}
              </a>
              {restaurant.doesDelivery && (
                <span class="delivery-icons delivery-icons-desktop">
                  {(restaurant.delivery?.services ?? []).map((service) => (
                    <a
                      class="delivery-link"
                      href={service.url}
                      target="_blank"
                      rel="noreferrer noopener"
                      aria-label={`Order ${restaurant.name} on ${service.name}`}
                      title={`Order on ${service.name}`}
                    >
                      <span class="delivery-icon" set:html={deliveryIconFor(service.name)} />
                    </a>
                  ))}
                </span>
              )}
            </h2>
            <div class="map-actions">
              <a
                class="maps-link"
                href={restaurant.googleMapsUrl}
                target="_blank"
                rel="noreferrer noopener"
                aria-label={`Open ${restaurant.name} on Google Maps`}
                title={`Open ${restaurant.name} on Google Maps`}
              >
                <span class="maps-icon" set:html={mapsIcon} />
              </a>
              {restaurant.doesDelivery && (
                <span class="delivery-icons delivery-icons-mobile">
                  {(restaurant.delivery?.services ?? []).map((service) => (
                    <a
                      class="delivery-link"
                      href={service.url}
                      target="_blank"
                      rel="noreferrer noopener"
                      aria-label={`Order ${restaurant.name} on ${service.name}`}
                      title={`Order on ${service.name}`}
                    >
                      <span class="delivery-icon" set:html={deliveryIconFor(service.name)} />
                    </a>
                  ))}
                </span>
              )}
            </div>
            <p class="address">{restaurant.address}</p>
            <p
              class={`price ${restaurant.price.source === "google_price_level" ? "price-fallback" : ""}`}
              title={restaurant.price.source === "google_price_level" ? "Google Maps price-level fallback" : "Google Maps price estimate"}
            >
              <span class="price-usd">{restaurant.price.usd.label}</span>
              <span class="price-ars">{restaurant.price.ars.label}</span>
            </p>
            <p
              class="rating"
              aria-label={`${restaurant.rating.toFixed(1)} Google Maps rating from ${restaurant.reviewCountLabel} ratings`}
            >
              <span class="rating-score">{restaurant.rating.toFixed(1)}</span>
              <span class="review-count">{restaurant.reviewCountLabel} ratings</span>
            </p>
            <p class="description">{restaurant.description}</p>
          </article>
        ))}
      </section>

      <section class="restaurant-map-section" aria-labelledby="restaurant-map-heading">
        <div class="map-copy">
          <p class="eyebrow">Map</p>
          <h2 id="restaurant-map-heading">Buenos Aires restaurant map</h2>
          <p id="restaurant-map-status" class="map-status">
            Showing all {restaurants.length} restaurants.
          </p>
        </div>
        {googleMapsApiKey ? (
          <div
            id="restaurant-map"
            class="restaurant-map"
            aria-label="Google Map with pins for Buenos Aires restaurants"
          ></div>
        ) : (
          <p class="map-unavailable">
            Map unavailable because the Google Maps public key is not configured.
          </p>
        )}
      </section>
    </main>
  </body>
</html>

<script is:inline define:vars={{ googleMapsApiKey, restaurantMapData }}>
  if (googleMapsApiKey) {
    ((g) => {
      let h;
      let a;
      let k;
      const p = "The Google Maps JavaScript API";
      const c = "google";
      const l = "importLibrary";
      const q = "__ib__";
      const m = document;
      let b = window;
      b = b[c] || (b[c] = {});
      const d = b.maps || (b.maps = {});
      const r = new Set();
      const e = new URLSearchParams();
      const u = () =>
        h ||
        (h = new Promise(async (resolve, reject) => {
          await (a = m.createElement("script"));
          e.set("libraries", [...r] + "");
          for (k in g) {
            e.set(k.replace(/[A-Z]/g, (t) => `_${t[0].toLowerCase()}`), g[k]);
          }
          e.set("callback", `${c}.maps.${q}`);
          a.src = `https://maps.${c}apis.com/maps/api/js?${e}`;
          d[q] = resolve;
          a.onerror = () => (h = reject(Error(`${p} could not load.`)));
          a.nonce = m.querySelector("script[nonce]")?.nonce || "";
          m.head.append(a);
        }));
      d[l] ? console.warn(`${p} only loads once. Ignoring:`, g) : (d[l] = (f, ...n) => r.add(f) && u().then(() => d[l](f, ...n)));
    })({
      key: googleMapsApiKey,
      v: "weekly",
    });
  }

  const neighborhoodFilter = document.querySelector("#neighborhood-filter");
  const cuisineFilter = document.querySelector("#cuisine-filter");
  const deliveryFilter = document.querySelector("#filter-delivery");
  const breakfastFilter = document.querySelector("#filter-breakfast");
  const brunchFilter = document.querySelector("#filter-brunch");
  const excludeHotelsFilter = document.querySelector("#filter-exclude-hotels");
  const defaultSort = document.querySelector("#sort-name");
  const defaultCurrency = document.querySelector("#currency-usd");
  const restaurantRows = [...document.querySelectorAll(".restaurant-row:not(.restaurant-head)")];
  const mapElement = document.querySelector("#restaurant-map");
  const mapStatus = document.querySelector("#restaurant-map-status");
  const buenosAiresCenter = { lat: -34.6037, lng: -58.3816 };
  const filterUrlParams = [
    "neighborhood",
    "cuisine",
    "delivery",
    "breakfast",
    "brunch",
    "excludeHotels",
  ];
  const markerRecords = [];
  let restaurantMap;
  let infoWindow;

  const escapeHtml = (value) =>
    String(value).replace(/[&<>"']/g, (character) => ({
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#39;",
    })[character]);

  const getVisibleRestaurants = (
    selectedNeighborhood,
    selectedCuisine,
    deliveryOnly,
    breakfastOnly,
    brunchOnly,
    excludeHotels,
  ) =>
    restaurantMapData.filter(
      (restaurant) =>
        (!selectedNeighborhood || restaurant.neighborhood === selectedNeighborhood) &&
        (!selectedCuisine || restaurant.cuisineTypes.includes(selectedCuisine)) &&
        (!deliveryOnly || restaurant.doesDelivery) &&
        (!breakfastOnly || restaurant.servesBreakfast) &&
        (!brunchOnly || restaurant.servesBrunch) &&
        (!excludeHotels || !restaurant.isHotelRestaurant),
    );

  const updateMapStatus = (
    selectedNeighborhood,
    selectedCuisine,
    deliveryOnly,
    breakfastOnly,
    brunchOnly,
    excludeHotels,
  ) => {
    if (!mapStatus) return;

    const visibleCount = getVisibleRestaurants(
      selectedNeighborhood,
      selectedCuisine,
      deliveryOnly,
      breakfastOnly,
      brunchOnly,
      excludeHotels,
    ).length;
    const restaurantLabel = visibleCount === 1 ? "restaurant" : "restaurants";
    const activeFilters = [
      deliveryOnly ? "delivery" : "",
      breakfastOnly ? "breakfast" : "",
      brunchOnly ? "brunch" : "",
    ].filter(Boolean);
    const filterPrefix = activeFilters.length ? `${activeFilters.join(" + ")} ` : "";
    const excludeSuffix = excludeHotels ? ", excluding hotels" : "";
    const categoryLabel = [selectedNeighborhood, selectedCuisine].filter(Boolean).join(" ");
    mapStatus.textContent = categoryLabel
      ? `Showing ${visibleCount} ${filterPrefix}${categoryLabel} ${restaurantLabel}${excludeSuffix}.`
      : `Showing ${filterPrefix ? "" : "all "}${visibleCount} ${filterPrefix}${restaurantLabel}${excludeSuffix}.`;
  };

  const fitMapToMarkers = (visibleRecords) => {
    if (!restaurantMap || !window.google?.maps || visibleRecords.length === 0) return;

    if (visibleRecords.length === 1) {
      restaurantMap.setCenter(visibleRecords[0].restaurant.position);
      restaurantMap.setZoom(14);
      return;
    }

    const bounds = new google.maps.LatLngBounds();

    for (const { restaurant } of visibleRecords) {
      bounds.extend(restaurant.position);
    }

    restaurantMap.fitBounds(bounds, 44);
  };

  const syncMapMarkers = (
    selectedNeighborhood,
    selectedCuisine,
    deliveryOnly,
    breakfastOnly,
    brunchOnly,
    excludeHotels,
  ) => {
    updateMapStatus(
      selectedNeighborhood,
      selectedCuisine,
      deliveryOnly,
      breakfastOnly,
      brunchOnly,
      excludeHotels,
    );

    if (!restaurantMap) return;

    const visibleIds = new Set(
      getVisibleRestaurants(
        selectedNeighborhood,
        selectedCuisine,
        deliveryOnly,
        breakfastOnly,
        brunchOnly,
        excludeHotels,
      ).map((restaurant) => restaurant.id),
    );
    const visibleRecords = [];

    for (const record of markerRecords) {
      const isVisible = visibleIds.has(record.restaurant.id);
      record.marker.setMap(isVisible ? restaurantMap : null);
      if (isVisible) visibleRecords.push(record);
    }

    if (mapElement) mapElement.dataset.visiblePins = String(visibleRecords.length);

    fitMapToMarkers(visibleRecords);
  };

  const updateFilterUrl = (
    selectedNeighborhood,
    selectedCuisine,
    deliveryOnly,
    breakfastOnly,
    brunchOnly,
    excludeHotels,
  ) => {
    const url = new URL(window.location.href);

    for (const paramName of filterUrlParams) {
      url.searchParams.delete(paramName);
    }

    if (selectedNeighborhood) url.searchParams.set("neighborhood", selectedNeighborhood);
    if (selectedCuisine) url.searchParams.set("cuisine", selectedCuisine);
    if (deliveryOnly) url.searchParams.set("delivery", "1");
    if (breakfastOnly) url.searchParams.set("breakfast", "1");
    if (brunchOnly) url.searchParams.set("brunch", "1");
    if (excludeHotels) url.searchParams.set("excludeHotels", "1");

    const nextUrl = `${url.pathname}${url.search}${url.hash}`;
    const currentUrl = `${window.location.pathname}${window.location.search}${window.location.hash}`;

    if (nextUrl !== currentUrl) {
      window.history.replaceState(null, "", nextUrl);
    }
  };

  const initRestaurantMap = async () => {
    if (!mapElement || !googleMapsApiKey || !window.google?.maps?.importLibrary) return;

    const { Map, InfoWindow } = await google.maps.importLibrary("maps");
    await google.maps.importLibrary("marker");

    restaurantMap = new Map(mapElement, {
      center: buenosAiresCenter,
      clickableIcons: false,
      fullscreenControl: true,
      mapTypeControl: false,
      streetViewControl: false,
      zoom: 12,
    });
    infoWindow = new InfoWindow();

    for (const restaurant of restaurantMapData) {
      const marker = new google.maps.Marker({
        map: restaurantMap,
        position: restaurant.position,
        title: restaurant.name,
      });

      marker.addListener("click", () => {
        infoWindow.setContent(
          `<strong>${escapeHtml(restaurant.name)}</strong><br><a href="${escapeHtml(restaurant.googleMapsUrl)}" target="_blank" rel="noreferrer noopener">Open in Google Maps</a>`,
        );
        infoWindow.open(restaurantMap, marker);
      });

      markerRecords.push({ restaurant, marker });
    }

    syncMapMarkers(
      neighborhoodFilter?.value ?? "",
      cuisineFilter?.value ?? "",
      deliveryFilter?.checked ?? false,
      breakfastFilter?.checked ?? false,
      brunchFilter?.checked ?? false,
      excludeHotelsFilter?.checked ?? false,
    );
  };

  const applyFilters = ({ syncUrl = true } = {}) => {
    const selectedNeighborhood = neighborhoodFilter?.value ?? "";
    const selectedCuisine = cuisineFilter?.value ?? "";
    const deliveryOnly = deliveryFilter?.checked ?? false;
    const breakfastOnly = breakfastFilter?.checked ?? false;
    const brunchOnly = brunchFilter?.checked ?? false;
    const excludeHotels = excludeHotelsFilter?.checked ?? false;

    if (syncUrl) {
      updateFilterUrl(
        selectedNeighborhood,
        selectedCuisine,
        deliveryOnly,
        breakfastOnly,
        brunchOnly,
        excludeHotels,
      );
    }

    for (const row of restaurantRows) {
      const cuisines = row.dataset.cuisineTypes?.split("|") ?? [];
      const neighborhoodMismatch =
        Boolean(selectedNeighborhood) && row.dataset.neighborhood !== selectedNeighborhood;
      const cuisineMismatch = Boolean(selectedCuisine) && !cuisines.includes(selectedCuisine);
      const deliveryMismatch = deliveryOnly && row.dataset.doesDelivery !== "true";
      const breakfastMismatch = breakfastOnly && row.dataset.servesBreakfast !== "true";
      const brunchMismatch = brunchOnly && row.dataset.servesBrunch !== "true";
      const hotelExcluded = excludeHotels && row.dataset.isHotelRestaurant === "true";
      row.hidden =
        neighborhoodMismatch ||
        cuisineMismatch ||
        deliveryMismatch ||
        breakfastMismatch ||
        brunchMismatch ||
        hotelExcluded;
    }

    syncMapMarkers(
      selectedNeighborhood,
      selectedCuisine,
      deliveryOnly,
      breakfastOnly,
      brunchOnly,
      excludeHotels,
    );
  };

  const resetControls = () => {
    if (defaultSort) defaultSort.checked = true;
    if (defaultCurrency) defaultCurrency.checked = true;
    if (neighborhoodFilter) neighborhoodFilter.value = "";
    if (cuisineFilter) cuisineFilter.value = "";
    if (deliveryFilter) deliveryFilter.checked = false;
    if (breakfastFilter) breakfastFilter.checked = false;
    if (brunchFilter) brunchFilter.checked = false;
    if (excludeHotelsFilter) excludeHotelsFilter.checked = false;
  };

  const setSelectFromUrl = (selectElement, value) => {
    if (!selectElement || !value) return;

    const hasOption = [...selectElement.options].some((option) => option.value === value);
    if (hasOption) selectElement.value = value;
  };

  const hasEnabledUrlParam = (params, paramName) => {
    const value = params.get(paramName);
    if (value === null) return false;

    return !["0", "false", "no", "off"].includes(value.toLowerCase());
  };

  const applyFiltersFromUrl = () => {
    const params = new URLSearchParams(window.location.search);

    resetControls();
    setSelectFromUrl(neighborhoodFilter, params.get("neighborhood"));
    setSelectFromUrl(cuisineFilter, params.get("cuisine"));
    if (deliveryFilter) deliveryFilter.checked = hasEnabledUrlParam(params, "delivery");
    if (breakfastFilter) breakfastFilter.checked = hasEnabledUrlParam(params, "breakfast");
    if (brunchFilter) brunchFilter.checked = hasEnabledUrlParam(params, "brunch");
    if (excludeHotelsFilter) excludeHotelsFilter.checked = hasEnabledUrlParam(params, "excludeHotels");

    applyFilters({ syncUrl: false });
  };

  neighborhoodFilter?.addEventListener("change", applyFilters);
  cuisineFilter?.addEventListener("change", applyFilters);
  deliveryFilter?.addEventListener("change", applyFilters);
  breakfastFilter?.addEventListener("change", applyFilters);
  brunchFilter?.addEventListener("change", applyFilters);
  excludeHotelsFilter?.addEventListener("change", applyFilters);
  applyFiltersFromUrl();
  window.addEventListener("pageshow", applyFiltersFromUrl);
  window.addEventListener("popstate", applyFiltersFromUrl);
  initRestaurantMap().catch((error) => {
    console.error("Unable to initialize restaurant map", error);
    if (mapStatus) mapStatus.textContent = "Map unavailable. Restaurant list still works.";
  });
</script>

