---
import { skiResortSource, skiResorts } from "../../data/skiResorts";

export const prerender = true;

const pageTitle = "Global ski resort efficiency ranking";
const pageDescription =
  "A wiki-backed ranking of operating ski resorts with at least 1,000 ft of vertical drop, sorted by the estimated share of lap time spent skiing.";
const themeColorLight = "#f4efe6";
const themeColorDark = "#121412";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const formatter = new Intl.NumberFormat("en-US");
const minuteFormatter = new Intl.NumberFormat("en-US", {
  minimumFractionDigits: 1,
  maximumFractionDigits: 1,
});
const percentFormatter = new Intl.NumberFormat("en-US", {
  style: "percent",
  minimumFractionDigits: 1,
  maximumFractionDigits: 1,
});
const snowFormatter = new Intl.NumberFormat("en-US", {
  minimumFractionDigits: 1,
  maximumFractionDigits: 1,
});
const wikiSnowCount = skiResorts.filter(
  (resort) => resort.snowEstimateSource === "wiki annual snowfall field",
).length;
const fallbackSnowCount = skiResorts.length - wikiSnowCount;
const topResorts = skiResorts.slice(0, 3);

const feet = (value: number | null) =>
  value === null ? "not listed" : `${formatter.format(value)} ft`;
const minutes = (value: number) => `${minuteFormatter.format(value)} min`;
const snowFeet = (value: number) => `${snowFormatter.format(value)} ft`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  numberOfItems: skiResorts.length,
  itemListElement: skiResorts.map((resort) => ({
    "@type": "ListItem",
    position: resort.rank,
    url: resort.wikiUrl,
    name: resort.name,
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="subject" content="Global ski resort efficiency ranking" />
    <meta
      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="googlebot"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="keywords"
      content="ski resorts, ski resort ranking, vertical drop, lift served vertical, skiing time, chairlift time"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta
      name="theme-color"
      content={themeColorDark}
      media="(prefers-color-scheme: dark)"
    />
    <meta name="msapplication-TileColor" content={themeColorDark} />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color={themeColorDark} />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Nikita Sokolsky" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <main class="page">
      <header class="page-header">
        <a class="home-link" href="/">Nikita Sokolsky</a>
        <p class="eyebrow">Skiing research</p>
        <h1>{pageTitle}</h1>
        <p class="intro">
          Operating English Wikipedia ski-area infoboxes with at least 1,000 ft
          of vertical. The score is the estimated share of a no-wait top-to-base
          lap spent moving downhill.
        </p>
        <dl class="summary-grid" aria-label="Ranking summary">
          <div>
            <dt>Qualified resorts</dt>
            <dd>{formatter.format(skiResorts.length)}</dd>
          </div>
          <div>
            <dt>Wiki infobox pages checked</dt>
            <dd>{formatter.format(skiResortSource.wikipediaInfoboxPagesChecked)}</dd>
          </div>
          <div>
            <dt>Top estimated ski share</dt>
            <dd>{percentFormatter.format(skiResorts[0].skiingShare)}</dd>
          </div>
        </dl>
      </header>

      <section class="podium" aria-labelledby="podium-heading">
        <div class="section-copy">
          <p class="eyebrow">Leaders</p>
          <h2 id="podium-heading">Fastest no-wait laps</h2>
        </div>
        <div class="podium-grid">
          {topResorts.map((resort) => (
            <article class="podium-card">
              <p class="rank">#{resort.rank}</p>
              <h3>
                <a href={resort.wikiUrl} target="_blank" rel="noreferrer noopener">
                  {resort.name}
                </a>
              </h3>
              <p class="location">{resort.location}</p>
              <p class="score">{percentFormatter.format(resort.skiingShare)} skiing</p>
              <p class="lap">
                {minutes(resort.descentMinutes)} down / {minutes(resort.ascentMinutes)} up
              </p>
            </article>
          ))}
        </div>
      </section>

      <section class="methodology" aria-labelledby="methodology-heading">
        <div class="section-copy">
          <p class="eyebrow">Method</p>
          <h2 id="methodology-heading">What the score means</h2>
        </div>
        <div class="method-grid">
          <article>
            <h3>Vertical</h3>
            <p>
              Inclusion comes from Wikipedia's ski-area infobox vertical field.
              When the field distinguishes total, hike-to and lift-served
              values, the lift-served value is used. Closed, defunct and
              inaccessible resorts are excluded.
            </p>
          </article>
          <article>
            <h3>Lap model</h3>
            <p>
              Ski share = descent time / (descent time + lift time). Lift time is
              inferred from the listed lift system: tram/cable car, gondola,
              detachable chair, fixed-grip chair, surface lift or unknown mixed lift.
            </p>
          </article>
          <article>
            <h3>Snow</h3>
            <p>
              Base/top peak-season snow is a median snowpack estimate, not part
              of the ranking. {wikiSnowCount} rows use wiki annual snowfall fields;
              {fallbackSnowCount} use regional/elevation fallbacks.
            </p>
          </article>
        </div>
      </section>

      <section class="ranking" aria-labelledby="ranking-heading">
        <div class="table-heading">
          <div>
            <p class="eyebrow">Full table</p>
            <h2 id="ranking-heading">All qualifying resorts</h2>
          </div>
          <p>
            No lift lines. No transfer time between lifts. The table only counts
            estimated time skiing and riding uphill.
          </p>
        </div>

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th scope="col">Rank</th>
                <th scope="col">Resort</th>
                <th scope="col">Vertical</th>
                <th scope="col">Skiing share</th>
                <th scope="col">Down</th>
                <th scope="col">Up</th>
                <th scope="col">Median base snow</th>
                <th scope="col">Median top snow</th>
                <th scope="col">Lift assumption</th>
                <th scope="col">Wiki data</th>
              </tr>
            </thead>
            <tbody>
              {skiResorts.map((resort) => (
                <tr>
                  <th scope="row">#{resort.rank}</th>
                  <td class="resort-cell">
                    <a href={resort.wikiUrl} target="_blank" rel="noreferrer noopener">
                      {resort.name}
                    </a>
                    <span>{resort.location}</span>
                  </td>
                  <td title={`Wiki vertical field: ${resort.wikiVerticalField}`}>
                    {feet(resort.verticalFt)}
                  </td>
                  <td class="score-cell">
                    {percentFormatter.format(resort.skiingShare)}
                  </td>
                  <td>{minutes(resort.descentMinutes)}</td>
                  <td>{minutes(resort.ascentMinutes)}</td>
                  <td title={resort.snowEstimateSource}>
                    {snowFeet(resort.snowAtBaseFt)}
                  </td>
                  <td title={resort.snowEstimateSource}>
                    {snowFeet(resort.snowAtTopFt)}
                  </td>
                  <td title={resort.liftSystem}>{resort.liftRouteAssumption}</td>
                  <td>
                    <a href={resort.wikiUrl} target="_blank" rel="noreferrer noopener">
                      source
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="notes" aria-labelledby="notes-heading">
        <h2 id="notes-heading">Coverage notes</h2>
        <p>
          Corpus rule: {skiResortSource.inclusionRule} Pages that use the ski-area
          infobox for race courses rather than resorts were excluded.
          {skiResortSource.operatingWindowRule}
        </p>
        <p>
          This is a speed-of-lap model, not a quality model. It ignores terrain
          variety, grooming, snow quality, chair capacity, weather, lines, crowds
          and the time it takes to skate across base areas.
        </p>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light dark;
    --bg: #f4efe6;
    --surface: #fffaf1;
    --text: #171510;
    --muted: #6d6254;
    --line: #d8cabb;
    --line-strong: #b9a791;
    --accent: #7d4a1f;
    --accent-soft: #ead5bd;
    --cold: #d9e5e7;
    --shadow: 0 24px 80px rgb(59 43 26 / 12%);
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #121412;
      --surface: #1b1c18;
      --text: #f3ede3;
      --muted: #b7ad9f;
      --line: #3b3932;
      --line-strong: #5b554a;
      --accent: #e7a765;
      --accent-soft: #3b2a1c;
      --cold: #24363a;
      --shadow: 0 24px 80px rgb(0 0 0 / 28%);
    }
  }

  * {
    box-sizing: border-box;
  }

  html {
    background:
      radial-gradient(circle at 20% 0%, var(--cold), transparent 32rem),
      linear-gradient(180deg, var(--bg), color-mix(in srgb, var(--bg) 88%, var(--surface)));
    color: var(--text);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    margin: 0;
    min-height: 100vh;
  }

  a {
    color: inherit;
    text-decoration-color: color-mix(in srgb, var(--accent) 52%, transparent);
    text-underline-offset: 0.18em;
  }

  a:hover {
    color: var(--accent);
  }

  .page {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
    padding: 22px 0 52px;
  }

  .page-header {
    padding: clamp(18px, 4vw, 42px) 0 clamp(22px, 4vw, 38px);
  }

  .home-link {
    display: inline-flex;
    margin-bottom: clamp(24px, 5vw, 48px);
    color: var(--muted);
    font-size: 0.86rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .eyebrow {
    margin: 0 0 10px;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 840px;
    margin-bottom: 16px;
    font-size: clamp(2.5rem, 7.4vw, 6.15rem);
    letter-spacing: -0.07em;
    line-height: 0.92;
  }

  .intro {
    max-width: 720px;
    margin-bottom: clamp(20px, 4vw, 34px);
    color: var(--muted);
    font-size: clamp(1rem, 1.8vw, 1.25rem);
    line-height: 1.4;
  }

  .summary-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    max-width: 870px;
    margin: 0;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 26px;
    background: var(--line);
    box-shadow: var(--shadow);
  }

  .summary-grid div {
    padding: 16px 18px;
    background: color-mix(in srgb, var(--surface) 90%, transparent);
  }

  .summary-grid dt {
    margin-bottom: 8px;
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .summary-grid dd {
    margin: 0;
    font-size: clamp(1.55rem, 3vw, 2.45rem);
    font-weight: 900;
    letter-spacing: -0.06em;
    line-height: 1;
  }

  section {
    margin-top: clamp(28px, 5vw, 54px);
  }

  .section-copy {
    display: grid;
    grid-template-columns: minmax(180px, 0.45fr) minmax(0, 1fr);
    gap: 18px;
    align-items: end;
    margin-bottom: 14px;
  }

  .section-copy h2,
  .table-heading h2,
  .notes h2 {
    margin-bottom: 0;
    font-size: clamp(1.65rem, 3.6vw, 3.2rem);
    letter-spacing: -0.06em;
    line-height: 1;
  }

  .podium-grid,
  .method-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  .podium-card,
  .method-grid article,
  .notes {
    border: 1px solid var(--line);
    border-radius: 26px;
    background: color-mix(in srgb, var(--surface) 88%, transparent);
    box-shadow: var(--shadow);
  }

  .podium-card {
    padding: 16px;
  }

  .rank {
    margin-bottom: 16px;
    color: var(--accent);
    font-size: clamp(1.9rem, 5vw, 3.6rem);
    font-weight: 950;
    letter-spacing: -0.08em;
    line-height: 0.8;
  }

  .podium-card h3 {
    margin-bottom: 6px;
    font-size: clamp(1.15rem, 2.2vw, 1.55rem);
    letter-spacing: -0.045em;
    line-height: 1;
  }

  .location,
  .lap,
  .method-grid p,
  .table-heading p,
  .notes p {
    color: var(--muted);
  }

  .score {
    display: inline-flex;
    margin: 8px 0 6px;
    padding: 5px 9px;
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 0.88rem;
    font-weight: 900;
  }

  .method-grid article {
    padding: 16px;
  }

  .method-grid h3 {
    margin-bottom: 6px;
    font-size: 1rem;
  }

  .method-grid p,
  .notes p {
    margin-bottom: 0;
  }

  .table-heading {
    display: grid;
    grid-template-columns: minmax(280px, 0.75fr) minmax(0, 1fr);
    gap: 18px;
    align-items: end;
    margin-bottom: 12px;
  }

  .table-heading p {
    max-width: 560px;
    margin-bottom: 4px;
  }

  .table-wrap {
    overflow-x: auto;
    border: 1px solid var(--line);
    border-radius: 26px;
    background: var(--surface);
    box-shadow: var(--shadow);
  }

  table {
    width: 100%;
    min-width: 1120px;
    border-collapse: separate;
    border-spacing: 0;
    font-size: 0.9rem;
  }

  th,
  td {
    padding: 9px 11px;
    border-bottom: 1px solid var(--line);
    text-align: left;
    vertical-align: top;
  }

  thead th {
    position: sticky;
    top: 0;
    z-index: 1;
    background: color-mix(in srgb, var(--surface) 94%, var(--bg));
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  tbody tr:nth-child(even) {
    background: color-mix(in srgb, var(--surface) 86%, var(--bg));
  }

  tbody tr:hover {
    background: color-mix(in srgb, var(--accent-soft) 42%, var(--surface));
  }

  tbody tr:last-child th,
  tbody tr:last-child td {
    border-bottom: 0;
  }

  tbody th {
    color: var(--accent);
    font-weight: 950;
    white-space: nowrap;
  }

  .resort-cell {
    min-width: 260px;
  }

  .resort-cell a {
    display: block;
    font-weight: 900;
    letter-spacing: -0.02em;
  }

  .resort-cell span {
    display: block;
    margin-top: 3px;
    color: var(--muted);
    font-size: 0.82rem;
  }

  .score-cell {
    font-weight: 950;
  }

  .notes {
    max-width: 820px;
    padding: 16px;
  }

  .notes h2 {
    margin-bottom: 8px;
    font-size: clamp(1.5rem, 3vw, 2.35rem);
  }

  .notes p + p {
    margin-top: 8px;
  }

  @media (max-width: 820px) {
    .summary-grid,
    .podium-grid,
    .method-grid,
    .section-copy,
    .table-heading {
      grid-template-columns: 1fr;
    }

    .summary-grid {
      border-radius: 22px;
    }

    .summary-grid div,
    .podium-card,
    .method-grid article,
    .notes {
      padding: 14px;
    }

    .home-link {
      margin-bottom: 28px;
    }
  }
</style>
