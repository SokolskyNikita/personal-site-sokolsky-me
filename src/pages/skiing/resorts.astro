---
import { skiResortSource, skiResorts } from "../../data/skiResorts";

export const prerender = true;

const pageTitle = "Global ski resort efficiency ranking";
const pageDescription =
  "A source-backed ranking of operating ski resorts with at least 1,000 ft of vertical drop, sorted by the estimated share of lap time spent skiing.";
const themeColorLight = "#fbf9f6";
const themeColorDark = "#121412";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const formatter = new Intl.NumberFormat("en-US");
const minuteFormatter = new Intl.NumberFormat("en-US", {
  minimumFractionDigits: 1,
  maximumFractionDigits: 1,
});
const percentFormatter = new Intl.NumberFormat("en-US", {
  style: "percent",
  minimumFractionDigits: 1,
  maximumFractionDigits: 1,
});
const snowFormatter = new Intl.NumberFormat("en-US", {
  minimumFractionDigits: 1,
  maximumFractionDigits: 1,
});
const wikiSnowCount = skiResorts.filter(
  (resort) => resort.snowEstimateSource === "wiki annual snowfall field",
).length;
const skiresortSnowCount = skiResorts.filter(
  (resort) => resort.snowEstimateSource === "skiresort.info peak snow average",
).length;
const fallbackSnowCount = skiResorts.length - wikiSnowCount - skiresortSnowCount;
const collator = new Intl.Collator("en", {
  sensitivity: "base",
  numeric: true,
});
const continentOrder = [
  "Africa",
  "Asia",
  "Europe",
  "North America",
  "Oceania",
  "South America",
] as const;
const continentOptions = continentOrder
  .map((continent) => ({
    name: continent,
    count: skiResorts.filter((resort) => resort.continent === continent).length,
  }))
  .filter((option) => option.count > 0);
const usStateNames = [
  "Alabama",
  "Alaska",
  "Arizona",
  "Arkansas",
  "California",
  "Colorado",
  "Connecticut",
  "Delaware",
  "Florida",
  "Georgia",
  "Hawaii",
  "Idaho",
  "Illinois",
  "Indiana",
  "Iowa",
  "Kansas",
  "Kentucky",
  "Louisiana",
  "Maine",
  "Maryland",
  "Massachusetts",
  "Michigan",
  "Minnesota",
  "Mississippi",
  "Missouri",
  "Montana",
  "Nebraska",
  "Nevada",
  "New Hampshire",
  "New Jersey",
  "New Mexico",
  "New York",
  "North Carolina",
  "North Dakota",
  "Ohio",
  "Oklahoma",
  "Oregon",
  "Pennsylvania",
  "Rhode Island",
  "South Carolina",
  "South Dakota",
  "Tennessee",
  "Texas",
  "Utah",
  "Vermont",
  "Virginia",
  "Washington",
  "West Virginia",
  "Wisconsin",
  "Wyoming",
] as const;
const escapeRegExp = (value: string) =>
  value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
const getUsState = (location: string, country: string) => {
  if (country !== "United States") return "";
  return (
    usStateNames.find((state) =>
      new RegExp(`(^|[^A-Za-z])${escapeRegExp(state)}([^A-Za-z]|$)`).test(
        location,
      ),
    ) ?? ""
  );
};
const countryCounts = skiResorts.reduce((counts, resort) => {
  counts.set(resort.country, (counts.get(resort.country) ?? 0) + 1);
  return counts;
}, new Map<string, number>());
const countryContinents = skiResorts.reduce((continents, resort) => {
  continents.set(resort.country, resort.continent);
  return continents;
}, new Map<string, string>());
const countryOptions = [...countryCounts.entries()]
  .sort(([first], [second]) => collator.compare(first, second))
  .map(([name, count]) => ({
    name,
    count,
    continent: countryContinents.get(name),
  }));
const usStateCounts = skiResorts.reduce((counts, resort) => {
  const state = getUsState(resort.location, resort.country);
  if (state) counts.set(state, (counts.get(state) ?? 0) + 1);
  return counts;
}, new Map<string, number>());
const usStateOptions = [...usStateCounts.entries()]
  .sort(([first], [second]) => collator.compare(first, second))
  .map(([name, count]) => ({ name, count }));

const feet = (value: number | null) =>
  value === null ? "not listed" : `${formatter.format(value)} ft`;
const minutes = (value: number) => `${minuteFormatter.format(value)} min`;
const snowFeet = (value: number) => `${snowFormatter.format(value)} ft`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  numberOfItems: skiResorts.length,
  itemListElement: skiResorts.map((resort) => ({
    "@type": "ListItem",
    position: resort.rank,
    url: resort.wikiUrl,
    name: resort.name,
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="subject" content="Global ski resort efficiency ranking" />
    <meta
      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="googlebot"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="keywords"
      content="ski resorts, ski resort ranking, vertical drop, lift served vertical, skiing time, chairlift time"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta
      name="theme-color"
      content={themeColorDark}
      media="(prefers-color-scheme: dark)"
    />
    <meta name="msapplication-TileColor" content={themeColorDark} />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color={themeColorDark} />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Nikita Sokolsky" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <main class="page">
      <header class="page-header">
        <a class="home-link" href="/">Nikita Sokolsky</a>
        <p class="eyebrow">Skiing research</p>
        <h1>{pageTitle}</h1>
        <p class="intro">
          Operating resorts from ski-area source pages and list rows with at
          least 1,000 ft of vertical. The score is the estimated share of a
          no-wait top-to-base lap spent moving downhill.
        </p>
      </header>

      <section class="methodology" aria-labelledby="methodology-heading">
        <div class="section-copy">
          <p class="eyebrow">Method</p>
          <h2 id="methodology-heading">What the score means</h2>
        </div>
        <div class="method-grid">
          <article>
            <h3>Vertical</h3>
            <p>
              Inclusion comes from ski-area infoboxes, selected list rows or
              targeted Skiresort.info source pages. When a field distinguishes
              total, hike-to and lift-served vertical, the lift-served value is
              used. Closed, defunct and inaccessible resorts are excluded.
            </p>
          </article>
          <article>
            <h3>Lap model</h3>
            <p>
              Ski share = descent time / (descent time + lift time). Lift time is
              inferred from the listed lift system: tram/cable car, gondola,
              detachable chair, fixed-grip chair, surface lift or unknown mixed lift.
            </p>
          </article>
          <article>
            <h3>Snow</h3>
            <p>
              Base/top peak-season snow is a median snowpack estimate. Resorts
              below 3 ft at the top or 2 ft at the base are excluded, but snow is
              not part of the ranking. {wikiSnowCount} rows use wiki annual
              snowfall fields; {skiresortSnowCount} use Skiresort.info peak
              snow averages; {fallbackSnowCount} use regional/elevation fallbacks.
            </p>
          </article>
        </div>
      </section>

      <section class="ranking" aria-labelledby="ranking-heading">
        <div class="table-heading">
          <div>
            <p class="eyebrow">Full table</p>
            <h2 id="ranking-heading">All qualifying resorts</h2>
          </div>
          <p>
            No lift lines. No transfer time between lifts. The table only counts
            estimated time skiing and riding uphill.
          </p>
        </div>

        <div class="filter-bar" aria-label="Resort filters">
          <label class="filter-field" for="continent-filter">
            <span>Continent</span>
            <select id="continent-filter" name="continent" autocomplete="off">
              <option value="">All ({skiResorts.length})</option>
              {continentOptions.map((option) => (
                <option value={option.name}>
                  {option.name} ({option.count})
                </option>
              ))}
            </select>
          </label>
          <label class="filter-field" for="country-filter">
            <span>Country</span>
            <select id="country-filter" name="country" autocomplete="off">
              <option value="">All ({skiResorts.length})</option>
              {countryOptions.map((option) => (
                <option value={option.name} data-continent={option.continent}>
                  {option.name} ({option.count})
                </option>
              ))}
            </select>
          </label>
          <label class="filter-field" for="state-filter" id="state-filter-field" hidden>
            <span>State</span>
            <select id="state-filter" name="state" autocomplete="off">
              <option value="">All US states ({countryCounts.get("United States") ?? 0})</option>
              {usStateOptions.map((option) => (
                <option value={option.name}>
                  {option.name} ({option.count})
                </option>
              ))}
            </select>
          </label>
          <p id="filter-status" class="filter-status">
            Showing all {skiResorts.length} resorts.
          </p>
        </div>

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th scope="col">Rank</th>
                <th scope="col" aria-sort="none">
                  <button class="sort-button" type="button" data-sort-key="name" data-sort-default="asc">
                    Resort
                  </button>
                </th>
                <th scope="col" aria-sort="none">
                  <button class="sort-button" type="button" data-sort-key="vertical" data-sort-default="desc">
                    Vertical
                  </button>
                </th>
                <th scope="col" aria-sort="descending">
                  <button class="sort-button" type="button" data-sort-key="share" data-sort-default="desc">
                    Skiing share
                  </button>
                </th>
                <th scope="col" aria-sort="none">
                  <button class="sort-button" type="button" data-sort-key="down" data-sort-default="desc">
                    Down
                  </button>
                </th>
                <th scope="col" aria-sort="none">
                  <button class="sort-button" type="button" data-sort-key="up" data-sort-default="asc">
                    Up
                  </button>
                </th>
                <th scope="col" aria-sort="none">
                  <button class="sort-button" type="button" data-sort-key="baseSnow" data-sort-default="desc">
                    Median base snow
                  </button>
                </th>
                <th scope="col" aria-sort="none">
                  <button class="sort-button" type="button" data-sort-key="topSnow" data-sort-default="desc">
                    Median top snow
                  </button>
                </th>
              </tr>
            </thead>
            <tbody>
              {skiResorts.map((resort) => (
                <tr
                  data-continent={resort.continent}
                  data-country={resort.country}
                  data-state={getUsState(resort.location, resort.country)}
                  data-name={resort.name}
                  data-vertical={resort.verticalFt}
                  data-share={resort.skiingShare}
                  data-down={resort.descentMinutes}
                  data-up={resort.ascentMinutes}
                  data-base-snow={resort.snowAtBaseFt}
                  data-top-snow={resort.snowAtTopFt}
                >
                  <th scope="row">#{resort.rank}</th>
                  <td class="resort-cell">
                    <a href={resort.wikiUrl} target="_blank" rel="noreferrer noopener">
                      {resort.name}
                    </a>
                    <span>{resort.location} · {resort.country}</span>
                  </td>
                  <td title={`Source vertical field: ${resort.wikiVerticalField}`}>
                    {feet(resort.verticalFt)}
                  </td>
                  <td class="score-cell">
                    {percentFormatter.format(resort.skiingShare)}
                  </td>
                  <td>{minutes(resort.descentMinutes)}</td>
                  <td>{minutes(resort.ascentMinutes)}</td>
                  <td title={resort.snowEstimateSource}>
                    {snowFeet(resort.snowAtBaseFt)}
                  </td>
                  <td title={resort.snowEstimateSource}>
                    {snowFeet(resort.snowAtTopFt)}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

    </main>
  </body>
</html>

<script is:inline>
  const continentFilter = document.querySelector("#continent-filter");
  const countryFilter = document.querySelector("#country-filter");
  const stateFilter = document.querySelector("#state-filter");
  const stateFilterField = document.querySelector("#state-filter-field");
  const filterStatus = document.querySelector("#filter-status");
  const resortTableBody = document.querySelector("tbody");
  const resortRows = [...document.querySelectorAll("tbody tr[data-continent]")];
  const sortButtons = [...document.querySelectorAll(".sort-button")];
  const totalResorts = resortRows.length;
  const collator = new Intl.Collator("en", {
    sensitivity: "base",
    numeric: true,
  });
  let currentSort = {
    key: "share",
    direction: "desc",
  };

  const updateCountryOptions = () => {
    const selectedContinent = continentFilter?.value ?? "";
    const options = [...(countryFilter?.options ?? [])];

    for (const option of options) {
      if (!option.value) continue;
      option.hidden = Boolean(
        selectedContinent && option.dataset.continent !== selectedContinent,
      );
    }

    const selectedCountry = countryFilter?.selectedOptions?.[0];
    if (selectedCountry?.hidden && countryFilter) {
      countryFilter.value = "";
    }
  };

  const updateStateFilter = () => {
    const isUnitedStatesSelected = countryFilter?.value === "United States";

    if (stateFilterField) {
      stateFilterField.hidden = !isUnitedStatesSelected;
    }

    if (!isUnitedStatesSelected && stateFilter) {
      stateFilter.value = "";
    }
  };

  const updateFilters = () => {
    updateCountryOptions();
    updateStateFilter();

    const selectedContinent = continentFilter?.value ?? "";
    const selectedCountry = countryFilter?.value ?? "";
    const selectedState =
      selectedCountry === "United States" ? (stateFilter?.value ?? "") : "";
    let visibleCount = 0;

    for (const row of resortRows) {
      const isVisible =
        (!selectedContinent || row.dataset.continent === selectedContinent) &&
        (!selectedCountry || row.dataset.country === selectedCountry) &&
        (!selectedState || row.dataset.state === selectedState);

      row.hidden = !isVisible;
      if (isVisible) visibleCount += 1;
    }

    if (filterStatus) {
      filterStatus.textContent =
        visibleCount === totalResorts
          ? `Showing all ${totalResorts} resorts.`
          : `Showing ${visibleCount} of ${totalResorts} resorts.`;
    }
  };

  const getSortValue = (row, key) => {
    if (key === "name") return row.dataset.name ?? "";
    return Number(row.dataset[key] ?? 0);
  };

  const compareRows = (firstRow, secondRow) => {
    const firstValue = getSortValue(firstRow, currentSort.key);
    const secondValue = getSortValue(secondRow, currentSort.key);
    const multiplier = currentSort.direction === "asc" ? 1 : -1;

    if (currentSort.key === "name") {
      return multiplier * collator.compare(String(firstValue), String(secondValue));
    }

    const numericDifference = Number(firstValue) - Number(secondValue);
    if (numericDifference !== 0) return multiplier * numericDifference;

    return collator.compare(
      firstRow.dataset.name ?? "",
      secondRow.dataset.name ?? "",
    );
  };

  const updateSortState = () => {
    for (const button of sortButtons) {
      const isActive = button.dataset.sortKey === currentSort.key;
      button.dataset.sortDirection = isActive ? currentSort.direction : "";
      button.closest("th")?.setAttribute(
        "aria-sort",
        isActive
          ? currentSort.direction === "asc"
            ? "ascending"
            : "descending"
          : "none",
      );
    }
  };

  const sortRows = () => {
    if (!resortTableBody) return;

    const sortedRows = [...resortRows].sort(compareRows);
    for (const row of sortedRows) {
      resortTableBody.append(row);
    }

    updateSortState();
    updateFilters();
  };

  continentFilter?.addEventListener("change", updateFilters);
  countryFilter?.addEventListener("change", updateFilters);
  stateFilter?.addEventListener("change", updateFilters);
  for (const button of sortButtons) {
    button.addEventListener("click", () => {
      const sortKey = button.dataset.sortKey;
      if (!sortKey) return;

      const defaultDirection = button.dataset.sortDefault ?? "desc";
      currentSort =
        currentSort.key === sortKey
          ? {
              key: sortKey,
              direction: currentSort.direction === "asc" ? "desc" : "asc",
            }
          : {
              key: sortKey,
              direction: defaultDirection,
            };

      sortRows();
    });
  }

  sortRows();
</script>

<style>
  :root {
    color-scheme: light dark;
    --bg: #fbf9f6;
    --surface: #fffaf1;
    --text: #171510;
    --muted: #6d6254;
    --line: #d8cabb;
    --line-strong: #b9a791;
    --accent: #7d4a1f;
    --accent-soft: #ead5bd;
    --cold: #d9e5e7;
    --shadow: 0 24px 80px rgb(59 43 26 / 12%);
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #121412;
      --surface: #1b1c18;
      --text: #f3ede3;
      --muted: #b7ad9f;
      --line: #3b3932;
      --line-strong: #5b554a;
      --accent: #e7a765;
      --accent-soft: #3b2a1c;
      --cold: #24363a;
      --shadow: 0 24px 80px rgb(0 0 0 / 28%);
    }
  }

  * {
    box-sizing: border-box;
  }

  html {
    background:
      radial-gradient(circle at 20% 0%, var(--cold), transparent 32rem),
      linear-gradient(180deg, var(--bg), color-mix(in srgb, var(--bg) 88%, var(--surface)));
    color: var(--text);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    margin: 0;
    min-height: 100vh;
  }

  a {
    color: inherit;
    text-decoration-color: color-mix(in srgb, var(--accent) 52%, transparent);
    text-underline-offset: 0.18em;
  }

  a:hover {
    color: var(--accent);
  }

  .page {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
    padding: 22px 0 52px;
  }

  .page-header {
    padding: clamp(18px, 4vw, 42px) 0 clamp(22px, 4vw, 38px);
  }

  .home-link {
    display: inline-flex;
    margin-bottom: clamp(24px, 5vw, 48px);
    color: var(--muted);
    font-size: 0.86rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .eyebrow {
    margin: 0 0 10px;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    margin-bottom: 16px;
    font-size: clamp(1.67rem, 4.96vw, 4.12rem);
    letter-spacing: -0.07em;
    line-height: 0.92;
  }

  .intro {
    max-width: 720px;
    margin-bottom: clamp(20px, 4vw, 34px);
    color: var(--muted);
    font-size: clamp(1rem, 1.8vw, 1.25rem);
    line-height: 1.4;
  }

  section {
    margin-top: clamp(28px, 5vw, 54px);
  }

  .section-copy {
    display: grid;
    grid-template-columns: minmax(180px, 0.45fr) minmax(0, 1fr);
    gap: 18px;
    align-items: end;
    margin-bottom: 14px;
  }

  .section-copy h2,
  .table-heading h2 {
    margin-bottom: 0;
    font-size: clamp(1.65rem, 3.6vw, 3.2rem);
    letter-spacing: -0.06em;
    line-height: 1;
  }

  .method-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  .method-grid article {
    border: 1px solid var(--line);
    border-radius: 26px;
    background: color-mix(in srgb, var(--surface) 88%, transparent);
    box-shadow: var(--shadow);
  }

  .method-grid p,
  .table-heading p {
    color: var(--muted);
  }

  .method-grid article {
    padding: 16px;
  }

  .method-grid h3 {
    margin-bottom: 6px;
    font-size: 1rem;
  }

  .method-grid p {
    margin-bottom: 0;
  }

  .table-heading {
    display: grid;
    grid-template-columns: minmax(280px, 0.75fr) minmax(0, 1fr);
    gap: 18px;
    align-items: end;
    margin-bottom: 12px;
  }

  .table-heading p {
    max-width: 560px;
    margin-bottom: 4px;
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: end;
    margin-bottom: 12px;
  }

  .filter-field {
    display: grid;
    gap: 5px;
    min-width: min(220px, 100%);
  }

  .filter-field[hidden] {
    display: none;
  }

  .filter-field span {
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .filter-field select {
    min-height: 38px;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--surface);
    color: var(--text);
    font: inherit;
    font-size: 0.92rem;
    font-weight: 750;
    padding: 7px 34px 7px 10px;
  }

  .filter-status {
    margin: 0 0 8px auto;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .table-wrap {
    overflow-x: auto;
    border: 1px solid var(--line);
    border-radius: 26px;
    background: var(--surface);
    box-shadow: var(--shadow);
  }

  table {
    width: 100%;
    min-width: 1120px;
    border-collapse: separate;
    border-spacing: 0;
    font-size: 0.9rem;
  }

  th,
