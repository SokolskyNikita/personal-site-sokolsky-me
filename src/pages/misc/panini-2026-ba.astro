---
import pageData from "../../data/panini-2026-ba.json";

export const prerender = true;

const pageTitle = "Where to buy Panini FIFA 2026 in Buenos Aires";
const pageDescription =
  "Buenos Aires guide to Panini FIFA World Cup 2026 stickers and cards: official ZonaKids stock, supermarket multi-pack buys, wholesale bulk, and loose-sticker pickup — with bulk options highlighted.";
const themeColorLight = "#f4f1ea";
const themeColorDark = "#12110f";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
type Seller = (typeof pageData.sellers)[number];
const sellers = pageData.sellers;
const updatedDate = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
}).format(new Date(pageData.generatedAt));
const arsFormatter = new Intl.NumberFormat("en-US", {
  style: "currency",
  currency: "ARS",
  maximumFractionDigits: 0,
});
const collator = new Intl.Collator("en", {
  sensitivity: "base",
  numeric: true,
});
const bulkCount = sellers.filter((seller: Seller) => seller.bulk).length;
const inStockCount = sellers.filter(
  (seller: Seller) => seller.stockStatus === "in",
).length;
const kindCounts = sellers.reduce((counts, seller: Seller) => {
  counts.set(seller.kind, (counts.get(seller.kind) ?? 0) + 1);
  return counts;
}, new Map<string, number>());
const kindLabels: Record<string, string> = {
  "official-online": "Official online",
  wholesale: "Wholesale",
  supermarket: "Supermarket",
  "toy-store": "Toy store",
  "loose-stickers": "Loose stickers",
  kiosk: "Kiosks",
};
const kindOptions = [...kindCounts.entries()]
  .sort(
    ([nameA, countA], [nameB, countB]) =>
      countB - countA || collator.compare(nameA, nameB),
  )
  .map(([name, count]) => ({
    name,
    label: kindLabels[name] ?? name,
    count,
  }));
const stockRank = (status: Seller["stockStatus"]) =>
  ({ in: 0, variable: 1, scarce: 2, out: 3 })[status] ?? 9;
const sortRank = (
  items: Seller[],
  compare: (a: Seller, b: Seller) => number,
) =>
  new Map<string, number>(
    items
      .toSorted(compare)
      .map((seller: Seller, index: number) => [seller.id, index + 1]),
  );
const priorityRanks = sortRank(
  sellers,
  (a: Seller, b: Seller) =>
    a.priority - b.priority || collator.compare(a.name, b.name),
);
const bulkRanks = sortRank(
  sellers,
  (a: Seller, b: Seller) =>
    Number(b.bulkHighlight) - Number(a.bulkHighlight) ||
    Number(b.bulk) - Number(a.bulk) ||
    stockRank(a.stockStatus) - stockRank(b.stockStatus) ||
    a.priority - b.priority,
);
const stockRanks = sortRank(
  sellers,
  (a: Seller, b: Seller) =>
    stockRank(a.stockStatus) - stockRank(b.stockStatus) ||
    Number(b.bulk) - Number(a.bulk) ||
    a.priority - b.priority,
);
const nameRanks = sortRank(sellers, (a: Seller, b: Seller) =>
  collator.compare(a.name, b.name),
);
const sellersWithSort = sellers.map((seller: Seller) => ({
  ...seller,
  kindLabel: kindLabels[seller.kind] ?? seller.kind,
  sortOrderStyle: [
    `--sort-priority: ${priorityRanks.get(seller.id)}`,
    `--sort-bulk: ${bulkRanks.get(seller.id)}`,
    `--sort-stock: ${stockRanks.get(seller.id)}`,
    `--sort-name: ${nameRanks.get(seller.id)}`,
  ].join("; "),
}));
const buenosAiresBounds = {
  latMin: -34.72,
  latMax: -34.48,
  lngMin: -58.56,
  lngMax: -58.3,
};
const mappableSellers = sellers.filter((seller: Seller) => {
  if (!seller.location) return false;
  const { lat, lng } = seller.location;
  return (
    lat >= buenosAiresBounds.latMin &&
    lat <= buenosAiresBounds.latMax &&
    lng >= buenosAiresBounds.lngMin &&
    lng <= buenosAiresBounds.lngMax
  );
});
const googleMapsApiKey =
  import.meta.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
  process.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
  "";
const sellerMapData = mappableSellers.map((seller: Seller) => ({
  id: seller.id,
  name: seller.name,
  googleMapsUrl: seller.googleMapsUrl,
  neighborhood: seller.neighborhood,
  kind: seller.kind,
  bulk: seller.bulk,
  bulkHighlight: seller.bulkHighlight,
  stockStatus: seller.stockStatus,
  position: seller.location,
}));
const mapsIcon = `<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="#1a73e8" d="M12 2.2c3.9 0 7.1 3.1 7.1 7 0 5.1-7.1 12.6-7.1 12.6S4.9 14.3 4.9 9.2c0-3.9 3.2-7 7.1-7Z"/><path fill="#34a853" d="M7.2 14.1 12 21.8l4.8-7.7-4.8-2.8-4.8 2.8Z"/><path fill="#fbbc04" d="M4.9 9.2c0 1.8.9 3.5 2.3 4.9l4.8-2.8V2.2c-3.9 0-7.1 3.1-7.1 7Z"/><path fill="#ea4335" d="M19.1 9.2c0 1.8-.9 3.5-2.3 4.9L12 11.3V2.2c3.9 0 7.1 3.1 7.1 7Z"/><circle cx="12" cy="9.3" r="2.45" fill="#fff"/></svg>`;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  numberOfItems: sellers.length,
  itemListElement: sellers.map((seller, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "Store",
      name: seller.name,
      url: seller.officialUrl,
      ...(seller.googleMapsUrl ? { sameAs: seller.googleMapsUrl } : {}),
      address: seller.fullAddress,
      ...(seller.location
        ? {
            geo: {
              "@type": "GeoCoordinates",
              latitude: seller.location.lat,
              longitude: seller.location.lng,
            },
          }
        : {}),
      description: seller.description,
    },
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="subject" content="Panini FIFA 2026 Buenos Aires" />
    <meta name="application-name" content={pageTitle} />
    <meta
      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="googlebot"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="keywords"
      content="Panini FIFA 2026 Buenos Aires, figuritas Mundial 2026 CABA, ZonaKids, caja sobres Panini, comprar figuritas bulk Argentina"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta
      name="theme-color"
      content={themeColorLight}
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content={themeColorDark}
      media="(prefers-color-scheme: dark)"
    />
    <meta name="msapplication-TileColor" content={themeColorDark} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color={themeColorDark} />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Nikita Sokolsky" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <main class="page">
      <header class="page-header">
        <a class="home-link" href="/">Nikita Sokolsky</a>
        <div class="headline">
          <p class="eyebrow">Buenos Aires guide</p>
          <h1>Panini FIFA 2026 in BA</h1>
          <p class="intro">
            {sellers.length} channels checked via Google Places, official stores, wholesalers, and press —
            stickers, albums, and Adrenalyn. Bulk options with inventory are highlighted; map pins physical stops.
          </p>
        </div>
        <div class="toolbar" aria-label="Seller controls">
          <fieldset class="sort-toggle">
            <legend>Sort by</legend>
            <input id="sort-bulk" type="radio" name="sort" autocomplete="off" checked />
            <label for="sort-bulk">Bulk first</label>
            <input id="sort-stock" type="radio" name="sort" autocomplete="off" />
            <label for="sort-stock">Stock</label>
            <input id="sort-priority" type="radio" name="sort" autocomplete="off" />
            <label for="sort-priority">Guide order</label>
            <input id="sort-name" type="radio" name="sort" autocomplete="off" />
            <label for="sort-name">Name</label>
          </fieldset>
          <fieldset class="extras-toggle">
            <legend>Filter</legend>
            <input id="filter-bulk" type="checkbox" autocomplete="off" />
            <label for="filter-bulk">Bulk only ({bulkCount})</label>
            <input id="filter-in-stock" type="checkbox" autocomplete="off" />
            <label for="filter-in-stock">Confirmed in stock ({inStockCount})</label>
          </fieldset>
          <label class="filter-dropdown" for="kind-filter">
            <span>Channel</span>
            <select id="kind-filter" name="kind" autocomplete="off">
              <option value="">All ({sellers.length})</option>
              {kindOptions.map((option) => (
                <option value={option.name}>
                  {option.label} ({option.count})
                </option>
              ))}
            </select>
          </label>
          <p class="meta">
            Updated {updatedDate}. MSRP pack {arsFormatter.format(pageData.official.packArs)} ·
            soft album {arsFormatter.format(pageData.official.albumSoftArs)}. Official store:{" "}
            <a href={pageData.official.onlineStore} target="_blank" rel="noreferrer noopener">
              {pageData.official.onlineStoreLabel}
            </a>.
          </p>
        </div>
      </header>

      <aside class="callout callout-bulk" aria-labelledby="bulk-heading">
        <p class="eyebrow">Bulk pick</p>
        <h2 id="bulk-heading">Bulk options right now</h2>
        <ul>
          <li>
            <strong>Sealed sticker bulk:</strong> WOWCO caja ×1000 (listed); ZonaKids Box/Pack ×50 —
            sold out, set alerts; Activa (Santa Fe) volume tiers from 1,000 packs.
          </li>
          <li>
            <strong>CABA wholesale pickup:</strong> Golmarymar Caballito & Mataderos (site promotes WC
            2026); Megafigus (San Cristóbal) — call first.
          </li>
          <li>
            <strong>Official sealed in stock:</strong> ZonaKids Adrenalyn XL display ×24 (cards, not
            stickers).
          </li>
          <li>
            <strong>Best BA shelf multi-pack:</strong> Carrefour Salguero, Jumbo Bullrich, Coto Santa
            Fe, Disco, Vea — buy stacks at MSRP when restocked.
          </li>
        </ul>
      </aside>

      <aside class="callout callout-warn" aria-labelledby="scam-heading">
        <p class="eyebrow">Scam watch</p>
        <h2 id="scam-heading">Official channels only</h2>
        <p>{pageData.scamWarning}</p>
      </aside>

      <section class="seller-list" aria-label="Panini sellers">
        <div class="seller-row seller-head" aria-hidden="true">
          <span>Seller</span>
          <span>Map</span>
          <span>Where</span>
          <span>Bulk</span>
          <span>Stock</span>
          <span>Price</span>
          <span>Notes</span>
        </div>

        {sellersWithSort.map((seller) => (
          <article
            class:list={[
              "seller-row",
              { "seller-bulk-highlight": seller.bulkHighlight },
            ]}
            style={seller.sortOrderStyle}
            data-kind={seller.kind}
            data-bulk={String(seller.bulk)}
            data-stock={seller.stockStatus}
            data-bulk-highlight={String(seller.bulkHighlight)}
          >
            <h2 class="seller-name">
              <a href={seller.officialUrl} target="_blank" rel="noreferrer noopener">
                {seller.name}
              </a>
              {seller.bulkHighlight && <span class="badge badge-bulk">Bulk pick</span>}
              <span class="kind-chip">{seller.kindLabel}</span>
            </h2>
            <div class="map-actions">
              {seller.googleMapsUrl ? (
                <a
                  class="maps-link"
                  href={seller.googleMapsUrl}
                  target="_blank"
                  rel="noreferrer noopener"
                  aria-label={`Open ${seller.name} on Google Maps`}
                  title={`Open ${seller.name} on Google Maps`}
                >
                  <span class="maps-icon" set:html={mapsIcon} />
                </a>
              ) : (
                <span class="maps-empty" aria-hidden="true">—</span>
              )}
            </div>
            <p class="address">
              <span class="address-line">{seller.address}</span>
              <span class="neighborhood">{seller.neighborhood}</span>
            </p>
            <p class="bulk-cell">
              <span class="bulk-label">{seller.bulkLabel}</span>
            </p>
            <p class={`stock stock-${seller.stockStatus}`}>
              <span class="stock-label">{seller.stockLabel}</span>
            </p>
            <p class="price">
              <span class="price-label">{seller.priceNote}</span>
              <span class="price-service">{seller.products}</span>
            </p>
            <p class="mobile-meta" aria-hidden="true">
              <span class={`stock stock-${seller.stockStatus}`}>{seller.stockLabel}</span>
              <span>{seller.bulkLabel}</span>
              <span>{seller.neighborhood}</span>
            </p>
            <p class="description">{seller.description}</p>
          </article>
        ))}
      </section>

      <section class="seller-map-section" aria-labelledby="seller-map-heading">
        <div class="map-copy">
          <p class="eyebrow">Map</p>
          <h2 id="seller-map-heading">Buenos Aires Panini map</h2>
          <p id="seller-map-status" class="map-status">
            Showing {mappableSellers.length} CABA / AMBA pins (online-only and out-of-area wholesalers
            stay in the list). Pins follow filters above.
          </p>
        </div>
        {googleMapsApiKey ? (
          <div
            id="seller-map"
            class="seller-map"
            aria-label="Google Map with pins for Buenos Aires Panini sellers"
          ></div>
        ) : (
          <p class="map-unavailable">
            Map unavailable because the Google Maps public key is not configured.
          </p>
        )}
      </section>

      <footer class="page-footer">
        <p>
          Verified with Google Places API plus{" "}
          <a href="https://zonakids.com/productos/colecciones-2026/fifa-world-cup-2026" target="_blank" rel="noreferrer noopener">ZonaKids</a>,{" "}
          <a href="https://wowco.com.ar/carpeta-ver.php?idcarpeta=125" target="_blank" rel="noreferrer noopener">WOWCO</a>,{" "}
          <a href="https://golmarymar.com.ar/" target="_blank" rel="noreferrer noopener">Golmarymar</a>,{" "}
          <a href="https://cromy-club.com.ar/" target="_blank" rel="noreferrer noopener">Cromy Club</a>,{" "}
          <a href="https://activadistribuidora.com.ar/producto/figuritas-panini-copa-mundial-fifa-2026/" target="_blank" rel="noreferrer noopener">Activa</a>,{" "}
          <a href="https://figusdelmundial.com/" target="_blank" rel="noreferrer noopener">Figus del Mundial</a>,{" "}
          and press (A24, Infobae, La Nación). Stock moves daily — call or check before you go.
        </p>
      </footer>
    </main>
  </body>
</html>

<script is:inline define:vars={{ googleMapsApiKey, sellerMapData }}>
  if (googleMapsApiKey) {
    ((g) => {
      let h;
      let a;
      let k;
      const p = "The Google Maps JavaScript API";
      const c = "google";
      const l = "importLibrary";
      const q = "__ib__";
      const m = document;
      let b = window;
      b = b[c] || (b[c] = {});
      const d = b.maps || (b.maps = {});
      const r = new Set();
      const e = new URLSearchParams();
      const u = () =>
        h ||
        (h = new Promise(async (resolve, reject) => {
          await (a = m.createElement("script"));
          e.set("libraries", [...r] + "");
          for (k in g) {
            e.set(k.replace(/[A-Z]/g, (t) => `_${t[0].toLowerCase()}`), g[k]);
          }
          e.set("callback", `${c}.maps.${q}`);
          a.src = `https://maps.${c}apis.com/maps/api/js?${e}`;
          d[q] = resolve;
          a.onerror = () => (h = reject(Error(`${p} could not load.`)));
          a.nonce = m.querySelector("script[nonce]")?.nonce || "";
          m.head.append(a);
        }));
      d[l] ? console.warn(`${p} only loads once. Ignoring:`, g) : (d[l] = (f, ...n) => r.add(f) && u().then(() => d[l](f, ...n)));
    })({
      key: googleMapsApiKey,
      v: "weekly",
    });
  }

  const kindFilter = document.querySelector("#kind-filter");
  const bulkFilter = document.querySelector("#filter-bulk");
  const inStockFilter = document.querySelector("#filter-in-stock");
  const defaultSort = document.querySelector("#sort-bulk");
  const sellerRows = [...document.querySelectorAll(".seller-row:not(.seller-head)")];
  const mapElement = document.querySelector("#seller-map");
  const mapStatus = document.querySelector("#seller-map-status");
  const buenosAiresCenter = { lat: -34.6037, lng: -58.3816 };
  const filterUrlParams = ["kind", "bulk", "inStock"];
  const markerRecords = [];
  let sellerMap;
  let infoWindow;

  const escapeHtml = (value) =>
    String(value).replace(/[&<>"']/g, (character) => ({
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#39;",
    })[character]);

  const matchesFilters = (seller, selectedKind, bulkOnly, inStockOnly) => {
    if (selectedKind && seller.kind !== selectedKind) return false;
    if (bulkOnly && !seller.bulk) return false;
    if (inStockOnly && seller.stockStatus !== "in") return false;
    return true;
  };

  const getVisibleSellers = (selectedKind, bulkOnly, inStockOnly) =>
    sellerMapData.filter((seller) =>
      matchesFilters(seller, selectedKind, bulkOnly, inStockOnly),
    );

  const updateMapStatus = (selectedKind, bulkOnly, inStockOnly) => {
    if (!mapStatus) return;

    const visibleCount = getVisibleSellers(selectedKind, bulkOnly, inStockOnly).length;
    const label = visibleCount === 1 ? "location" : "locations";
    const bits = [];
    if (bulkOnly) bits.push("bulk");
    if (inStockOnly) bits.push("in stock");
    const suffix = bits.length ? ` (${bits.join(", ")})` : "";
    mapStatus.textContent = `Showing ${visibleCount} mapped ${label}${suffix}.`;
  };

  const fitMapToMarkers = (visibleRecords) => {
    if (!sellerMap || !window.google?.maps || visibleRecords.length === 0) return;

    if (visibleRecords.length === 1) {
      sellerMap.setCenter(visibleRecords[0].seller.position);
      sellerMap.setZoom(13);
      return;
    }

    const bounds = new google.maps.LatLngBounds();
    for (const { seller } of visibleRecords) {
      bounds.extend(seller.position);
    }
    sellerMap.fitBounds(bounds, 44);
  };

  const syncMapMarkers = (selectedKind, bulkOnly, inStockOnly) => {
    updateMapStatus(selectedKind, bulkOnly, inStockOnly);
    if (!sellerMap) return;

    const visibleIds = new Set(
      getVisibleSellers(selectedKind, bulkOnly, inStockOnly).map((seller) => seller.id),
    );
    const visibleRecords = [];

    for (const record of markerRecords) {
      const isVisible = visibleIds.has(record.seller.id);
      record.marker.setMap(isVisible ? sellerMap : null);
      if (isVisible) visibleRecords.push(record);
    }

    if (mapElement) mapElement.dataset.visiblePins = String(visibleRecords.length);
    fitMapToMarkers(visibleRecords);
  };

  const updateFilterUrl = (selectedKind, bulkOnly, inStockOnly) => {
    const url = new URL(window.location.href);
    for (const paramName of filterUrlParams) {
      url.searchParams.delete(paramName);
    }
    if (selectedKind) url.searchParams.set("kind", selectedKind);
    if (bulkOnly) url.searchParams.set("bulk", "1");
    if (inStockOnly) url.searchParams.set("inStock", "1");

    const nextUrl = `${url.pathname}${url.search}${url.hash}`;
    const currentUrl = `${window.location.pathname}${window.location.search}${window.location.hash}`;
    if (nextUrl !== currentUrl) {
      window.history.replaceState(null, "", nextUrl);
    }
  };

  const initSellerMap = async () => {
    if (!mapElement || !googleMapsApiKey || !window.google?.maps?.importLibrary) return;

    const { Map, InfoWindow } = await google.maps.importLibrary("maps");
    await google.maps.importLibrary("marker");

    sellerMap = new Map(mapElement, {
      center: buenosAiresCenter,
      clickableIcons: false,
      fullscreenControl: true,
      mapTypeControl: false,
      streetViewControl: false,
      zoom: 12,
    });
    infoWindow = new InfoWindow();

    for (const seller of sellerMapData) {
      const marker = new google.maps.Marker({
        map: sellerMap,
        position: seller.position,
        title: seller.name,
      });

      marker.addListener("click", () => {
        const mapsLink = seller.googleMapsUrl
          ? `<br><a href="${escapeHtml(seller.googleMapsUrl)}" target="_blank" rel="noreferrer noopener">Open in Google Maps</a>`
          : "";
        const bulkBit = seller.bulk ? "<br>Bulk-capable" : "";
        infoWindow.setContent(
          `<strong>${escapeHtml(seller.name)}</strong><br>${escapeHtml(seller.neighborhood)}${bulkBit}${mapsLink}`,
        );
        infoWindow.open(sellerMap, marker);
      });

      markerRecords.push({ seller, marker });
    }

    syncMapMarkers(
      kindFilter?.value ?? "",
      bulkFilter?.checked ?? false,
      inStockFilter?.checked ?? false,
    );
  };

  const applyFilters = ({ syncUrl = true } = {}) => {
    const selectedKind = kindFilter?.value ?? "";
    const bulkOnly = bulkFilter?.checked ?? false;
    const inStockOnly = inStockFilter?.checked ?? false;

    if (syncUrl) {
      updateFilterUrl(selectedKind, bulkOnly, inStockOnly);
    }

    for (const row of sellerRows) {
      const kindMismatch = Boolean(selectedKind) && row.dataset.kind !== selectedKind;
      const bulkMismatch = bulkOnly && row.dataset.bulk !== "true";
      const stockMismatch = inStockOnly && row.dataset.stock !== "in";
      row.hidden = kindMismatch || bulkMismatch || stockMismatch;
    }

    syncMapMarkers(selectedKind, bulkOnly, inStockOnly);
  };

  const resetControls = () => {
    if (defaultSort) defaultSort.checked = true;
    if (kindFilter) kindFilter.value = "";
    if (bulkFilter) bulkFilter.checked = false;
    if (inStockFilter) inStockFilter.checked = false;
  };

  const setSelectFromUrl = (selectElement, value) => {
    if (!selectElement || !value) return;
    const hasOption = [...selectElement.options].some((option) => option.value === value);
    if (hasOption) selectElement.value = value;
  };

  const hasEnabledUrlParam = (params, paramName) => {
    const value = params.get(paramName);
    if (value === null) return false;
    return !["0", "false", "no", "off"].includes(value.toLowerCase());
  };

  const applyFiltersFromUrl = () => {
    const params = new URLSearchParams(window.location.search);
    resetControls();
    setSelectFromUrl(kindFilter, params.get("kind"));
    if (bulkFilter) bulkFilter.checked = hasEnabledUrlParam(params, "bulk");
    if (inStockFilter) inStockFilter.checked = hasEnabledUrlParam(params, "inStock");
    applyFilters({ syncUrl: false });
  };

  kindFilter?.addEventListener("change", applyFilters);
  bulkFilter?.addEventListener("change", applyFilters);
  inStockFilter?.addEventListener("change", applyFilters);
  applyFiltersFromUrl();
  window.addEventListener("pageshow", applyFiltersFromUrl);
  window.addEventListener("popstate", applyFiltersFromUrl);
  initSellerMap().catch((error) => {
    console.error("Unable to initialize Panini seller map", error);
    if (mapStatus) mapStatus.textContent = "Map unavailable. Seller list still works.";
  });
</script>

