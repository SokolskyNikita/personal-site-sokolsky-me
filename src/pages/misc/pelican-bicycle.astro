---
export const prerender = true;

const pageTitle = "Pelican bicycle";
const pageDescription =
  "An animated pelican riding a bicycle — full-screen scene.";
const themeColor = "#87ceeb";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content={themeColor} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="sokolsky.me" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>

    <style is:global>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html,
      body {
        width: 100%;
        height: 100%;
        overflow: hidden;
        background: #88cdd4;
      }

      body {
        position: fixed;
        inset: 0;
        overscroll-behavior: none;
        -webkit-tap-highlight-color: transparent;
      }
    </style>
  </head>
  <body>
    <main class="scene" aria-label="An animated pelican cheerfully riding a bicycle">
      <svg
        class="illustration"
        viewBox="0 0 1600 900"
        preserveAspectRatio="xMidYMid slice"
        role="img"
        aria-labelledby="scene-title scene-description"
      >
        <title id="scene-title">Pelican riding a bicycle</title>
        <desc id="scene-description">
          A white pelican pedals a red bicycle along a sunny coastal road while
          clouds, grasses, and road markings pass by.
        </desc>

        <defs>
          <linearGradient id="sky" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#72c4d5" />
            <stop offset="0.7" stop-color="#b8e0d2" />
            <stop offset="1" stop-color="#f4d8a1" />
          </linearGradient>
          <linearGradient id="road" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#596867" />
            <stop offset="1" stop-color="#2f3d3d" />
          </linearGradient>
          <radialGradient id="sun-glow">
            <stop offset="0" stop-color="#fff2b8" stop-opacity=".75" />
            <stop offset="1" stop-color="#fff2b8" stop-opacity="0" />
          </radialGradient>
          <filter id="soft-shadow" x="-40%" y="-40%" width="180%" height="180%">
            <feGaussianBlur stdDeviation="12" />
          </filter>
          <filter id="soften" x="-20%" y="-20%" width="140%" height="140%">
            <feGaussianBlur stdDeviation="3" />
          </filter>
          <clipPath id="body-clip">
            <ellipse cx="793" cy="439" rx="118" ry="101" />
          </clipPath>
        </defs>

        <rect width="1600" height="900" fill="url(#sky)" />
        <circle cx="1275" cy="170" r="155" fill="url(#sun-glow)" />
        <circle cx="1275" cy="170" r="62" fill="#f8d56a" />

        <g class="clouds clouds--far" fill="#e8f3e9" opacity=".72">
          <path d="M-150 202c25-45 76-61 116-34 29-58 119-53 143 8 47-17 94 16 95 67h-354Z" />
          <path d="M990 278c18-38 64-53 99-29 31-54 111-42 125 18 45-11 81 22 82 62H955c1-27 13-43 35-51Z" />
          <path d="M1630 134c22-44 76-60 114-31 30-61 121-54 143 10 49-18 99 15 99 68h-386c0-25 10-40 30-47Z" />
        </g>
        <g class="clouds clouds--near" fill="#f4f6df" opacity=".9">
          <path d="M154 108c21-48 80-70 123-38 39-73 147-58 161 24 57-13 108 28 109 83H113c1-34 14-57 41-69Z" />
          <path d="M1470 280c26-54 95-71 139-30 41-70 151-53 163 31 61-13 111 31 112 87h-459c1-41 16-71 45-88Z" />
        </g>

        <path
