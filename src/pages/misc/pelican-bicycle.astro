              stroke="#394844"
              stroke-width="8"
            />
            <path d="M774 401c37 28 74 46 111 54M760 421c33 31 67 53 102 65" fill="none" stroke="#b8baaa" stroke-width="5" stroke-linecap="round" />

            <path
              d="M845 392c-5-88 2-158 35-208 22-35 61-49 98-35 46 17 65 70 40 111-17 27-47 39-83 37 5 50 0 94-17 131Z"
              fill="#f3efdc"
              stroke="#394844"
              stroke-width="8"
            />
            <path
              d="M937 207c33-9 74-5 113 12l119 52-135 35c-41 11-83 2-111-25Z"
