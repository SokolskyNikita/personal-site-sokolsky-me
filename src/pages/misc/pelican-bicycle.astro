              stroke="#394844"
              stroke-width="8"
              stroke-linejoin="round"
            />
            <path d="M966 470c12-9 26-6 34 5-8 12-20 17-35 15" fill="#e2a94a" stroke="#394844" stroke-width="6" stroke-linecap="round" />

            <g class="feet" fill="none" stroke="#d7a142" stroke-width="16" stroke-linecap="round" stroke-linejoin="round">
              <path id="leg-back" d="M760 505 Q737 567 782 612 Q813 674 850 674" />
              <path id="leg-front" d="M821 514 Q853 565 844 616 Q813 674 776 674" />
            </g>
          </g>

          <g class="crank" fill="none" stroke-linecap="round">
            <circle cx="813" cy="674" r="13" fill="#e5c46d" stroke="#273b39" stroke-width="5" />
            <path id="crank-arm-a" d="M813 674 850 674" stroke="#d8b65d" stroke-width="8" />
            <path id="crank-arm-b" d="M813 674 776 674" stroke="#d8b65d" stroke-width="8" />
            <path id="pedal-a" d="M836 674h28" stroke="#273b39" stroke-width="8" />
            <path id="pedal-b" d="M762 674h28" stroke="#273b39" stroke-width="8" />
          </g>
        </g>

        <g class="grass grass--front" fill="#6e752d">
          <path d="M0 900v-38l18 27 9-59 12 58 24-45 4 48 20-70 9 68 31-42 2 45 27-69 8 67 30-52 7 55 24-78 9 77 28-46 6 48 29-68 7 68 31-51 5 53 34-73 5 72 31-49 8 51 29-79 8 78 31-47 7 49 27-67 8 66 35-50 4 52 31-75 8 73 31-49 7 51 29-70 7 69 34-48 5 50 31-80 8 78 32-47 7 50 28-69 8 68 32-43 6 46 34-78 7 76 31-47 8 49 29-67 7 66 33-47 6 50 31-78 8 76 32-48 7 51 29-68 8 67 32-45 6 48 33-76 7 74 32-47 7 50 30-69 7 68 31-43 7 45 31-78 8 76 32-47 7 49 29-67 8 66 33-44 5 46 33-75 7 73 30-45 8 48 27-66 10 65 32-45 6 47 32-76 8 75 32-48 7 49 30-67 8 66 33-45 6 47 31-76 8 75 31-48 7 50 31-68 7 66 33-43 6 45 31-78 8 77 32-48 7 49 30-67 8 66 32-44 6 46 32-76 8 75 32-47 7 49 29-67 8 66 34-45 5 47v38Z" />
        </g>
      </svg>

      <p class="motion-note" aria-hidden="true">PEDALING SOMEWHERE</p>
    </main>

    <style>
      .scene {
        position: fixed;
        inset: 0;
        width: 100vw;
        height: 100vh;
        width: 100dvw;
        height: 100dvh;
        overflow: hidden;
        background: #88cdd4;
        isolation: isolate;
      }

      .illustration {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        display: block;
        animation: scene-in 900ms cubic-bezier(.16, 1, .3, 1) both;
      }

      .clouds,
      .road-marks,
      .grass {
        will-change: transform;
      }

      .clouds--far {
        animation: scenery-pass 30s linear infinite;
      }

      .clouds--near {
        animation: scenery-pass 19s linear infinite;
      }

      .road-marks {
        animation: road-pass 1.1s linear infinite;
      }

      .grass--back {
        animation: grass-pass 3.5s linear infinite;
      }

      .grass--front {
        animation: grass-pass 1.8s linear infinite;
      }

      .rider {
        transform-origin: 800px 670px;
        transform: translateX(var(--rider-shift-x, 0px)) scale(var(--rider-scale, 1));
        animation: rider-bob 520ms ease-in-out infinite alternate;
      }

      .rider-shadow {
        transform-origin: center;
        animation: shadow-pulse 520ms ease-in-out infinite alternate;
      }

      .wheel {
        transform-box: view-box;
        animation: wheel-spin 680ms linear infinite;
      }

      .wheel--left {
        transform-origin: 626px 674px;
      }

      .wheel--right {
        transform-origin: 979px 674px;
      }

      .wing {
        transform-box: view-box;
        transform-origin: 800px 405px;
        animation: feather-ruffle 780ms ease-in-out infinite alternate;
      }

      .front-wing {
        transform-box: view-box;
        transform-origin: 850px 405px;
        animation: steer 1.4s ease-in-out infinite alternate;
      }

      .tail {
        transform-box: view-box;
        transform-origin: 700px 455px;
        animation: tail-flutter 410ms ease-in-out infinite alternate;
      }

      .lower-beak {
        transform-box: view-box;
        transform-origin: 930px 276px;
        animation: beak-chatter 2.8s ease-in-out infinite;
      }

      .motion-note {
        position: fixed;
        left: max(18px, env(safe-area-inset-left));
        bottom: max(14px, env(safe-area-inset-bottom));
        color: #f4e7ba;
        font: 700 clamp(.58rem, 1.2vw, .78rem)/1.1 ui-rounded, "Avenir Next", sans-serif;
        letter-spacing: .2em;
        opacity: .72;
        text-shadow: 0 1px 0 rgb(22 41 38 / .4);
        animation: note-in 1s 450ms cubic-bezier(.16, 1, .3, 1) both;
      }

      @keyframes scene-in {
        from { opacity: 0; transform: scale(1.025); }
        to { opacity: 1; transform: scale(1); }
      }

      @keyframes scenery-pass {
        to { transform: translateX(-1600px); }
      }

      @keyframes road-pass {
        to { transform: translateX(-270px); }
      }

      @keyframes grass-pass {
        to { transform: translateX(-180px); }
      }

      @keyframes wheel-spin {
        to { transform: rotate(360deg); }
      }

      @keyframes rider-bob {
        from { transform: translateX(var(--rider-shift-x, 0px)) scale(var(--rider-scale, 1)) translateY(-3px) rotate(-.25deg); }
        to { transform: translateX(var(--rider-shift-x, 0px)) scale(var(--rider-scale, 1)) translateY(5px) rotate(.25deg); }
      }

      @keyframes shadow-pulse {
        from { transform: scaleX(.96); opacity: .22; }
        to { transform: scaleX(1.03); opacity: .3; }
      }

      @keyframes feather-ruffle {
        from { transform: rotate(-1deg); }
        to { transform: rotate(2.5deg); }
      }

      @keyframes steer {
        from { transform: rotate(-1deg); }
        to { transform: rotate(1.5deg); }
      }

      @keyframes tail-flutter {
        from { transform: rotate(-2deg); }
        to { transform: rotate(4deg); }
      }

      @keyframes beak-chatter {
        0%, 82%, 100% { transform: rotate(0); }
        88% { transform: rotate(2.5deg); }
        94% { transform: rotate(.5deg); }
      }

      @keyframes note-in {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: .72; transform: translateY(0); }
      }

      @media (max-aspect-ratio: 3 / 4) {
        .motion-note {
          display: none;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .illustration,
        .clouds,
        .road-marks,
        .grass,
        .rider,
        .rider-shadow,
        .wheel,
        .wing,
        .front-wing,
        .tail,
        .lower-beak,
        .motion-note {
          animation: none;
        }
      }
    </style>

    <script>
      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
      const rider = document.querySelector<SVGGElement>(".rider");
      const legBack = document.getElementById("leg-back");
      const legFront = document.getElementById("leg-front");
      const crankArmA = document.getElementById("crank-arm-a");
      const crankArmB = document.getElementById("crank-arm-b");
      const pedalA = document.getElementById("pedal-a");
      const pedalB = document.getElementById("pedal-b");

      const center = { x: 813, y: 674 };
      const radius = 37;
      let frameId = 0;
      let resizeFrameId = 0;
      let startedAt = performance.now();

      const fitRiderToViewport = () => {
        const aspect = window.innerWidth / window.innerHeight;
        const sceneAspect = 16 / 9;
        let scale = 1;
        let shiftX = 0;

        if (aspect < sceneAspect) {
          const visibleSceneWidth = 900 * aspect;
          scale = Math.min(1, Math.max(0.44, (visibleSceneWidth - 56) / 740));
          shiftX = -Math.min(50, Math.max(0, (0.9 - aspect) * 105));
        } else if (aspect > sceneAspect) {
          const visibleSceneHeight = 1600 / aspect;
          scale = Math.min(1, Math.max(0.6, (visibleSceneHeight - 40) / 670));
        }

        rider?.style.setProperty("--rider-scale", scale.toFixed(3));
        rider?.style.setProperty("--rider-shift-x", `${shiftX.toFixed(1)}px`);
      };

      const pedalPoint = (angle: number) => ({
        x: center.x + Math.cos(angle) * radius,
        y: center.y + Math.sin(angle) * radius,
      });

      const legPath = (
        hipX: number,
        hipY: number,
        footX: number,
        footY: number,
        bend: number,
      ) => {
        const kneeX = (hipX + footX) / 2 + bend;
        const kneeY = (hipY + footY) / 2 - 5;
        return `M${hipX} ${hipY} Q${kneeX} ${kneeY} ${footX} ${footY}`;
      };

      const drawPedal = (time: number) => {
        const angle = ((time - startedAt) / 680) * Math.PI * 2;
        const a = pedalPoint(angle);
        const b = pedalPoint(angle + Math.PI);

        legBack?.setAttribute("d", legPath(760, 505, a.x, a.y, -24));
        legFront?.setAttribute("d", legPath(821, 514, b.x, b.y, 24));
        crankArmA?.setAttribute("d", `M${center.x} ${center.y} ${a.x} ${a.y}`);
        crankArmB?.setAttribute("d", `M${center.x} ${center.y} ${b.x} ${b.y}`);
        pedalA?.setAttribute("d", `M${a.x - 14} ${a.y}h28`);
        pedalB?.setAttribute("d", `M${b.x - 14} ${b.y}h28`);

        frameId = requestAnimationFrame(drawPedal);
      };

      const syncMotionPreference = () => {
        cancelAnimationFrame(frameId);
        if (reducedMotion.matches) {
          drawPedal(startedAt);
          cancelAnimationFrame(frameId);
          return;
        }
        startedAt = performance.now();
        frameId = requestAnimationFrame(drawPedal);
      };

      syncMotionPreference();
      fitRiderToViewport();
      reducedMotion.addEventListener("change", syncMotionPreference);

      window.addEventListener("resize", () => {
        cancelAnimationFrame(resizeFrameId);
        resizeFrameId = requestAnimationFrame(fitRiderToViewport);
      });

      document.addEventListener("visibilitychange", () => {
        if (document.hidden) {
          cancelAnimationFrame(frameId);
        } else {
          syncMotionPreference();
        }
      });

      window.addEventListener("pagehide", () => {
        cancelAnimationFrame(frameId);
        cancelAnimationFrame(resizeFrameId);
        reducedMotion.removeEventListener("change", syncMotionPreference);
      }, { once: true });
    </script>
  </body>
</html>
