            <g stroke="#c7d1ca" stroke-width="3" opacity=".88">
              <path d="M979 569v210M874 674h210M905 600l148 148M1053 600 905 748M928 583l102 182M1030 583 928 765M876 651l206 46M876 697l206-46" />
            </g>
            <circle cx="979" cy="674" r="12" fill="#263636" stroke="#e7d6a2" stroke-width="5" />
          </g>

          <g class="bicycle" fill="none" stroke-linecap="round" stroke-linejoin="round">
