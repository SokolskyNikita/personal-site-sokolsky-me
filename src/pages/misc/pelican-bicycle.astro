              stroke="#394844"
              stroke-width="7"
              stroke-linejoin="round"
            />
            <path d="M944 278c61 5 123 2 185-7" fill="none" stroke="#8c6935" stroke-width="5" stroke-linecap="round" />
            <circle cx="973" cy="194" r="18" fill="#f7d36b" stroke="#394844" stroke-width="6" />
            <circle cx="977" cy="194" r="7" fill="#243432" />
            <circle cx="981" cy="189" r="2.5" fill="#f3efdc" />
            <path d="M937 164c17-12 39-16 59-8" fill="none" stroke="#394844" stroke-width="7" stroke-linecap="round" />

            <path
              class="front-wing"
              d="M844 394c39 9 72 32 98 71l31 5 5 20-51 2c-40-18-72-43-96-75Z"
