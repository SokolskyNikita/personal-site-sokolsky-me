              <path d="M697 457c-56 13-92 31-112 54" fill="none" stroke="#bfc0ae" stroke-width="5" />
            </g>

            <ellipse cx="793" cy="439" rx="118" ry="101" fill="#f3efdc" stroke="#394844" stroke-width="8" />
