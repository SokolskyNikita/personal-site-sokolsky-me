const entriesByYear = entries.reduce<Record<string, Entry[]>>((acc, entry) => {
  const year = entry.sortDate.slice(0, 4);
  if (!acc[year]) {
    acc[year] = [];
  }
  acc[year].push(entry);
  return acc;
}, {});

const orderedYears = Object.keys(entriesByYear).sort();
const totalLinks = entries.length;
const statsByYear: YearStat[] = orderedYears.map((year) => {
  const { oneP, threeP } = entriesByYear[year].reduce(
    (acc, entry) => {
      if (entry.type === "1P") {
        acc.oneP += 1;
      } else {
        acc.threeP += 1;
      }
      return acc;
    },
    { oneP: 0, threeP: 0 }
  );

  return {
    year,
    oneP,
    threeP,
    total: oneP + threeP
  };
});
