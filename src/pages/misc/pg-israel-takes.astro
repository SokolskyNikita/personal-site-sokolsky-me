<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="subject" content="Paul Graham posts and reposts about Israel-adjacent topics." />
    <meta name="application-name" content={pageTitle} />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="googlebot" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="keywords" content="Paul Graham, PG, Israel, Palestine, Gaza, takes, posts, reposts, tweets, timeline" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta name="theme-color" content={themeColorLight} media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content={themeColorDark} media="(prefers-color-scheme: dark)" />
    <meta name="msapplication-TileColor" content={themeColorDark} />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color={themeColorDark} />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={pageTitle} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <main class="page">
      <header class="page-header">
        <h1>{pageTitle}</h1>
        <div class="legend">
          <span class="pill one">1P</span>
          <span class="legend-label">post</span>
          <span class="pill three">3P</span>
          <span class="legend-label">repost</span>
        </div>
      </header>

      <section class="stats-block" aria-label="Link statistics">
        <p class="stats-total">
          <span class="stats-total-label">Total links on this page</span>
          <strong>{totalLinks}</strong>
        </p>
        <details class="stats-details">
          <summary>full stats</summary>
          <div class="stats-grid">
            {statsByYear.map((stat) => (
              <article class="stats-card">
                <h3>{stat.year}</h3>
                <dl>
                  <div>
                    <dt>1P</dt>
                    <dd>{stat.oneP}</dd>
                  </div>
                  <div>
                    <dt>3P</dt>
                    <dd>{stat.threeP}</dd>
                  </div>
                  <div>
                    <dt>1P+3P</dt>
                    <dd>{stat.total}</dd>
                  </div>
                </dl>
              </article>
            ))}
          </div>
        </details>
      </section>

      {orderedYears.map((year) => (
        <section class="year-section">
          <h2>{year}</h2>
          <ul class="entry-list">
            {entriesByYear[year].map((entry) => (
              <li class="entry-card">
                <div class="entry-meta">
                  <span class={`pill ${entry.type === "1P" ? "one" : "three"}`}>{entry.type}</span>
                  <time datetime={entry.sortDate}>{entry.date}</time>
                </div>
                <p>
                  {entry.summary}{" "}
                  <a href={entry.url} target="_blank" rel="noreferrer noopener">
                    [link]
                  </a>
                </p>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light dark;
    --bg: #ffffff;
    --text: #111111;
    --text-muted: #5f6368;
    --border: #e6e6e6;
    --card: #fafafa;
    --one-bg: #111111;
    --one-text: #ffffff;
    --three-bg: #f0f0f0;
    --three-text: #111111;
    --link: #111111;
    --link-hover: #555555;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #101113;
      --text: #f2f2f2;
      --text-muted: #a9acb1;
      --border: #2f3237;
      --card: #181a1f;
      --one-bg: #f2f2f2;
      --one-text: #101113;
      --three-bg: #2d3137;
      --three-text: #f2f2f2;
      --link: #f2f2f2;
      --link-hover: #c9c9c9;
    }
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    font-size: 16px;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    margin: 0;
    padding: 2rem 1rem 3rem;
    display: flex;
    justify-content: center;
    background: var(--bg);
  }

  .page {
    width: 100%;
    max-width: 58rem;
    display: grid;
    gap: 1.8rem;
  }

  .page-header {
    display: grid;
    gap: 0.75rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 1rem;
  }

  h1 {
    margin: 0;
    font-size: clamp(1.15rem, 3.2vw, 1.7rem);
    font-weight: 650;
    letter-spacing: -0.02em;
  }

  .legend {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.45rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .legend-label {
    margin-right: 0.7rem;
  }

  .stats-block {
    display: grid;
    gap: 0.75rem;
  }

  .stats-total {
    margin: 0;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--card);
    padding: 0.8rem 0.95rem;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.7rem;
    flex-wrap: wrap;
  }

  .stats-total-label {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .stats-total strong {
    font-size: clamp(1.05rem, 4.8vw, 1.34rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
  }

  .stats-details {
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--card);
    overflow: hidden;
  }

  .stats-details > summary {
    cursor: pointer;
    list-style: none;
    padding: 0.75rem 0.95rem;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .stats-details > summary::-webkit-details-marker {
    display: none;
  }

  .stats-details > summary::after {
    content: "+";
    float: right;
    color: var(--text-muted);
    font-weight: 500;
  }

  .stats-details[open] > summary::after {
    content: "−";
  }

  .stats-grid {
    display: grid;
    gap: 0.65rem;
    padding: 0 0.75rem 0.75rem;
    grid-template-columns: repeat(auto-fit, minmax(145px, 1fr));
  }

  .stats-card {
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg);
    padding: 0.6rem 0.7rem;
    display: grid;
    gap: 0.4rem;
  }

  .stats-card h3 {
    margin: 0;
    font-size: 0.85rem;
    font-weight: 650;
    color: var(--text-muted);
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .stats-card dl {
    margin: 0;
    display: grid;
    gap: 0.2rem;
  }

  .stats-card dl div {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.55rem;
  }

