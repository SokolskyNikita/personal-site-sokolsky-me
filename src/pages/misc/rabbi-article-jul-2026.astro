          var(--paper);
        box-shadow: 0 24px 70px rgb(0 0 0 / 8%);
        padding: clamp(24px, 5vw, 52px);
      }

      .home-link {
        display: inline-flex;
        width: fit-content;
        margin-bottom: 48px;
        color: var(--muted);
        font:
          700 0.78rem/1.2 ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        letter-spacing: 0.08em;
        text-decoration: none;
        text-transform: uppercase;
      }

      .home-link:hover {
        color: var(--accent);
      }

      .eyebrow {
        margin: 0 0 14px;
        color: var(--accent);
        font:
          800 0.8rem/1.2 ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

