---
import propertyData from "../../data/ba-final-where-2026.json";

export const prerender = true;

const pageTitle = "Where to stay with a view of the Obelisk: 2026 World Cup final in Buenos Aires";
const pageDescription =
  "Real-time availability of Buenos Aires hotels and Airbnbs with direct views of the Obelisk for the World Cup final night (Sunday July 19, 2026). Only showing verified available rooms.";
const themeColorLight = "#fcfaf6";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const checkedDate = "July 16, 2026";

type Property = {
  name: string;
  address: string;
  price: string;
  rating: number | string;
  reviews?: number;
  status: string;
  detail: string;
  mapsQuery: string;
  bookingUrl?: string;
  highlight?: boolean;
  warning?: boolean;
  location?: { lat: number; lng: number };
};

const mapsIcon = `<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="#1a73e8" d="M12 2.2c3.9 0 7.1 3.1 7.1 7 0 5.1-7.1 12.6-7.1 12.6S4.9 14.3 4.9 9.2c0-3.9 3.2-7 7.1-7Z"/><path fill="#34a853" d="M7.2 14.1 12 21.8l4.8-7.7-4.8-2.8-4.8 2.8Z"/><path fill="#fbbc04" d="M4.9 9.2c0 1.8.9 3.5 2.3 4.9l4.8-2.8V2.2c-3.9 0-7.1 3.1-7.1 7Z"/><path fill="#ea4335" d="M19.1 9.2c0 1.8-.9 3.5-2.3 4.9L12 11.3V2.2c3.9 0 7.1 3.1 7.1 7Z"/><circle cx="12" cy="9.3" r="2.45" fill="#fff"/></svg>`;
const bookingIcon = `<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="currentColor" d="M7 2.75a.75.75 0 0 1 .75.75V5h8.5V3.5a.75.75 0 0 1 1.5 0V5H19a2 2 0 0 1 2 2v12.25A2.75 2.75 0 0 1 18.25 22H5.75A2.75 2.75 0 0 1 3 19.25V7a2 2 0 0 1 2-2h1.25V3.5A.75.75 0 0 1 7 2.75Zm12 7.75H5v8.75c0 .69.56 1.25 1.25 1.25h12.5c.69 0 1.25-.56 1.25-1.25V10.5ZM5 7v2h14V7a.5.5 0 0 0-.5-.5H5.5A.5.5 0 0 0 5 7Zm4.22 5.22a.75.75 0 0 1 1.06 0l1.47 1.47 3.47-3.47a.75.75 0 1 1 1.06 1.06l-4 4a.75.75 0 0 1-1.06 0l-2-2a.75.75 0 0 1 0-1.06Z"/></svg>`;

const mapsUrl = (query: string) =>
  `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(query)}`;

const availableProperties = propertyData.availableProperties as Property[];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  numberOfItems: availableProperties.length,
  itemListElement: availableProperties.map((prop, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "Hotel",
      name: prop.name,
      address: prop.address,
      description: prop.detail,
      url: prop.bookingUrl ?? mapsUrl(prop.mapsQuery),
      ...(prop.location
        ? {
            geo: {
              "@type": "GeoCoordinates",
              latitude: prop.location.lat,
              longitude: prop.location.lng,
            },
          }
        : {}),
    },
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta
      name="subject"
      content="Hotels and Airbnbs with Obelisk view in Buenos Aires for World Cup Final 2026"
    />
    <meta name="application-name" content={pageTitle} />
    <meta
      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="googlebot"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="keywords"
      content="Obelisco view hotels, hotels near Obelisk Buenos Aires, Airbnb Obelisco, World Cup Final 2026 Buenos Aires, available hotels Buenos Aires July 19"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta name="msapplication-TileColor" content={themeColorLight} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="sokolsky.me" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <main class="page">
      <header class="hero">
        <div class="topbar">
          <a class="home-link" href="/" aria-label="Back to home">sokolsky.me</a>
          <p class="updated">Checked {checkedDate}</p>
        </div>

        <div class="hero-grid">
          <div>
            <p class="eyebrow">Buenos Aires · World Cup Final 2026</p>
            <h1>{pageTitle}</h1>
            <p class="dek">
              The World Cup final kicks off on <strong>Sunday, July 19, 2026</strong>. If Argentina wins, the <strong>Obelisk</strong> will be the epicenter of the largest street celebration on Earth. This guide lists the real-time availability of nearby hotels and Airbnbs for <strong>Sunday, July 19th to Monday, July 20th (1 night)</strong>.
            </p>
          </div>
        </div>
      </header>

      <section class="region" id="available-properties" aria-labelledby="available-heading">
        <div class="region-heading">
          <p class="eyebrow">Last-minute options</p>
          <h2 id="available-heading">Verified available hotels (July 19-20)</h2>
          <p>
            These properties are confirmed available for a 1-night stay during the final. To get a view of the celebrations or the Obelisk, we recommend booking immediately and requesting a <strong>high-floor, front-facing room</strong>.
          </p>
        </div>

        <div class="venue-grid">
          {availableProperties.map((prop) => (
            <article
              class:list={["venue-card", prop.highlight && "is-pick", prop.warning && "is-warning"]}
            >
              <div class="option-topline">
                <span>{prop.status}</span>
                <strong>{prop.price}</strong>
              </div>
              <div class="venue-title-row">
                <h3>
                  <a href={prop.bookingUrl ?? mapsUrl(prop.mapsQuery)} target="_blank" rel="noreferrer noopener">
                    {prop.name}
                  </a>
                </h3>
                <div class="venue-actions">
                  <a
                    class="maps-link"
                    href={mapsUrl(prop.mapsQuery)}
                    target="_blank"
                    rel="noreferrer noopener"
                    aria-label={`Open ${prop.name} on Google Maps`}
                    title="Open in Google Maps"
                  >
                    <span class="maps-icon" set:html={mapsIcon} />
                  </a>
                  {prop.bookingUrl && (
                    <a
                      class="reservation-link"
                      href={prop.bookingUrl}
                      target="_blank"
                      rel="noreferrer noopener"
                      aria-label={`Book at ${prop.name}`}
                      title="Book now"
                    >
                      <span class="reservation-icon" set:html={bookingIcon} />
                    </a>
                  )}
                </div>
              </div>
              <p class="address">{prop.address}</p>
              <p class="detail">{prop.detail}</p>
              {prop.rating && (
                <p class="source-tag">
                  Rating: {prop.rating}/5.0 ({prop.reviews ?? 0} reviews)
                </p>
              )}
            </article>
          ))}
        </div>
      </section>

    </main>

    <style>
      :root {
        color-scheme: light only;
        --bg: #fcfaf6;
        --paper: #fffdf9;
        --paper-strong: #fff3d2;
        --ink: #21180f;
        --muted: #6f5f4a;
        --line: rgb(75 51 25 / 16%);
        --accent: #b43f1d;
        --accent-strong: #762813;
        --green: #2d6b4b;
        --warn: #8a4b12;
        --shadow: 0 12px 36px rgb(68 42 16 / 8%);
      }

      * {
        box-sizing: border-box;
      }

      html {
        background: var(--bg);
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background:
          radial-gradient(circle at 12% 0%, rgb(255 162 79 / 25%), transparent 30rem),
          linear-gradient(135deg, rgb(255 255 255 / 28%), transparent 26rem),
          var(--bg);
        color: var(--ink);
        font-family:
          ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
      }

      a {
        color: inherit;
        text-decoration-color: color-mix(in srgb, var(--accent) 58%, transparent);
        text-decoration-thickness: 0.08em;
        text-underline-offset: 0.18em;
      }

      a:hover {
        color: var(--accent-strong);
      }

      h1,
      h2,
      h3,
      p,
      dl,
      dd,
      ul {
        margin: 0;
      }

      .page {
        width: min(1320px, calc(100% - clamp(16px, 3vw, 40px)));
        margin: 0 auto;
        padding: clamp(10px, 1.5vw, 20px) 0 clamp(16px, 3vw, 36px);
      }

      .hero,
      .panel,
      .region {
        border: 1px solid var(--line);
        border-radius: clamp(18px, 2.4vw, 26px);
        background:
          linear-gradient(145deg, rgb(255 255 255 / 38%), transparent 34rem),
          var(--paper);
        box-shadow: var(--shadow);
      }

      .hero {
        padding: clamp(12px, 2vw, 22px);
      }

      .topbar,
      .hero-grid,
      .region-heading {
        display: grid;
        gap: clamp(10px, 1.6vw, 18px);
      }

      .topbar {
        grid-template-columns: 1fr auto;
        align-items: center;
        margin-bottom: clamp(10px, 1.8vw, 16px);
      }

      .home-link,
      .updated,
      .eyebrow,
      .option-topline span {
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.11em;
        text-transform: uppercase;
      }

      .home-link {
        color: var(--muted);
        text-decoration: none;
      }

      .updated {
        color: var(--muted);
      }

      .hero-grid {
        align-items: start;
      }

      .eyebrow {
        color: var(--accent);
        margin-bottom: 6px;
      }

      h1 {
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(1.3rem, 2.2vw, 1.75rem);
        font-weight: 780;
        letter-spacing: -0.04em;
        line-height: 1.1;
        text-wrap: balance;
      }

      .dek {
        max-width: 760px;
        margin-top: clamp(10px, 1.6vw, 16px);
        color: var(--muted);
        font-size: clamp(0.98rem, 1.4vw, 1.08rem);
        line-height: 1.45;
      }

      .dek strong {
        color: var(--ink);
      }

      .panel,
      .region {
        margin-top: clamp(8px, 1.2vw, 14px);
        padding: clamp(12px, 1.8vw, 20px);
      }

      h2 {
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(0.98rem, 1.3vw, 1.15rem);
        letter-spacing: -0.03em;
        line-height: 1.15;
        text-wrap: balance;
      }

      .region-heading p {
        color: var(--muted);
        font-size: clamp(0.94rem, 1.2vw, 1.02rem);
        line-height: 1.5;
      }

      .region-heading p:not(.eyebrow) {
        margin-top: 8px;
        max-width: 760px;
      }

      .region-heading {
        margin-bottom: 10px;
      }

      .venue-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px;
      }

      .venue-grid--compact {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .venue-card {
        display: grid;
        gap: 5px;
        border: 1px solid var(--line);
        border-radius: 14px;
        background:
          linear-gradient(160deg, rgb(255 255 255 / 30%), transparent 18rem),
          color-mix(in srgb, var(--paper) 88%, var(--paper-strong));
        padding: clamp(10px, 1.2vw, 14px);
      }

      .venue-card.is-pick {
        border-color: color-mix(in srgb, var(--green) 45%, var(--line));
        background:
          linear-gradient(160deg, color-mix(in srgb, var(--green) 10%, transparent), transparent 16rem),
          color-mix(in srgb, var(--paper) 88%, var(--paper-strong));
      }

      .venue-card.is-warning {
        border-color: color-mix(in srgb, var(--warn) 40%, var(--line));
      }

      .option-topline {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 12px;
      }

      .option-topline span {
        color: var(--green);
      }

      .sold-out-tag {
        color: var(--warn) !important;
      }

      .venue-card.is-warning .option-topline span {
        color: var(--warn);
      }

      .option-topline strong {
        color: var(--ink);
        font-size: 0.95rem;
        font-weight: 800;
        letter-spacing: 0.02em;
        text-align: right;
      }

      .venue-card h3 {
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(0.9rem, 1.1vw, 1.0rem);
        letter-spacing: -0.02em;
        line-height: 1.2;
        text-wrap: balance;
      }

      .venue-title-row {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 8px;
      }

      .venue-title-row h3 {
        flex: 1;
        min-width: 0;
      }

      .venue-actions {
        display: flex;
        flex-shrink: 0;
        align-items: center;
        gap: 0.35rem;
        padding-top: 0.15rem;
      }

      .maps-link,
      .reservation-link {
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent);
        text-decoration: none;
      }

      .maps-icon,
      .reservation-icon {
        display: flex;
      }

      .maps-icon :global(svg),
      .reservation-icon :global(svg) {
        width: 1.35rem;
        height: 1.35rem;
      }

      .venue-card h3 a {
        text-decoration: none;
      }

      .venue-card h3 a:hover {
        text-decoration: underline;
      }

      .address {
        color: var(--ink);
        font-size: 0.88rem;
        font-weight: 650;
        line-height: 1.35;
      }

      .detail {
        color: var(--muted);
        font-size: 0.9rem;
        line-height: 1.45;
      }

      .source-tag {
        color: var(--muted);
        font-size: 0.78rem;
        font-weight: 650;
        letter-spacing: 0.02em;
      }

      @media (max-width: 980px) {
        .hero-grid,
        .venue-grid--compact {
          grid-template-columns: 1fr;
        }

        .venue-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 760px) {
        .page {
          width: min(100% - 16px, 1320px);
          padding-top: 8px;
        }

        .topbar {
          grid-template-columns: 1fr;
          gap: 6px;
          margin-bottom: 12px;
        }

        h1 {
          font-size: clamp(1.25rem, 6vw, 1.6rem);
        }
      }

      @media (min-width: 981px) and (max-width: 1280px) {
        .venue-grid--compact {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }

    </style>
  </body>
</html>
