---
export const prerender = true;

const pageTitle = "FIFA 2026 streaming options";
const pageDescription =
  "A compact comparison of FIFA World Cup 2026 streaming options for Argentina and the US, with prices normalized to USD.";
const themeColorLight = "#fcfaf6";
const themeColorDark = "#17130d";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const checkedDate = "July 3, 2026";
const exchangeRate = "ARS 1,488.50 per USD";

type Option = {
  name: string;
  tag: string;
  price: string;
  href: string;
  coverage: string;
  access: string;
  macAccess: string;
  language: string;
  picture: string;
  latency: string;
  bestFor: string;
  caveat: string;
  pick?: boolean;
};

type Channel = {
  name: string;
  tag: string;
  scope: string;
  href: string;
  bestFor: string;
  where: string;
  resolution: string;
  delay: string;
  remaining: string;
  pros: string;
  cons: string;
  caveat: string;
};

