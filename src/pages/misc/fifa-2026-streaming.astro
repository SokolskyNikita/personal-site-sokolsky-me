const structuredData = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  dateModified: "2026-07-03",
  inLanguage: "en",
  author: {
    "@type": "Person",
    name: "Nikita Sokolsky"
  }
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="googlebot" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta name="theme-color" content={themeColorLight} media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content={themeColorDark} media="(prefers-color-scheme: dark)" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="sokolsky.me" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <main class="page">
      <header class="hero">
        <div class="topbar">
          <a class="home-link" href="/" aria-label="Back to home">sokolsky.me</a>
          <p class="updated">Checked {checkedDate}</p>
        </div>

        <div class="hero-grid">
          <div>
            <p class="eyebrow">World Cup viewing plan</p>
            <h1>{pageTitle}</h1>
            <p class="dek">
              Practical options for watching the 2026 World Cup from Argentina or
              the US, with prices normalized to USD and the recommendations tuned
              for cost, language, picture quality and delay.
            </p>
          </div>

          <aside class="conversion-note" aria-label="Price conversion note">
            <span>Price basis</span>
            <strong>All prices are shown in USD.</strong>
            <p>
              Argentina plan prices were converted at about {exchangeRate}; each
              card shows one median-style estimate for easier comparison.
            </p>
          </aside>
        </div>

      </header>

      <section class="panel quick-answer" id="quick-answer" aria-labelledby="quick-answer-heading">
        <div class="section-copy">
          <p class="eyebrow">Bottom line</p>
          <h2 id="quick-answer-heading">Pick by feed, not by rights chaos</h2>
          <p>
            In the US, every remaining knockout match is on FOX in English and
            Telemundo in Spanish, so the choice is mostly language, picture
            quality, price and delay. In Argentina, DSports is the all-match TV
            signal family; Paramount+ with DSports is the standout cheap stream,
            while TyC Sports, Telefe and TV Publica are selected-match channels.
          </p>
        </div>

        <div class="decision-grid">
          {decisionCards.map((card) => (
            <article class="decision-card">
              <p>{card.label}</p>
              <h3>{card.title}</h3>
              <span>{card.detail}</span>
              {card.items && (
                <dl class="latency-helper">
                  {card.items.map((item) => (
                    <div>
                      <dt>{item.label}</dt>
                      <dd>{item.value}</dd>
                    </div>
                  ))}
                </dl>
              )}
            </article>
          ))}
        </div>
      </section>

      <section class="region" id="argentina-options" aria-labelledby="argentina-heading">
        <div class="region-heading">
          <p class="eyebrow">Argentina options</p>
          <h2 id="argentina-heading">Cheap all-match coverage exists</h2>
          <p>
            If you can subscribe from Argentina, the question is whether you want
            the lowest all-match stream, a TV bundle or free partial coverage for
            Argentina-heavy viewing.
          </p>
        </div>

        <div class="option-grid">
          {argentinaOptions.map((option) => (
            <article class={`option-card${option.pick ? " is-pick" : ""}`}>
              <div class="option-topline">
                <span>{option.tag}</span>
                <strong>{option.price}</strong>
              </div>
              <h3>
                <a href={option.href} target="_blank" rel="noreferrer noopener">
                  {option.name}
                </a>
              </h3>
              <p class="best-for">{option.bestFor}</p>
              <dl class="facts">
                <div>
                  <dt>Coverage</dt>
                  <dd>{option.coverage}</dd>
                </div>
                <div>
                  <dt>Access</dt>
                  <dd>{option.access}</dd>
                </div>
                <div>
                  <dt>Can watch via Mac?</dt>
                  <dd>{option.macAccess}</dd>
                </div>
                <div>
                  <dt>Language</dt>
                  <dd>{option.language}</dd>
                </div>
                <div>
                  <dt>Resolution</dt>
                  <dd>{option.picture}</dd>
                </div>
                <div>
                  <dt>Delay</dt>
                  <dd>{option.latency}</dd>
                </div>
              </dl>
              <p class="caveat">{option.caveat}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="region" id="argentina-channels" aria-labelledby="argentina-channels-heading">
        <div class="region-heading">
          <p class="eyebrow">Argentina TV channels</p>
          <h2 id="argentina-channels-heading">What to tune for the remaining games</h2>
          <p>
            These are the actual TV/cable signals carrying the tournament in
            Argentina. DSports is the only all-match family; the other channels
            are useful because they carry Argentina and selected high-interest
            fixtures.
          </p>
        </div>

        <div class="channel-grid">
          {argentinaChannels.map((channel) => (
            <article class="channel-card">
              <div class="option-topline">
                <span>{channel.tag}</span>
                <strong>{channel.scope}</strong>
              </div>
              <h3>
                <a href={channel.href} target="_blank" rel="noreferrer noopener">
                  {channel.name}
                </a>
              </h3>
              <p class="best-for">{channel.bestFor}</p>
              <dl class="facts">
                <div>
                  <dt>Coverage</dt>
                  <dd>{channel.remaining}</dd>
                </div>
                <div>
                  <dt>Access</dt>
                  <dd>{channel.where}</dd>
                </div>
                <div>
                  <dt>Language</dt>
                  <dd>Spanish.</dd>
                </div>
                <div>
                  <dt>Resolution</dt>
                  <dd>{channel.resolution}</dd>
                </div>
                <div>
                  <dt>Delay</dt>
                  <dd>{channel.delay}</dd>
                </div>
              </dl>
              <div class="tradeoffs">
                <p><strong>Pros:</strong> {channel.pros}</p>
                <p><strong>Cons:</strong> {channel.cons}</p>
              </div>
              <p class="caveat">{channel.caveat}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="region" id="us-options" aria-labelledby="us-heading">
        <div class="region-heading">
          <p class="eyebrow">US options</p>
          <h2 id="us-heading">English is FOX, Spanish is Peacock</h2>
          <p>
            The cheap US split is clean: FOX One for English, Peacock for
            Spanish. Both have 4K paths on supported devices. Use OTA or cable
            only when latency matters more than app convenience.
          </p>
        </div>

        <div class="option-grid">
          {usOptions.map((option) => (
            <article class={`option-card${option.pick ? " is-pick" : ""}`}>
              <div class="option-topline">
                <span>{option.tag}</span>
                <strong>{option.price}</strong>
              </div>
              <h3>
                <a href={option.href} target="_blank" rel="noreferrer noopener">
                  {option.name}
                </a>
              </h3>
              <p class="best-for">{option.bestFor}</p>
              <dl class="facts">
                <div>
                  <dt>Coverage</dt>
                  <dd>{option.coverage}</dd>
                </div>
                <div>
                  <dt>Access</dt>
                  <dd>{option.access}</dd>
                </div>
                <div>
                  <dt>Can watch via Mac?</dt>
                  <dd>{option.macAccess}</dd>
                </div>
                <div>
                  <dt>Language</dt>
                  <dd>{option.language}</dd>
                </div>
                <div>
                  <dt>Resolution</dt>
                  <dd>{option.picture}</dd>
                </div>
                <div>
                  <dt>Delay</dt>
                  <dd>{option.latency}</dd>
                </div>
              </dl>
              <p class="caveat">{option.caveat}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="panel notes" aria-labelledby="notes-heading">
        <div>
          <p class="eyebrow">Operating notes</p>
          <h2 id="notes-heading">What I would actually run</h2>
        </div>
        <div class="note-columns">
          <p>
            Use <strong>Paramount+ Argentina</strong> as the default for most
            matches if Spanish is acceptable. It is dramatically cheaper than a
            US live-TV bundle and still gives every match.
          </p>
          <p>
            Switch to <strong>FOX One</strong> for big matches where English and
            4K matter. For spoiler-sensitive Argentina or US matches, prefer the
            fastest broadcast feed you can reach instead of any app.
          </p>
        </div>
      </section>

      <section class="sources" id="sources" aria-labelledby="sources-heading">
        <div class="region-heading">
          <p class="eyebrow">Sources</p>
          <h2 id="sources-heading">Checked against live sources</h2>
          <p>
            Source pages were checked with regular web search and BrightData MCP.
            Prices and rights can change during the tournament.
          </p>
        </div>

        <ul class="source-list">
          {sourceLinks.map((source) => (
            <li>
              <a href={source.href} target="_blank" rel="noreferrer noopener">
                {source.label}
              </a>
            </li>
          ))}
        </ul>
      </section>
    </main>

    <style>
      :root {
        color-scheme: light;
        --bg: #fcfaf6;
        --paper: #fffdf9;
        --paper-strong: #fff3d2;
        --ink: #21180f;
        --muted: #6f5f4a;
        --line: rgb(75 51 25 / 16%);
        --accent: #b43f1d;
        --accent-strong: #762813;
        --green: #2d6b4b;
        --shadow: 0 24px 70px rgb(68 42 16 / 12%);
      }

      @media (prefers-color-scheme: dark) {
        :root {
          color-scheme: dark;
          --bg: #17130d;
          --paper: #211a12;
          --paper-strong: #2e2417;
          --ink: #f5ead6;
          --muted: #c8b89d;
          --line: rgb(245 234 214 / 16%);
          --accent: #ff9d64;
          --accent-strong: #ffc9a6;
          --green: #93d2ac;
          --shadow: 0 24px 70px rgb(0 0 0 / 28%);
        }
      }

      * {
        box-sizing: border-box;
      }

      html {
        background: var(--bg);
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background:
          radial-gradient(circle at 12% 0%, rgb(255 162 79 / 25%), transparent 30rem),
          linear-gradient(135deg, rgb(255 255 255 / 28%), transparent 26rem),
          var(--bg);
        color: var(--ink);
        font-family:
          ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
      }

      a {
        color: inherit;
        text-decoration-color: color-mix(in srgb, var(--accent) 58%, transparent);
        text-decoration-thickness: 0.08em;
        text-underline-offset: 0.18em;
      }

      a:hover {
        color: var(--accent-strong);
      }

      h1,
      h2,
      h3,
      p,
      dl,
      dd {
        margin: 0;
      }

      .page {
        width: min(1180px, calc(100% - clamp(28px, 5vw, 72px)));
        margin: 0 auto;
        padding: clamp(18px, 3.2vw, 42px) 0 clamp(32px, 6vw, 72px);
      }

      .hero,
      .panel,
      .region,
      .sources {
        border: 1px solid var(--line);
        border-radius: clamp(22px, 3vw, 34px);
        background:
          linear-gradient(145deg, rgb(255 255 255 / 38%), transparent 34rem),
          var(--paper);
        box-shadow: var(--shadow);
      }

      .hero {
        padding: clamp(20px, 3.8vw, 42px);
      }

      .topbar,
      .hero-grid,
      .region-heading,
      .quick-answer,
      .notes {
        display: grid;
        gap: clamp(16px, 2.4vw, 28px);
      }

      .topbar {
        grid-template-columns: 1fr auto;
        align-items: center;
        margin-bottom: clamp(28px, 5vw, 54px);
      }

      .home-link,
      .updated,
      .eyebrow,
      .option-topline span,
      .decision-card p,
      dt {
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.11em;
        text-transform: uppercase;
      }

      .home-link {
        color: var(--muted);
        text-decoration: none;
      }

      .updated {
        color: var(--muted);
      }

      .hero-grid {
        grid-template-columns: minmax(0, 1fr);
        align-items: start;
      }

      .eyebrow {
        color: var(--accent);
        margin-bottom: 12px;
      }

      h1 {
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(1.7rem, 5.1vw, 4rem);
        font-weight: 780;
        letter-spacing: -0.07em;
        line-height: 0.9;
        text-wrap: balance;
      }

      .dek {
        max-width: 760px;
        margin-top: clamp(18px, 2.6vw, 28px);
        color: var(--muted);
        font-size: clamp(1.06rem, 1.8vw, 1.35rem);
        line-height: 1.45;
      }

      .conversion-note {
        max-width: 760px;
        border: 1px solid var(--line);
        border-radius: 24px;
        background: var(--paper-strong);
        padding: 18px;
      }

      .conversion-note span {
        display: block;
        color: var(--accent);
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      .conversion-note strong {
        display: block;
        margin-top: 10px;
        font-size: clamp(1.12rem, 1.9vw, 1.5rem);
        line-height: 1.1;
      }

      .conversion-note p {
        margin-top: 10px;
        color: var(--muted);
        font-size: 0.96rem;
        line-height: 1.5;
      }

      .panel,
      .region,
      .sources {
        margin-top: clamp(14px, 2vw, 22px);
        padding: clamp(20px, 3.8vw, 42px);
      }

      .quick-answer {
        grid-template-columns: minmax(360px, 0.9fr) minmax(0, 1fr);
        align-items: start;
      }

      h2 {
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(1.1rem, 2.28vw, 2rem);
        letter-spacing: -0.045em;
        line-height: 1;
        text-wrap: balance;
      }

      .section-copy p,
      .region-heading p,
      .note-columns p {
        color: var(--muted);
        font-size: clamp(1rem, 1.4vw, 1.1rem);
        line-height: 1.6;
      }

      .section-copy p:not(.eyebrow),
      .region-heading p:not(.eyebrow) {
        margin-top: 14px;
        max-width: 760px;
      }

      .decision-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
      }

      .decision-card:nth-child(3) {
        grid-column: 1 / -1;
      }

      .decision-card {
        border: 1px solid var(--line);
        border-radius: 22px;
        background: color-mix(in srgb, var(--paper-strong) 72%, var(--paper));
        padding: 16px;
      }

      .decision-card p {
        color: var(--accent);
      }

      .decision-card h3 {
        margin-top: 10px;
        font-size: clamp(1.1rem, 1.7vw, 1.35rem);
        line-height: 1.1;
        letter-spacing: -0.03em;
      }

      .decision-card span {
        display: block;
        margin-top: 10px;
        color: var(--muted);
        font-size: 0.94rem;
        line-height: 1.45;
      }

      .latency-helper {
        display: grid;
        gap: 8px;
        margin-top: 12px;
      }

      .decision-card:nth-child(3) .latency-helper {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .latency-helper div {
        border-top: 1px solid var(--line);
        padding-top: 8px;
      }

      .latency-helper dt {
        color: var(--accent);
        font-size: 0.68rem;
      }

      .latency-helper dd {
        margin-top: 4px;
        color: var(--muted);
        font-size: 0.9rem;
        line-height: 1.35;
      }

      .region-heading {
        grid-template-columns: minmax(420px, 0.82fr) minmax(260px, 0.44fr);
        align-items: end;
        margin-bottom: 18px;
      }

      .region-heading .eyebrow {
        grid-column: 1 / -1;
        margin-bottom: -6px;
      }

      .option-grid,
      .channel-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
      }

      .option-card,
      .channel-card {
        display: grid;
        gap: 14px;
        border: 1px solid var(--line);
        border-radius: 24px;
        background:
          linear-gradient(160deg, rgb(255 255 255 / 30%), transparent 18rem),
          color-mix(in srgb, var(--paper) 88%, var(--paper-strong));
        padding: clamp(16px, 2.4vw, 24px);
      }

      .option-topline {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 12px;
      }

      .option-topline span {
        color: var(--green);
      }

      .option-topline strong {
        color: var(--accent-strong);
        font-size: clamp(1.12rem, 2vw, 1.55rem);
        line-height: 1;
        white-space: nowrap;
      }

      .option-card h3,
      .channel-card h3 {
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(1.4rem, 2.7vw, 2.35rem);
        letter-spacing: -0.045em;
        line-height: 1;
        text-wrap: balance;
      }

      .best-for {
        color: color-mix(in srgb, var(--ink) 86%, var(--accent));
        font-size: clamp(1.02rem, 1.45vw, 1.13rem);
        font-weight: 760;
        line-height: 1.42;
      }

      .facts {
        display: grid;
        gap: 8px;
      }

      .facts div {
        display: grid;
        grid-template-columns: 7.5rem minmax(0, 1fr);
        gap: 12px;
        border-top: 1px solid var(--line);
        padding-top: 8px;
      }

      dt {
        color: var(--muted);
      }

      dd {
        color: var(--muted);
        font-size: 0.96rem;
        line-height: 1.42;
      }

      .tradeoffs {
        display: grid;
        gap: 6px;
        color: var(--muted);
        font-size: 0.94rem;
        line-height: 1.46;
      }

      .tradeoffs strong {
        color: var(--ink);
      }

      .caveat {
        border-left: 3px solid color-mix(in srgb, var(--accent) 55%, var(--line));
        padding-left: 12px;
        color: var(--muted);
        font-size: 0.94rem;
        line-height: 1.48;
      }

      .notes {
        grid-template-columns: minmax(360px, 0.72fr) minmax(0, 1fr);
        align-items: start;
      }

      .note-columns {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
      }

      .note-columns p {
        border: 1px solid var(--line);
        border-radius: 20px;
        background: rgb(255 255 255 / 22%);
        padding: 16px;
      }

      .source-list {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px 18px;
        margin: 0;
        padding-left: 1.2rem;
      }

      .source-list li {
        color: var(--muted);
        line-height: 1.45;
      }

      @media (max-width: 920px) {
        .hero-grid,
        .quick-answer,
        .region-heading,
        .notes {
          grid-template-columns: 1fr;
        }

        .decision-grid {
          grid-template-columns: 1fr;
        }

        .decision-card:nth-child(3) .latency-helper {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 760px) {
        .page {
          width: min(100% - 20px, 1180px);
          padding-top: 10px;
        }

        .topbar {
          grid-template-columns: 1fr;
          gap: 8px;
          margin-bottom: 24px;
        }

        .option-grid,
        .channel-grid,
        .note-columns,
        .source-list {
          grid-template-columns: 1fr;
        }

        .option-topline {
          align-items: flex-start;
          flex-direction: column;
          gap: 8px;
        }

        .option-topline strong {
          white-space: normal;
        }

        .facts div {
          grid-template-columns: 1fr;
          gap: 4px;
        }

        .hero,
        .panel,
        .region,
        .sources {
          border-radius: 22px;
        }
      }
    </style>
  </body>
</html>
