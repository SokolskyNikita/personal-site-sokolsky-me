---
import pageData from "../../data/ba-lincoln-trip.json";

export const prerender = true;

const pageTitle = "Buenos Aires → Lincoln same-day road trip";
const pageDescription =
  "Sunday same-day car trip ideas from Buenos Aires to Lincoln, Buenos Aires Province: route, lunch, Sunday-open stops on RN7/RN188, and a map of places worth a look.";
const themeColorLight = "#fafcfb";
const themeColorDark = "#121614";
const siteUrl = (Astro.site?.toString() ?? "https://sokolsky.me").replace(
  /\/$/,
  "",
);
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
type Place = (typeof pageData.places)[number];
const kindOrder = [
  "pit-stop",
  "plaza",
  "church",
  "food",
  "museum",
  "park",
] as const;
const kindLabels: Record<(typeof kindOrder)[number], string> = {
  "pit-stop": "Pit stop",
  plaza: "Plaza",
  church: "Church",
  food: "Food",
  museum: "Museum",
  park: "Park",
};
const places = pageData.places.toSorted(
  (a: Place, b: Place) => a.priority - b.priority,
);
const kindOptions = kindOrder
  .map((kind) => ({
    kind,
    label: kindLabels[kind],
    count: places.filter((place: Place) => place.kind === kind).length,
  }))
  .filter((option) => option.count > 0);
const googleMapsApiKey =
  import.meta.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
  process.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
  "";
const placeMapData = places.map((place: Place) => ({
  id: place.id,
  name: place.name,
  town: place.town,
  kind: place.kind,
  googleMapsUrl: place.googleMapsUrl,
  position: place.location,
}));
const mapsIcon = `<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="#1a73e8" d="M12 2.2c3.9 0 7.1 3.1 7.1 7 0 5.1-7.1 12.6-7.1 12.6S4.9 14.3 4.9 9.2c0-3.9 3.2-7 7.1-7Z"/><path fill="#34a853" d="M7.2 14.1 12 21.8l4.8-7.7-4.8-2.8-4.8 2.8Z"/><path fill="#fbbc04" d="M4.9 9.2c0 1.8.9 3.5 2.3 4.9l4.8-2.8V2.2c-3.9 0-7.1 3.1-7.1 7Z"/><path fill="#ea4335" d="M19.1 9.2c0 1.8-.9 3.5-2.3 4.9L12 11.3V2.2c3.9 0 7.1 3.1 7.1 7Z"/><circle cx="12" cy="9.3" r="2.45" fill="#fff"/></svg>`;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  numberOfItems: places.length,
  itemListElement: places.map((place: Place, index: number) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "Place",
      name: place.name,
      description: place.note,
      address: place.address,
      sameAs: place.googleMapsUrl,
      geo: {
        "@type": "GeoCoordinates",
        latitude: place.location.lat,
        longitude: place.location.lng,
      },
    },
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="subject" content="Buenos Aires Lincoln road trip" />
    <meta name="application-name" content={pageTitle} />
    <meta
      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="keywords"
      content="Buenos Aires to Lincoln road trip, Lincoln Buenos Aires Province, RN7 RN188, Flamenco Lincoln, same day trip Argentina"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta
      name="theme-color"
      content={themeColorLight}
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content={themeColorDark}
      media="(prefers-color-scheme: dark)"
    />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Nikita Sokolsky" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}
    ></script>
  </head>
  <body>
    <main class="page">
      <header class="page-header">
        <a class="home-link" href="/">Nikita Sokolsky</a>
        <div class="headline">
          <p class="eyebrow">Same-day car trip · Sunday</p>
          <h1>BA → Lincoln → BA</h1>
          <p class="intro">
            Ideas for a Sunday drive to Lincoln (~{pageData.route.oneWayKm} km /
            {pageData.route.oneWayDrive}), lunch in town, then back by midnight.
            Not a fixed itinerary — pick stops that fit the clock.
          </p>
        </div>
      </header>

      <div class="toolbar" aria-label="Place filters">
        <fieldset class="kind-toggle">
          <legend>Show</legend>
          <input
            id="kind-all"
            type="radio"
            name="kind"
            value=""
            autocomplete="off"
            checked
          />
          <label for="kind-all">All ({places.length})</label>
          {
            kindOptions.flatMap(({ kind, label, count }) => [
              <input
                id={`kind-${kind}`}
                type="radio"
                name="kind"
                value={kind}
                autocomplete="off"
              />,
              <label for={`kind-${kind}`} class={`kind-filter kind-${kind}`}>
                {label} ({count})
              </label>,
            ])
          }
        </fieldset>
      </div>

      <section class="place-section" aria-label="Trip stop ideas">
        <div class="place-list" role="table" aria-label="Trip stop ideas">
          <div class="place-row place-head" role="row">
            <span role="columnheader" aria-sort="none">
              <button
                class="sort-button"
                type="button"
                data-sort-key="name"
                data-sort-default="asc"
              >
                Place
              </button>
            </span>
            <span role="columnheader" aria-sort="none">
              <span class="sort-static">Map</span>
            </span>
            <span role="columnheader" aria-sort="none">
              <button
                class="sort-button"
                type="button"
                data-sort-key="town"
                data-sort-default="asc"
              >
                Where
              </button>
            </span>
            <span role="columnheader" aria-sort="none">
              <button
                class="sort-button"
                type="button"
                data-sort-key="hours"
                data-sort-default="asc"
              >
                Hours
              </button>
            </span>
            <span role="columnheader" aria-sort="descending">
              <button
                class="sort-button"
                type="button"
                data-sort-key="ratings"
                data-sort-default="desc"
                data-sort-direction="desc"
              >
                Rating
              </button>
            </span>
            <span role="columnheader" aria-sort="none">
              <button
                class="sort-button"
                type="button"
                data-sort-key="note"
                data-sort-default="asc"
              >
                Notes
              </button>
            </span>
          </div>
          {
            places.map((place: Place) => (
              <article
                class="place-row"
                role="row"
                data-kind={place.kind}
                data-name={place.name}
                data-town={place.town}
                data-hours={place.sundayHours}
                data-rating={place.rating ?? ""}
                data-ratings={place.ratings ?? ""}
                data-note={place.note}
              >
                <h2 class="place-name">
                  {place.name}
                  <span class={`kind-chip kind-${place.kind}`}>
                    {kindLabels[place.kind as keyof typeof kindLabels] ??
                      place.kind}
                  </span>
                </h2>
                <div class="map-actions">
                  <a
                    class="maps-link"
                    href={place.googleMapsUrl}
                    target="_blank"
                    rel="noreferrer noopener"
                    aria-label={`Open ${place.name} on Google Maps`}
                    title={`Open ${place.name} on Google Maps`}
                  >
                    <span class="maps-icon" set:html={mapsIcon} />
                  </a>
                </div>
                <p class="meta-line">
                  <span class="town">{place.town}</span>
                  <span class="address">{place.address}</span>
                </p>
                <p class="hours">{place.sundayHours}</p>
                <p class="rating">
                  {place.rating != null
                    ? `${place.rating}★ (${place.ratings})`
                    : "—"}
                </p>
                <p class="note">{place.note}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="place-map-section" aria-labelledby="place-map-heading">
        <div class="map-copy">
          <p class="eyebrow">Map</p>
          <h2 id="place-map-heading">Stops on the corridor</h2>
          <p id="place-map-status" class="map-status">
            Showing {places.length} places from BA corridor towns through Lincoln.
          </p>
        </div>
        {
          googleMapsApiKey ? (
            <div
              id="place-map"
              class="place-map"
              aria-label="Google Map with pins for BA–Lincoln trip stops"
            />
          ) : (
            <p class="map-unavailable">
              Map unavailable because the Google Maps public key is not
              configured.
            </p>
          )
        }
      </section>

      <footer class="page-footer">
        <p>
          Hours cross-checked Jul 2026 via Google Places (ES), municipal /
          tourism pages (Lincoln, Carmen de Areco, Giles, Junín, San Antonio de
          Areco), Museo Las Lilas, Museo Güiraldes, and Spanish press. Closed
          Sundays and skipped: Lo de Galar, Museo Histórico de Junín, Casa de
          la Cultura Chacabuco. Museums change — confirm before you detour.
        </p>
      </footer>
    </main>
  </body>
</html>

<script is:inline define:vars={{ googleMapsApiKey, placeMapData }}>
  if (googleMapsApiKey) {
    ((g) => {
      let h;
      let a;
      let k;
      const p = "The Google Maps JavaScript API";
      const c = "google";
      const l = "importLibrary";
      const q = "__ib__";
      const m = document;
      let b = window;
      b = b[c] || (b[c] = {});
      const d = b.maps || (b.maps = {});
      const r = new Set();
      const e = new URLSearchParams();
      const u = () =>
        h ||
        (h = new Promise(async (resolve, reject) => {
          await (a = m.createElement("script"));
          e.set("libraries", [...r] + "");
          for (k in g) {
            e.set(k.replace(/[A-Z]/g, (t) => `_${t[0].toLowerCase()}`), g[k]);
          }
          e.set("callback", `${c}.maps.${q}`);
          a.src = `https://maps.${c}apis.com/maps/api/js?${e}`;
          d[q] = resolve;
          a.onerror = () => (h = reject(Error(`${p} could not load.`)));
          a.nonce = m.querySelector("script[nonce]")?.nonce || "";
          m.head.append(a);
        }));
      d[l]
        ? console.warn(`${p} only loads once. Ignoring:`, g)
        : (d[l] = (f, ...n) => r.add(f) && u().then(() => d[l](f, ...n)));
    })({
      key: googleMapsApiKey,
      v: "weekly",
    });
  }

  const kindInputs = [...document.querySelectorAll('input[name="kind"]')];
  const placeList = document.querySelector(".place-list");
  const placeHead = document.querySelector(".place-head");
  const placeRows = [
    ...document.querySelectorAll(".place-row:not(.place-head)"),
  ];
  const sortButtons = [...document.querySelectorAll(".sort-button")];
  const mapElement = document.querySelector("#place-map");
  const mapStatus = document.querySelector("#place-map-status");
  const mapCenter = { lat: -34.65, lng: -60.5 };
  const markerRecords = [];
  const collator = new Intl.Collator("en", { sensitivity: "base" });
  let placeMap;
  let infoWindow;
  let currentSort = { key: "ratings", direction: "desc" };

  const kindColors = {
    "pit-stop": "#1f4f73",
    plaza: "#2a5a38",
    church: "#5a3d6e",
    food: "#8a3f1f",
    museum: "#5a4a2e",
    park: "#1f5c4a",
  };

  const kindLabels = {
    "pit-stop": "Pit stop",
    plaza: "Plaza",
    church: "Church",
    food: "Food",
    museum: "Museum",
    park: "Park",
  };

  const escapeHtml = (value) =>
    String(value).replace(
      /[&<>"']/g,
      (character) =>
        ({
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#39;",
        })[character],
    );

  const selectedKind = () =>
    kindInputs.find((input) => input.checked)?.value ?? "";

  const placePasses = (place, kind) => {
    if (kind && place.kind !== kind) return false;
    return true;
  };

  const visiblePlaces = () => {
    const kind = selectedKind();
    return placeMapData.filter((place) => placePasses(place, kind));
  };

  const updateMapStatus = () => {
    if (!mapStatus) return;
    const visible = visiblePlaces();
    const kind = selectedKind();
    const suffix = kind ? ` · ${kindLabels[kind] ?? kind}` : "";
    mapStatus.textContent = `Showing ${visible.length} place${visible.length === 1 ? "" : "s"}${suffix}.`;
  };

  const fitMapToMarkers = (visibleRecords) => {
    if (!placeMap || !window.google?.maps || visibleRecords.length === 0) return;
    if (visibleRecords.length === 1) {
      placeMap.setCenter(visibleRecords[0].place.position);
      placeMap.setZoom(13);
      return;
    }
    const bounds = new google.maps.LatLngBounds();
    for (const { place } of visibleRecords) {
      bounds.extend(place.position);
    }
    placeMap.fitBounds(bounds, 48);
  };

  const syncMapMarkers = () => {
    updateMapStatus();
    if (!placeMap) return;
    const visibleIds = new Set(visiblePlaces().map((place) => place.id));
    const visibleRecords = [];
    for (const record of markerRecords) {
      const isVisible = visibleIds.has(record.place.id);
      record.marker.setMap(isVisible ? placeMap : null);
      if (isVisible) visibleRecords.push(record);
    }
    if (mapElement) mapElement.dataset.visiblePins = String(visibleRecords.length);
    fitMapToMarkers(visibleRecords);
  };

  const getSortValue = (row, key) => {
    if (key === "ratings" || key === "rating") {
      return Number(row.dataset[key] || 0);
    }
    return row.dataset[key] ?? "";
  };

  const compareRows = (firstRow, secondRow) => {
    const firstValue = getSortValue(firstRow, currentSort.key);
    const secondValue = getSortValue(secondRow, currentSort.key);
    const multiplier = currentSort.direction === "asc" ? 1 : -1;

    if (currentSort.key === "ratings" || currentSort.key === "rating") {
      const numericDifference = Number(firstValue) - Number(secondValue);
      if (numericDifference !== 0) return multiplier * numericDifference;
      return collator.compare(
        firstRow.dataset.name ?? "",
        secondRow.dataset.name ?? "",
      );
    }

    const textCompare = collator.compare(
      String(firstValue),
      String(secondValue),
    );
    if (textCompare !== 0) return multiplier * textCompare;
    return collator.compare(
      firstRow.dataset.name ?? "",
      secondRow.dataset.name ?? "",
    );
  };

  const updateSortState = () => {
    for (const button of sortButtons) {
      const isActive = button.dataset.sortKey === currentSort.key;
      button.dataset.sortDirection = isActive ? currentSort.direction : "";
      button.closest("[role='columnheader']")?.setAttribute(
        "aria-sort",
        isActive
          ? currentSort.direction === "asc"
            ? "ascending"
            : "descending"
          : "none",
      );
    }
  };

  const sortRows = () => {
    if (!placeList) return;
    const sortedRows = [...placeRows].sort(compareRows);
    for (const row of sortedRows) {
      placeList.append(row);
    }
    if (placeHead) placeList.prepend(placeHead);
    updateSortState();
  };

  const applyFilters = () => {
    const kind = selectedKind();

    for (const row of placeRows) {
      const rowKind = row.dataset.kind ?? "";
      row.hidden = Boolean(kind) && rowKind !== kind;
    }

    syncMapMarkers();
  };

  const initPlaceMap = async () => {
    if (!mapElement || !googleMapsApiKey || !window.google?.maps?.importLibrary)
      return;

    const { Map, InfoWindow } = await google.maps.importLibrary("maps");
    await google.maps.importLibrary("marker");

    placeMap = new Map(mapElement, {
      center: mapCenter,
      clickableIcons: false,
      fullscreenControl: true,
      mapTypeControl: false,
      streetViewControl: false,
      zoom: 8,
    });
    infoWindow = new InfoWindow();

    for (const place of placeMapData) {
      const marker = new google.maps.Marker({
        map: placeMap,
        position: place.position,
        title: place.name,
        icon: {
          path: google.maps.SymbolPath.CIRCLE,
          scale: 8,
          fillColor: kindColors[place.kind] ?? "#444",
          fillOpacity: 0.95,
          strokeColor: "#ffffff",
          strokeWeight: 1.5,
        },
      });

      marker.addListener("click", () => {
        infoWindow.setContent(
          `<strong>${escapeHtml(place.name)}</strong><br>${escapeHtml(place.town)} · ${escapeHtml(kindLabels[place.kind] ?? place.kind)}<br><a href="${escapeHtml(place.googleMapsUrl)}" target="_blank" rel="noreferrer noopener">Open in Google Maps</a>`,
        );
        infoWindow.open(placeMap, marker);
      });

      markerRecords.push({ place, marker });
    }

    applyFilters();
  };

  for (const input of kindInputs) {
    input.addEventListener("change", applyFilters);
  }
  for (const button of sortButtons) {
    button.addEventListener("click", () => {
      const sortKey = button.dataset.sortKey;
      if (!sortKey) return;

      const defaultDirection = button.dataset.sortDefault ?? "asc";
      currentSort =
        currentSort.key === sortKey
          ? {
              key: sortKey,
              direction: currentSort.direction === "asc" ? "desc" : "asc",
            }
          : {
              key: sortKey,
              direction: defaultDirection,
            };

      sortRows();
      applyFilters();
    });
  }
  updateSortState();
  applyFilters();
  initPlaceMap().catch((error) => {
    console.error("Unable to initialize trip map", error);
    if (mapStatus)
      mapStatus.textContent = "Map unavailable. Place list still works.";
  });
</script>

<style>
  :root {
    color-scheme: light dark;
    --bg: #fafcfb;
    --surface: #fbfcfb;
    --surface-soft: #e3e9e5;
    --text: #15201b;
    --text-muted: #5c6a63;
    --border: #c7d0cb;
    --border-strong: #aeb8b2;
    --accent: #2f6f5e;
    --accent-soft: #d5e8e1;
    --lincoln: #8b3a2b;
    --lincoln-soft: #f0ddd7;
    --optional: #5a6470;
    --link: #15201b;
    --shadow: 0 10px 28px rgba(28, 42, 36, 0.06);
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #101412;
      --surface: #171c19;
      --surface-soft: #222925;
      --text: #eef3f0;
      --text-muted: #9aa69f;
      --border: #303833;
      --border-strong: #465049;
      --accent: #8fc4b2;
      --accent-soft: #1e322c;
      --lincoln: #e0a090;
      --lincoln-soft: #3a2420;
      --optional: #a8b0b8;
      --link: #eef3f0;
      --shadow: none;
    }
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-family: Georgia, "Iowan Old Style", "Palatino Linotype", Palatino, serif;
    font-size: 15px;
    background: var(--bg);
    color: var(--text);
    line-height: 1.45;
    -webkit-font-smoothing: antialiased;
  }

  body {
    margin: 0;
    background:
      linear-gradient(
        160deg,
        color-mix(in srgb, var(--accent-soft), transparent 35%) 0%,
        transparent 38%
      ),
      linear-gradient(
        210deg,
        color-mix(in srgb, var(--lincoln-soft), transparent 45%) 0%,
        transparent 32%
      ),
      var(--bg);
  }

  a {
    color: var(--link);
    text-decoration-color: color-mix(in srgb, var(--link), transparent 62%);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  a:hover {
    text-decoration-color: currentColor;
  }

  .page {
    width: min(100%, 72rem);
    margin: 0 auto;
    padding: 0.65rem clamp(0.65rem, 1.6vw, 1.1rem) 1.25rem;
  }

  .page-header {
    display: grid;
    gap: 0.5rem;
    padding: 0.28rem 0 0.45rem;
  }

  .home-link {
    width: fit-content;
    color: var(--text-muted);
    font-size: 0.82rem;
    text-decoration: none;
  }

  .home-link:hover {
    color: var(--text);
  }

  .headline {
    display: grid;
    gap: 0.35rem;
    max-width: 44rem;
  }

  .eyebrow {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(1.42rem, 3.4vw, 2.05rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.08;
  }

  .intro {
    margin: 0;
    max-width: 40rem;
    color: var(--text-muted);
    font-size: 0.92rem;
  }

  .map-copy h2 {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .intro,
  .toolbar,
  .meta-line,
  .hours,
  .rating,
  .note,
  .map-status,
  .page-footer,
  .kind-chip,
  .kind-toggle label,
  .place-head {
    font-family:
      "Segoe UI",
      "Helvetica Neue",
      Helvetica,
      Arial,
      sans-serif;
  }

  .toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 0 0 0.5rem;
  }

  .kind-toggle {
    display: flex;
    width: fit-content;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin: 0;
    padding: 0.28rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: color-mix(in srgb, var(--surface), transparent 6%);
  }

  .kind-toggle legend {
    margin: 0 0.25rem 0 0.15rem;
    padding: 0;
    color: var(--text-muted);
    font-size: 0.65rem;
