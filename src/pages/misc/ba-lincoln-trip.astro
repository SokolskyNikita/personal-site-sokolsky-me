---
import pageData from "../../data/ba-lincoln-trip.json";

export const prerender = true;

const pageTitle = "Buenos Aires → Lincoln same-day road trip";
const pageDescription =
  "Sunday same-day car trip ideas from Buenos Aires to Lincoln, Buenos Aires Province: route, lunch, Sunday-open stops on RN7/RN188, and a map of places worth a look.";
const themeColorLight = "#eef2f0";
const themeColorDark = "#121614";
const siteUrl = (Astro.site?.toString() ?? "https://sokolsky.me").replace(
  /\/$/,
  "",
);
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
type Place = (typeof pageData.places)[number];
const places = pageData.places;
const updatedDate = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
}).format(new Date(pageData.generatedAt));
const segmentOrder = ["en-route", "lincoln", "optional"] as const;
const segmentLabels: Record<(typeof segmentOrder)[number], string> = {
  "en-route": "On the way (RN7 corridor)",
  lincoln: "In Lincoln",
  optional: "Optional detours",
};
const segmentShort: Record<(typeof segmentOrder)[number], string> = {
  "en-route": "En route",
  lincoln: "Lincoln",
  optional: "Detours",
};
const kindLabels: Record<string, string> = {
  "pit-stop": "Pit stop",
  plaza: "Plaza",
  church: "Church",
  food: "Food",
  museum: "Museum",
  park: "Park",
};
const sundayLabels: Record<string, string> = {
  true: "Sunday OK",
  maybe: "Check first",
  false: "Closed Sunday",
};
const placesBySegment = segmentOrder.map((segment) => ({
  segment,
  label: segmentLabels[segment],
  places: places
    .filter((place: Place) => place.segment === segment)
    .toSorted((a: Place, b: Place) => a.priority - b.priority),
}));
const googleMapsApiKey =
  import.meta.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
  process.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
  "";
const placeMapData = places.map((place: Place) => ({
  id: place.id,
  name: place.name,
  town: place.town,
  segment: place.segment,
  kind: place.kind,
  sundayOk: place.sundayOk,
  googleMapsUrl: place.googleMapsUrl,
  position: place.location,
}));
const mapsIcon = `<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="#1a73e8" d="M12 2.2c3.9 0 7.1 3.1 7.1 7 0 5.1-7.1 12.6-7.1 12.6S4.9 14.3 4.9 9.2c0-3.9 3.2-7 7.1-7Z"/><path fill="#34a853" d="M7.2 14.1 12 21.8l4.8-7.7-4.8-2.8-4.8 2.8Z"/><path fill="#fbbc04" d="M4.9 9.2c0 1.8.9 3.5 2.3 4.9l4.8-2.8V2.2c-3.9 0-7.1 3.1-7.1 7Z"/><path fill="#ea4335" d="M19.1 9.2c0 1.8-.9 3.5-2.3 4.9L12 11.3V2.2c3.9 0 7.1 3.1 7.1 7Z"/><circle cx="12" cy="9.3" r="2.45" fill="#fff"/></svg>`;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  numberOfItems: places.length,
  itemListElement: places.map((place: Place, index: number) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "Place",
      name: place.name,
      description: place.note,
      address: place.address,
      sameAs: place.googleMapsUrl,
      geo: {
        "@type": "GeoCoordinates",
        latitude: place.location.lat,
        longitude: place.location.lng,
      },
    },
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="subject" content="Buenos Aires Lincoln road trip" />
    <meta name="application-name" content={pageTitle} />
    <meta
      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="keywords"
      content="Buenos Aires to Lincoln road trip, Lincoln Buenos Aires Province, RN7 RN188, Flamenco Lincoln, same day trip Argentina"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta
      name="theme-color"
      content={themeColorLight}
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content={themeColorDark}
      media="(prefers-color-scheme: dark)"
    />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Nikita Sokolsky" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}
    ></script>
  </head>
  <body>
    <main class="page">
      <header class="page-header">
        <a class="home-link" href="/">Nikita Sokolsky</a>
        <div class="headline">
          <p class="eyebrow">Same-day car trip · Sunday</p>
          <h1>BA → Lincoln → BA</h1>
          <p class="intro">
            Ideas for a Sunday drive to Lincoln (~{pageData.route.oneWayKm} km /
            {pageData.route.oneWayDrive}), lunch in town, then back by midnight.
            Not a fixed itinerary — pick stops that fit the clock.
          </p>
        </div>
        <aside class="route-box" aria-label="Route snapshot">
          <p>
            <strong>Route:</strong>
            {pageData.route.summary}
          </p>
          <p>
            <strong>Leave BA:</strong>
            {pageData.route.leaveBy} ·
            <strong>Leave Lincoln:</strong>
            by {pageData.route.leaveLincolnBy}
          </p>
          <p>
            Check{" "}
            <a
              href={pageData.route.roadStatusUrl}
              target="_blank"
              rel="noreferrer noopener">national road status</a
            >
            before you go. Updated {updatedDate}.
          </p>
        </aside>
      </header>

      <section class="schedule" aria-labelledby="schedule-heading">
        <h2 id="schedule-heading">Rough day shape</h2>
        <ol class="schedule-list">
          {
            pageData.scheduleHint.map((row) => (
              <li>
                <span class="time">{row.time}</span>
                <span class="plan">{row.plan}</span>
              </li>
            ))
          }
        </ol>
      </section>

      <div class="toolbar" aria-label="Place filters">
        <fieldset class="segment-toggle">
          <legend>Show</legend>
          <input
            id="seg-all"
            type="radio"
            name="segment"
            value=""
            autocomplete="off"
            checked
          />
          <label for="seg-all">All ({places.length})</label>
          {
            placesBySegment.flatMap(({ segment, places: group }) => [
              <input
                id={`seg-${segment}`}
                type="radio"
                name="segment"
                value={segment}
                autocomplete="off"
              />,
              <label for={`seg-${segment}`}>
                {segmentShort[segment]} ({group.length})
              </label>,
            ])
          }
        </fieldset>
        <fieldset class="extras-toggle">
          <legend>Filter</legend>
          <input id="filter-sunday" type="checkbox" autocomplete="off" checked />
          <label for="filter-sunday">Sunday-solid only</label>
        </fieldset>
      </div>

      {
        placesBySegment.map(({ segment, label, places: group }) => (
          <section
            class="place-section"
            data-segment={segment}
            aria-labelledby={`heading-${segment}`}
          >
            <div class="section-head">
              <h2 id={`heading-${segment}`}>{label}</h2>
              <p class="section-count" data-section-count={segment}>
                {group.length} places
              </p>
            </div>
            <div class="place-list">
              {group.map((place: Place) => (
                <article
                  class="place-row"
                  data-segment={place.segment}
                  data-sunday={String(place.sundayOk)}
                  data-kind={place.kind}
                >
                  <h3 class="place-name">
                    {place.name}
                    <span class="kind-chip">
                      {kindLabels[place.kind] ?? place.kind}
                    </span>
                    <span
                      class:list={[
                        "sunday-chip",
                        `sunday-${place.sundayOk === true ? "ok" : place.sundayOk}`,
                      ]}
                    >
                      {sundayLabels[String(place.sundayOk)] ?? "Sunday?"}
                    </span>
                  </h3>
                  <div class="map-actions">
                    <a
                      class="maps-link"
                      href={place.googleMapsUrl}
                      target="_blank"
                      rel="noreferrer noopener"
                      aria-label={`Open ${place.name} on Google Maps`}
                      title={`Open ${place.name} on Google Maps`}
                    >
                      <span class="maps-icon" set:html={mapsIcon} />
                    </a>
                  </div>
                  <p class="meta-line">
                    <span class="town">{place.town}</span>
                    <span class="address">{place.address}</span>
                  </p>
                  <p class="hours">{place.sundayHours}</p>
                  <p class="rating">
                    {place.rating != null
                      ? `${place.rating}★ (${place.ratings})`
                      : "—"}
                  </p>
                  <p class="note">{place.note}</p>
                </article>
              ))}
            </div>
          </section>
        ))
      }

      <section class="place-map-section" aria-labelledby="place-map-heading">
        <div class="map-copy">
          <p class="eyebrow">Map</p>
          <h2 id="place-map-heading">Stops on the corridor</h2>
          <p id="place-map-status" class="map-status">
            Showing {places.length} places from BA corridor towns through Lincoln.
          </p>
        </div>
        {
          googleMapsApiKey ? (
            <div
              id="place-map"
              class="place-map"
              aria-label="Google Map with pins for BA–Lincoln trip stops"
            />
          ) : (
            <p class="map-unavailable">
              Map unavailable because the Google Maps public key is not
              configured.
            </p>
          )
        }
      </section>

      <footer class="page-footer">
        <p>
          Hours cross-checked Jul 2026 via Google Places (ES), municipal /
          tourism pages (Lincoln, Carmen de Areco, Giles, Junín, San Antonio de
          Areco), Museo Las Lilas, Museo Güiraldes, and Spanish press. Closed
          Sundays and skipped: Lo de Galar, Museo Histórico de Junín, Casa de
          la Cultura Chacabuco. Museums change — confirm before you detour.
        </p>
      </footer>
    </main>
  </body>
</html>

<script is:inline define:vars={{ googleMapsApiKey, placeMapData }}>
  if (googleMapsApiKey) {
    ((g) => {
      let h;
      let a;
      let k;
      const p = "The Google Maps JavaScript API";
      const c = "google";
      const l = "importLibrary";
      const q = "__ib__";
      const m = document;
      let b = window;
      b = b[c] || (b[c] = {});
      const d = b.maps || (b.maps = {});
      const r = new Set();
      const e = new URLSearchParams();
      const u = () =>
        h ||
        (h = new Promise(async (resolve, reject) => {
          await (a = m.createElement("script"));
          e.set("libraries", [...r] + "");
          for (k in g) {
            e.set(k.replace(/[A-Z]/g, (t) => `_${t[0].toLowerCase()}`), g[k]);
          }
          e.set("callback", `${c}.maps.${q}`);
          a.src = `https://maps.${c}apis.com/maps/api/js?${e}`;
          d[q] = resolve;
          a.onerror = () => (h = reject(Error(`${p} could not load.`)));
          a.nonce = m.querySelector("script[nonce]")?.nonce || "";
          m.head.append(a);
        }));
      d[l]
        ? console.warn(`${p} only loads once. Ignoring:`, g)
        : (d[l] = (f, ...n) => r.add(f) && u().then(() => d[l](f, ...n)));
    })({
      key: googleMapsApiKey,
      v: "weekly",
    });
  }

  const segmentInputs = [...document.querySelectorAll('input[name="segment"]')];
  const sundayFilter = document.querySelector("#filter-sunday");
  const placeRows = [...document.querySelectorAll(".place-row")];
  const placeSections = [...document.querySelectorAll(".place-section")];
  const mapElement = document.querySelector("#place-map");
  const mapStatus = document.querySelector("#place-map-status");
  const mapCenter = { lat: -34.65, lng: -60.5 };
  const markerRecords = [];
  let placeMap;
  let infoWindow;

  const segmentColors = {
    "en-route": "#2f6f5e",
    lincoln: "#8b3a2b",
    optional: "#5a6470",
  };

  const escapeHtml = (value) =>
    String(value).replace(
      /[&<>"']/g,
      (character) =>
        ({
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#39;",
        })[character],
    );

  const selectedSegment = () =>
    segmentInputs.find((input) => input.checked)?.value ?? "";

  const sundaySolidOnly = () => Boolean(sundayFilter?.checked);

  const placePasses = (place, segment, sundayOnly) => {
    if (segment && place.segment !== segment) return false;
    if (sundayOnly && place.sundayOk !== true) return false;
    return true;
  };

  const visiblePlaces = () => {
    const segment = selectedSegment();
    const sundayOnly = sundaySolidOnly();
    return placeMapData.filter((place) =>
      placePasses(place, segment, sundayOnly),
    );
  };

  const updateMapStatus = () => {
    if (!mapStatus) return;
    const visible = visiblePlaces();
    const bits = [];
    const segment = selectedSegment();
    if (segment) bits.push(segment);
    if (sundaySolidOnly()) bits.push("Sunday-solid");
    const suffix = bits.length ? ` · ${bits.join(" · ")}` : "";
    mapStatus.textContent = `Showing ${visible.length} place${visible.length === 1 ? "" : "s"}${suffix}.`;
  };

  const fitMapToMarkers = (visibleRecords) => {
    if (!placeMap || !window.google?.maps || visibleRecords.length === 0) return;
    if (visibleRecords.length === 1) {
      placeMap.setCenter(visibleRecords[0].place.position);
      placeMap.setZoom(13);
      return;
    }
    const bounds = new google.maps.LatLngBounds();
    for (const { place } of visibleRecords) {
      bounds.extend(place.position);
    }
    placeMap.fitBounds(bounds, 48);
  };

  const syncMapMarkers = () => {
    updateMapStatus();
    if (!placeMap) return;
    const visibleIds = new Set(visiblePlaces().map((place) => place.id));
    const visibleRecords = [];
    for (const record of markerRecords) {
      const isVisible = visibleIds.has(record.place.id);
      record.marker.setMap(isVisible ? placeMap : null);
      if (isVisible) visibleRecords.push(record);
    }
    if (mapElement) mapElement.dataset.visiblePins = String(visibleRecords.length);
    fitMapToMarkers(visibleRecords);
  };

  const applyFilters = () => {
    const segment = selectedSegment();
    const sundayOnly = sundaySolidOnly();

    for (const row of placeRows) {
      const rowSegment = row.dataset.segment ?? "";
      const rowSunday = row.dataset.sunday ?? "";
      const sundayOk = rowSunday === "true";
      const show =
        (!segment || rowSegment === segment) && (!sundayOnly || sundayOk);
      row.hidden = !show;
    }

    for (const section of placeSections) {
      const rows = [...section.querySelectorAll(".place-row")];
      const visibleCount = rows.filter((row) => !row.hidden).length;
      section.hidden = visibleCount === 0;
      const countEl = section.querySelector("[data-section-count]");
      if (countEl) {
        countEl.textContent = `${visibleCount} place${visibleCount === 1 ? "" : "s"}`;
      }
    }

    syncMapMarkers();
  };

  const initPlaceMap = async () => {
    if (!mapElement || !googleMapsApiKey || !window.google?.maps?.importLibrary)
      return;

    const { Map, InfoWindow } = await google.maps.importLibrary("maps");
    await google.maps.importLibrary("marker");

    placeMap = new Map(mapElement, {
      center: mapCenter,
      clickableIcons: false,
      fullscreenControl: true,
      mapTypeControl: false,
      streetViewControl: false,
      zoom: 8,
    });
    infoWindow = new InfoWindow();

    for (const place of placeMapData) {
      const marker = new google.maps.Marker({
        map: placeMap,
        position: place.position,
        title: place.name,
        icon: {
          path: google.maps.SymbolPath.CIRCLE,
          scale: 8,
          fillColor: segmentColors[place.segment] ?? "#444",
          fillOpacity: 0.95,
          strokeColor: "#ffffff",
          strokeWeight: 1.5,
        },
      });

      marker.addListener("click", () => {
        infoWindow.setContent(
          `<strong>${escapeHtml(place.name)}</strong><br>${escapeHtml(place.town)} · ${escapeHtml(place.kind)}<br><a href="${escapeHtml(place.googleMapsUrl)}" target="_blank" rel="noreferrer noopener">Open in Google Maps</a>`,
        );
        infoWindow.open(placeMap, marker);
      });

      markerRecords.push({ place, marker });
    }

    applyFilters();
  };

  for (const input of segmentInputs) {
    input.addEventListener("change", applyFilters);
  }
  sundayFilter?.addEventListener("change", applyFilters);
  applyFilters();
  initPlaceMap().catch((error) => {
    console.error("Unable to initialize trip map", error);
    if (mapStatus)
      mapStatus.textContent = "Map unavailable. Place list still works.";
  });
</script>

<style>
  :root {
    color-scheme: light dark;
    --bg: #eef2f0;
    --surface: #fbfcfb;
    --surface-soft: #e3e9e5;
    --text: #15201b;
    --text-muted: #5c6a63;
    --border: #c7d0cb;
    --border-strong: #aeb8b2;
    --accent: #2f6f5e;
    --accent-soft: #d5e8e1;
    --lincoln: #8b3a2b;
    --lincoln-soft: #f0ddd7;
    --optional: #5a6470;
    --link: #15201b;
    --shadow: 0 10px 28px rgba(28, 42, 36, 0.06);
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #101412;
      --surface: #171c19;
      --surface-soft: #222925;
      --text: #eef3f0;
      --text-muted: #9aa69f;
      --border: #303833;
      --border-strong: #465049;
      --accent: #8fc4b2;
      --accent-soft: #1e322c;
      --lincoln: #e0a090;
      --lincoln-soft: #3a2420;
      --optional: #a8b0b8;
      --link: #eef3f0;
      --shadow: none;
    }
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-family: Georgia, "Iowan Old Style", "Palatino Linotype", Palatino, serif;
    font-size: 15px;
    background: var(--bg);
    color: var(--text);
    line-height: 1.45;
    -webkit-font-smoothing: antialiased;
  }

  body {
    margin: 0;
    background:
      linear-gradient(
        160deg,
        color-mix(in srgb, var(--accent-soft), transparent 35%) 0%,
        transparent 38%
      ),
      linear-gradient(
        210deg,
        color-mix(in srgb, var(--lincoln-soft), transparent 45%) 0%,
        transparent 32%
      ),
      var(--bg);
  }

  a {
    color: var(--link);
    text-decoration-color: color-mix(in srgb, var(--link), transparent 62%);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  a:hover {
    text-decoration-color: currentColor;
  }

  .page {
    width: min(100%, 72rem);
    margin: 0 auto;
    padding: 0.75rem clamp(0.7rem, 2vw, 1.25rem) 1.5rem;
  }

  .page-header {
    display: grid;
    gap: 0.65rem;
    padding: 0.35rem 0 0.55rem;
  }

  .home-link {
    width: fit-content;
    color: var(--text-muted);
    font-size: 0.82rem;
    text-decoration: none;
  }

  .home-link:hover {
    color: var(--text);
  }

  .headline {
    display: grid;
    gap: 0.35rem;
    max-width: 44rem;
  }

  .eyebrow {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(1.55rem, 4.2vw, 2.35rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.05;
  }

  .intro {
    margin: 0;
    max-width: 40rem;
    color: var(--text-muted);
    font-size: 0.92rem;
  }

  .route-box {
    margin: 0;
    padding: 0.65rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 0.7rem;
    background: color-mix(in srgb, var(--surface), transparent 8%);
    box-shadow: var(--shadow);
  }

  .route-box p {
    margin: 0 0 0.3rem;
    color: var(--text-muted);
    font-size: 0.82rem;
  }

  .route-box p:last-child {
    margin-bottom: 0;
  }

  .route-box strong {
    color: var(--text);
    font-weight: 700;
  }

  .schedule {
    margin: 0.55rem 0 0.7rem;
    padding: 0.65rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 0.7rem;
    background: var(--surface);
  }

  .schedule h2,
  .section-head h2,
  .map-copy h2 {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .intro,
  .route-box,
  .schedule-list,
  .toolbar,
  .meta-line,
  .hours,
  .rating,
  .note,
  .map-status,
  .page-footer,
  .kind-chip,
  .sunday-chip,
  .segment-toggle label,
  .extras-toggle label,
  .section-count {
    font-family:
      "Segoe UI",
      "Helvetica Neue",
      Helvetica,
      Arial,
      sans-serif;
  }

  .schedule-list {
    margin: 0.45rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.28rem;
  }

  .schedule-list li {
    display: grid;
    grid-template-columns: minmax(7.5rem, 9.5rem) 1fr;
    gap: 0.45rem;
    align-items: baseline;
    font-size: 0.84rem;
  }

  .time {
    color: var(--accent);
    font-weight: 750;
    font-variant-numeric: tabular-nums;
  }

  .plan {
    color: var(--text-muted);
  }

  .toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 0 0 0.65rem;
  }

  .segment-toggle,
  .extras-toggle {
    display: flex;
    width: fit-content;
