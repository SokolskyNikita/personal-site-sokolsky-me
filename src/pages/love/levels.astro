      "nl-nl": [6, 7, 8],
      "cz-cs": [8, 9],
    },
  },
  {
    label: "Undefined gray zone",
    levels: {
      "us-en": 8,
      "cn-zh": [4, 8],
      "de-de": 9,
      "jp-ja": 7,
      "uk-en": 10,
      "in-en": 8,
      "fr-fr": 9,
      "it-it": 9,
      "ru-ru": 10,
      "br-pt": 9,
      "ca-en": 8,
      "ar-es": 11,
      "nl-nl": [9, 10],
      "cz-cs": 10,
    },
