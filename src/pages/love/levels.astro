---
import usa from "../../data/love-levels/usa.json";
import china from "../../data/love-levels/china.json";
import germany from "../../data/love-levels/germany.json";
import japan from "../../data/love-levels/japan.json";
import uk from "../../data/love-levels/uk.json";
import india from "../../data/love-levels/india.json";
import france from "../../data/love-levels/france.json";
import italy from "../../data/love-levels/italy.json";
import brazil from "../../data/love-levels/brazil.json";
import canada from "../../data/love-levels/canada.json";
import argentina from "../../data/love-levels/argentina.json";
import czechRepublic from "../../data/love-levels/czech-republic.json";
import russia from "../../data/love-levels/russia.json";
import netherlands from "../../data/love-levels/netherlands.json";

export const prerender = true;

const pageTitle = "Relationship levels by country";
const pageDescription =
  "Informal dating and relationship ladders by country — USA, China, Germany, Japan, UK, India, France, Italy, Russia, Brazil, Canada, Argentina, Czech Republic, and the Netherlands.";
const themeColorLight = "#ffffff";
const themeColorDark = "#111111";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
// Order: IMF WEO Apr 2026 nominal GDP (current prices, not PPP)
const locales = [
  usa,
  china,
  germany,
  japan,
  uk,
  india,
  france,
  italy,
  russia,
  brazil,
  canada,
  argentina,
  netherlands,
  czechRepublic,
];
const defaultLocale = locales.find((l) => l.default) ?? locales[0];
const allLocaleId = "all";
type Locale = (typeof locales)[number];
type LevelMapValue = number | number[] | null;
type StageRow = {
  label: string;
  levels: {
    default?: LevelMapValue;
    [localeId: string]: LevelMapValue | undefined;
  };
};

const semanticStageRows: StageRow[] = [
  { label: "None / single", levels: { default: 0 } },
  { label: "Attraction", levels: { default: 1 } },
  { label: "Flirting", levels: { default: 2 } },
  { label: "Talking / texting", levels: { default: 3, "ar-es": null } },
  {
    label: "Getting to know",
    levels: { default: 4, "cn-zh": 7, "ar-es": 3, "nl-nl": 3 },
  },
  {
    label: "Kiss / make out",
    levels: {
      default: 5,
      "us-en": null,
      "cn-zh": null,
      "in-en": null,
      "ca-en": null,
      "nl-nl": null,
    },
  },
  {
    label: "One-off sex",
    levels: {
      default: 6,
      "us-en": 5,
      "cn-zh": 5,
      "jp-ja": null,
      "in-en": 5,
      "br-pt": null,
      "ca-en": 5,
      "ar-es": 5,
      "nl-nl": 4,
    },
  },
  {
    label: "FWB / regular hookup",
    levels: {
      default: 7,
      "us-en": 6,
      "cn-zh": 6,
      "jp-ja": 6,
      "in-en": 6,
      "ca-en": 6,
      "ar-es": [6, 7, 8],
      "nl-nl": 5,
    },
  },
  {
    label: "Casual dating",
    levels: {
      default: 8,
      "us-en": 7,
      "cn-zh": null,
      "jp-ja": null,
      "uk-en": [8, 9],
      "in-en": 7,
      "ru-ru": [8, 9],
      "ca-en": 7,
