      "ca-en": 12,
      "ar-es": 15,
      "nl-nl": 16,
      "cz-cs": 14,
    },
  },
  {
    label: "Legal partnership",
    levels: {
      "us-en": null,
      "cn-zh": null,
      "de-de": null,
      "jp-ja": null,
      "uk-en": 16,
      "in-en": null,
      "fr-fr": 14,
      "it-it": null,
      "ru-ru": null,
      "br-pt": 13,
      "ca-en": 12,
      "ar-es": 16,
      "nl-nl": 17,
      "cz-cs": null,
    },
  },
  {
    label: "Engaged",
    levels: {
      "us-en": 13,
      "cn-zh": 13,
      "de-de": 14,
      "jp-ja": 12,
      "uk-en": 15,
      "in-en": 13,
      "fr-fr": 13,
      "it-it": 14,
      "ru-ru": 15,
      "br-pt": 14,
      "ca-en": 13,
      "ar-es": 17,
      "nl-nl": 18,
      "cz-cs": 15,
    },
  },
  {
    label: "Married",
    levels: {
      "us-en": 14,
      "cn-zh": 14,
      "de-de": 15,
      "jp-ja": 13,
      "uk-en": 16,
      "in-en": 14,
      "fr-fr": 14,
      "it-it": 15,
      "ru-ru": 16,
      "br-pt": 15,
      "ca-en": 14,
      "ar-es": 18,
      "nl-nl": 19,
      "cz-cs": 16,
    },
  },
  {
    label: "Married + kids",
    levels: {
      "us-en": 15,
      "cn-zh": 15,
      "de-de": 16,
      "jp-ja": 14,
      "uk-en": 17,
      "in-en": 15,
      "fr-fr": 15,
      "it-it": 16,
      "ru-ru": 17,
      "br-pt": 16,
      "ca-en": 15,
      "ar-es": 19,
      "nl-nl": 20,
      "cz-cs": 17,
    },
  },
];

const toLevelList = (value: LevelMapValue | undefined) => {
  if (value == null) return [];
  return Array.isArray(value) ? value : [value];
};
const getStageValue = (row: StageRow, locale: Locale) =>
  Object.prototype.hasOwnProperty.call(row.levels, locale.id)
    ? row.levels[locale.id]
    : row.levels.default;
const levelMapRows = semanticStageRows.map((row) => ({
  label: row.label,
  terms: locales.map((locale) => ({
    locale,
    term: toLevelList(getStageValue(row, locale))
      .map((level) => locale.levels.find((item) => item.level === level)?.term)
      .filter(Boolean)
      .join(" / "),
  })),
}));
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="googlebot" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta name="theme-color" content={themeColorLight} media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content={themeColorDark} media="(prefers-color-scheme: dark)" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="sokolsky.me" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <main>
      <p class="crumb"><a href="/">sokolsky.me</a></p>
      <h1>{pageTitle}</h1>
      <p class="lede">
        Informal ladders locals actually use — not official scales. Order is approximate; people skip and overlap.
      </p>

      <div class="locale-bar" role="tablist" aria-label="Country / language">
        <button
          type="button"
          class="locale-btn"
          role="tab"
          aria-selected="false"
          aria-controls={`panel-${allLocaleId}`}
          id={`tab-${allLocaleId}`}
          data-locale={allLocaleId}
        >
          <span class="locale-short">All</span>
          <span class="locale-full">All countries</span>
        </button>
        {
          locales.map((locale) => (
            <button
              type="button"
              class:list={["locale-btn", { active: locale.id === defaultLocale.id }]}
              role="tab"
              aria-selected={locale.id === defaultLocale.id ? "true" : "false"}
              aria-controls={`panel-${locale.id}`}
              id={`tab-${locale.id}`}
              data-locale={locale.id}
            >
              <span class="locale-short">{locale.shortLabel}</span>
              <span class="locale-full">{locale.label}</span>
            </button>
          ))
        }
      </div>

      <section
        class="locale-panel"
        id={`panel-${allLocaleId}`}
        role="tabpanel"
        aria-labelledby={`tab-${allLocaleId}`}
        hidden
        data-locale={allLocaleId}
      >
        <div class="panel-head">
          <p class="meta">
            <span class="lang">All countries</span>
            <span class="sep">·</span>
            <span class="count">{levelMapRows.length} mapped stages</span>
          </p>
          <p class="note">
            Semantic mapping across countries. Rows are broad relationship stages; cells show the closest local term or grouped terms, not matching numeric levels.
          </p>
        </div>
        <div class="table-wrap">
          <table class="mapping-table">
            <thead>
              <tr>
                <th scope="col">Stage</th>
                {locales.map((locale) => <th scope="col">{locale.shortLabel}</th>)}
              </tr>
            </thead>
            <tbody>
              {
                levelMapRows.map((row) => (
                  <tr>
                    <th scope="row">{row.label}</th>
                    {row.terms.map(({ term }) => (
                      <td>{term || "—"}</td>
                    ))}
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </section>

      {
        locales.map((locale) => (
          <section
            class:list={["locale-panel", { active: locale.id === defaultLocale.id }]}
            id={`panel-${locale.id}`}
            role="tabpanel"
            aria-labelledby={`tab-${locale.id}`}
            hidden={locale.id !== defaultLocale.id}
            data-locale={locale.id}
          >
            <div class="panel-head">
              <p class="meta">
                <span class="lang">{locale.language}</span>
                <span class="sep">·</span>
                <span class="count">0–{locale.levels[locale.levels.length - 1].level}</span>
              </p>
              <p class="note">{locale.ladderNote}</p>
            </div>
            <ol class="ladder">
              {locale.levels.map((item) => (
                <li>
                  <span class="lvl" aria-hidden="true">
                    {item.level}
                  </span>
                  <div class="body">
                    <p class="term">{item.term}</p>
                    <p class="meaning">{item.meaning}</p>
                  </div>
                </li>
              ))}
            </ol>
          </section>
        ))
      }

      <p class="footnote">
        Verified against local-facing sources only (local media, local forums). Dropped tourist/expat glosses and US calques without local evidence. Order is approximate.
      </p>
    </main>

    <script>
      const buttons = document.querySelectorAll<HTMLButtonElement>(".locale-btn");
      const panels = document.querySelectorAll<HTMLElement>(".locale-panel");

      function selectLocale(id: string) {
        buttons.forEach((btn) => {
          const on = btn.dataset.locale === id;
          btn.classList.toggle("active", on);
          btn.setAttribute("aria-selected", on ? "true" : "false");
        });
        panels.forEach((panel) => {
          const on = panel.dataset.locale === id;
          panel.classList.toggle("active", on);
          panel.hidden = !on;
        });
        try {
          history.replaceState(null, "", `#${id}`);
        } catch {
          /* ignore */
        }
      }

      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const locale = btn.dataset.locale;
          if (locale) selectLocale(locale);
        });
      });

      const hash = location.hash.replace(/^#/, "");
      if (hash && document.querySelector(`[data-locale="${hash}"]`)) {
        selectLocale(hash);
      }
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: light dark;
    --bg: #ffffff;
    --text: #111111;
    --muted: #555555;
    --line: #e4e4e4;
    --chip: #f3f3f3;
    --chip-on: #111111;
    --chip-on-text: #ffffff;
    --lvl: #888888;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #111111;
      --text: #eeeeee;
      --muted: #aaaaaa;
      --line: #2a2a2a;
      --chip: #1c1c1c;
      --chip-on: #eeeeee;
      --chip-on-text: #111111;
      --lvl: #888888;
    }
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial,
      sans-serif;
    line-height: 1.4;
    -webkit-text-size-adjust: 100%;
  }

  body {
    margin: 0;
    padding: 0.75rem 0.85rem 1.5rem;
  }

  main {
    max-width: 36rem;
    margin: 0 auto;
  }

  .crumb {
    margin: 0 0 0.35rem;
    font-size: 0.8rem;
    color: var(--muted);
  }

  .crumb a {
    color: var(--muted);
  }

  h1 {
    margin: 0 0 0.25rem;
    font-size: 1.15rem;
    font-weight: 650;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .lede {
    margin: 0 0 0.65rem;
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.35;
  }

  .locale-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin: 0 0 0.7rem;
  }

  .locale-btn {
    appearance: none;
    border: 1px solid var(--line);
    background: var(--chip);
    color: var(--text);
    border-radius: 0.35rem;
    padding: 0.35rem 0.55rem;
    font: inherit;
    font-size: 0.78rem;
    line-height: 1.2;
    cursor: pointer;
    min-height: 2rem;
  }

  .locale-btn .locale-full {
    display: none;
  }

  .locale-btn.active {
    background: var(--chip-on);
    color: var(--chip-on-text);
    border-color: var(--chip-on);
  }

  @media (min-width: 420px) {
    .locale-btn .locale-short {
      display: none;
    }
    .locale-btn .locale-full {
      display: inline;
    }
  }

  .locale-panel {
    display: none;
  }

  .locale-panel.active {
    display: block;
  }

  @media (min-width: 760px) {
    .locale-panel[data-locale="all"] {
      width: 80vw;
      margin-left: 50%;
      transform: translateX(-50%);
    }
  }

  .panel-head {
    height: 5.75rem;
    margin: 0 0 0.55rem;
    overflow: hidden;
  }

  .meta {
    margin: 0 0 0.2rem;
    font-size: 0.75rem;
    color: var(--muted);
  }

  .sep {
    margin: 0 0.25rem;
  }

  .note {
    margin: 0;
    font-size: 0.75rem;
    color: var(--muted);
    line-height: 1.35;
  }

  @media (max-width: 420px) {
    .panel-head {
      height: 8.5rem;
    }
  }

  .ladder {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--line);
  }

  .ladder li {
    display: grid;
    grid-template-columns: 1.6rem 1fr;
    gap: 0.45rem;
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--line);
    align-items: start;
  }

  .lvl {
    font-size: 0.72rem;
    font-variant-numeric: tabular-nums;
    color: var(--lvl);
    padding-top: 0.12rem;
    text-align: right;
  }

  .body {
    min-width: 0;
  }

  .term {
    margin: 0;
    font-size: 0.88rem;
    font-weight: 600;
    line-height: 1.25;
  }

  .meaning {
    margin: 0.1rem 0 0;
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.3;
  }

  .table-wrap {
    overflow-x: auto;
    border: 1px solid var(--line);
    border-radius: 0.35rem;
  }

  .mapping-table {
    width: 100%;
    min-width: 58rem;
    border-collapse: collapse;
    font-size: 0.7rem;
    line-height: 1.25;
  }

  .mapping-table th,
  .mapping-table td {
    border-bottom: 1px solid var(--line);
    border-right: 1px solid var(--line);
    padding: 0.32rem 0.38rem;
    text-align: left;
    vertical-align: top;
  }

  .mapping-table th:last-child,
  .mapping-table td:last-child {
    border-right: 0;
  }

  .mapping-table tbody tr:last-child th,
  .mapping-table tbody tr:last-child td {
    border-bottom: 0;
  }

  .mapping-table thead th {
    background: var(--chip);
    font-weight: 650;
    white-space: nowrap;
  }

  .mapping-table thead th:first-child {
    min-width: 8rem;
  }

  .mapping-table tbody th {
    color: var(--lvl);
    font-weight: 600;
    min-width: 8rem;
    white-space: normal;
  }

  .mapping-table td {
    min-width: 6.5rem;
  }

  .footnote {
    margin: 0.75rem 0 0;
    font-size: 0.7rem;
    color: var(--muted);
    line-height: 1.35;
  }

  a {
    color: inherit;
  }
</style>
