      "de-de": 10,
      "jp-ja": 8,
      "uk-en": 11,
      "in-en": 9,
      "fr-fr": 10,
      "it-it": 10,
      "ru-ru": null,
      "br-pt": 10,
      "ca-en": 9,
      "ar-es": 12,
      "nl-nl": [11, 12],
      "cz-cs": null,
    },
  },
  {
    label: "Official relationship",
    levels: {
      "us-en": 10,
      "cn-zh": 10,
      "de-de": 11,
      "jp-ja": 9,
      "uk-en": 12,
      "in-en": 10,
      "fr-fr": 11,
      "it-it": 11,
      "ru-ru": [11, 12],
      "br-pt": 11,
      "ca-en": 10,
      "ar-es": 13,
      "nl-nl": 13,
      "cz-cs": 11,
    },
  },
  {
    label: "Partner / couple",
    levels: {
      "us-en": 11,
      "cn-zh": 11,
      "de-de": 12,
      "jp-ja": 10,
      "uk-en": 13,
      "in-en": 11,
      "fr-fr": 11,
      "it-it": 12,
      "ru-ru": 13,
      "br-pt": 12,
      "ca-en": 11,
      "ar-es": 14,
      "nl-nl": 14,
      "cz-cs": [12, 13],
    },
  },
  {
    label: "Living apart",
    levels: {
      "us-en": null,
      "cn-zh": null,
      "de-de": null,
      "jp-ja": null,
      "uk-en": null,
      "in-en": null,
      "fr-fr": null,
      "it-it": null,
      "ru-ru": null,
