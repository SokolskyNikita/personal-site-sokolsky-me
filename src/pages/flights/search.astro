---
import "../../styles/flights-search.css";
import { MAX_TOTAL_HOURS_OPTIONS } from "../../lib/flights/types";
import { DEFAULT_FORM } from "../../lib/flights/url";

export const prerender = true;

const pageTitle = "Flight search";
const pageDescription =
  "Find the cheapest one-way itineraries by cabin and lie-flat policy over the next two weeks.";
const themeColorLight = "#f7f6f3";
const themeColorDark = "#121412";
const siteUrl = (Astro.site?.toString() ?? "https://sokolsky.me").replace(
  /\/$/,
  "",
);
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const tomorrow = new Date();
tomorrow.setUTCDate(tomorrow.getUTCDate() + 1);
const defaultStart = tomorrow.toISOString().slice(0, 10);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle} · sokolsky.me</title>
    <meta name="description" content={pageDescription} />
    <meta name="theme-color" content={themeColorLight} />
    <meta
      name="theme-color"
      content={themeColorLight}
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content={themeColorDark}
      media="(prefers-color-scheme: dark)"
    />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600;650&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="fs-page" id="fs-app">
      <div class="fs-top">
        <h1 class="fs-title">Flight search</h1>
        <a class="fs-home" href="/">sokolsky.me</a>
      </div>

      <form class="fs-form" id="fs-form" onsubmit="return false;">
        <div class="fs-primary">
          <div class="fs-field fs-field-origin">
            <label for="fs-origin-reg">Origin</label>
            <div class="fs-loc">
              <select id="fs-origin-reg" data-registry aria-label="Origin location"></select>
              <input
                id="fs-origin-iata"
                type="text"
                maxlength="3"
                placeholder="IATA"
                aria-label="Origin IATA override"
                autocomplete="off"
                spellcheck="false"
              />
            </div>
          </div>

          <button type="button" class="fs-swap" id="fs-swap" title="Swap origin and destination" aria-label="Swap origin and destination">⇄</button>

          <div class="fs-field fs-field-destination">
            <label for="fs-dest-reg">Destination</label>
            <div class="fs-loc">
              <select id="fs-dest-reg" data-registry aria-label="Destination location"></select>
              <input
                id="fs-dest-iata"
                type="text"
                maxlength="3"
                placeholder="IATA"
                aria-label="Destination IATA override"
                autocomplete="off"
                spellcheck="false"
              />
            </div>
          </div>

          <div class="fs-field fs-field-mode">
            <label for="fs-mode">Cabin and seat</label>
            <select id="fs-mode"></select>
          </div>

          <div class="fs-field fs-field-date">
            <label for="fs-start">Start date</label>
            <input id="fs-start" type="date" value={defaultStart} />
          </div>
        </div>

        <div class="fs-secondary">
          <div class="fs-field fs-field-days">
            <label for="fs-days">Search window <span><strong id="fs-days-value">{DEFAULT_FORM.days}</strong> <span id="fs-days-unit">days</span></span></label>
            <input
              id="fs-days"
              type="range"
              min="1"
              max="14"
              value={String(DEFAULT_FORM.days)}
              aria-valuemin="1"
              aria-valuemax="14"
              aria-valuenow={String(DEFAULT_FORM.days)}
            />
          </div>

          <div class="fs-field">
            <label for="fs-max-stops">Max stops</label>
            <select id="fs-max-stops">
              <option value="1">1 stop</option>
              <option value="2">2 stops</option>
            </select>
          </div>

          <div class="fs-field">
            <label for="fs-max-hours">Max total hours</label>
            <select id="fs-max-hours">
              {
                MAX_TOTAL_HOURS_OPTIONS.map((hours) => (
                  <option
                    value={String(hours)}
                    selected={hours === DEFAULT_FORM.maxTotalHours}
                  >
                    {hours}h
                  </option>
                ))
              }
            </select>
          </div>

          <div class="fs-field">
            <label for="fs-topn">Results / date</label>
            <input id="fs-topn" type="number" min="1" max="20" value={String(DEFAULT_FORM.topN)} />
          </div>

          <div class="fs-toggles">
            <div class="fs-check-help">
              <label class="fs-check">
                <input id="fs-deep" type="checkbox" />
                <span>Deep search</span>
              </label>
              <div class="fs-help">
                <button
                  type="button"
                  aria-label="What deep search does"
                  aria-describedby="fs-deep-help"
                ></button>
                <div class="fs-help-popover" id="fs-deep-help" role="tooltip">
                  <strong>More complete, but slower.</strong>
                  <span>
                    Waits for Google Flights to load fully so results more closely
                    match the browser. It does not widen dates or airports or make
                    extra search calls.
                  </span>
                  <a
                    href="https://serpapi.com/google-flights-api"
                    target="_blank"
                    rel="noopener noreferrer">SerpApi docs ↗</a
                  >
                </div>
              </div>
            </div>
          </div>

          <div class="fs-actions">
            <button type="button" class="fs-btn fs-btn-primary" id="fs-run">Run search</button>
          </div>
        </div>
      </form>

      <div class="fs-status" aria-live="polite">
        <p class="fs-search-summary" id="fs-search-summary">
          Cached results are reused automatically.
        </p>
        <div id="fs-banners"></div>
        <p class="fs-progress" id="fs-progress"></p>
      </div>
      <div id="fs-results" aria-live="polite"></div>
      <div class="fs-footer-stats" id="fs-footer"></div>

      <div class="fs-search-progress" id="fs-search-progress" hidden>
        <div class="fs-search-progress-copy">
          <strong id="fs-search-progress-label">Preparing search</strong>
          <span id="fs-search-progress-count"></span>
        </div>
        <div
          class="fs-search-progress-track"
          id="fs-search-progress-track"
          role="progressbar"
          aria-label="Flight search progress"
          aria-valuemin="0"
          aria-valuemax="100"
        >
          <span id="fs-search-progress-fill"></span>
        </div>
      </div>
    </div>

    <script>
      import { mountFlightSearch } from "../../components/flights/search-app";
      const root = document.getElementById("fs-app");
      if (root) mountFlightSearch(root);
    </script>
  </body>
</html>
