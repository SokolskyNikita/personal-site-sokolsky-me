---
import "../../styles/flights-search.css";
import { MAX_TOTAL_HOURS_OPTIONS } from "../../lib/flights/types";
import { DEFAULT_FORM } from "../../lib/flights/url";

export const prerender = true;

const pageTitle = "Flight search";
const pageDescription =
  "Find the cheapest one-way itineraries by cabin and lie-flat policy over the next two weeks.";
const themeColorLight = "#f7f6f3";
const themeColorDark = "#121412";
const siteUrl = (Astro.site?.toString() ?? "https://sokolsky.me").replace(
  /\/$/,
  "",
);
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const defaultStart = new Date().toISOString().slice(0, 10);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle} · sokolsky.me</title>
    <meta name="description" content={pageDescription} />
    <meta name="theme-color" content={themeColorLight} />
    <meta
      name="theme-color"
      content={themeColorLight}
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content={themeColorDark}
      media="(prefers-color-scheme: dark)"
    />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600;650&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="fs-page" id="fs-app">
      <header class="fs-top">
        <div class="fs-heading">
          <span class="fs-eyebrow">Fare explorer</span>
          <h1 class="fs-title">Flight search</h1>
          <p>Compare the best itineraries across a flexible date range.</p>
        </div>
        <a class="fs-home" href="/">sokolsky.me</a>
      </header>

      <form class="fs-form" id="fs-form">
        <section class="fs-form-section" aria-labelledby="fs-route-heading">
          <header class="fs-section-heading">
            <h2 id="fs-route-heading">Route and dates</h2>
            <div class="fs-route-tools">
              <p>
                Choose an airport group (including Anywhere — the 125 busiest
                airports), or enter a specific IATA code. Anywhere cannot be
                used on both sides.
              </p>
              <label class="fs-check fs-custom-airports">
                <input
                  id="fs-custom-airports"
                  type="checkbox"
                  aria-controls="fs-origin-iata fs-dest-iata"
                  aria-expanded="false"
                />
                <span>Enter airport codes</span>
              </label>
            </div>
          </header>

          <div class="fs-primary">
            <div class="fs-field fs-field-origin">
              <label for="fs-origin-reg">Origin</label>
              <div class="fs-loc">
                <select id="fs-origin-reg" data-registry aria-label="Origin location"></select>
                <input
                  id="fs-origin-iata"
                  type="text"
                  maxlength="3"
                  placeholder="IATA"
                  aria-label="Origin IATA override"
                  autocomplete="off"
                  spellcheck="false"
                  hidden
                />
              </div>
            </div>

            <button type="button" class="fs-swap" id="fs-swap" title="Swap origin and destination" aria-label="Swap origin and destination">⇄</button>

            <div class="fs-field fs-field-destination">
              <label for="fs-dest-reg">Destination</label>
              <div class="fs-loc">
                <select id="fs-dest-reg" data-registry aria-label="Destination location"></select>
                <input
                  id="fs-dest-iata"
                  type="text"
                  maxlength="3"
                  placeholder="IATA"
                  aria-label="Destination IATA override"
                  autocomplete="off"
                  spellcheck="false"
                  hidden
                />
              </div>
            </div>

            <div class="fs-field fs-field-mode">
              <label for="fs-mode">Cabin and seat</label>
              <select id="fs-mode"></select>
            </div>

            <div class="fs-field fs-field-date">
              <label for="fs-start">Start date</label>
              <input id="fs-start" type="date" value={defaultStart} />
            </div>
          </div>
        </section>

        <section class="fs-form-section fs-form-section-options" aria-labelledby="fs-options-heading">
          <header class="fs-section-heading">
            <h2 id="fs-options-heading">Search preferences</h2>
            <p>Fine-tune the balance between speed and choice.</p>
          </header>

          <div class="fs-secondary">
          <div class="fs-field fs-field-days">
            <label for="fs-days">Date range <span><strong id="fs-days-value">{DEFAULT_FORM.days}</strong> <span id="fs-days-unit">days</span></span></label>
            <input
              id="fs-days"
              type="range"
              min="1"
              max="14"
              value={String(DEFAULT_FORM.days)}
              aria-valuemin="1"
              aria-valuemax="14"
              aria-valuenow={String(DEFAULT_FORM.days)}
            />
          </div>

          <div class="fs-field">
            <label for="fs-max-stops">Max stops</label>
            <select id="fs-max-stops">
              <option value="0">0 stops</option>
              <option value="1">1 stop</option>
              <option value="2">2 stops</option>
            </select>
          </div>

          <div class="fs-field">
            <label for="fs-max-hours">Max total hours</label>
            <select id="fs-max-hours">
              {
                MAX_TOTAL_HOURS_OPTIONS.map((hours) => (
                  <option
                    value={String(hours)}
                    selected={hours === DEFAULT_FORM.maxTotalHours}
                  >
                    {hours}h
                  </option>
                ))
              }
            </select>
          </div>

          <div class="fs-field">
            <label for="fs-topn">Flights per date</label>
            <input id="fs-topn" type="number" min="1" max="20" value={String(DEFAULT_FORM.topN)} />
          </div>

          <div class="fs-field">
            <span class="fs-field-label" id="fs-currency-label">Currency</span>
            <div
              class="fs-currency-toggle"
              role="radiogroup"
              aria-labelledby="fs-currency-label"
            >
              <label class="fs-currency-option">
                <input
                  type="radio"
                  name="fs-currency"
                  value="USD"
                  checked={DEFAULT_FORM.currency === "USD"}
                />
                <span>USD</span>
              </label>
              <label class="fs-currency-option">
                <input
                  type="radio"
                  name="fs-currency"
                  value="EUR"
                  checked={DEFAULT_FORM.currency === "EUR"}
                />
                <span>EUR</span>
              </label>
              <label class="fs-currency-option">
                <input
                  type="radio"
                  name="fs-currency"
                  value="GBP"
                  checked={DEFAULT_FORM.currency === "GBP"}
                />
                <span>GBP</span>
              </label>
            </div>
          </div>

          <div class="fs-toggles">
            <label class="fs-check">
              <input id="fs-round-trip" type="checkbox" />
              <span>Round trip</span>
            </label>
            <div class="fs-trip-controls" id="fs-trip-controls" hidden>
              <div class="fs-field fs-trip-length">
                <label for="fs-trip-length">Return after</label>
                <select id="fs-trip-length">
                  {[3, 5, 7, 10, 14, 21, 28, 45, 60, 85].map((days) => (
                    <option
                      value={String(days)}
                      selected={days === DEFAULT_FORM.tripLengthDays}
                    >
                      {days} {days === 1 ? "day" : "days"}
                    </option>
                  ))}
                </select>
              </div>
              <label
                class="fs-check fs-trip-flex"
                title="Search return dates up to five days before and after the selected trip length"
              >
                <input id="fs-flexible-trip-length" type="checkbox" />
                <span>± 5 days</span>
              </label>
            </div>
          </div>

          <div class="fs-actions">
            <button type="submit" class="fs-btn fs-btn-primary" id="fs-run">Search flights</button>
            <button type="button" class="fs-btn" id="fs-cancel" hidden>
              Cancel
            </button>
          </div>
          </div>
        </section>
      </form>

      <div class="fs-status" aria-live="polite">
        <p class="fs-search-summary" id="fs-search-summary">
          Ready to search. Cached results are reused automatically.
        </p>
        <div id="fs-banners"></div>
        <p class="fs-progress" id="fs-progress"></p>
      </div>
      <div class="fs-results-toolbar" id="fs-results-toolbar" hidden>
        <label class="fs-check fs-group-city">
          <input id="fs-group-city" type="checkbox" />
          <span>Group by city</span>
        </label>
        <div class="fs-city-side" id="fs-city-side-wrap" hidden>
          <label for="fs-city-side">City side</label>
          <select id="fs-city-side">
            <option value="departure" selected>Departure</option>
            <option value="arrival">Arrival</option>
          </select>
        </div>
        <div class="fs-city-sort" id="fs-city-sort-wrap" hidden>
          <label for="fs-city-sort">Sort cities</label>
          <select id="fs-city-sort">
            <option value="cheapest_city" selected>Cheapest city</option>
            <option value="price_per_distance">$/distance</option>
            <option value="distance">Distance</option>
            <option value="alpha">A–Z</option>
          </select>
        </div>
        <label for="fs-sort">Sort days</label>
        <select id="fs-sort">
          <option value="date">By date</option>
          <option value="cheapest_day" selected>Cheapest day</option>
        </select>
      </div>
      <div id="fs-results" aria-live="polite"></div>
      <p class="fs-trust-note">
        Seat details are reported by Google Flights. Airlines can substitute
        aircraft, so confirm the seat product before booking.
      </p>
      <div class="fs-footer-stats" id="fs-footer"></div>

      <div class="fs-search-progress" id="fs-search-progress" hidden>
        <div class="fs-search-progress-copy">
          <strong id="fs-search-progress-label">Preparing search</strong>
          <span id="fs-search-progress-count"></span>
        </div>
        <div
          class="fs-search-progress-track"
          id="fs-search-progress-track"
          role="progressbar"
          aria-label="Flight search progress"
          aria-valuemin="0"
          aria-valuemax="100"
        >
          <span id="fs-search-progress-fill"></span>
        </div>
      </div>
    </div>

    <script>
      import { mountFlightSearch } from "../../components/flights/search-app";
      const root = document.getElementById("fs-app");
      if (root) mountFlightSearch(root);
    </script>
  </body>
</html>
