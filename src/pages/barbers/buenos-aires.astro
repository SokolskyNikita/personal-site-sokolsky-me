---
import pageData from "../../data/barbers-buenos-aires.json";

export const prerender = true;

const pageTitle = "Best barbershops in Buenos Aires with online booking";
const pageDescription =
  "Buenos Aires barbershops with verified non-WhatsApp online booking, checked against Google Maps with ratings, hours, addresses, prices in USD and official links.";
const themeColorLight = "#f7f2ea";
const themeColorDark = "#111111";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
type Barber = (typeof pageData.barbers)[number];
const barbersWithoutOnlineBooking = new Set<string>([
  "la-cueva",
  "barberin",
  "hacha-brava-nunez",
  "hacha-brava-san-telmo",
  "jf-barbershop",
  "le-place",
  "the-respect",
  "la-mint",
]);
const barbers = pageData.barbers.filter(
  (barber: Barber) => !barbersWithoutOnlineBooking.has(barber.id),
);
const updatedDate = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
}).format(new Date(pageData.generatedAt));
const formatter = new Intl.NumberFormat("en-US", {
  maximumFractionDigits: 0,
});
const arsPerUsd = 1525;
const usdFormatter = new Intl.NumberFormat("en-US", {
  style: "currency",
  currency: "USD",
  maximumFractionDigits: 0,
});
const usdPriceLabel = (ars: number | undefined) =>
  typeof ars === "number" ? usdFormatter.format(Math.round(ars / arsPerUsd)) : "Not published";
const collator = new Intl.Collator("en", {
  sensitivity: "base",
  numeric: true,
});
const neighborhoodCounts = barbers.reduce((counts, barber: Barber) => {
  counts.set(barber.neighborhood, (counts.get(barber.neighborhood) ?? 0) + 1);
  return counts;
}, new Map<string, number>());
const neighborhoodOptions = [...neighborhoodCounts.entries()]
  .sort(
    ([nameA, countA], [nameB, countB]) =>
      countB - countA || collator.compare(nameA, nameB),
  )
  .map(([name, count]) => ({ name, count }));
const openSundayCount = barbers.filter((barber: Barber) => barber.openSunday).length;
const pricedCount = barbers.filter((barber: Barber) => barber.price.status === "published").length;
const priceValue = (barber: Barber) =>
  typeof barber.price.ars === "number" ? barber.price.ars : Number.MAX_SAFE_INTEGER;
const sortRank = (
  items: Barber[],
  compare: (a: Barber, b: Barber) => number,
) =>
  new Map<string, number>(
    items
      .toSorted(compare)
      .map((barber: Barber, index: number) => [barber.id, index + 1]),
  );
const nameRanks = sortRank(barbers, (a: Barber, b: Barber) =>
  collator.compare(a.name, b.name),
);
const ratingRanks = sortRank(
  barbers,
  (a: Barber, b: Barber) =>
    b.rating - a.rating ||
    b.reviewCount - a.reviewCount ||
    collator.compare(a.name, b.name),
);
const priceRanks = sortRank(
  barbers,
  (a: Barber, b: Barber) =>
    priceValue(a) - priceValue(b) ||
    b.rating - a.rating ||
    collator.compare(a.name, b.name),
);
const popularityRanks = sortRank(
  barbers,
  (a: Barber, b: Barber) =>
    b.reviewCount - a.reviewCount ||
    b.rating - a.rating ||
    collator.compare(a.name, b.name),
);
const barbersWithSort = barbers.map((barber: Barber) => ({
  ...barber,
  reviewCountLabel: formatter.format(barber.reviewCount),
  displayPriceLabel: usdPriceLabel(barber.price.ars),
  priceTitle: `Source: ${barber.price.source}. Converted from the published shop price.`,
  sortOrderStyle: [
    `--sort-price: ${priceRanks.get(barber.id)}`,
    `--sort-name: ${nameRanks.get(barber.id)}`,
    `--sort-rating: ${ratingRanks.get(barber.id)}`,
    `--sort-popularity: ${popularityRanks.get(barber.id)}`,
  ].join("; "),
}));
const googleMapsApiKey =
  import.meta.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
  process.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
  "";
const barberMapData = barbers.map((barber: Barber) => ({
  id: barber.id,
  name: barber.name,
  googleMapsUrl: barber.googleMapsUrl,
  neighborhood: barber.neighborhood,
  openSunday: barber.openSunday,
  position: barber.location,
}));
const mapsIcon = `<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="#1a73e8" d="M12 2.2c3.9 0 7.1 3.1 7.1 7 0 5.1-7.1 12.6-7.1 12.6S4.9 14.3 4.9 9.2c0-3.9 3.2-7 7.1-7Z"/><path fill="#34a853" d="M7.2 14.1 12 21.8l4.8-7.7-4.8-2.8-4.8 2.8Z"/><path fill="#fbbc04" d="M4.9 9.2c0 1.8.9 3.5 2.3 4.9l4.8-2.8V2.2c-3.9 0-7.1 3.1-7.1 7Z"/><path fill="#ea4335" d="M19.1 9.2c0 1.8-.9 3.5-2.3 4.9L12 11.3V2.2c3.9 0 7.1 3.1 7.1 7Z"/><circle cx="12" cy="9.3" r="2.45" fill="#fff"/></svg>`;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  numberOfItems: barbers.length,
  itemListElement: barbers.map((barber, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "LocalBusiness",
      additionalType: "https://schema.org/BarberShop",
      name: barber.name,
      url: barber.officialUrl,
      sameAs: barber.googleMapsUrl,
      address: barber.fullAddress,
      geo: {
        "@type": "GeoCoordinates",
        latitude: barber.location.lat,
        longitude: barber.location.lng,
      },
      aggregateRating: {
        "@type": "AggregateRating",
        ratingValue: barber.rating.toFixed(1),
        ratingCount: barber.reviewCount,
      },
      ...(barber.price.status === "published"
        ? { priceRange: usdPriceLabel(barber.price.ars) }
        : {}),
    },
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="subject" content="Best barbershops in Buenos Aires with online booking" />
    <meta name="application-name" content={pageTitle} />
    <meta
      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="googlebot"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="keywords"
      content="Buenos Aires barbershops, best barbershops Buenos Aires, barbería Buenos Aires, online booking barber Buenos Aires, barber Palermo, barber Recoleta"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta
      name="theme-color"
      content={themeColorLight}
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content={themeColorDark}
      media="(prefers-color-scheme: dark)"
    />
    <meta name="msapplication-TileColor" content={themeColorDark} />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color={themeColorDark} />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Nikita Sokolsky" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <main class="page">
      <header class="page-header">
        <a class="home-link" href="/">Nikita Sokolsky</a>
        <div class="headline">
          <p class="eyebrow">Buenos Aires guide</p>
          <h1>{pageTitle}</h1>
          <p class="intro">
            {barbers.length} barbershops listed as open in Google Maps with at least 25 reviews, a published standalone men's haircut price, and verified online booking. WhatsApp-only booking does not count.
          </p>
        </div>
        <div class="toolbar" aria-label="Barbershop controls">
          <fieldset class="sort-toggle">
            <legend>Sort by</legend>
            <input id="sort-price" type="radio" name="sort" autocomplete="off" checked />
            <label for="sort-price">Price</label>
            <input id="sort-name" type="radio" name="sort" autocomplete="off" />
            <label for="sort-name">Name</label>
            <input id="sort-rating" type="radio" name="sort" autocomplete="off" />
            <label for="sort-rating">GMaps rating</label>
            <input id="sort-popularity" type="radio" name="sort" autocomplete="off" />
            <label for="sort-popularity">Popularity</label>
          </fieldset>
          <fieldset class="extras-toggle">
            <legend>Filter</legend>
            <input id="filter-open-sunday" type="checkbox" autocomplete="off" />
            <label for="filter-open-sunday">Open on Sundays ({openSundayCount})</label>
          </fieldset>
          <label class="filter-dropdown" for="neighborhood-filter">
            <span>Neighborhood</span>
            <select id="neighborhood-filter" name="neighborhood" autocomplete="off">
              <option value="">All ({barbers.length})</option>
              {neighborhoodOptions.map((option) => (
                <option value={option.name}>{option.name} ({option.count})</option>
              ))}
            </select>
          </label>
          <p class="meta">
            Updated {updatedDate}. Only shops with non-WhatsApp online booking are listed. Prices are shown in USD for a standard men's cut, unless a promo or cash price is labeled.
          </p>
        </div>
      </header>

      <section class="barber-list" aria-label="Buenos Aires barbershops">
        <div class="barber-row barber-head" aria-hidden="true">
          <span>Barbershop</span>
          <span>Map</span>
          <span>Address</span>
          <span>Price</span>
          <span>Hours</span>
          <span>GMaps rating</span>
          <span>Description</span>
        </div>

        {barbersWithSort.map((barber) => (
          <article
            class="barber-row"
            style={barber.sortOrderStyle}
            data-neighborhood={barber.neighborhood}
            data-open-sunday={String(barber.openSunday)}
          >
            <h2 class="barber-name">
              <a href={barber.officialUrl} target="_blank" rel="noreferrer noopener">
                {barber.name}
              </a>
            </h2>
            <div class="map-actions">
              <a
                class="maps-link"
                href={barber.googleMapsUrl}
                target="_blank"
                rel="noreferrer noopener"
                aria-label={`Open ${barber.name} on Google Maps`}
                title={`Open ${barber.name} on Google Maps`}
              >
                <span class="maps-icon" set:html={mapsIcon} />
              </a>
            </div>
            <p class="address">{barber.address}</p>
            <p
              class={`price ${barber.price.status === "published" ? "" : "price-unpublished"}`}
              title={barber.priceTitle}
            >
              <span class="price-label">{barber.displayPriceLabel}</span>
              {barber.price.primaryService && (
                <span class="price-service">{barber.price.primaryService}</span>
              )}
            </p>
            <p class="hours">{barber.hours}</p>
            <p
              class="rating"
              aria-label={`${barber.rating.toFixed(1)} Google Maps rating from ${barber.reviewCountLabel} ratings`}
            >
              <span class="rating-score">{barber.rating.toFixed(1)}</span>
              <span class="review-count">{barber.reviewCountLabel} ratings</span>
            </p>
            <p class="description">{barber.description}</p>
          </article>
        ))}
      </section>

      <section class="barber-map-section" aria-labelledby="barber-map-heading">
        <div class="map-copy">
          <p class="eyebrow">Map</p>
          <h2 id="barber-map-heading">Buenos Aires barbershop map</h2>
          <p id="barber-map-status" class="map-status">
            Showing all {barbers.length} barbershops.
          </p>
        </div>
        {googleMapsApiKey ? (
          <div
            id="barber-map"
            class="barber-map"
            aria-label="Google Map with pins for Buenos Aires barbershops"
          ></div>
        ) : (
          <p class="map-unavailable">
            Map unavailable because the Google Maps public key is not configured.
          </p>
        )}
      </section>
    </main>
  </body>
</html>

<script is:inline define:vars={{ googleMapsApiKey, barberMapData }}>
  if (googleMapsApiKey) {
    ((g) => {
      let h;
      let a;
      let k;
      const p = "The Google Maps JavaScript API";
      const c = "google";
      const l = "importLibrary";
      const q = "__ib__";
      const m = document;
      let b = window;
      b = b[c] || (b[c] = {});
      const d = b.maps || (b.maps = {});
      const r = new Set();
      const e = new URLSearchParams();
      const u = () =>
        h ||
        (h = new Promise(async (resolve, reject) => {
          await (a = m.createElement("script"));
          e.set("libraries", [...r] + "");
          for (k in g) {
            e.set(k.replace(/[A-Z]/g, (t) => `_${t[0].toLowerCase()}`), g[k]);
          }
          e.set("callback", `${c}.maps.${q}`);
          a.src = `https://maps.${c}apis.com/maps/api/js?${e}`;
          d[q] = resolve;
          a.onerror = () => (h = reject(Error(`${p} could not load.`)));
          a.nonce = m.querySelector("script[nonce]")?.nonce || "";
          m.head.append(a);
        }));
      d[l] ? console.warn(`${p} only loads once. Ignoring:`, g) : (d[l] = (f, ...n) => r.add(f) && u().then(() => d[l](f, ...n)));
    })({
      key: googleMapsApiKey,
      v: "weekly",
    });
  }

  const neighborhoodFilter = document.querySelector("#neighborhood-filter");
  const openSundayFilter = document.querySelector("#filter-open-sunday");
  const defaultSort = document.querySelector("#sort-price");
  const barberRows = [...document.querySelectorAll(".barber-row:not(.barber-head)")];
  const mapElement = document.querySelector("#barber-map");
  const mapStatus = document.querySelector("#barber-map-status");
  const buenosAiresCenter = { lat: -34.6037, lng: -58.3816 };
  const filterUrlParams = ["neighborhood", "openSunday"];
  const markerRecords = [];
  let barberMap;
  let infoWindow;

  const escapeHtml = (value) =>
    String(value).replace(/[&<>"']/g, (character) => ({
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#39;",
    })[character]);

  const getVisibleBarbers = (selectedNeighborhood, openSundayOnly) =>
    barberMapData.filter(
      (barber) =>
        (!selectedNeighborhood || barber.neighborhood === selectedNeighborhood) &&
        (!openSundayOnly || barber.openSunday),
    );

  const updateMapStatus = (selectedNeighborhood, openSundayOnly) => {
    if (!mapStatus) return;

    const visibleCount = getVisibleBarbers(selectedNeighborhood, openSundayOnly).length;
    const barberLabel = visibleCount === 1 ? "barbershop" : "barbershops";
    const sundaySuffix = openSundayOnly ? " open on Sundays" : "";
    mapStatus.textContent = selectedNeighborhood
      ? `Showing ${visibleCount} ${selectedNeighborhood} ${barberLabel}${sundaySuffix}.`
      : `Showing ${openSundayOnly ? "" : "all "}${visibleCount} ${barberLabel}${sundaySuffix}.`;
  };

  const fitMapToMarkers = (visibleRecords) => {
    if (!barberMap || !window.google?.maps || visibleRecords.length === 0) return;

    if (visibleRecords.length === 1) {
      barberMap.setCenter(visibleRecords[0].barber.position);
      barberMap.setZoom(14);
      return;
    }

    const bounds = new google.maps.LatLngBounds();

    for (const { barber } of visibleRecords) {
      bounds.extend(barber.position);
    }

    barberMap.fitBounds(bounds, 44);
  };

  const syncMapMarkers = (selectedNeighborhood, openSundayOnly) => {
    updateMapStatus(selectedNeighborhood, openSundayOnly);

    if (!barberMap) return;

    const visibleIds = new Set(
      getVisibleBarbers(selectedNeighborhood, openSundayOnly).map((barber) => barber.id),
    );
    const visibleRecords = [];

    for (const record of markerRecords) {
      const isVisible = visibleIds.has(record.barber.id);
      record.marker.setMap(isVisible ? barberMap : null);
      if (isVisible) visibleRecords.push(record);
    }

    if (mapElement) mapElement.dataset.visiblePins = String(visibleRecords.length);

    fitMapToMarkers(visibleRecords);
  };

  const updateFilterUrl = (selectedNeighborhood, openSundayOnly) => {
    const url = new URL(window.location.href);

    for (const paramName of filterUrlParams) {
      url.searchParams.delete(paramName);
    }

    if (selectedNeighborhood) url.searchParams.set("neighborhood", selectedNeighborhood);
    if (openSundayOnly) url.searchParams.set("openSunday", "1");

    const nextUrl = `${url.pathname}${url.search}${url.hash}`;
    const currentUrl = `${window.location.pathname}${window.location.search}${window.location.hash}`;

    if (nextUrl !== currentUrl) {
      window.history.replaceState(null, "", nextUrl);
    }
  };

  const initBarberMap = async () => {
    if (!mapElement || !googleMapsApiKey || !window.google?.maps?.importLibrary) return;

    const { Map, InfoWindow } = await google.maps.importLibrary("maps");
    await google.maps.importLibrary("marker");

    barberMap = new Map(mapElement, {
      center: buenosAiresCenter,
      clickableIcons: false,
      fullscreenControl: true,
      mapTypeControl: false,
      streetViewControl: false,
      zoom: 12,
    });
    infoWindow = new InfoWindow();

    for (const barber of barberMapData) {
      const marker = new google.maps.Marker({
        map: barberMap,
        position: barber.position,
        title: barber.name,
      });

      marker.addListener("click", () => {
        infoWindow.setContent(
          `<strong>${escapeHtml(barber.name)}</strong><br><a href="${escapeHtml(barber.googleMapsUrl)}" target="_blank" rel="noreferrer noopener">Open in Google Maps</a>`,
        );
        infoWindow.open(barberMap, marker);
      });

      markerRecords.push({ barber, marker });
    }

    syncMapMarkers(
      neighborhoodFilter?.value ?? "",
      openSundayFilter?.checked ?? false,
    );
  };

  const applyFilters = ({ syncUrl = true } = {}) => {
    const selectedNeighborhood = neighborhoodFilter?.value ?? "";
    const openSundayOnly = openSundayFilter?.checked ?? false;

    if (syncUrl) {
      updateFilterUrl(selectedNeighborhood, openSundayOnly);
    }

    for (const row of barberRows) {
      const neighborhoodMismatch =
        Boolean(selectedNeighborhood) && row.dataset.neighborhood !== selectedNeighborhood;
      const sundayMismatch = openSundayOnly && row.dataset.openSunday !== "true";
      row.hidden = neighborhoodMismatch || sundayMismatch;
    }

    syncMapMarkers(selectedNeighborhood, openSundayOnly);
  };

  const resetControls = () => {
    if (defaultSort) defaultSort.checked = true;
    if (neighborhoodFilter) neighborhoodFilter.value = "";
    if (openSundayFilter) openSundayFilter.checked = false;
  };

  const setSelectFromUrl = (selectElement, value) => {
    if (!selectElement || !value) return;

    const hasOption = [...selectElement.options].some((option) => option.value === value);
    if (hasOption) selectElement.value = value;
  };

  const hasEnabledUrlParam = (params, paramName) => {
    const value = params.get(paramName);
    if (value === null) return false;

    return !["0", "false", "no", "off"].includes(value.toLowerCase());
  };

  const applyFiltersFromUrl = () => {
    const params = new URLSearchParams(window.location.search);

    resetControls();
    setSelectFromUrl(neighborhoodFilter, params.get("neighborhood"));
    if (openSundayFilter) openSundayFilter.checked = hasEnabledUrlParam(params, "openSunday");

    applyFilters({ syncUrl: false });
  };

  neighborhoodFilter?.addEventListener("change", applyFilters);
  openSundayFilter?.addEventListener("change", applyFilters);
  applyFiltersFromUrl();
  window.addEventListener("pageshow", applyFiltersFromUrl);
  window.addEventListener("popstate", applyFiltersFromUrl);
  initBarberMap().catch((error) => {
    console.error("Unable to initialize barbershop map", error);
    if (mapStatus) mapStatus.textContent = "Map unavailable. Barbershop list still works.";
  });
</script>

<style>
  :root {
    color-scheme: light dark;
    --bg: #f7f2ea;
    --surface: #fffdf8;
    --surface-soft: #efe7db;
    --text: #181612;
    --text-muted: #6f675c;
    --border: #d9cfc0;
    --border-strong: #c8baa8;
    --accent: #28402f;
    --accent-soft: #dfe8d7;
    --link: #17281d;
    --shadow: 0 20px 60px rgba(61, 44, 22, 0.08);
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #10100e;
      --surface: #171613;
      --surface-soft: #211f1a;
      --text: #f2eee7;
      --text-muted: #aaa297;
      --border: #343027;
      --border-strong: #4a4338;
      --accent: #dce8d2;
      --accent-soft: #263022;
      --link: #f6f1e8;
      --shadow: none;
    }
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    font-size: 16px;
    background: var(--bg);
    color: var(--text);
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at 15% 0%, color-mix(in srgb, var(--accent-soft), transparent 35%), transparent 32rem),
      var(--bg);
  }

  a {
    color: var(--link);
    text-decoration-color: color-mix(in srgb, var(--link), transparent 62%);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
  }

  a:hover {
    text-decoration-color: currentColor;
  }

  .page {
    width: min(100%, 88rem);
    margin: 0 auto;
    padding: clamp(0.8rem, 2vw, 2rem);
  }

  .page-header {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(0.75rem, 2vw, 1.35rem);
    align-items: start;
    padding: clamp(0.85rem, 2.2vw, 1.8rem) 0 clamp(0.75rem, 2vw, 1.35rem);
  }

  .home-link {
    grid-column: 1 / -1;
    width: fit-content;
    color: var(--text-muted);
    font-size: 0.92rem;
    text-decoration: none;
  }

  .home-link:hover {
    color: var(--text);
  }

  .headline {
    display: grid;
    gap: 0.5rem;
