---
import pageData from "../../data/car-rental-ba-options.json";

export const prerender = true;

const pageTitle = "Car rental options in Buenos Aires";
const pageDescription =
  "Buenos Aires car rental desks open Sundays per Google Maps, with online booking, approximate all-in smallest-SUV day rates in USD, hours, addresses, and a map.";
const themeColorLight = "#eef3f7";
const themeColorDark = "#0d1419";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
type Rental = (typeof pageData.rentals)[number];
const rentals = pageData.rentals;
const airportExceptionMinReviews =
  pageData.validation.airportBrandException?.minReviewCount ?? 15;
const airportExceptionCount = rentals.filter(
  (rental: Rental) => rental.reviewTier === "airport-exception",
).length;
const updatedDate = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
}).format(new Date(pageData.generatedAt));
const formatter = new Intl.NumberFormat("en-US", {
  maximumFractionDigits: 0,
});
const exchangeRateLabel = `1 USD ≈ ARS ${formatter.format(
  pageData.currency.arsPerUsd,
)}`;
const collator = new Intl.Collator("en", {
  sensitivity: "base",
  numeric: true,
});
const suvPriceSortValue = (rental: Rental) => {
  if (rental.suvDayRate?.status === "quoted" && rental.suvDayRate.usd != null) {
    return rental.suvDayRate.usd;
  }
  return Number.MAX_SAFE_INTEGER;
};
const neighborhoodCounts = rentals.reduce((counts, rental: Rental) => {
  counts.set(rental.neighborhood, (counts.get(rental.neighborhood) ?? 0) + 1);
  return counts;
}, new Map<string, number>());
const neighborhoodOptions = [...neighborhoodCounts.entries()]
  .sort(
    ([nameA, countA], [nameB, countB]) =>
      countB - countA || collator.compare(nameA, nameB),
  )
  .map(([name, count]) => ({ name, count }));
const brandCounts = rentals.reduce((counts, rental: Rental) => {
  counts.set(rental.brand, (counts.get(rental.brand) ?? 0) + 1);
  return counts;
}, new Map<string, number>());
const brandOptions = [...brandCounts.entries()]
  .sort(
    ([nameA, countA], [nameB, countB]) =>
      countB - countA || collator.compare(nameA, nameB),
  )
  .map(([name, count]) => ({ name, count }));
const airportCount = rentals.filter((rental: Rental) => rental.area === "airport").length;
const cityCount = rentals.filter((rental: Rental) => rental.area === "city").length;
const sortRank = (
  items: Rental[],
  compare: (a: Rental, b: Rental) => number,
) =>
  new Map<string, number>(
    items
      .toSorted(compare)
      .map((rental: Rental, index: number) => [rental.id, index + 1]),
  );
const nameRanks = sortRank(rentals, (a: Rental, b: Rental) =>
  collator.compare(a.name, b.name),
);
const ratingRanks = sortRank(
  rentals,
  (a: Rental, b: Rental) =>
    b.rating - a.rating ||
    b.reviewCount - a.reviewCount ||
    collator.compare(a.name, b.name),
);
const popularityRanks = sortRank(
  rentals,
  (a: Rental, b: Rental) =>
    b.reviewCount - a.reviewCount ||
    b.rating - a.rating ||
    collator.compare(a.name, b.name),
);
const priceRanks = sortRank(
  rentals,
  (a: Rental, b: Rental) =>
    suvPriceSortValue(a) - suvPriceSortValue(b) ||
    b.reviewCount - a.reviewCount ||
    collator.compare(a.name, b.name),
);
const rentalsWithSort = rentals.map((rental: Rental) => {
  const rate = rental.suvDayRate;
  const priceTitle =
    rate?.status === "quoted"
      ? `${rate.usdLabel}/day · ${rate.arsLabel}/day · ${rate.exampleVehicle ?? "smallest SUV"} · ${rate.note}`
      : (rate?.note ?? "No public all-in SUV day rate found");
  return {
    ...rental,
    reviewCountLabel: formatter.format(rental.reviewCount),
    officialLabel: "Book",
    areaLabel: rental.area === "airport" ? "Airport" : "City",
    priceLabel: rate?.usdLabel ?? "—",
    priceSubLabel: "SUV / day",
    priceTitle,
    sortOrderStyle: [
      `--sort-popularity: ${popularityRanks.get(rental.id)}`,
      `--sort-rating: ${ratingRanks.get(rental.id)}`,
      `--sort-price: ${priceRanks.get(rental.id)}`,
      `--sort-name: ${nameRanks.get(rental.id)}`,
    ].join("; "),
  };
});
const googleMapsApiKey =
  import.meta.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
  process.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
  "";
const rentalMapData = rentals.map((rental: Rental) => ({
  id: rental.id,
  name: rental.name,
  googleMapsUrl: rental.googleMapsUrl,
  neighborhood: rental.neighborhood,
  brand: rental.brand,
  area: rental.area,
  position: rental.location,
}));
const mapsIcon = `<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="#1a73e8" d="M12 2.2c3.9 0 7.1 3.1 7.1 7 0 5.1-7.1 12.6-7.1 12.6S4.9 14.3 4.9 9.2c0-3.9 3.2-7 7.1-7Z"/><path fill="#34a853" d="M7.2 14.1 12 21.8l4.8-7.7-4.8-2.8-4.8 2.8Z"/><path fill="#fbbc04" d="M4.9 9.2c0 1.8.9 3.5 2.3 4.9l4.8-2.8V2.2c-3.9 0-7.1 3.1-7.1 7Z"/><path fill="#ea4335" d="M19.1 9.2c0 1.8-.9 3.5-2.3 4.9L12 11.3V2.2c3.9 0 7.1 3.1 7.1 7Z"/><circle cx="12" cy="9.3" r="2.45" fill="#fff"/></svg>`;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  numberOfItems: rentals.length,
  itemListElement: rentals.map((rental, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "AutoRental",
      name: rental.name,
      url: rental.officialUrl,
      sameAs: rental.googleMapsUrl,
      address: rental.fullAddress,
      geo: {
        "@type": "GeoCoordinates",
        latitude: rental.location.lat,
        longitude: rental.location.lng,
      },
      aggregateRating: {
        "@type": "AggregateRating",
        ratingValue: rental.rating.toFixed(1),
        ratingCount: rental.reviewCount,
      },
    },
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="subject" content="Car rental options in Buenos Aires" />
    <meta name="application-name" content={pageTitle} />
    <meta
      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="googlebot"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="keywords"
      content="Buenos Aires car rental, alquiler de autos Buenos Aires, rent a car Buenos Aires, Hertz Ezeiza, Aeroparque car rental, open Sunday car hire BA"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta
      name="theme-color"
      content={themeColorLight}
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content={themeColorDark}
      media="(prefers-color-scheme: dark)"
    />
    <meta name="msapplication-TileColor" content={themeColorDark} />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color={themeColorDark} />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Nikita Sokolsky" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <main class="page">
      <header class="page-header">
        <a class="home-link" href="/">Nikita Sokolsky</a>
        <div class="headline">
          <p class="eyebrow">Buenos Aires guide</p>
          <h1>{pageTitle}</h1>
          <p class="intro">
            {rentals.length} Sunday-open desks with online booking. {rentals.length - airportExceptionCount} have {pageData.validation.minReviewCount}+ Maps reviews; {airportExceptionCount} Avis/Budget/Alamo airport desks from {airportExceptionMinReviews}+.
          </p>
        </div>
        <div class="toolbar" aria-label="Car rental controls">
          <fieldset class="sort-toggle">
            <legend>Sort by</legend>
            <input id="sort-popularity" type="radio" name="sort" autocomplete="off" checked />
            <label for="sort-popularity">GMaps reviews count</label>
            <input id="sort-rating" type="radio" name="sort" autocomplete="off" />
            <label for="sort-rating">GMaps reviews score</label>
            <input id="sort-price" type="radio" name="sort" autocomplete="off" />
            <label for="sort-price">SUV day price</label>
            <input id="sort-name" type="radio" name="sort" autocomplete="off" />
            <label for="sort-name">Name</label>
          </fieldset>
          <fieldset class="extras-toggle">
            <legend>Filter</legend>
            <input id="filter-airport" type="checkbox" autocomplete="off" />
            <label for="filter-airport">Airport ({airportCount})</label>
            <input id="filter-city" type="checkbox" autocomplete="off" />
            <label for="filter-city">City ({cityCount})</label>
          </fieldset>
          <label class="filter-dropdown" for="neighborhood-filter">
            <span>Neighborhood</span>
            <select id="neighborhood-filter" name="neighborhood" autocomplete="off">
              <option value="">All ({rentals.length})</option>
              {neighborhoodOptions.map((option) => (
                <option value={option.name}>{option.name} ({option.count})</option>
              ))}
            </select>
          </label>
          <label class="filter-dropdown" for="brand-filter">
            <span>Brand</span>
            <select id="brand-filter" name="brand" autocomplete="off">
              <option value="">All ({rentals.length})</option>
              {brandOptions.map((option) => (
                <option value={option.name}>{option.name} ({option.count})</option>
              ))}
            </select>
          </label>
          <p class="meta">
            Updated {updatedDate}. {exchangeRateLabel}. SUV prices are approximate 1-day all-in quotes for each brand’s smallest SUV class; deposits/franchise usually extra.
          </p>
        </div>
      </header>

      <section class="rental-list" aria-label="Buenos Aires car rental options">
        <div class="rental-row rental-head" aria-hidden="true">
          <span>Rental desk</span>
          <span>Map</span>
          <span>Address</span>
          <span>Booking</span>
          <span>Hours</span>
          <span>SUV / day</span>
          <span>GMaps rating</span>
          <span>Notes</span>
        </div>

        {rentalsWithSort.map((rental) => (
          <article
            class="rental-row"
            style={rental.sortOrderStyle}
            data-neighborhood={rental.neighborhood}
            data-brand={rental.brand}
            data-area={rental.area}
          >
            <h2 class="rental-name">
              <a href={rental.officialUrl} target="_blank" rel="noreferrer noopener">
                {rental.name}
              </a>
              <span>
                {rental.areaLabel} · {rental.officialLabel}
                {rental.reviewTier === "airport-exception" ? " · 15+ reviews" : ""}
              </span>
            </h2>
            <div class="map-actions">
              <a
                class="maps-link"
                href={rental.googleMapsUrl}
                target="_blank"
                rel="noreferrer noopener"
                aria-label={`Open ${rental.name} on Google Maps`}
                title={`Open ${rental.name} on Google Maps`}
              >
                <span class="maps-icon" set:html={mapsIcon} />
              </a>
            </div>
            <p class="address">{rental.address}</p>
            <p class="service-proof" title={rental.onlineBooking.quote}>
              <span class="proof-label">{rental.onlineBooking.label}</span>
              <a href={rental.onlineBooking.sourceUrl} target="_blank" rel="noreferrer noopener">
                {rental.onlineBooking.source}
              </a>
            </p>
            <p class="hours">{rental.hours}</p>
            <p class="price" title={rental.priceTitle}>
              <span class="price-amount">{rental.priceLabel}</span>
              <span class="price-sub">{rental.priceSubLabel}</span>
            </p>
            <p
              class="rating"
              aria-label={`${rental.rating.toFixed(1)} Google Maps rating from ${rental.reviewCountLabel} reviews`}
            >
              <span class="rating-score">{rental.rating.toFixed(1)}</span>
              <span class="review-count">{rental.reviewCountLabel} reviews</span>
            </p>
            <p class="description">{rental.description}</p>
          </article>
        ))}
      </section>

      <section class="method-card" aria-labelledby="method-heading">
        <p class="eyebrow">Method</p>
        <h2 id="method-heading">How entries made the list</h2>
        <p>
          Each desk had to be listed as {pageData.validation.includedStatus.toLowerCase()} in Google Maps, open on Sunday, and offer online booking on its own website or app. The main bar is {pageData.validation.minReviewCount}+ Google reviews. Avis, Budget, Alamo, Enterprise, and National airport desks are also included from {airportExceptionMinReviews}+ reviews when they are open Sundays. Phone/WhatsApp-only quote brokers and Sunday-closed city desks were excluded.
        </p>
        <p>
          SUV / day is an approximate all-in 1-day rate for the smallest SUV class each brand publishes ({pageData.pricing.metric.toLowerCase()}). Most quotes come from Rentcars Buenos Aires brand pages; World Car and Rentennials use their own listings. Converted at {exchangeRateLabel}. Credit-card holds, deductibles, and add-ons are usually extra. Desks without a public SUV day rate or without an SUV in the published fleet were excluded.
        </p>
      </section>

      <section class="rental-map-section" aria-labelledby="rental-map-heading">
        <div class="map-copy">
          <p class="eyebrow">Map</p>
          <h2 id="rental-map-heading">Buenos Aires car rental map</h2>
          <p id="rental-map-status" class="map-status">
            Showing all {rentals.length} rental desks.
          </p>
        </div>
        {googleMapsApiKey ? (
          <div
            id="rental-map"
            class="rental-map"
            aria-label="Google Map with pins for Buenos Aires car rental desks"
          ></div>
        ) : (
          <p class="map-unavailable">
            Map unavailable because the Google Maps public key is not configured.
          </p>
        )}
      </section>
    </main>
  </body>
</html>

<script is:inline define:vars={{ googleMapsApiKey, rentalMapData }}>
  if (googleMapsApiKey) {
    ((g) => {
      let h;
      let a;
      let k;
      const p = "The Google Maps JavaScript API";
      const c = "google";
      const l = "importLibrary";
      const q = "__ib__";
      const m = document;
      let b = window;
      b = b[c] || (b[c] = {});
      const d = b.maps || (b.maps = {});
      const r = new Set();
      const e = new URLSearchParams();
      const u = () =>
        h ||
        (h = new Promise(async (resolve, reject) => {
          await (a = m.createElement("script"));
          e.set("libraries", [...r] + "");
          for (k in g) {
            e.set(k.replace(/[A-Z]/g, (t) => `_${t[0].toLowerCase()}`), g[k]);
          }
          e.set("callback", `${c}.maps.${q}`);
          a.src = `https://maps.${c}apis.com/maps/api/js?${e}`;
          d[q] = resolve;
          a.onerror = () => (h = reject(Error(`${p} could not load.`)));
          a.nonce = m.querySelector("script[nonce]")?.nonce || "";
          m.head.append(a);
        }));
      d[l] ? console.warn(`${p} only loads once. Ignoring:`, g) : (d[l] = (f, ...n) => r.add(f) && u().then(() => d[l](f, ...n)));
    })({
      key: googleMapsApiKey,
      v: "weekly",
    });
  }

  const neighborhoodFilter = document.querySelector("#neighborhood-filter");
  const brandFilter = document.querySelector("#brand-filter");
  const airportFilter = document.querySelector("#filter-airport");
  const cityFilter = document.querySelector("#filter-city");
  const defaultSort = document.querySelector("#sort-popularity");
  const rentalRows = [...document.querySelectorAll(".rental-row:not(.rental-head)")];
  const mapElement = document.querySelector("#rental-map");
  const mapStatus = document.querySelector("#rental-map-status");
  const buenosAiresCenter = { lat: -34.6037, lng: -58.3816 };
  const filterUrlParams = ["neighborhood", "brand", "airport", "city"];
  const markerRecords = [];
  let rentalMap;
  let infoWindow;

  const escapeHtml = (value) =>
    String(value).replace(/[&<>"']/g, (character) => ({
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#39;",
    })[character]);

  const getVisibleRentals = (selectedNeighborhood, selectedBrand, airportOnly, cityOnly) =>
    rentalMapData.filter(
      (rental) =>
        (!selectedNeighborhood || rental.neighborhood === selectedNeighborhood) &&
        (!selectedBrand || rental.brand === selectedBrand) &&
        (!airportOnly || rental.area === "airport") &&
        (!cityOnly || rental.area === "city"),
    );

  const updateMapStatus = (selectedNeighborhood, selectedBrand, airportOnly, cityOnly) => {
    if (!mapStatus) return;

    const visibleCount = getVisibleRentals(
      selectedNeighborhood,
      selectedBrand,
      airportOnly,
      cityOnly,
    ).length;
    const rentalLabel = visibleCount === 1 ? "rental desk" : "rental desks";
    const suffixParts = [
      airportOnly ? "at airports" : "",
      cityOnly ? "in the city" : "",
      selectedBrand ? `from ${selectedBrand}` : "",
    ].filter(Boolean);
    const suffix = suffixParts.length ? ` ${suffixParts.join(" · ")}` : "";
    mapStatus.textContent = selectedNeighborhood
      ? `Showing ${visibleCount} ${selectedNeighborhood} ${rentalLabel}${suffix}.`
      : `Showing ${airportOnly || cityOnly || selectedBrand ? "" : "all "}${visibleCount} ${rentalLabel}${suffix}.`;
  };

  const fitMapToMarkers = (visibleRecords) => {
    if (!rentalMap || !window.google?.maps || visibleRecords.length === 0) return;

    if (visibleRecords.length === 1) {
      rentalMap.setCenter(visibleRecords[0].rental.position);
      rentalMap.setZoom(14);
      return;
    }

    const bounds = new google.maps.LatLngBounds();

    for (const { rental } of visibleRecords) {
      bounds.extend(rental.position);
    }

    rentalMap.fitBounds(bounds, 44);
  };

  const syncMapMarkers = (selectedNeighborhood, selectedBrand, airportOnly, cityOnly) => {
    updateMapStatus(selectedNeighborhood, selectedBrand, airportOnly, cityOnly);

    if (!rentalMap) return;

    const visibleIds = new Set(
      getVisibleRentals(selectedNeighborhood, selectedBrand, airportOnly, cityOnly).map(
        (rental) => rental.id,
      ),
    );
    const visibleRecords = [];

    for (const record of markerRecords) {
      const isVisible = visibleIds.has(record.rental.id);
      record.marker.setMap(isVisible ? rentalMap : null);
      if (isVisible) visibleRecords.push(record);
    }

    if (mapElement) mapElement.dataset.visiblePins = String(visibleRecords.length);

    fitMapToMarkers(visibleRecords);
  };

  const updateFilterUrl = (selectedNeighborhood, selectedBrand, airportOnly, cityOnly) => {
    const url = new URL(window.location.href);

    for (const paramName of filterUrlParams) {
      url.searchParams.delete(paramName);
    }

    if (selectedNeighborhood) url.searchParams.set("neighborhood", selectedNeighborhood);
    if (selectedBrand) url.searchParams.set("brand", selectedBrand);
    if (airportOnly) url.searchParams.set("airport", "1");
    if (cityOnly) url.searchParams.set("city", "1");

    const nextUrl = `${url.pathname}${url.search}${url.hash}`;
    const currentUrl = `${window.location.pathname}${window.location.search}${window.location.hash}`;

    if (nextUrl !== currentUrl) {
      window.history.replaceState(null, "", nextUrl);
    }
  };

  const initRentalMap = async () => {
    if (!mapElement || !googleMapsApiKey || !window.google?.maps?.importLibrary) return;

    const { Map, InfoWindow } = await google.maps.importLibrary("maps");
    await google.maps.importLibrary("marker");

    rentalMap = new Map(mapElement, {
      center: buenosAiresCenter,
      clickableIcons: false,
      fullscreenControl: true,
      mapTypeControl: false,
      streetViewControl: false,
      zoom: 11,
    });
    infoWindow = new InfoWindow();

    for (const rental of rentalMapData) {
      const marker = new google.maps.Marker({
        map: rentalMap,
        position: rental.position,
        title: rental.name,
      });

      marker.addListener("click", () => {
        infoWindow.setContent(
          `<strong>${escapeHtml(rental.name)}</strong><br><a href="${escapeHtml(rental.googleMapsUrl)}" target="_blank" rel="noreferrer noopener">Open in Google Maps</a>`,
        );
        infoWindow.open(rentalMap, marker);
      });

      markerRecords.push({ rental, marker });
    }

    syncMapMarkers(
      neighborhoodFilter?.value ?? "",
      brandFilter?.value ?? "",
      airportFilter?.checked ?? false,
      cityFilter?.checked ?? false,
    );
  };

  const applyFilters = ({ syncUrl = true } = {}) => {
    const selectedNeighborhood = neighborhoodFilter?.value ?? "";
    const selectedBrand = brandFilter?.value ?? "";
    const airportOnly = airportFilter?.checked ?? false;
    const cityOnly = cityFilter?.checked ?? false;

    if (syncUrl) {
      updateFilterUrl(selectedNeighborhood, selectedBrand, airportOnly, cityOnly);
    }

    for (const row of rentalRows) {
      const neighborhoodMismatch =
        Boolean(selectedNeighborhood) && row.dataset.neighborhood !== selectedNeighborhood;
      const brandMismatch = Boolean(selectedBrand) && row.dataset.brand !== selectedBrand;
      const airportMismatch = airportOnly && row.dataset.area !== "airport";
      const cityMismatch = cityOnly && row.dataset.area !== "city";
      row.hidden = neighborhoodMismatch || brandMismatch || airportMismatch || cityMismatch;
    }

    syncMapMarkers(selectedNeighborhood, selectedBrand, airportOnly, cityOnly);
  };

  const resetControls = () => {
    if (defaultSort) defaultSort.checked = true;
    if (neighborhoodFilter) neighborhoodFilter.value = "";
    if (brandFilter) brandFilter.value = "";
    if (airportFilter) airportFilter.checked = false;
    if (cityFilter) cityFilter.checked = false;
  };

  const setSelectFromUrl = (selectElement, value) => {
    if (!selectElement || !value) return;

    const hasOption = [...selectElement.options].some((option) => option.value === value);
    if (hasOption) selectElement.value = value;
  };

  const hasEnabledUrlParam = (params, paramName) => {
    const value = params.get(paramName);
    if (value === null) return false;

    return !["0", "false", "no", "off"].includes(value.toLowerCase());
  };

  const applyFiltersFromUrl = () => {
    const params = new URLSearchParams(window.location.search);

    resetControls();
    setSelectFromUrl(neighborhoodFilter, params.get("neighborhood"));
    setSelectFromUrl(brandFilter, params.get("brand"));
    if (airportFilter) airportFilter.checked = hasEnabledUrlParam(params, "airport");
    if (cityFilter) cityFilter.checked = hasEnabledUrlParam(params, "city");

    applyFilters({ syncUrl: false });
  };

  neighborhoodFilter?.addEventListener("change", applyFilters);
  brandFilter?.addEventListener("change", applyFilters);
  airportFilter?.addEventListener("change", applyFilters);
  cityFilter?.addEventListener("change", applyFilters);
  applyFiltersFromUrl();
  window.addEventListener("pageshow", applyFiltersFromUrl);
  window.addEventListener("popstate", applyFiltersFromUrl);
  initRentalMap().catch((error) => {
    console.error("Unable to initialize car rental map", error);
    if (mapStatus) mapStatus.textContent = "Map unavailable. Rental list still works.";
  });
</script>

