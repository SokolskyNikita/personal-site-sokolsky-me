            </div>
            <label class="year-scrubber">
              <span>Year</span>
              <input type="range" min="1990" max="2026" value="2026" step="1" data-property-year-scrubber />
              <output data-property-year-output>2026</output>
            </label>
            <figcaption class="chart-caption">
              <span data-property-caption>Switch between purchase prices per m² and monthly rent per m². Both series are inflation-adjusted to 2026 dollars.</span>
            </figcaption>
            <p class="chart-source">Data: supplied historical Recoleta property-price and median-income series.</p>
            <script
              type="application/json"
              data-property-data
              set:html={JSON.stringify({
                prices: recoletaPropertyPrices,
                income: medianNetMonthlyIncome
              })}
            ></script>
