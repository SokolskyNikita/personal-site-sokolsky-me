---
const pageTitle = "Why Argentina stopped growing: 1990–2026, fact-checked";
const pageDescription =
  "A plain-English guide to Argentina's economic decline: what the evidence shows, where economists disagree, and which popular explanations do not fit the facts.";
const themeColorLight = "#fefdfa";
const themeColorDark = "#171410";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  author: {
    "@type": "Person",
    name: "Nikita Sokolsky"
  },
  inLanguage: "en"
};

// Both World Bank series use the post-2016 reconstruction of Argentina's national
// accounts, not the GDP path published during the 2007–15 INDEC intervention.
// Current US$ uses official period-average FX by definition. PPP uses international
// dollars and is therefore the better view of domestic purchasing power.
const currentDollarGdpPerCapita = [
  [1990, 4315], [1991, 5709], [1992, 6790], [1993, 6932], [1994, 7438],
  [1995, 7358], [1996, 7663], [1997, 8147], [1998, 8219], [1999, 7706],
  [2000, 7637], [2001, 7141], [2002, 2570], [2003, 3320], [2004, 4242],
  [2005, 5068], [2006, 5869], [2007, 7185], [2008, 8944], [2009, 8150],
  [2010, 10260], [2011, 12704], [2012, 12950], [2013, 12964], [2014, 12233],
  [2015, 13680], [2016, 12700], [2017, 14533], [2018, 11753], [2019, 9956],
  [2020, 8536], [2021, 10738], [2022, 13962], [2023, 14262], [2024, 13970],
  [2025, 14898]
] as const;

// World Bank WDI through 2024. The 2025 point extrapolates the 2024 WDI level
// by the IMF WEO April 2026 estimate of 2025 PPP-per-capita growth (6.45%).
const pppGdpPerCapita = [
  [1990, 7158], [1991, 7961], [1992, 8668], [1993, 9472], [1994, 10103],
  [1995, 9891], [1996, 10496], [1997, 11403], [1998, 11836], [1999, 11464],
  [2000, 11500], [2001, 11118], [2002, 9953], [2003, 10933], [2004, 12118],
  [2005, 13465], [2006, 14844], [2007, 16455], [2008, 17277], [2009, 16182],
  [2010, 17848], [2011, 19105], [2012, 19430], [2013, 19929], [2014, 19487],
  [2015, 19899], [2016, 20106], [2017, 23385], [2018, 24410], [2019, 23517],
  [2020, 22393], [2021, 26300], [2022, 29809], [2023, 30221], [2024, 30431],
  [2025, 32382]
] as const;

const gdpSeries = {
  current: currentDollarGdpPerCapita,
  ppp: pppGdpPerCapita
};

const medianNetMonthlyIncome = [
  [1990, 980], [1991, 980], [1992, 1139], [1993, 1222], [1994, 1247],
  [1995, 1193], [1996, 1125], [1997, 1103], [1998, 1074], [1999, 988],
  [2000, 926], [2001, 848], [2002, 251], [2003, 312], [2004, 330],
  [2005, 383], [2006, 435], [2007, 521], [2008, 630], [2009, 641],
  [2010, 752], [2011, 842], [2012, 776], [2013, 637], [2014, 565],
  [2015, 608], [2016, 890], [2017, 931], [2018, 676], [2019, 493],
  [2020, 270], [2021, 283], [2022, 288], [2023, 260], [2024, 382],
  [2025, 582], [2026, 625]
] as const;

const recoletaPropertyPrices = [
  [1990, 2750, 16.3], [1991, 3000, 16.8], [1992, 3260, 17.0],
  [1993, 3390, 17.2], [1994, 3200, 16.5], [1995, 3000, 16.1],
  [1996, 2970, 15.6], [1997, 3000, 15.5], [1998, 3010, 15.4],
  [1999, 2850, 14.5], [2000, 2660, 14.1], [2001, 2490, 13.8],
  [2002, 1820, 10.0], [2003, 2130, 11.6], [2004, 2340, 12.1],
  [2005, 2090, 11.0], [2006, 2510, 12.0], [2007, 2810, 12.3],
  [2008, 3000, 12.2], [2009, 3050, 12.2], [2010, 3260, 12.7],
  [2011, 3560, 12.8], [2012, 3810, 13.5], [2013, 3650, 12.6],
  [2014, 3450, 11.7], [2015, 3660, 12.4], [2016, 3990, 12.5],
  [2017, 4260, 12.8], [2018, 4400, 11.7], [2019, 4250, 11.0],
  [2020, 3760, 9.1], [2021, 3140, 8.0], [2022, 2850, 8.0],
  [2023, 2500, 9.4], [2024, 2610, 10.7], [2025, 2590, 12.7],
  [2026, 2650, 12.5]
] as const;

const chart = {
  width: 760,
  height: 390,
  left: 88,
  right: 20,
  top: 48,
  bottom: 48,
  max: 16000
};
const plotWidth = chart.width - chart.left - chart.right;
const plotHeight = chart.height - chart.top - chart.bottom;
const xForYear = (year: number) =>
  chart.left + ((year - 1990) / (2025 - 1990)) * plotWidth;
const yForValue = (value: number) =>
  chart.top + plotHeight - (value / chart.max) * plotHeight;
const linePath = currentDollarGdpPerCapita
  .map(([year, value], index) =>
    `${index === 0 ? "M" : "L"} ${xForYear(year).toFixed(1)} ${yForValue(value).toFixed(1)}`
  )
  .join(" ");
const areaPath = `${linePath} L ${xForYear(2025).toFixed(1)} ${(chart.top + plotHeight).toFixed(1)} L ${xForYear(1990).toFixed(1)} ${(chart.top + plotHeight).toFixed(1)} Z`;
const xTicks = [1990, 2000, 2010, 2020, 2025];
const yTicks = [0, 4000, 8000, 12000, 16000];

const incomeChart = { ...chart, max: 1400 };
const xForIncomeYear = (year: number) =>
  incomeChart.left + ((year - 1990) / (2026 - 1990)) * plotWidth;
const yForIncome = (value: number) =>
  incomeChart.top + plotHeight - (value / incomeChart.max) * plotHeight;
const incomeLinePath = medianNetMonthlyIncome
  .map(([year, value], index) =>
    `${index === 0 ? "M" : "L"} ${xForIncomeYear(year).toFixed(1)} ${yForIncome(value).toFixed(1)}`
  )
  .join(" ");
const incomeAreaPath = `${incomeLinePath} L ${xForIncomeYear(2026).toFixed(1)} ${(incomeChart.top + plotHeight).toFixed(1)} L ${xForIncomeYear(1990).toFixed(1)} ${(incomeChart.top + plotHeight).toFixed(1)} Z`;
const incomeXTicks = [1990, 2000, 2010, 2020, 2026];
const incomeYTicks = [0, 350, 700, 1050, 1400];

const propertyChart = { ...chart, min: 1250, max: 5000 };
const propertyPlotWidth = plotWidth;
const xForPropertyYear = (year: number) =>
  propertyChart.left + ((year - 1990) / (2026 - 1990)) * propertyPlotWidth;
const yForBuyPrice = (value: number) =>
  propertyChart.top + plotHeight -
  ((value - propertyChart.min) / (propertyChart.max - propertyChart.min)) * plotHeight;
const propertyBuyPath = recoletaPropertyPrices
  .map(([year, buy], index) =>
    `${index === 0 ? "M" : "L"} ${xForPropertyYear(year).toFixed(1)} ${yForBuyPrice(buy).toFixed(1)}`
  )
  .join(" ");
const propertyXTicks = [1990, 2000, 2010, 2020, 2026];
const propertyBuyTicks = [1250, 2500, 3750, 5000];
