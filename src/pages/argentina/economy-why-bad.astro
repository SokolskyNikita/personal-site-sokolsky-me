            </div>
            <div class="chart-meta">
              <p class="chart-unit" data-chart-unit>1990–2025 · current US$ at official period-average FX</p>
              <p class="chart-status"><span aria-hidden="true"></span>Revised national accounts</p>
            </div>
            <div class="chart-stage">
              <div class="chart-readout" aria-live="polite" aria-atomic="true">
