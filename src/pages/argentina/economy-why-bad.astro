                aria-labelledby="property-chart-title property-chart-desc"
                data-property-chart-svg
              >
                <title id="property-chart-title">Interactive chart of Recoleta buy and rent prices, 1990 to 2026</title>
                <desc id="property-chart-desc">Choose purchase prices per square meter or monthly rents per square meter. Both are expressed in constant 2026 US dollars. Move across or click the plot, or use the year slider and arrow keys, to inspect annual values.</desc>

                <g data-property-y-axis>
                  {propertyBuyTicks.map((tick) => (
