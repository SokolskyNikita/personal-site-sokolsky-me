                <path class="property-line" d={propertyBuyPath} data-property-line></path>
                <g class="property-points" data-property-points>
                  {recoletaPropertyPrices.map(([year, buy]) => (
                    <circle cx={xForPropertyYear(year)} cy={yForBuyPrice(buy)} r="2.2"></circle>
