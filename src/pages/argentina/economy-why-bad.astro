    <meta name="description" content={pageDescription} />
    <meta name="subject" content="A fact-checked account of why Argentina's per-capita growth stalled after 1990, with IMF and free-market diagnoses." />
    <meta name="application-name" content={pageTitle} />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="googlebot" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="keywords" content="Argentina economy, Argentina GDP per capita, fiscal dominance, convertibility, cepo, Milei, IMF Argentina, dollarization" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
