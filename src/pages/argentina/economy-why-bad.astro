---
export const prerender = true;

const pageTitle = "Why Argentina stopped growing: 1990-2026, fact-checked";
const pageDescription =
  "What the IMF's own post-mortems and free-market economists actually blame, where they disagree with each other and which popular explanations don't survive contact with the data.";
const themeColorLight = "#fdfcf9";
const themeColorDark = "#171410";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  author: {
    "@type": "Person",
    name: "Nikita Sokolsky"
  },
  inLanguage: "en"
};

const worldBankGdpPerCapita = [
  [1990, 4315], [1991, 5709], [1992, 6790], [1993, 6932], [1994, 7438],
  [1995, 7358], [1996, 7663], [1997, 8147], [1998, 8219], [1999, 7706],
  [2000, 7637], [2001, 7141], [2002, 2570], [2003, 3320], [2004, 4242],
  [2005, 5068], [2006, 5869], [2007, 7185], [2008, 8944], [2009, 8150],
  [2010, 10260], [2011, 12704], [2012, 12950], [2013, 12964], [2014, 12233],
  [2015, 13680], [2016, 12700], [2017, 14533], [2018, 11753], [2019, 9956],
  [2020, 8536], [2021, 10738], [2022, 13962], [2023, 14262], [2024, 13970],
  [2025, 14898]
] as const;

const worldBankConstant2015 = {
  2006: 11870, 2007: 12812, 2008: 13197, 2009: 12285, 2010: 13387,
  2011: 14041, 2012: 13754, 2013: 13946, 2014: 13456, 2015: 13680
} as const;

// Parallel-market FX correction for cepo years (official ÷ blue-dollar rate).
const parallelFxFactor = {
  2011: 0.92, 2012: 0.75, 2013: 0.63, 2014: 0.66, 2015: 0.67
} as const;

const arklemsCagr2007_2015 = 0.018;
const arklemsRealBase2006 = worldBankConstant2015[2006];

const adjustedGdpPerCapita = worldBankGdpPerCapita.map(([year, value]) => {
  if (year < 2007 || year > 2015) return [year, value];

  const arklemsReal =
    arklemsRealBase2006 * Math.pow(1 + arklemsCagr2007_2015, year - 2006);
  const conversionRatio =
    value / worldBankConstant2015[year as keyof typeof worldBankConstant2015];
  const fxFactor =
    parallelFxFactor[year as keyof typeof parallelFxFactor] ?? 1;
  const adjusted = Math.round(arklemsReal * conversionRatio * fxFactor);
  return [year, adjusted];
});

const chart = {
  width: 760,
  height: 390,
  left: 62,
  right: 20,
  top: 48,
  bottom: 48,
  max: 16000
};
const plotWidth = chart.width - chart.left - chart.right;
const plotHeight = chart.height - chart.top - chart.bottom;
const xForYear = (year: number) =>
  chart.left + ((year - 1990) / (2025 - 1990)) * plotWidth;
const yForValue = (value: number) =>
  chart.top + plotHeight - (value / chart.max) * plotHeight;
const pathForSeries = (series: [number, number][]) =>
  series
    .map(([year, value], index) =>
      `${index === 0 ? "M" : "L"} ${xForYear(year).toFixed(1)} ${yForValue(value).toFixed(1)}`
    )
    .join(" ");
const adjustedLinePath = pathForSeries(adjustedGdpPerCapita);
const publishedLinePath = pathForSeries(worldBankGdpPerCapita);
const areaPath = `${adjustedLinePath} L ${xForYear(2025).toFixed(1)} ${(chart.top + plotHeight).toFixed(1)} L ${xForYear(1990).toFixed(1)} ${(chart.top + plotHeight).toFixed(1)} Z`;
const xTicks = [1990, 2000, 2010, 2020, 2025];
const yTicks = [0, 4000, 8000, 12000, 16000];
const adjustedByYear = Object.fromEntries(adjustedGdpPerCapita);
const chartLabels = ([1998, 2002, 2011, 2025] as const).map((year) => [
  year,
  adjustedByYear[year]
]);
const formatDollars = (value: number) =>
  `$${Math.round(value / 100) / 10}k`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
