---
import venueGeoData from "../../data/fifa-2026-finals-ba-venues.json";

export const prerender = true;

const pageTitle = "Where to watch the 2026 World Cup semis & final in Buenos Aires";
const pageDescription =
  "Buenos Aires spots with confirmed World Cup semi/final screening at 16:00 BA time: Plaza Seeber Fan Fest, Locos x el Fútbol, BetWarrior, Cantina Recoleta and other verified rooms.";
const themeColorLight = "#f7f2e7";
const themeColorDark = "#17130d";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const checkedDate = "July 12, 2026";
const googleMapsApiKey =
  import.meta.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
  process.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
  "";

const categoryLabels: Record<string, string> = {
  public: "Public screening",
  indoor: "Indoor bar",
  neighborhood: "Neighborhood",
  "final-only": "Final only",
  amba: "AMBA",
};

const venueMapData = venueGeoData.venues
  .filter((venue) => venue.location)
  .map((venue) => ({
    id: venue.id,
    name: venue.name,
    address: venue.address,
    category: venue.category,
    categoryLabel: categoryLabels[venue.category] ?? venue.category,
    status: venue.status,
    googleMapsUrl: venue.googleMapsUrl,
    position: venue.location,
    acceptsReservations: Boolean(venue.acceptsReservations),
    reservationUrl: venue.reservationUrl ?? null,
  }));

type Match = {
  label: string;
  date: string;
  note?: string;
};

type DecisionPick = {
  label: string;
  title: string;
  detail: string;
};

type Venue = {
  name: string;
  address: string;
  neighborhood?: string;
  status: string;
  detail: string;
  mapsQuery: string;
  source?: string;
  highlight?: boolean;
  warning?: boolean;
  acceptsReservations?: boolean;
  reservationUrl?: string;
};

const mapsIcon = `<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="#1a73e8" d="M12 2.2c3.9 0 7.1 3.1 7.1 7 0 5.1-7.1 12.6-7.1 12.6S4.9 14.3 4.9 9.2c0-3.9 3.2-7 7.1-7Z"/><path fill="#34a853" d="M7.2 14.1 12 21.8l4.8-7.7-4.8-2.8-4.8 2.8Z"/><path fill="#fbbc04" d="M4.9 9.2c0 1.8.9 3.5 2.3 4.9l4.8-2.8V2.2c-3.9 0-7.1 3.1-7.1 7Z"/><path fill="#ea4335" d="M19.1 9.2c0 1.8-.9 3.5-2.3 4.9L12 11.3V2.2c3.9 0 7.1 3.1 7.1 7Z"/><circle cx="12" cy="9.3" r="2.45" fill="#fff"/></svg>`;
const reservationIcon = `<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="currentColor" d="M7 2.75a.75.75 0 0 1 .75.75V5h8.5V3.5a.75.75 0 0 1 1.5 0V5H19a2 2 0 0 1 2 2v12.25A2.75 2.75 0 0 1 18.25 22H5.75A2.75 2.75 0 0 1 3 19.25V7a2 2 0 0 1 2-2h1.25V3.5A.75.75 0 0 1 7 2.75Zm12 7.75H5v8.75c0 .69.56 1.25 1.25 1.25h12.5c.69 0 1.25-.56 1.25-1.25V10.5ZM5 7v2h14V7a.5.5 0 0 0-.5-.5H5.5A.5.5 0 0 0 5 7Zm4.22 5.22a.75.75 0 0 1 1.06 0l1.47 1.47 3.47-3.47a.75.75 0 1 1 1.06 1.06l-4 4a.75.75 0 0 1-1.06 0l-2-2a.75.75 0 0 1 0-1.06Z"/></svg>`;

