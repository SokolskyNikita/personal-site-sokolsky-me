const geoByName = new Map(
  venueGeoData.venues.map((venue) => [venue.name, venue] as const),
);

const allVenuesForSchema = [
  ...publicVenues,
  ...indoorBars,
  ...neighborhoodSpots,
  ...finalOnlyVenues,
  ...ambaVenues,
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  numberOfItems: allVenuesForSchema.length,
  itemListElement: allVenuesForSchema.map((venue, index) => {
    const geo = geoByName.get(venue.name);
    return {
      "@type": "ListItem",
      position: index + 1,
      item: {
        "@type": "BarOrPub",
        name: venue.name,
        address: venue.address,
        description: venue.detail,
        url: geo?.googleMapsUrl ?? mapsUrl(venue.mapsQuery),
        ...(geo?.location
          ? {
              geo: {
                "@type": "GeoCoordinates",
                latitude: geo.location.lat,
                longitude: geo.location.lng,
              },
            }
          : {}),
      },
    };
  }),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta
      name="subject"
      content="Where to watch FIFA World Cup 2026 semifinals and final in Buenos Aires"
    />
    <meta name="application-name" content={pageTitle} />
