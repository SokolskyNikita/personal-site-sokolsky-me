      @media (prefers-color-scheme: dark) {
        :root {
          color-scheme: dark;
          --bg: #17130d;
          --paper: #211a12;
          --paper-strong: #2e2417;
          --ink: #f5ead6;
          --muted: #c8b89d;
          --line: rgb(245 234 214 / 16%);
          --accent: #ff9d64;
          --accent-strong: #ffc9a6;
          --green: #93d2ac;
          --warn: #ffc078;
          --shadow: 0 12px 36px rgb(0 0 0 / 22%);
        }
      }

      * {
        box-sizing: border-box;
      }

      html {
        background: var(--bg);
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background:
          radial-gradient(circle at 12% 0%, rgb(255 162 79 / 25%), transparent 30rem),
          linear-gradient(135deg, rgb(255 255 255 / 28%), transparent 26rem),
          var(--bg);
        color: var(--ink);
        font-family:
          ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
      }

      a {
        color: inherit;
        text-decoration-color: color-mix(in srgb, var(--accent) 58%, transparent);
        text-decoration-thickness: 0.08em;
        text-underline-offset: 0.18em;
      }

      a:hover {
        color: var(--accent-strong);
      }

      h1,
      h2,
      h3,
      p,
      dl,
      dd,
      ul {
        margin: 0;
      }

      .page {
        width: min(1180px, calc(100% - clamp(24px, 4vw, 56px)));
        margin: 0 auto;
        padding: clamp(12px, 2vw, 28px) 0 clamp(24px, 4vw, 48px);
      }

      .hero,
      .panel,
      .region {
        border: 1px solid var(--line);
        border-radius: clamp(18px, 2.4vw, 26px);
        background:
          linear-gradient(145deg, rgb(255 255 255 / 38%), transparent 34rem),
          var(--paper);
        box-shadow: var(--shadow);
      }

      .hero {
        padding: clamp(16px, 2.6vw, 28px);
      }

      .topbar,
      .hero-grid,
      .region-heading,
      .quick-answer,
      .notes,
      .caveats,
      .match-picks {
        display: grid;
        gap: clamp(10px, 1.6vw, 18px);
      }

      .topbar {
        grid-template-columns: 1fr auto;
        align-items: center;
        margin-bottom: clamp(14px, 2.4vw, 28px);
      }

      .home-link,
      .updated,
      .eyebrow,
      .option-topline span,
      .decision-card > p,
      .match-card > p,
      dt {
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.11em;
        text-transform: uppercase;
      }

      .home-link {
        color: var(--muted);
        text-decoration: none;
      }

      .updated {
        color: var(--muted);
      }

      .hero-grid {
        grid-template-columns: minmax(0, 1.4fr) minmax(240px, 0.7fr);
        align-items: start;
      }

      .eyebrow {
        color: var(--accent);
        margin-bottom: 6px;
      }

      h1 {
        max-width: 22ch;
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(1.45rem, 3.2vw, 2.15rem);
        font-weight: 780;
        letter-spacing: -0.045em;
        line-height: 1.05;
        text-wrap: balance;
      }

      .dek {
        max-width: 760px;
        margin-top: clamp(10px, 1.6vw, 16px);
        color: var(--muted);
        font-size: clamp(0.98rem, 1.4vw, 1.08rem);
        line-height: 1.45;
      }

