        margin-top: 8px;
        max-width: 760px;
      }

      .decision-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 8px;
      }

      .decision-card {
        border: 1px solid var(--line);
        border-radius: 16px;
        background: color-mix(in srgb, var(--paper-strong) 72%, var(--paper));
        padding: 12px 14px;
      }

      .decision-card > p {
        color: var(--accent);
      }

      .decision-card h3 {
        margin-top: 6px;
        font-size: clamp(0.98rem, 1.3vw, 1.12rem);
        line-height: 1.2;
        letter-spacing: -0.02em;
      }

