      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="googlebot"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="keywords"
      content="FIFA 2026 Buenos Aires, where to watch World Cup final Buenos Aires, Plaza Seeber Fan Fest, Locos x el Futbol, Argentina England semis bars"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta
      name="theme-color"
      content={themeColorLight}
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content={themeColorDark}
      media="(prefers-color-scheme: dark)"
    />
    <meta name="msapplication-TileColor" content={themeColorDark} />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color={themeColorDark} />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="sokolsky.me" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <main class="page">
      <header class="hero">
        <div class="topbar">
          <a class="home-link" href="/" aria-label="Back to home">sokolsky.me</a>
          <p class="updated">Checked {checkedDate}</p>
        </div>

        <div class="hero-grid">
          <div>
            <p class="eyebrow">Buenos Aires · FIFA 2026</p>
            <h1>{pageTitle}</h1>
            <p class="dek">
              All three matches kick off at <strong>16:00 (4pm) Buenos Aires time</strong>.
              This list keeps only places with current confirmation they can host that
              afternoon kickoff — night-only World Cup plans and bars that open at/after
              17:00 are out.
            </p>
          </div>

          <aside class="kickoff-note" aria-label="Reservation timing">
            <span>Reservation window</span>
            <strong>Reserve by Monday for Argentina–England.</strong>
            <p>
              For the final, lock something in immediately after the second semifinal.
              Streaming-at-home options:
              <a href="/misc/fifa-2026-streaming/">FIFA 2026 streaming guide</a>.
            </p>
          </aside>
        </div>

        <div class="match-row" aria-label="Match schedule">
          {matches.map((match) => (
            <article class="match-card">
              <p>{match.date}</p>
              <h2>{match.label}</h2>
              {match.note && <span>{match.note}</span>}
            </article>
          ))}
        </div>
      </header>

      <section class="panel quick-answer" id="tldr" aria-labelledby="tldr-heading">
        <div class="section-copy">
          <p class="eyebrow">TL;DR</p>
          <h2 id="tldr-heading">Confirmed for a 16:00 kickoff</h2>
          <p>
            Plaza Seeber is the only public screen with official semis/final dates.
            Indoor locks that open early enough: Locos, BetWarrior, Cantina Recoleta and
            Triumph. Everything else below was re-checked against current City / press /
            venue sources on July 12.
          </p>
        </div>

        <div class="decision-grid">
          {decisionPicks.map((pick) => (
            <article class="decision-card">
              <p>{pick.label}</p>
              <h3>{pick.title}</h3>
              <span>{pick.detail}</span>
            </article>
          ))}
        </div>
      </section>

      <section class="region" id="public-screenings" aria-labelledby="public-heading">
        <div class="region-heading">
          <p class="eyebrow">Official public screening</p>
