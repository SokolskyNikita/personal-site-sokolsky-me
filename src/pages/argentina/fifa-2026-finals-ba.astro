        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px;
      }

      .venue-grid--compact {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .venue-card {
        display: grid;
        gap: 6px;
        border: 1px solid var(--line);
        border-radius: 18px;
        background:
          linear-gradient(160deg, rgb(255 255 255 / 30%), transparent 18rem),
          color-mix(in srgb, var(--paper) 88%, var(--paper-strong));
        padding: clamp(12px, 1.8vw, 16px);
      }

      .venue-card.is-pick {
        border-color: color-mix(in srgb, var(--green) 45%, var(--line));
        background:
          linear-gradient(160deg, color-mix(in srgb, var(--green) 10%, transparent), transparent 16rem),
          color-mix(in srgb, var(--paper) 88%, var(--paper-strong));
      }

      .venue-card.is-warning {
        border-color: color-mix(in srgb, var(--warn) 40%, var(--line));
      }

      .option-topline {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 12px;
      }

      .option-topline span {
        color: var(--green);
      }

      .venue-card.is-warning .option-topline span {
        color: var(--warn);
      }

      .option-topline strong {
        color: var(--muted);
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.02em;
        text-align: right;
      }

      .venue-card h3 {
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(1.02rem, 1.5vw, 1.2rem);
        letter-spacing: -0.025em;
        line-height: 1.15;
        text-wrap: balance;
      }

      .venue-title-row {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 8px;
      }

      .venue-title-row h3 {
        flex: 1;
        min-width: 0;
      }

      .venue-actions {
        display: flex;
        flex-shrink: 0;
        align-items: center;
        gap: 0.35rem;
        padding-top: 0.15rem;
      }

      .maps-link,
      .reservation-link {
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent);
        text-decoration: none;
      }

      .maps-icon,
      .reservation-icon {
        display: flex;
      }

      .maps-icon :global(svg),
      .reservation-icon :global(svg) {
        width: 1.35rem;
        height: 1.35rem;
      }

      .venue-card.is-filtered-out {
        display: none;
      }

      .venue-card h3 a {
        text-decoration: none;
      }

      .venue-card h3 a:hover {
        text-decoration: underline;
      }

      .address {
        color: var(--ink);
        font-size: 0.88rem;
        font-weight: 650;
        line-height: 1.35;
      }

      .detail {
        color: var(--muted);
        font-size: 0.9rem;
        line-height: 1.45;
      }

      .source-tag {
        color: var(--muted);
        font-size: 0.78rem;
        font-weight: 650;
        letter-spacing: 0.02em;
      }

      .source-list {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px 18px;
        margin: 0;
        padding-left: 1.2rem;
      }

      .source-list li {
        color: var(--muted);
        line-height: 1.45;
      }

      .trap-list {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px;
        padding: 0;
        list-style: none;
      }

      .trap-list li {
        border: 1px solid var(--line);
        border-radius: 16px;
        background: color-mix(in srgb, var(--paper-strong) 55%, var(--paper));
        padding: 12px 14px;
      }

      .trap-list a {
        font-weight: 750;
        text-decoration: none;
      }

      .trap-list a:hover {
        text-decoration: underline;
      }

      .trap-address {
        display: block;
        margin-top: 4px;
        color: var(--muted);
        font-size: 0.86rem;
      }

      .trap-list p {
        margin-top: 6px;
        color: var(--muted);
        font-size: 0.9rem;
        line-height: 1.4;
      }

      .match-pick-grid {
        display: grid;
        gap: 8px;
      }

      .match-pick-card {
        border: 1px solid var(--line);
        border-radius: 16px;
        background: rgb(255 255 255 / 22%);
        padding: 12px 14px;
      }

      .match-pick-card h3 {
        font-size: clamp(0.98rem, 1.3vw, 1.1rem);
        letter-spacing: -0.015em;
        line-height: 1.25;
      }

      .match-pick-card p {
        margin-top: 6px;
        color: var(--muted);
        font-size: 0.9rem;
        line-height: 1.45;
      }

      .notes,
      .caveats,
      .match-picks {
        grid-template-columns: minmax(200px, 0.45fr) minmax(0, 1fr);
        align-items: start;
      }

      .note-columns {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px;
      }

      .note-columns p {
        border: 1px solid var(--line);
        border-radius: 16px;
        background: rgb(255 255 255 / 22%);
        padding: 12px 14px;
      }

      .note-columns strong {
        color: var(--ink);
      }

      .tip-list {
        display: grid;
        gap: 8px;
      }

      .tip-list > div {
        display: grid;
        grid-template-columns: minmax(9rem, 0.32fr) minmax(0, 1fr);
        gap: 10px;
        border-top: 1px solid var(--line);
        padding-top: 8px;
      }

      .tip-list dt {
        color: var(--accent);
      }

      .tip-list dd {
        color: var(--muted);
        font-size: 0.9rem;
        line-height: 1.45;
      }

      @media (max-width: 980px) {
        .hero-grid,
        .quick-answer,
        .notes,
        .caveats,
        .match-picks,
        .venue-grid--compact {
          grid-template-columns: 1fr;
        }

        .match-row,
        .venue-grid,
        .trap-list,
        .note-columns,
        .source-list {
          grid-template-columns: 1fr;
        }

        .tip-list > div {
          grid-template-columns: 1fr;
          gap: 6px;
        }
      }

      @media (max-width: 760px) {
        .page {
          width: min(100% - 16px, 1180px);
          padding-top: 8px;
        }

        .topbar {
          grid-template-columns: 1fr;
          gap: 6px;
          margin-bottom: 14px;
        }

        h1 {
          max-width: 100%;
          font-size: clamp(1.35rem, 6.5vw, 1.85rem);
        }
      }

      @media (min-width: 981px) and (max-width: 1180px) {
        .venue-grid--compact {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }

      .venue-map-section .region-heading {
        margin-bottom: 8px;
      }

      .map-status,
      .map-unavailable {
        color: var(--muted);
        font-size: 0.9rem;
        line-height: 1.4;
      }

      .map-filters {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-bottom: 10px;
      }

      .map-filter {
        appearance: none;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: color-mix(in srgb, var(--paper-strong) 70%, var(--paper));
        color: var(--muted);
        cursor: pointer;
        padding: 0.35rem 0.7rem;
        font: inherit;
        font-size: 0.74rem;
        font-weight: 750;
        letter-spacing: 0.04em;
      }

      .map-filter:hover {
        color: var(--accent-strong);
      }

      .map-filter.is-active {
        border-color: color-mix(in srgb, var(--accent) 45%, var(--line));
        background: var(--ink);
        color: var(--bg);
      }

      .map-filter--toggle.is-active {
        border-color: color-mix(in srgb, var(--green) 55%, var(--line));
        background: color-mix(in srgb, var(--green) 88%, var(--ink));
        color: var(--bg);
      }

      .venue-map {
        min-height: clamp(16rem, 42vw, 28rem);
        overflow: hidden;
        border: 1px solid var(--line);
        border-radius: 18px;
        background: var(--paper-strong);
      }
    </style>
  </body>
</html>

<script is:inline define:vars={{ googleMapsApiKey, venueMapData }}>
  if (googleMapsApiKey) {
    ((g) => {
      let h;
      let a;
      let k;
      const p = "The Google Maps JavaScript API";
      const c = "google";
      const l = "importLibrary";
      const q = "__ib__";
      const m = document;
      let b = window;
      b = b[c] || (b[c] = {});
      const d = b.maps || (b.maps = {});
      const r = new Set();
      const e = new URLSearchParams();
      const u = () =>
        h ||
        (h = new Promise(async (resolve, reject) => {
          await (a = m.createElement("script"));
          e.set("libraries", [...r] + "");
          for (k in g) {
            e.set(k.replace(/[A-Z]/g, (t) => `_${t[0].toLowerCase()}`), g[k]);
          }
          e.set("callback", `${c}.maps.${q}`);
          a.src = `https://maps.${c}apis.com/maps/api/js?${e}`;
          d[q] = resolve;
          a.onerror = () => (h = reject(Error(`${p} could not load.`)));
          a.nonce = m.querySelector("script[nonce]")?.nonce || "";
          m.head.append(a);
        }));
      d[l]
        ? console.warn(`${p} only loads once. Ignoring:`, g)
        : (d[l] = (f, ...n) => r.add(f) && u().then(() => d[l](f, ...n)));
    })({
      key: googleMapsApiKey,
      v: "weekly",
    });
  }

  const mapElement = document.querySelector("#venue-map");
  const mapStatus = document.querySelector("#venue-map-status");
  const filterButtons = [...document.querySelectorAll("[data-map-filter]")];
  const reservationFilterButton = document.querySelector("[data-reservation-filter]");
  const venueCards = [...document.querySelectorAll("[data-venue-card]")];
  const buenosAiresCenter = { lat: -34.595, lng: -58.42 };
  const markerRecords = [];
  let venueMap;
  let infoWindow;
  let activeCategory = "";
  let reservationsOnly = false;

  const escapeHtml = (value) =>
    String(value).replace(/[&<>"']/g, (character) =>
      ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      })[character],
    );

  const getVisibleVenues = () =>
    venueMapData.filter((venue) => {
      if (activeCategory && venue.category !== activeCategory) return false;
      if (reservationsOnly && !venue.acceptsReservations) return false;
      return true;
    });

  const syncVenueCards = () => {
    for (const card of venueCards) {
      const accepts = card.dataset.acceptsReservations === "true";
      card.classList.toggle("is-filtered-out", reservationsOnly && !accepts);
    }
  };

  const updateMapStatus = () => {
    if (!mapStatus) return;

    const visibleCount = getVisibleVenues().length;
    const venueLabel = visibleCount === 1 ? "venue" : "venues";
    const reservationNote = reservationsOnly ? " that accept reservations" : "";

    if (!activeCategory) {
      mapStatus.textContent = reservationsOnly
        ? `Showing ${visibleCount} ${venueLabel}${reservationNote}.`
        : `Showing all ${visibleCount} ${venueLabel} across CABA and nearby AMBA.`;
      return;
    }

    const label =
      venueMapData.find((venue) => venue.category === activeCategory)?.categoryLabel ??
      activeCategory;
    mapStatus.textContent = `Showing ${visibleCount} ${label.toLowerCase()} ${venueLabel}${reservationNote}.`;
  };

  const fitMapToMarkers = (visibleRecords) => {
    if (!venueMap || !window.google?.maps || visibleRecords.length === 0) return;

    if (visibleRecords.length === 1) {
      venueMap.setCenter(visibleRecords[0].venue.position);
      venueMap.setZoom(14);
      return;
    }

    const bounds = new google.maps.LatLngBounds();
    for (const { venue } of visibleRecords) {
      bounds.extend(venue.position);
    }
    venueMap.fitBounds(bounds, 56);
  };

  const syncMapMarkers = () => {
    updateMapStatus();
    syncVenueCards();
    if (!venueMap) return;

    const visibleIds = new Set(getVisibleVenues().map((venue) => venue.id));
    const visibleRecords = [];

    for (const record of markerRecords) {
      const isVisible = visibleIds.has(record.venue.id);
      record.marker.setMap(isVisible ? venueMap : null);
      if (isVisible) visibleRecords.push(record);
    }

    if (mapElement) {
      mapElement.dataset.visiblePins = String(visibleRecords.length);
    }

    fitMapToMarkers(visibleRecords);
  };

  const setActiveFilter = (category) => {
    activeCategory = category;
    for (const button of filterButtons) {
      const isActive = (button.dataset.mapFilter ?? "") === category;
      button.classList.toggle("is-active", isActive);
    }
    syncMapMarkers();
  };

  const setReservationsOnly = (enabled) => {
    reservationsOnly = enabled;
    if (reservationFilterButton) {
      reservationFilterButton.classList.toggle("is-active", enabled);
      reservationFilterButton.setAttribute("aria-pressed", enabled ? "true" : "false");
    }
    syncMapMarkers();
  };

  const initVenueMap = async () => {
    if (!mapElement || !googleMapsApiKey || !window.google?.maps?.importLibrary) {
      return;
    }

    const { Map, InfoWindow } = await google.maps.importLibrary("maps");
    await google.maps.importLibrary("marker");

    venueMap = new Map(mapElement, {
      center: buenosAiresCenter,
      clickableIcons: false,
      fullscreenControl: true,
      mapTypeControl: false,
      streetViewControl: false,
      zoom: 12,
    });
    infoWindow = new InfoWindow();

    for (const venue of venueMapData) {
      const marker = new google.maps.Marker({
        map: venueMap,
        position: venue.position,
        title: venue.name,
      });

      marker.addListener("click", () => {
        const reservationLink =
          venue.acceptsReservations && venue.reservationUrl
            ? `<br><a href="${escapeHtml(venue.reservationUrl)}" target="_blank" rel="noreferrer noopener">Book / reserve</a>`
            : "";
        infoWindow.setContent(
          `<strong>${escapeHtml(venue.name)}</strong><br>${escapeHtml(venue.categoryLabel)} · ${escapeHtml(venue.status)}<br>${escapeHtml(venue.address)}<br><a href="${escapeHtml(venue.googleMapsUrl)}" target="_blank" rel="noreferrer noopener">Open in Google Maps</a>${reservationLink}`,
        );
        infoWindow.open(venueMap, marker);
      });

      markerRecords.push({ venue, marker });
    }

    syncMapMarkers();
  };

  for (const button of filterButtons) {
    button.addEventListener("click", () => {
      setActiveFilter(button.dataset.mapFilter ?? "");
    });
  }

  if (reservationFilterButton) {
    reservationFilterButton.addEventListener("click", () => {
      setReservationsOnly(!reservationsOnly);
    });
  }

  syncVenueCards();
  updateMapStatus();

  initVenueMap().catch((error) => {
    console.error("Unable to initialize venue map", error);
    if (mapStatus) {
      mapStatus.textContent = "Map unavailable. Venue list above still works.";
    }
  });
</script>
