---
import venueGeoData from "../../data/fifa-2026-finals-ba-venues.json";

export const prerender = true;

const pageTitle = "Where to watch the 2026 World Cup semis & final in Buenos Aires";
const pageDescription =
  "Buenos Aires spots with confirmed World Cup semi/final screening at 16:00 BA time: Plaza Seeber Fan Fest, Locos x el Fútbol, BetWarrior, Cantina Recoleta and other verified rooms.";
const themeColorLight = "#f7f2e7";
const themeColorDark = "#17130d";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const checkedDate = "July 12, 2026";
const googleMapsApiKey =
  import.meta.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
  process.env.GOOGLE_MAPS_API_KEY_PUBLIC ??
  "";

const categoryLabels: Record<string, string> = {
  public: "Public screening",
  indoor: "Indoor bar",
  neighborhood: "Neighborhood",
};

const venueMapData = venueGeoData.venues
  .filter((venue) => venue.location)
  .map((venue) => ({
    id: venue.id,
    name: venue.name,
    address: venue.address,
    category: venue.category,
    categoryLabel: categoryLabels[venue.category] ?? venue.category,
    status: venue.status,
    googleMapsUrl: venue.googleMapsUrl,
    position: venue.location,
    acceptsReservations: Boolean(venue.acceptsReservations),
    reservationUrl: venue.reservationUrl ?? null,
  }));

type Match = {
  label: string;
  date: string;
  note?: string;
};

type Venue = {
  name: string;
  address: string;
  neighborhood?: string;
  status: string;
  detail: string;
  mapsQuery: string;
  source?: string;
  highlight?: boolean;
  warning?: boolean;
  acceptsReservations?: boolean;
  reservationUrl?: string;
};

const mapsIcon = `<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="#1a73e8" d="M12 2.2c3.9 0 7.1 3.1 7.1 7 0 5.1-7.1 12.6-7.1 12.6S4.9 14.3 4.9 9.2c0-3.9 3.2-7 7.1-7Z"/><path fill="#34a853" d="M7.2 14.1 12 21.8l4.8-7.7-4.8-2.8-4.8 2.8Z"/><path fill="#fbbc04" d="M4.9 9.2c0 1.8.9 3.5 2.3 4.9l4.8-2.8V2.2c-3.9 0-7.1 3.1-7.1 7Z"/><path fill="#ea4335" d="M19.1 9.2c0 1.8-.9 3.5-2.3 4.9L12 11.3V2.2c3.9 0 7.1 3.1 7.1 7Z"/><circle cx="12" cy="9.3" r="2.45" fill="#fff"/></svg>`;
const reservationIcon = `<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="currentColor" d="M7 2.75a.75.75 0 0 1 .75.75V5h8.5V3.5a.75.75 0 0 1 1.5 0V5H19a2 2 0 0 1 2 2v12.25A2.75 2.75 0 0 1 18.25 22H5.75A2.75 2.75 0 0 1 3 19.25V7a2 2 0 0 1 2-2h1.25V3.5A.75.75 0 0 1 7 2.75Zm12 7.75H5v8.75c0 .69.56 1.25 1.25 1.25h12.5c.69 0 1.25-.56 1.25-1.25V10.5ZM5 7v2h14V7a.5.5 0 0 0-.5-.5H5.5A.5.5 0 0 0 5 7Zm4.22 5.22a.75.75 0 0 1 1.06 0l1.47 1.47 3.47-3.47a.75.75 0 1 1 1.06 1.06l-4 4a.75.75 0 0 1-1.06 0l-2-2a.75.75 0 0 1 0-1.06Z"/></svg>`;

const mapsUrl = (query: string) =>
  `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(query)}`;

const matches: Match[] = [
  {
    label: "France–Spain",
    date: "Tuesday, July 14",
    note: "Smaller crowds — walk-in almost anywhere.",
  },
  {
    label: "Argentina–England",
    date: "Wednesday, July 15",
    note: "Reserve by Monday.",
  },
  {
    label: "Final",
    date: "Sunday, July 19",
    note: "Reserve right after the second semifinal.",
  },
];

const publicVenues: Venue[] = [
  {
    name: "Buenos Aires Fan Fest — Plaza Seeber",
    address: "Av. del Libertador & Av. Sarmiento, Palermo",
    neighborhood: "Palermo",
    status: "Confirmed Jul 14 / 15 / 18 / 19",
    detail:
      "Official City listing: opens 12:00 on the semifinal days, third-place day and final. Free, giant screen, food court, performances. Nearest subte: Plaza Italia (Line D), ~5 blocks; Line D hours extend on Argentina match days. Reserve via Boti (WhatsApp 11-5050-0147, message \"Mundial\") / Entradas BA if live. Arrive 12:30–13:00 for a semifinal; use the 12:00 opening for the final.",
    mapsQuery: "Plaza Seeber Av. del Libertador Av. Sarmiento Palermo Buenos Aires",
    source: "linda.buenosaires.gob.ar",
    highlight: true,
    acceptsReservations: true,
    reservationUrl: "https://wa.me/5491150500147?text=Mundial",
  },
];

const indoorBars: Venue[] = [
  {
    name: "Locos x el Fútbol",
    address: "Av. Las Heras 2101, Recoleta",
    neighborhood: "Recoleta",
    status: "All matches · opens 10:00",
    detail:
      "Time Out lists every World Cup match on the giant screen and wall TVs; opens Tuesday–Sunday from 10:00, so the 16:00 kickoffs fit. On Argentina days the street often closes and police attend — reserve.",
    mapsQuery: "Locos x el Futbol Av. Las Heras 2101 Recoleta Buenos Aires",
    source: "Time Out BA · El Destape",
    highlight: true,
    acceptsReservations: true,
    reservationUrl: "https://fiweex.com/reservas_portal_bienvenida/ZoN1gA==",
  },
  {
    name: "BetWarrior Sport Bar",
    address: "Av. del Libertador 4101, inside Hipódromo de Palermo",
    neighborhood: "Palermo",
    status: "Biggest indoor room",
    detail:
      "Hipódromo promoted World Cup viewing here; one of the largest sports bars in the city with multiple enormous screens. Daytime hours start by early afternoon.",
    mapsQuery: "BetWarrior Sport Bar Hipódromo de Palermo Buenos Aires",
    source: "Hipódromo Palermo · Baires Secreta",
    highlight: true,
  },
  {
    name: "Cantina Recoleta",
    address: "Av. Santa Fe 1430",
    neighborhood: "Recoleta",
    status: "All matches · 09:00–01:00",
    detail:
      "Ámbito: three giant screens and live transmission of every tournament match for the whole World Cup, with extended all-day hours and table reservations. Strong seated option with a real meal.",
    mapsQuery: "Cantina Recoleta Av. Santa Fe 1430 Buenos Aires",
    source: "Ámbito",
    highlight: true,
    acceptsReservations: true,
    reservationUrl: "https://www.wokiapp.com/restaurante/cantina-recoleta",
  },
  {
    name: "Triumph Sports Bar",
    address: "Bernardo de Irigoyen 19, Microcentro",
    neighborhood: "Microcentro",
    status: "Near Obelisco · opens early",
    detail:
      "El Destape listed it for Argentina knockout viewing: multiple large screens a short walk from the Obelisco. Watch indoors, then walk over only after a confirmed win.",
    mapsQuery: "Triumph Sports Bar Bernardo de Irigoyen 19 Buenos Aires",
    source: "El Destape · Baires Secreta",
    acceptsReservations: true,
    reservationUrl: "https://wa.me/5491127400244",
  },
  {
    name: "Sullivan's Irish Pub",
    address: "Jorge Luis Borges 1702, Palermo Soho",
    neighborhood: "Palermo Soho",
    status: "Opens from 09:00",
    detail:
      "Publishing Argentina match days through the tournament; multi-floor Irish sports pub with 8+ screens, rooftop and mixed local/international crowd.",
    mapsQuery: "Sullivan's Irish Pub Jorge Luis Borges 1702 Palermo Buenos Aires",
    source: "Sullivan's IG · Baires Secreta",
    acceptsReservations: true,
    reservationUrl: "https://wa.me/5491135784811",
  },
  {
    name: "La Puerta Roja",
    address: "Chacabuco 733, San Telmo",
    neighborhood: "San Telmo",
    status: "All matches · from noon",
    detail:
      "Time Out: transmitting every World Cup match; opens from noon (well before 16:00). Hidden red-door bar with big screen, pool table and backpacker-and-locals crowd.",
    mapsQuery: "La Puerta Roja Chacabuco 733 San Telmo Buenos Aires",
    source: "Time Out BA",
    acceptsReservations: true,
    reservationUrl: "https://www.instagram.com/puertaroja.santelmo/",
  },
];

const neighborhoodSpots: Venue[] = [
  {
    name: "La Farola",
    address: "Amenábar 1602, Belgrano (and other CABA branches)",
    neighborhood: "Belgrano",
    status: "All matches · from early morning",
    detail:
      "Time Out: transmitting every World Cup match from the early afternoon, with daily hours from early morning until midnight — covers the Tuesday/Wednesday semis and Sunday final at 16:00. Classic milanesas/pizza chain; Amenábar is the Belgrano flagship listed by Time Out.",
    mapsQuery: "La Farola Amenábar 1602 Belgrano Buenos Aires",
    source: "Time Out BA",
    highlight: true,
    acceptsReservations: true,
    reservationUrl: "https://wa.me/5491147803526",
  },
  {
    name: "Hell's Pizza",
    address: "Humboldt 1654, Palermo (also Devoto and other branches)",
    neighborhood: "Palermo",
    status: "Argentina · semis + final",
    detail:
      "3copas / Hell’s: live projector screening for every Argentina World Cup match including the semis and final, with salón service from about noon. Confirmed for Argentina’s remaining 16:00 games — not claimed for France–Spain.",
    mapsQuery: "Hell's Pizza Humboldt 1654 Palermo Buenos Aires",
    source: "3copas · Hell’s IG",
    highlight: true,
    acceptsReservations: true,
    reservationUrl: "https://wa.me/5491128564402",
  },
  {
    name: "Roma del Abasto",
    address: "Anchorena 806, Abasto",
    neighborhood: "Abasto",
    status: "All matches",
    detail:
      "Time Out: transmitting every World Cup match with tournament promos (Quilmes 2x1, pizza deals). Classic porteño bar/pizzeria open from midday.",
    mapsQuery: "Roma del Abasto Anchorena 806 Buenos Aires",
    source: "Time Out BA",
    acceptsReservations: true,
    reservationUrl: "https://www.instagram.com/romadelabasto/",
  },
  {
    name: "Pizzería Nani",
    address: "Av. Francisco Beiró 4819, Villa Devoto",
    neighborhood: "Villa Devoto",
    status: "All matches · 20+ screens · from 08:00",
    detail:
      "Time Out: every World Cup match in a football-themed room with 20+ screens. Opens early enough for any 16:00 kickoff.",
    mapsQuery: "Pizzería Nani Av. Francisco Beiró 4819 Villa Devoto Buenos Aires",
    source: "Time Out BA",
    acceptsReservations: true,
    reservationUrl: "https://wa.me/5491151490966",
  },
  {
    name: "Bilbao",
    address: "Thames 1795, Palermo",
    neighborhood: "Palermo",
    status: "WC matches · all day on Argentina dates",
    detail:
      "La Nación: transmitting World Cup matches, with all-day service when Argentina plays. Tapas, vermouth and cocktails; opens from 10:00.",
    mapsQuery: "Bilbao Thames 1795 Palermo Buenos Aires",
    source: "La Nación",
    acceptsReservations: true,
    reservationUrl: "https://www.opentable.com/r/bilbao-palermo-buenos-aires",
  },
  {
    name: "Burgio",
    address: "Av. Cabildo 2477, Belgrano",
    neighborhood: "Belgrano",
    status: "All matches · opens early",
    detail:
      "Time Out: screens for every World Cup match; historic Belgrano pizzeria open from early morning with tournament merch and promos. Walk-in only — they do not take reservations.",
    mapsQuery: "Burgio Av. Cabildo 2477 Belgrano Buenos Aires",
    source: "Time Out BA",
  },
  {
    name: "El Banderín",
    address: "Guardia Vieja 3601, Almagro",
    neighborhood: "Almagro",
    status: "Confirmed WC screening",
    detail:
      "Hosted Japan’s ambassador for a World Cup group-stage match; walls of 500+ club pennants. Character over 4K — confirm the specific semi/final still, but screening is proven this tournament. No reservations.",
    mapsQuery: "El Banderín Guardia Vieja 3601 Almagro Buenos Aires",
    source: "CEMBA / press",
  },
];

const geoByName = new Map(
  venueGeoData.venues.map((venue) => [venue.name, venue] as const),
);

const allVenuesForSchema = [
  ...publicVenues,
  ...indoorBars,
  ...neighborhoodSpots,
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  numberOfItems: allVenuesForSchema.length,
  itemListElement: allVenuesForSchema.map((venue, index) => {
    const geo = geoByName.get(venue.name);
    return {
      "@type": "ListItem",
      position: index + 1,
      item: {
        "@type": "BarOrPub",
        name: venue.name,
        address: venue.address,
        description: venue.detail,
        url: geo?.googleMapsUrl ?? mapsUrl(venue.mapsQuery),
        ...(geo?.location
          ? {
              geo: {
                "@type": "GeoCoordinates",
                latitude: geo.location.lat,
                longitude: geo.location.lng,
              },
            }
          : {}),
      },
    };
  }),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta
      name="subject"
      content="Where to watch FIFA World Cup 2026 semifinals and final in Buenos Aires"
    />
    <meta name="application-name" content={pageTitle} />
    <meta
      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="googlebot"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <meta
      name="keywords"
      content="FIFA 2026 Buenos Aires, where to watch World Cup final Buenos Aires, Plaza Seeber Fan Fest, Locos x el Futbol, Argentina England semis bars"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta
      name="theme-color"
      content={themeColorLight}
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content={themeColorDark}
      media="(prefers-color-scheme: dark)"
    />
    <meta name="msapplication-TileColor" content={themeColorDark} />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color={themeColorDark} />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="sokolsky.me" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <main class="page">
      <header class="hero">
        <div class="topbar">
          <a class="home-link" href="/" aria-label="Back to home">sokolsky.me</a>
          <p class="updated">Checked {checkedDate}</p>
        </div>

        <div class="hero-grid">
          <div>
            <p class="eyebrow">Buenos Aires · FIFA 2026</p>
            <h1>{pageTitle}</h1>
            <p class="dek">
              All three matches kick off at <strong>16:00 (4pm) Buenos Aires time</strong>.
              This list keeps only places with current confirmation they can host that
              afternoon kickoff — night-only World Cup plans and bars that open at/after
              17:00 are out.
            </p>
          </div>

          <aside class="kickoff-note" aria-label="Reservation timing">
            <span>Reservation window</span>
            <strong>Reserve by Monday for Argentina–England.</strong>
            <p>
              For the final, lock something in immediately after the second semifinal.
              Streaming-at-home options:
              <a href="/misc/fifa-2026-streaming/">FIFA 2026 streaming guide</a>.
            </p>
          </aside>
        </div>

        <div class="match-row" aria-label="Match schedule">
          {matches.map((match) => (
            <article class="match-card">
              <p>{match.date}</p>
              <h2>{match.label}</h2>
              {match.note && <span>{match.note}</span>}
            </article>
          ))}
        </div>
      </header>

      <section class="region" id="public-screenings" aria-labelledby="public-heading">
        <div class="region-heading">
          <p class="eyebrow">Official public screening</p>
          <h2 id="public-heading">Plaza Seeber Fan Fest</h2>
          <p>
            The only City-listed free screen with published dates for July 14, 15, 18 and
            19. Parque Los Andes is finished and not on the semis/final calendar.
          </p>
        </div>

        <div class="venue-grid">
          {publicVenues.map((venue) => (
            <article
              class:list={["venue-card", venue.highlight && "is-pick"]}
              data-venue-card
              data-accepts-reservations={venue.acceptsReservations ? "true" : "false"}
            >
              <div class="option-topline">
                <span>{venue.status}</span>
                {venue.neighborhood && <strong>{venue.neighborhood}</strong>}
              </div>
              <div class="venue-title-row">
                <h3>
                  <a href={mapsUrl(venue.mapsQuery)} target="_blank" rel="noreferrer noopener">
                    {venue.name}
                  </a>
                </h3>
                <div class="venue-actions">
                  <a
                    class="maps-link"
                    href={mapsUrl(venue.mapsQuery)}
                    target="_blank"
                    rel="noreferrer noopener"
                    aria-label={`Open ${venue.name} on Google Maps`}
                    title="Open in Google Maps"
                  >
                    <span class="maps-icon" set:html={mapsIcon} />
                  </a>
                  {venue.acceptsReservations && venue.reservationUrl && (
                    <a
                      class="reservation-link"
                      href={venue.reservationUrl}
                      target="_blank"
                      rel="noreferrer noopener"
                      aria-label={`Book or reserve at ${venue.name}`}
                      title="Accepts reservations — open booking"
                    >
                      <span class="reservation-icon" set:html={reservationIcon} />
                    </a>
                  )}
                </div>
              </div>
              <p class="address">{venue.address}</p>
              <p class="detail">{venue.detail}</p>
              {venue.source && <p class="source-tag">Source: {venue.source}</p>}
            </article>
          ))}
        </div>
      </section>

      <section class="region" id="indoor-bars" aria-labelledby="indoor-heading">
        <div class="region-heading">
          <p class="eyebrow">Confirmed indoor bars</p>
          <h2 id="indoor-heading">Open early enough for 16:00</h2>
          <p>
            Each of these has a current World Cup screening claim plus hours that cover
            an afternoon kickoff.
          </p>
        </div>

        <div class="venue-grid">
          {indoorBars.map((venue) => (
            <article
              class:list={["venue-card", venue.highlight && "is-pick"]}
              data-venue-card
              data-accepts-reservations={venue.acceptsReservations ? "true" : "false"}
            >
              <div class="option-topline">
                <span>{venue.status}</span>
                {venue.neighborhood && <strong>{venue.neighborhood}</strong>}
              </div>
              <div class="venue-title-row">
                <h3>
                  <a href={mapsUrl(venue.mapsQuery)} target="_blank" rel="noreferrer noopener">
                    {venue.name}
                  </a>
                </h3>
                <div class="venue-actions">
                  <a
                    class="maps-link"
                    href={mapsUrl(venue.mapsQuery)}
                    target="_blank"
                    rel="noreferrer noopener"
                    aria-label={`Open ${venue.name} on Google Maps`}
                    title="Open in Google Maps"
                  >
                    <span class="maps-icon" set:html={mapsIcon} />
                  </a>
                  {venue.acceptsReservations && venue.reservationUrl && (
                    <a
                      class="reservation-link"
                      href={venue.reservationUrl}
                      target="_blank"
                      rel="noreferrer noopener"
                      aria-label={`Book or reserve at ${venue.name}`}
                      title="Accepts reservations — open booking"
                    >
                      <span class="reservation-icon" set:html={reservationIcon} />
                    </a>
                  )}
                </div>
              </div>
              <p class="address">{venue.address}</p>
              <p class="detail">{venue.detail}</p>
              {venue.source && <p class="source-tag">Source: {venue.source}</p>}
            </article>
          ))}
        </div>
      </section>

      <section class="region" id="neighborhood" aria-labelledby="neighborhood-heading">
        <div class="region-heading">
          <p class="eyebrow">Neighborhood spots</p>
          <h2 id="neighborhood-heading">Confirmed porteño rooms</h2>
          <p>Bars and pizzerias with current World Cup transmission notes and daytime hours.</p>
        </div>

        <div class="venue-grid venue-grid--compact">
          {neighborhoodSpots.map((venue) => (
            <article
              class="venue-card"
              data-venue-card
              data-accepts-reservations={venue.acceptsReservations ? "true" : "false"}
            >
              <div class="option-topline">
                <span>{venue.status}</span>
                {venue.neighborhood && <strong>{venue.neighborhood}</strong>}
              </div>
              <div class="venue-title-row">
                <h3>
                  <a href={mapsUrl(venue.mapsQuery)} target="_blank" rel="noreferrer noopener">
                    {venue.name}
                  </a>
                </h3>
                <div class="venue-actions">
                  <a
                    class="maps-link"
                    href={mapsUrl(venue.mapsQuery)}
                    target="_blank"
                    rel="noreferrer noopener"
                    aria-label={`Open ${venue.name} on Google Maps`}
                    title="Open in Google Maps"
                  >
                    <span class="maps-icon" set:html={mapsIcon} />
                  </a>
                  {venue.acceptsReservations && venue.reservationUrl && (
                    <a
                      class="reservation-link"
                      href={venue.reservationUrl}
                      target="_blank"
                      rel="noreferrer noopener"
                      aria-label={`Book or reserve at ${venue.name}`}
                      title="Accepts reservations — open booking"
                    >
                      <span class="reservation-icon" set:html={reservationIcon} />
                    </a>
                  )}
                </div>
              </div>
              <p class="address">{venue.address}</p>
              <p class="detail">{venue.detail}</p>
              {venue.source && <p class="source-tag">Source: {venue.source}</p>}
            </article>
          ))}
        </div>
      </section>

      <section class="region venue-map-section" id="map" aria-labelledby="venue-map-heading">
        <div class="region-heading">
          <p class="eyebrow">Map</p>
          <h2 id="venue-map-heading">All listed spots</h2>
          <p id="venue-map-status" class="map-status">
            Showing {venueMapData.length} venues across Buenos Aires.
          </p>
        </div>

        <div class="map-filters" role="group" aria-label="Filter map by venue type">
          <button type="button" class="map-filter is-active" data-map-filter="">
            All
          </button>
          {
            Object.entries(categoryLabels).map(([value, label]) => (
              <button type="button" class="map-filter" data-map-filter={value}>
                {label}
              </button>
            ))
          }
          <button
            type="button"
            class="map-filter map-filter--toggle"
            data-reservation-filter
            aria-pressed="false"
          >
            Accepts reservations
          </button>
        </div>

        {
          googleMapsApiKey ? (
            <div
              id="venue-map"
              class="venue-map"
              aria-label="Google Map with pins for FIFA 2026 watch spots in Buenos Aires"
            ></div>
          ) : (
            <p class="map-unavailable">
              Map unavailable because the Google Maps public key is not configured.
            </p>
          )
        }
      </section>
    </main>

    <style>
