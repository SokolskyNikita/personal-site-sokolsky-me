    <script is:inline>
      const languageCopy = {
        en: {
          documentLang: "en",
          title: "Argentina's Independence Day: much more than you wanted to know",
        description:
          "A researched account of 9 July 1816: the Congreso de Tucumán, why it is not the May Revolution, the Casa Histórica and how the holiday has been rewritten.",
          homeLabel: "Back to home",
          navLabel: "Language"
        },
        es: {
          documentLang: "es-AR",
          title: "Día de la Independencia argentina: mucho más de lo que querías saber",
        description:
          "Un relato documentado sobre el 9 de julio de 1816: el Congreso de Tucumán, por qué no es la Revolución de Mayo, la Casa Histórica y cómo se reescribió la fiesta.",
          homeLabel: "Volver al inicio",
          navLabel: "Idioma"
        }
      };

      const panels = document.querySelectorAll("[data-language-panel]");
      const toggles = document.querySelectorAll("[data-language-toggle]");
      const title = document.querySelector("[data-language-title]");
      const dek = document.querySelector("[data-language-dek]");
      const description = document.querySelector('meta[name="description"]');
      const homeLink = document.querySelector(".home-link");
      const switcher = document.querySelector(".language-switch");

      function setLanguage(language, updateUrl = true) {
        const nextLanguage = language === "es" ? "es" : "en";
        const copy = languageCopy[nextLanguage];

        document.documentElement.lang = copy.documentLang;
        document.title = copy.title;
        title.textContent = title.dataset[nextLanguage];
        dek.textContent = dek.dataset[nextLanguage];
        description?.setAttribute("content", description.dataset[nextLanguage] ?? copy.description);
        homeLink?.setAttribute("aria-label", copy.homeLabel);
        switcher?.setAttribute("aria-label", copy.navLabel);

        panels.forEach((panel) => {
          panel.hidden = panel.dataset.languagePanel !== nextLanguage;
        });

        toggles.forEach((toggle) => {
          const isCurrent = toggle.dataset.languageToggle === nextLanguage;
          toggle.setAttribute("aria-pressed", String(isCurrent));
        });

        localStorage.setItem("independence-day-language", nextLanguage);

        if (updateUrl) {
          const nextHash = nextLanguage === "es" ? "#es" : location.pathname + location.search;
          history.replaceState(null, "", nextHash);
        }
      }

      toggles.forEach((toggle) => {
        toggle.addEventListener("click", () => {
          setLanguage(toggle.dataset.languageToggle);
        });
      });

      const initialLanguage =
        location.hash === "#es" ? "es" : localStorage.getItem("independence-day-language") === "es" ? "es" : "en";

      setLanguage(initialLanguage, false);
    </script>

