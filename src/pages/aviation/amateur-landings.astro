---
export const prerender = true;

const pageTitle =
  "When the pilot collapses: documented cases of amateurs landing the plane";
const pageDescription =
  "Documented cases of passengers and undertrained pilots landing aircraft after pilot incapacitation, including fatal attempts and why airliners are different.";
const themeColorLight = "#fafbfc";
const themeColorDark = "#10151a";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  author: {
    "@type": "Person",
    name: "Nikita Sokolsky",
  },
  about: {
    "@type": "Thing",
    name: "Pilot incapacitation and passenger landings",
  },
  inLanguage: "en",
};

type Experience =
  | "non-pilot"
  | "trainee"
  | "lapsed"
  | "licensed-unfamiliar"
  | "commercial-unqualified";

type CaseOutcome = "success" | "partial" | "failure";

type LandingCase = {
  id: string;
  when: string;
  where: string;
  aircraft?: string;
  passenger: string;
  experience: Experience;
  outcome: CaseOutcome;
  /** HTML with short inline source links (anchor text ≤4 words). */
  body: string;
};

const experienceLabels: Record<Experience, string> = {
  "non-pilot": "Non-pilot",
  trainee: "Trainee",
  lapsed: "Lapsed / rusty",
  "licensed-unfamiliar": "Licensed, unfamiliar type",
  "commercial-unqualified": "CPL, not type-qualified",
};

const successes: LandingCase[] = [
  {
    id: "1974-75-unnamed",
    when: "June 1974",
    where: "McGuire AFB, New Jersey",
    aircraft: "Piper Cherokee",
    passenger: "Martha Waite",
    experience: "non-pilot",
    outcome: "partial",
    body: `An <a href="https://pubmed.ncbi.nlm.nih.gov/708352/" target="_blank" rel="noopener noreferrer">aviation-medical study</a> by Mohler and Booze of 13 US general-aviation pilots who died of cardiovascular disease in flight during 1974–75 records that one pilot's wife, a non-pilot, landed the aircraft. Press coverage identifies her as Martha Waite: after William Waite, 52, suffered a fatal heart seizure in their Piper Cherokee, controllers and a shadow aircraft talked her into a crash-landing at McGuire Air Force Base (<a href="https://www.nytimes.com/1974/06/17/archives/wife-lands-plane-safely-as-man-dies-at-controls.html" target="_blank" rel="noopener noreferrer">New York Times</a>). Gear and propeller were damaged; nobody else was hurt.`,
  },
  {
    id: "1985-lansing",
    when: "July 1985",
    where: "Lansing, Michigan",
    aircraft: "Cessna",
    passenger: "Unnamed passenger",
    experience: "trainee",
    outcome: "success",
    body: `A passenger who had reportedly flown a plane only once brought a single-engine airplane down safely at Capital City Airport in Lansing after the pilot suffered a fatal heart attack mid-flight (<a href="https://www.wsj.com/articles/BL-MSB-3586" target="_blank" rel="noopener noreferrer">Wall Street Journal</a>).`,
  },
  {
    id: "1996-renton",
    when: "March 20, 1996",
    where: "Renton, Washington",
    aircraft: "Cessna U206E floatplane",
    passenger: "Leland Capps",
    experience: "non-pilot",
    outcome: "partial",
    body: `Leland Capps, 52, had limited flying experience but was not a pilot when Raymond Ihrke suffered a fatal heart attack in a Cessna U206E floatplane. Capps called Renton tower, where a controller who was also a flight instructor talked him down. After an unsuccessful first approach, he landed hard beside the paved runway; the floats collapsed and the aircraft sustained substantial damage (<a href="https://aviation-safety.net/wikibase/31201" target="_blank" rel="noopener noreferrer">NTSB case summary</a>; <a href="https://www.spokesman.com/stories/1996/mar/21/man-lands-plane-after-pilot-dies/" target="_blank" rel="noopener noreferrer">contemporary report</a>). Capps was treated for minor injuries and released.`,
  },
  {
    id: "1998-mount-comfort",
    when: "June 17, 1998",
    where: "Greenfield, Indiana",
    aircraft: "Cessna 172R",
    passenger: "Unnamed passenger",
    experience: "non-pilot",
    outcome: "partial",
    body: `An 81-year-old non-pilot took over a Cessna 172R after its pilot suffered a fatal heart attack near Greenfield, Indiana. A commercial pilot in another airplane coached him into Mount Comfort Airport. The Cessna bounced; the passenger's recovery attempt overloaded and collapsed the nose gear, but he was not injured (<a href="https://aviation-safety.net/wikibase/34738" target="_blank" rel="noopener noreferrer">NTSB case summary</a>; <a href="https://www.orlandosentinel.com/1998/06/18/pilot-dies-at-controls-passenger-lands-plane/" target="_blank" rel="noopener noreferrer">contemporary report</a>).`,
  },
  {
    id: "1998-mineral-wells",
    when: "November 10, 1998",
    where: "Mineral Wells, Texas",
    aircraft: "Piper PA-23-235 Apache",
    passenger: "Unnamed pilot-rated passenger",
    experience: "licensed-unfamiliar",
    outcome: "success",
    body: `A 600-hour pilot rated only for single-engine aircraft took over a twin-engine Piper Apache after its owner-pilot became incapacitated during a practice approach near Mineral Wells. An airline pilot coached the passenger by radio. He landed without damage or injury; emergency personnel met the airplane, but the original pilot died (<a href="https://data.ntsb.gov/carol-repgen/api/Aviation/ReportMain/GenerateNewestReport/45284/pdf" target="_blank" rel="noopener noreferrer">NTSB final report</a>; <a href="https://aviation-safety.net/wikibase/40066" target="_blank" rel="noopener noreferrer">case summary</a>).`,
  },
  {
    id: "2000-winter-haven",
    when: "August 5, 2000",
    where: "Winter Haven, Florida",
    aircraft: "Piper Cherokee Six",
    passenger: "Henry Anhalt",
    experience: "non-pilot",
    outcome: "partial",
    body: `Pilot Kristopher Pearce, 36, collapsed at the controls of a Piper Cherokee Six / Saratoga and later died of an apparent heart attack. Passenger Henry Anhalt, 33, who had never flown an aircraft, took over with his wife and three sons aboard. He transmitted a mayday. Flight instructor Dan McCullough, airborne nearby giving instrument lessons, talked him down as fuel ran low (<a href="https://www.aopa.org/news-and-media/all-news/2000/october/pilot/pilot-briefing-(10)" target="_blank" rel="noopener noreferrer">AOPA Pilot briefing</a>; <a href="https://www.theledger.com/story/news/2000/08/13/faa-thanks-rescue-pilot/8091204007/" target="_blank" rel="noopener noreferrer">Ledger coverage</a>). Anhalt bounced, ran off the runway and caused minor damage; nobody was hurt.`,
  },
  {
    id: "2002-cape-cod",
    when: "February 8, 2002",
    where: "Provincetown, Massachusetts",
    aircraft: "Cessna 402",
    passenger: "Melanie Oswalt",
    experience: "trainee",
    outcome: "partial",
    body: `Melanie Oswalt, a Cape Air employee and student pilot with roughly 48 hours of training, took the controls of a twin-engine Cessna 402 after pilot Ronald Crews became incoherent from an insulin reaction on a Cape Air flight from Martha's Vineyard toward Hyannis (<a href="https://avweb.com/news/jail-for-diabetic-pilot/" target="_blank" rel="noopener noreferrer">AVweb report</a>; <a href="https://www.capecodtimes.com/story/news/2002/02/12/emergency-pilot-conquered-long-odds/50910986007/" target="_blank" rel="noopener noreferrer">Cape Cod Times</a>). Other passengers restrained Crews. With the intended airport behind them and Provincetown closed and unmanned, she crash-landed gear-up beside the runway. Everyone aboard survived.`,
  },
  {
    id: "2005-north-las-vegas",
    when: "May 5, 2005",
    where: "North Las Vegas, Nevada",
    aircraft: "Gulfstream 695A",
    passenger: "Unnamed passenger",
    experience: "non-pilot",
    outcome: "partial",
    body: `The pilot of a pressurized twin-turboprop Gulfstream 695A became incapacitated and died while flying from North Las Vegas to San Diego. A right-seat passenger with no piloting experience took control while the other passenger worked the radio. On the fourth landing attempt, the amateur pilot stalled at low altitude and the airplane struck terrain flat on its belly a few hundred feet short of the runway (<a href="https://data.ntsb.gov/carol-repgen/api/Aviation/ReportMain/GenerateNewestReport/61404/pdf" target="_blank" rel="noopener noreferrer">NTSB final report</a>; <a href="https://www.aopa.org/training-and-safety/air-safety-institute/accident-analysis/featured-accidents/epilot-asf-accident-reports-pilot-conks-out-passengers-save-the-day" target="_blank" rel="noopener noreferrer">AOPA case review</a>). One passenger was seriously injured and the other received minor injuries, but both survived.`,
  },
  {
    id: "2009-fort-myers",
    when: "April 12, 2009",
    where: "Fort Myers, Florida",
    aircraft: "Beechcraft King Air 200",
    passenger: "Doug White",
    experience: "licensed-unfamiliar",
    outcome: "success",
    body: `Doug White, a 56-year-old Louisiana pharmacist flying home from his brother's funeral with his wife and two daughters, watched charter pilot Joe Cabuk die shortly after takeoff in a Beechcraft King Air 200. White held a private certificate with about 230 hours, all in Cessna 172s. He had never flown the larger, faster twin turboprop or flown from the right seat (<a href="https://www.aopa.org/news-and-media/all-news/2009/april/14/unintentional-king-air-pilot-an-interview-with-doug-white" target="_blank" rel="noopener noreferrer">AOPA interview</a>; <a href="https://www.nbcnews.com/id/wbna30190350" target="_blank" rel="noopener noreferrer">NBC News report</a>). His questions ran through a relay: Fort Myers controllers Brian Norton and Dan Favio phoned Connecticut King Air instructor Kari Sorenson on his personal cell phone. Sorenson's core advice was to fly it like a single. White made what he called a "greaser" landing. Sorenson later said he did not think you could have made the plane more complex or the pilot less experienced and still have succeeded. The story became the <a href="https://en.wikipedia.org/wiki/Doug_White_(aviator)" target="_blank" rel="noopener noreferrer">2023 film adaptation</a>.`,
  },
  {
    id: "2011-california-colorado",
    when: "May 27, 2011",
    where: "En route from California to Colorado",
    passenger: "Unnamed woman",
    experience: "non-pilot",
    outcome: "success",
    body: `A woman landed the plane, its type unrecorded in press accounts, after her husband, the pilot, had trouble breathing. Another pilot in the air talked her down (<a href="https://en.wikipedia.org/wiki/Talk-down_aircraft_landing" target="_blank" rel="noopener noreferrer">talk-down landing list</a>).`,
  },
  {
    id: "2012-sturgeon-bay",
    when: "April 2, 2012",
    where: "Sturgeon Bay, Wisconsin",
    aircraft: "Cessna 414",
    passenger: "Helen Collins",
    experience: "lapsed",
    outcome: "partial",
    body: `Helen Collins, 80, took over a twin-engine Cessna 414 after her husband John, 81, lost consciousness from a heart attack he did not survive. She had some flight training decades earlier but hadn't piloted in years and had never flown the twin (<a href="https://abcnews.com/US/wisconsin-wife-80-lands-plane-dying-pilot-husband/story?id=16062534" target="_blank" rel="noopener noreferrer">ABC News report</a>; <a href="https://www.csmonitor.com/USA/Latest-News-Wires/2012/0403/An-80-year-old-woman-lands-plane-after-pilot-passes-out" target="_blank" rel="noopener noreferrer">CS Monitor wire</a>). Her son and an instructor coached her by radio while another pilot flew a shadow aircraft off her wing. She circled for about 90 minutes practicing approaches as one engine ran dry and the other sputtered, then put the plane down hard. The nose gear collapsed and it skidded about 1,000 feet. Collins survived with a crushed vertebra and a cracked rib.`,
  },
  {
    id: "2013-humberside",
    when: "October 8, 2013",
    where: "Humberside, England",
    aircraft: "Cessna 172",
    passenger: "John Wildey",
    experience: "non-pilot",
    outcome: "partial",
    body: `John Wildey, 77, a former RAF serviceman who had never been a pilot, took control of a Cessna 172 after the pilot collapsed and later died. Wildey flew for over an hour in darkness, at first unable to work the controls or the lighting, while instructor Roy Murray and colleagues talked him through repeated approaches (<a href="https://www.bbc.com/news/uk-england-humber-24457031" target="_blank" rel="noopener noreferrer">BBC News report</a>; <a href="https://www.theguardian.com/uk-news/2013/oct/09/passenger-landing-plane-passenger" target="_blank" rel="noopener noreferrer">Guardian interview</a>). He landed on the fourth attempt, a controlled crash rough enough to throw sparks, with a punctured tire the main damage. The incident became the television documentary <cite>Mayday: The Passenger Who Landed a Plane</cite>.`,
  },
  {
    id: "2017-alta-gracia",
    when: "April 22, 2017",
    where: "Alta Gracia, Argentina",
    passenger: "Néstor Sargioto",
    experience: "trainee",
    outcome: "partial",
    body: `Néstor Sargioto, 33, a trainee with basic flying knowledge but none in the larger aircraft involved, took the controls after pilot Rodolfo Ostermeyer suffered convulsions and lost consciousness near the Alta Gracia aeroclub (<a href="https://eldoce.tv/sociedad/el-piloto-se-desmayo-y-un-pasajero-aterrizo-el-avion-aeroclub-alta-gracia_40353/" target="_blank" rel="noopener noreferrer">El Doce report</a>). He contacted emergency services and circled the town while receiving instructions. He didn't know how to lower the landing gear, so he landed without it. All four occupants survived, and the pilot regained consciousness after landing.`,
  },
  {
    id: "2019-jandakot",
    when: "August 31, 2019",
    where: "Jandakot, Australia",
    aircraft: "Cessna 152",
    passenger: "Max Sylvester",
    experience: "trainee",
    outcome: "success",
    body: `Max Sylvester, 29, was on an early flying lesson and his first in that Cessna 152 when instructor Robert Mollard blacked out and slumped onto his shoulder. Sylvester had never landed an aircraft. Controllers coached him through practice approaches, and after nearly an hour alone at the controls he landed cleanly (<a href="https://www.abc.net.au/news/2019-09-01/trainee-pilot-makes-emergency-landing-jandakot/11468580" target="_blank" rel="noopener noreferrer">ABC News Australia</a>; <a href="https://nypost.com/2019/09/03/student-pilot-lands-plane-during-first-lesson-after-instructor-loses-consciousness/" target="_blank" rel="noopener noreferrer">New York Post</a>). The instructor survived; he was later diagnosed with a brain tumour.`,
  },
  {
    id: "2022-palm-beach",
    when: "May 10, 2022",
    where: "Palm Beach, Florida",
    aircraft: "Cessna 208 Caravan",
    passenger: "Darren Harrison",
    experience: "non-pilot",
    outcome: "success",
    body: `Pilot Ken Allen suffered an aortic dissection on a flight from the Bahamas and collapsed, knocking the autopilot of his Cessna 208 Caravan off. The plane dove about 3,500 feet and hit 295 knots, well past its 190-knot limit, before passenger Darren Harrison, a 39-year-old with zero flight time, climbed forward, pulled it level and found a working radio (<a href="https://sundaylongread.com/2024/10/17/palm-beach-airport-heart-surgeon/" target="_blank" rel="noopener noreferrer">Sunday Long Read</a>; <a href="https://www.nbcnews.com/news/us-news/passenger-no-flight-experience-saved-plane-nosedive-landed-pilot-passe-rcna28492" target="_blank" rel="noopener noreferrer">NBC News report</a>). Controllers first had to locate the aircraft, because Harrison couldn't say where he was. Robert Morgan, a controller who was also a flight instructor, was called off his break and guided Harrison by radio through flaps, trim, touchdown and braking on Palm Beach's long runway (<a href="https://www.bbc.com/news/world-us-canada-61416384" target="_blank" rel="noopener noreferrer">BBC News report</a>). Allen survived after emergency surgery. Aortic dissection kills a large share of victims before hospital arrival; published estimates range from about 20% to 50% (<a href="https://pmc.ncbi.nlm.nih.gov/articles/PMC10871943/" target="_blank" rel="noopener noreferrer">PMC review</a>).`,
  },
  {
    id: "2023-marthas-vineyard",
    when: "July 15, 2023",
    where: "Martha's Vineyard",
    aircraft: "Piper Meridian",
    passenger: "Unnamed passenger",
    experience: "non-pilot",
    outcome: "partial",
    body: `The 79-year-old pilot of a Piper PA-46 Meridian suffered a medical emergency during a go-around at Martha's Vineyard Airport. His passenger, who was not a pilot, took the controls and made an emergency gear-up landing off the runway; the left wing fractured (<a href="https://data.ntsb.gov/carol-repgen/api/Aviation/ReportMain/GenerateNewestReport/192636/pdf" target="_blank" rel="noopener noreferrer">NTSB final report</a>; <a href="https://apnews.com/article/airplane-crash-landing-marthas-vineyard-massachusetts-8bccda0624046936e606a3d9ea3f5c54" target="_blank" rel="noopener noreferrer">AP News report</a>). The pilot was fatally injured; the passenger sustained minor injuries. It was a destructive landing but a successful intervention.`,
  },
  {
    id: "2024-raleigh-durham",
    when: "April 7, 2024",
    where: "Raleigh-Durham, North Carolina",
    aircraft: "Cirrus SR-20",
    passenger: "Unnamed passenger",
    experience: "non-pilot",
    outcome: "success",
    body: `Joseph Izatt, 61, chair of Duke University's biomedical engineering department, suffered a medical emergency while flying his Cirrus SR-20. His lone passenger radioed that the pilot was slumped over the controls, took over and landed safely at RDU (<a href="https://www.nbcnews.com/news/us-news/passenger-lands-single-engine-plane-duke-professor-piloting-aircraft-s-rcna147219" target="_blank" rel="noopener noreferrer">NBC News report</a>; <a href="https://abc11.com/post/duke-professor-joseph-izat-passenger-lands-small-plane-at-rdu-after-pilot-suffers-medical-emergency/14636400/" target="_blank" rel="noopener noreferrer">ABC11 coverage</a>). Izatt died at the hospital.`,
  },
  {
    id: "2024-bakersfield",
    when: "October 4, 2024",
    where: "Bakersfield, California",
    aircraft: "Beechcraft King Air C90B",
    passenger: "Yvonne Kinane-Wells",
    experience: "non-pilot",
    outcome: "success",
    body: `Yvonne Kinane-Wells assumed control of a twin-engine Beechcraft King Air C90B after her husband, Eliot Alper, became incapacitated on a flight from Henderson, Nevada, toward Monterey. She had ridden along often but reportedly had no piloting experience. With controller assistance she diverted to Meadows Field and landed (<a href="https://apnews.com/article/california-pilot-wife-emergency-landing-plane-06348a2665bf6479d0afad07e181bfb2" target="_blank" rel="noopener noreferrer">AP News report</a>; <a href="https://www.latimes.com/california/story/2024-10-08/wife-lands-plane-after-husbands-heart-attack-audio-files-reveal-tense-moments" target="_blank" rel="noopener noreferrer">Los Angeles Times</a>). Alper later died. The King Air was far more complex than the trainers used in most novice landings.`,
  },
];

const failures: LandingCase[] = [
  {
    id: "2005-helios-522",
    when: "August 14, 2005",
    where: "Greece",
    aircraft: "Boeing 737 (Helios Airways Flight 522)",
    passenger: "Andreas Prodromou",
    experience: "commercial-unqualified",
    outcome: "failure",
    body: `A pressurization failure incapacitated both pilots and nearly everyone aboard the Boeing 737. Flight attendant Andreas Prodromou, who held a UK commercial pilot license but was not qualified on the 737, reached the cockpit on portable oxygen (<a href="https://en.wikipedia.org/wiki/Helios_Airways_Flight_522" target="_blank" rel="noopener noreferrer">Helios Flight 522</a>; <a href="https://www.faa.gov/lessons_learned/transport_airplane/accidents/HCY522" target="_blank" rel="noopener noreferrer">FAA lessons learned</a>). Greek fighter pilots shadowing the jet, along with flight data, showed him trying to control it after the first engine flamed out from fuel starvation. His mayday calls never transmitted because the radio wasn't set to the correct frequency. The second engine quit before impact. All 121 aboard died. Prodromou was no amateur; he may have been hypoxic too.`,
  },
  {
    id: "2025-lebanon-tn",
    when: "November 8, 2025",
    where: "Near Lebanon, Tennessee",
    aircraft: "Airbus EC130 (Vanderbilt LifeFlight)",
    passenger: "Andrew Sikes",
    experience: "non-pilot",
    outcome: "failure",
    body: `A Vanderbilt LifeFlight medical helicopter, an Airbus EC130, crashed after the pilot suffered a medical emergency mid-flight. Flight paramedic Andrew Sikes, who had no flight training, saw the pilot go blank, grabbed the stick over the pilot's hands and tried to slow and land the helicopter by imitating what he'd seen pilots do (<a href="https://people.com/ntsb-report-reveals-untrained-pilot-took-over-controls-before-fatal-helicopter-crash-11890023" target="_blank" rel="noopener noreferrer">NTSB preliminary report</a>; <a href="https://www.newschannel5.com/news/state/tennessee/wilson-county/paramedic-took-control-of-helicopter-during-pilots-medical-emergency" target="_blank" rel="noopener noreferrer">NewsChannel 5</a>). The aircraft struck treetops. Flight nurse Allan Williams, 55, was killed; the pilot and Sikes were seriously injured. Investigators have reported no mechanical malfunction so far. Helicopters are far less forgiving than fixed-wing aircraft, and without a talk-down or an inherently stable airframe the odds collapse.`,
  },
];

const outcomeLabels: Record<CaseOutcome, string> = {
  success: "Landed",
  partial: "Survived rough landing",
  failure: "Fatal / crashed",
};
