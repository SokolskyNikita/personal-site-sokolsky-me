---
export const prerender = true;

const pageTitle = "Ukraine's population to 2150: how many people will still live there?";
const pageDescription =
  "Plain-English projection for people actually living in Kyiv-controlled territory: about 29 million in 2026, 20-21 million in 2050, 8 million in 2100 and about 4 million in 2150.";
const themeColorLight = "#fefdfa";
const themeColorDark = "#171410";
const siteUrl =
  (Astro.site?.toString() ?? "https://sokolsky.me").replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  datePublished: "2026-07-13",
  author: {
    "@type": "Person",
    name: "Nikita Sokolsky"
  },
  about: {
    "@type": "Country",
    name: "Ukraine"
  },
  inLanguage: "en"
};

// Central fertility converges to 1.0 child per woman; the adverse and strong
// paths converge to 0.8 and 1.2 respectively. After 2100, each path keeps its
// migration rule while the age structure gradually becomes less extreme.
const scenarios = {
  adverse: [
    [2026, 29.0], [2030, 26.7], [2040, 22.1], [2050, 18.0],
    [2060, 14.6], [2070, 11.8], [2080, 9.5], [2090, 7.7], [2100, 6.3],
    [2110, 5.1], [2120, 4.1], [2130, 3.3], [2140, 2.7], [2150, 2.2]
  ],
  central: [
    [2026, 29.0], [2030, 27.3], [2040, 24.6], [2050, 20.8],
    [2060, 17.3], [2070, 14.4], [2080, 11.9], [2090, 9.9], [2100, 8.3],
    [2110, 7.0], [2120, 5.9], [2130, 5.0], [2140, 4.3], [2150, 3.7]
  ],
  strong: [
    [2026, 29.0], [2030, 27.7], [2040, 26.3], [2050, 23.7],
    [2060, 21.2], [2070, 19.1], [2080, 17.3], [2090, 15.8], [2100, 14.5],
    [2110, 13.3], [2120, 12.3], [2130, 11.5], [2140, 10.8], [2150, 10.2]
  ]
} as const;

const chart = {
  width: 760,
  height: 400,
  left: 52,
  right: 24,
  top: 52,
  bottom: 48,
  minYear: 2026,
  maxYear: 2150,
  minPop: 0,
  maxPop: 32
};

const plotWidth = chart.width - chart.left - chart.right;
const plotHeight = chart.height - chart.top - chart.bottom;

const xForYear = (year: number) =>
  chart.left + ((year - chart.minYear) / (chart.maxYear - chart.minYear)) * plotWidth;
const yForPop = (value: number) =>
  chart.top + plotHeight - ((value - chart.minPop) / (chart.maxPop - chart.minPop)) * plotHeight;

const pathFor = (series: readonly (readonly [number, number])[]) =>
  series
    .map(([year, value], index) =>
      `${index === 0 ? "M" : "L"} ${xForYear(year).toFixed(1)} ${yForPop(value).toFixed(1)}`
    )
    .join(" ");

const adversePath = pathFor(scenarios.adverse);
const centralPath = pathFor(scenarios.central);
const strongPath = pathFor(scenarios.strong);
const xTicks = [2026, 2050, 2075, 2100, 2125, 2150];
const yTicks = [0, 4, 8, 12, 16, 20, 24, 28, 32];
const formatMillions = (value: number) =>
  value % 1 === 0 ? `${value}m` : `${value.toFixed(1)}m`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="subject" content="Plain-English projection of Ukraine's resident population to 2150." />
    <meta name="application-name" content={pageTitle} />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="googlebot" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="keywords" content="Ukraine population 2150, Ukraine population 2100, Ukraine demographics, Ukraine fertility rate, Ukrainian refugees return" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content={themeColorLight} />
    <meta name="theme-color" content={themeColorLight} media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content={themeColorDark} media="(prefers-color-scheme: dark)" />
    <meta name="msapplication-TileColor" content={themeColorDark} />
