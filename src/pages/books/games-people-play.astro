  .ego-state + .ego-state {
    border-left: 1px solid var(--rule);
  }

  .state-letter {
    display: grid;
    width: 2rem;
    height: 2rem;
    place-items: center;
    margin: 0 0 0.65rem;
    border: 1px solid var(--accent);
    border-radius: 50%;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
  }

  .ego-state p:last-child {
    margin-top: 0.4rem;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .ladder {
    margin-bottom: 0;
    padding: 0;
    border-top: 1px solid var(--rule);
    list-style: none;
  }

  .ladder li {
    display: grid;
    grid-template-columns: minmax(7rem, 0.32fr) 1fr;
    gap: 0.8rem 1.25rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--rule);
  }

  .ladder strong {
    color: var(--text);
    font-size: 0.82rem;
    letter-spacing: 0.035em;
    text-transform: uppercase;
  }

  .ladder span {
    color: var(--text-soft);
  }

  .sequence {
    counter-reset: step;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border: 1px solid var(--rule);
    background: var(--paper);
  }

  .sequence > div {
    min-width: 0;
    padding: 0.85rem;
  }

  .sequence > div + div {
    border-left: 1px solid var(--rule);
  }

  .sequence > div:nth-child(n + 3) {
    border-top: 1px solid var(--rule);
  }

  .sequence span {
    color: var(--accent);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.1em;
  }

  .sequence p {
