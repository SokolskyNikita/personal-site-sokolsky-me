    :root {
      --bg: #171410;
      --paper: #1f1b16;
      --text: #f3eadf;
      --text-soft: #d9cabc;
      --muted: #aa9a8a;
      --rule: #3d342b;
      --accent: #e0ae74;
      --accent-soft: #2b241d;
      --selection: #6e4a25;
    }
  }

  * {
    box-sizing: border-box;
  }

  ::selection {
    background: var(--selection);
    color: var(--text);
  }

  html {
    max-width: 100%;
    background: var(--bg);
    color: var(--text);
    font-family: var(--serif);
    font-size: 16px;
    font-kerning: normal;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    max-width: 100%;
    margin: 0;
    overflow-x: clip;
    background:
