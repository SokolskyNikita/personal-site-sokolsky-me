      var(--bg);
  }

  .page {
    width: 100%;
    max-width: 72rem;
    margin: 0 auto;
    padding: clamp(0.9rem, 2.2vw, 1.8rem);
  }

  .hero {
    min-width: 0;
    display: grid;
    gap: 0.45rem;
    border-bottom: 1px solid var(--rule);
    padding: 0 0 clamp(0.75rem, 2vw, 1.15rem);
  }

  .home-link,
  .eyebrow,
  .state-letter,
