    max-width: 44rem;
    margin: 0.1rem 0 0;
    color: var(--text-soft);
    font-size: clamp(0.98rem, 1.35vw, 1.1rem);
    line-height: 1.45;
    letter-spacing: -0.01em;
    overflow-wrap: break-word;
  }

