    width: 100%;
    display: grid;
    gap: clamp(1.6rem, 3vw, 2.5rem);
    max-width: 67ch;
    margin: 0 auto;
    padding: clamp(0.9rem, 2.2vw, 1.5rem) 0 3rem;
